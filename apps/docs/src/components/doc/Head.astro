---
import type { StarlightRouteData } from '@astrojs/starlight/route-data'
import m from '@/copy/messages'
import { useRuntimeConfig } from '@/config/runtime'
import { defaultLocale, locales } from '@/services/locale'
import { resolveMessageLocale } from '@/services/message-locale'

const { head, entry } = Astro.locals.starlightRoute as StarlightRouteData

for (let index = head.length - 1; index >= 0; index -= 1) {
  const item = head[index]
  if (item?.tag === 'link' && item.attrs?.rel === 'alternate') {
    head.splice(index, 1)
  }
}

const stripLocalePath = (pathname: string): string => {
  for (const locale of locales) {
    if (pathname === `/${locale}`) return '/'
    if (pathname.startsWith(`/${locale}/`)) return pathname.slice(locale.length + 1) || '/'
  }
  return pathname || '/'
}

const runtimeConfig = useRuntimeConfig()
const baseUrl = Astro.site?.toString() || 'https://capgo.app'
const basePath = stripLocalePath(Astro.url.pathname)
const localizedUrl = (locale: string) => {
  const pathname = locale === defaultLocale ? basePath : basePath === '/' ? `/${locale}/` : `/${locale}${basePath}`
  return new URL(pathname, baseUrl).toString()
}

for (const locale of locales) {
  head.push({
    tag: 'link',
    attrs: {
      rel: 'alternate',
      hreflang: locale,
      href: localizedUrl(locale),
    },
  })
}
head.push({
  tag: 'link',
  attrs: {
    rel: 'alternate',
    hreflang: 'x-default',
    href: localizedUrl(defaultLocale),
  },
})

const messageLocale = resolveMessageLocale(Astro.locals.starlightRoute.locale, Astro.currentLocale)
const defaultDescription = m.website_description({}, { locale: messageLocale })

const brand = runtimeConfig.public.brand || 'Capgo'
const escapeRegExp = (value: string) => value.replace(/[.*+?^${}()|[\]\\]/g, '\\$&')
const normalizeWhitespace = (value: string) => value.replace(/\s+/g, ' ').trim()

const buildSeoTitle = (input: string) => {
  const maxLength = 60
  const minLength = 50
  const separator = ' | '

  const maxCoreLength = maxLength - separator.length - brand.length
  const minCoreLength = minLength - separator.length - brand.length

  let core = normalizeWhitespace(input)

  const brandPrefix = new RegExp(`^${escapeRegExp(brand)}\\s*[|\\-–—:]\\s*`, 'i')
  const brandSuffix = new RegExp(`\\s*[|\\-–—:]\\s*${escapeRegExp(brand)}\\s*$`, 'i')

  core = normalizeWhitespace(core.replace(brandPrefix, '').replace(brandSuffix, ''))

  const path = Astro.url.pathname
  const sectionDescriptor = (() => {
    if (path.startsWith('/docs/cli/')) return 'Capacitor Live Updates CLI Docs'
    if (path.startsWith('/docs/plugins/')) return 'Capacitor Plugin Docs & Examples'
    if (path.startsWith('/docs/webapp/')) return 'Capacitor Live Updates Web App Docs'
    return 'Capacitor Live Updates Documentation'
  })()

  if (core.length > 0 && core.length < minCoreLength) {
    const expanded = `${core} - ${sectionDescriptor}`
    core = normalizeWhitespace(expanded)
  }

  if (core.length > maxCoreLength) {
    const truncated = core
      .slice(0, Math.max(0, maxCoreLength - 1))
      .trimEnd()
      .replace(/[\s,.:;\-–—]+$/, '')
    core = truncated ? `${truncated}…` : core.slice(0, maxCoreLength)
  }

  if (!core) core = brand

  return `${core}${separator}${brand}`
}

const titleIndex = head.findIndex(({ tag }) => tag === 'title')
if (titleIndex !== -1) {
  const raw = typeof head[titleIndex].content === 'string' ? head[titleIndex].content : ''
  head[titleIndex].content = buildSeoTitle(raw)
}
const entryData = (entry?.data as Record<string, unknown> | undefined) ?? undefined

const entryTitle = typeof entryData?.title === 'string' ? entryData.title : ''
const entryDescription = typeof entryData?.description === 'string' ? entryData.description : typeof entryData?.summary === 'string' ? entryData.summary : ''

const normalizeMetaDescription = (value: string) => normalizeWhitespace(value).replace(/"/g, "'").trim()

const minDescriptionLength = 120
const maxDescriptionLength = 159
const shortDescriptionSuffix = 'Capgo helps Capacitor teams ship live updates, automate rollbacks, manage channels, and monitor delivery without app store delays.'

const buildMetaDescription = (value: string) => {
  let nextDescription = normalizeMetaDescription(value)
  const normalizedDefaultDescription = normalizeMetaDescription(defaultDescription)

  if (nextDescription.length < minDescriptionLength && normalizedDefaultDescription && nextDescription !== normalizedDefaultDescription) {
    nextDescription = nextDescription + ' - ' + normalizedDefaultDescription
  }

  if (nextDescription.length < minDescriptionLength) {
    nextDescription = nextDescription + ' - ' + shortDescriptionSuffix
  }

  if (nextDescription.length > maxDescriptionLength) nextDescription = nextDescription.substring(0, maxDescriptionLength - 3) + '...'

  return nextDescription
}

const metaDescription = buildMetaDescription(entryDescription || entryTitle || defaultDescription)

const setHeadMetaContent = (keyName: 'name' | 'property', keyValue: string, content: string) => {
  const existingMeta = head.find(({ tag, attrs }) => tag === 'meta' && attrs?.[keyName] === keyValue)
  if (existingMeta) {
    existingMeta.attrs = { ...existingMeta.attrs, content }
    return
  }

  head.push({
    tag: 'meta',
    attrs: {
      [keyName]: keyValue,
      content,
    },
  })
}

if (metaDescription) {
  setHeadMetaContent('name', 'description', metaDescription)
  setHeadMetaContent('property', 'og:description', metaDescription)
  setHeadMetaContent('name', 'twitter:description', metaDescription)
}

// Add og:image if not present
const hasOgImage = head.some(({ tag, attrs }) => tag === 'meta' && attrs?.property === 'og:image')
if (!hasOgImage) {
  head.push({
    tag: 'meta',
    attrs: {
      property: 'og:image',
      content: 'https://capgo.app/capgo_social.png',
    },
  })
  head.push({
    tag: 'meta',
    attrs: {
      property: 'og:image:width',
      content: '1200',
    },
  })
  head.push({
    tag: 'meta',
    attrs: {
      property: 'og:image:height',
      content: '630',
    },
  })
  head.push({
    tag: 'meta',
    attrs: {
      property: 'og:image:type',
      content: 'image/png',
    },
  })
  head.push({
    tag: 'meta',
    attrs: {
      name: 'twitter:image',
      content: 'https://capgo.app/capgo_social.png',
    },
  })
}
---

{head.map(({ tag: Tag, attrs, content }) => <Tag {...attrs} set:html={content} />)}
