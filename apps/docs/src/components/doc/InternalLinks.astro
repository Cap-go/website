---
const route = Astro.locals.starlightRoute
const currentPath = Astro.url.pathname.replace(/\/$/, '')

const candidates = [
  {
    href: '/docs/getting-started/quickstart/',
    label: 'Live update quickstart',
    description: 'Install Capgo and send the first bundle through the documented flow.',
  },
  {
    href: '/docs/live-updates/channels/',
    label: 'Channels and rollout',
    description: 'Route updates through development, beta, staging, and production channels.',
  },
  {
    href: '/docs/plugins/updater/',
    label: 'Updater plugin docs',
    description: 'Review the Capacitor updater API before changing release behavior.',
  },
  {
    href: '/blog/how-to-use-capgo-documentation-for-ota-updates/',
    label: 'Docs usage guide',
    description: 'Read the blog walkthrough for turning documentation into an OTA update workflow.',
  },
  {
    href: '/plugins/',
    label: 'Plugin directory',
    description: 'Find maintained native plugins that pair with the docs you are reading.',
  },
  {
    href: '/live-update/',
    label: 'Live updates product',
    description: 'See how the docs map to Capgo release, rollback, and channel controls.',
  },
  {
    href: '/native-build/',
    label: 'Native build product',
    description: 'Build signed iOS and Android binaries when documentation changes touch native code.',
  },
]

const links = candidates.filter((link) => link.href.replace(/\/$/, '') !== currentPath).slice(0, 5)
const pageTitle = route?.entry?.data?.title
---

<aside class="capgo-doc-links" aria-labelledby="capgo-doc-links-title">
  <div class="capgo-doc-links__intro">
    <p class="capgo-doc-links__eyebrow">Capgo note</p>
    <h2 id="capgo-doc-links-title">Connect this doc to the rest of Capgo</h2>
    <p>
      {
        pageTitle
          ? `After reading ${pageTitle}, keep the release path connected with these related Capgo pages.`
          : 'Keep the release path connected with these related Capgo pages.'
      }
    </p>
  </div>
  <div class="capgo-doc-links__grid">
    {
      links.map((link) => (
        <a href={link.href}>
          <span>
            {link.label}
            <span aria-hidden="true">-&gt;</span>
          </span>
          <small>{link.description}</small>
        </a>
      ))
    }
  </div>
</aside>

<style>
  .capgo-doc-links {
    margin: 3rem auto 2rem;
    padding: 1.5rem 0 0;
    border-top: 1px solid var(--sl-color-gray-5);
    display: grid;
    gap: 1.25rem;
  }

  .capgo-doc-links__intro {
    display: grid;
    gap: 0.45rem;
  }

  .capgo-doc-links__eyebrow {
    color: var(--sl-color-text-accent);
    font-size: 0.72rem;
    font-weight: 700;
    letter-spacing: 0.12em;
    line-height: 1;
    margin: 0;
    text-transform: uppercase;
  }

  .capgo-doc-links h2 {
    color: var(--sl-color-white);
    font-size: var(--sl-text-2xl);
    line-height: 1.2;
    margin: 0;
  }

  .capgo-doc-links p {
    color: var(--sl-color-gray-3);
    font-size: var(--sl-text-sm);
    line-height: 1.6;
    margin: 0;
    max-width: 48rem;
  }

  .capgo-doc-links__grid {
    display: grid;
    gap: 0.75rem;
  }

  .capgo-doc-links a {
    border: 1px solid var(--sl-color-gray-5);
    border-radius: 0.5rem;
    color: inherit;
    display: grid;
    gap: 0.4rem;
    padding: 0.9rem 1rem;
    text-decoration: none;
    transition:
      background 0.2s ease,
      border-color 0.2s ease,
      color 0.2s ease;
  }

  .capgo-doc-links a:hover {
    background: color-mix(in srgb, var(--sl-color-text-accent) 10%, transparent);
    border-color: color-mix(in srgb, var(--sl-color-text-accent) 40%, var(--sl-color-gray-5));
  }

  .capgo-doc-links a > span {
    align-items: center;
    color: var(--sl-color-white);
    display: flex;
    font-size: var(--sl-text-sm);
    font-weight: 650;
    gap: 0.5rem;
    justify-content: space-between;
  }

  .capgo-doc-links small {
    color: var(--sl-color-gray-3);
    font-size: var(--sl-text-xs);
    line-height: 1.5;
  }

  @media (min-width: 50rem) {
    .capgo-doc-links {
      grid-template-columns: minmax(0, 0.78fr) minmax(0, 1.22fr);
      align-items: start;
    }

    .capgo-doc-links__grid {
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }
  }
</style>
