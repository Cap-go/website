---
// Interactive decision tree for "Configure your signing credentials" in the
// Capgo Builder Getting Started guide. Mirrors the pattern of
// ConditionalQuestionnaire.astro (inline stepper + question flow data).
// Styling reuses the existing .question-buttons / .question-btn /
// .questionnaire-code / .questionnaire-warning classes from src/css/docs.css.
// Icons are inline SVGs (currentColor) so they need no assets and theme correctly.

const ICONS = {
  apple:
    '<svg width="18" height="18" viewBox="0 0 814 1000" fill="currentColor" aria-hidden="true"><path d="M788.1 340.9c-5.8 4.5-108.2 62.2-108.2 190.5 0 148.4 130.3 200.9 134.2 202.2-.6 3.2-20.7 71.9-68.7 141.9-42.8 61.6-87.5 123.1-155.5 123.1s-85.5-39.5-164-39.5c-76.5 0-103.7 40.8-165.9 40.8s-105.6-57-155.5-127C46.7 790.7 0 663 0 541.8c0-194.4 126.4-297.5 250.8-297.5 66.1 0 121.2 43.4 162.7 43.4 39.5 0 101.1-46 176.3-46 28.5 0 130.9 2.6 198.3 99.2zm-234-181.5c31.1-36.9 53.1-88.1 53.1-139.3 0-7.1-.6-14.3-1.9-20.1-50.6 1.9-110.8 33.7-147.1 75.8-28.5 32.4-55.1 83.6-55.1 135.5 0 7.8 1.3 15.6 1.9 18.1 3.2.6 8.4 1.3 13.6 1.3 45.4 0 102.5-30.4 135.5-71.3z"/></svg>',
  android:
    '<svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M17.6 9.48l1.84-3.18a.38.38 0 0 0-.66-.38l-1.86 3.22a11.4 11.4 0 0 0-8.84 0L6.22 5.92a.38.38 0 1 0-.66.38L7.4 9.48A10.78 10.78 0 0 0 2 18h20a10.78 10.78 0 0 0-4.4-8.52zM7 15.25A1.25 1.25 0 1 1 8.25 14 1.25 1.25 0 0 1 7 15.25zm10 0A1.25 1.25 0 1 1 18.25 14 1.25 1.25 0 0 1 17 15.25z"/></svg>',
  store:
    '<svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M6 2 3 6v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2V6l-3-4Z"/><path d="M3 6h18"/><path d="M16 10a4 4 0 0 1-8 0"/></svg>',
  device:
    '<svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><rect x="5" y="2" width="14" height="20" rx="2"/><path d="M12 18h.01"/></svg>',
  check:
    '<svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M20 6 9 17l-5-5"/></svg>',
  sparkle:
    '<svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="m12 3 1.9 4.1L18 9l-4.1 1.9L12 15l-1.9-4.1L6 9l4.1-1.9Z"/><path d="m19 14 .7 1.5L21 16l-1.3.5L19 18l-.7-1.5L17 16l1.3-.5Z"/></svg>',
}

const questionFlow = {
  q_platform: {
    type: 'buttons',
    question: 'Which platform do you want to configure?',
    answers: [
      { id: 'ios', text: 'iOS', icon: ICONS.apple, next: 'q_ios_dist' },
      { id: 'android', text: 'Android', icon: ICONS.android, next: 'q_android_creds' },
    ],
  },
  q_ios_dist: {
    type: 'buttons',
    question: 'How will you distribute your iOS app?',
    answers: [
      { id: 'appstore', text: 'App Store / TestFlight', icon: ICONS.store, next: 'q_ios_creds' },
      { id: 'adhoc', text: 'Ad-hoc (direct to registered devices)', icon: ICONS.device, next: 'final_ios_adhoc' },
    ],
  },
  q_ios_creds: {
    type: 'buttons',
    question:
      'Do you already have your iOS signing credentials? <span style="font-weight:400;opacity:.75">(distribution certificate + provisioning profile — e.g. from another CI/CD setup)</span>',
    answers: [
      { id: 'yes', text: 'Yes, I already have them', icon: ICONS.check, next: 'final_ios_have' },
      { id: 'no', text: "No / I'm not sure", icon: ICONS.sparkle, next: 'final_ios_none' },
    ],
  },
  q_android_creds: {
    type: 'buttons',
    question:
      'Have you already set up native Android builds in another CI/CD system? <span style="font-weight:400;opacity:.75">(i.e. you already have a Google Play service account — and a signing keystore)</span>',
    answers: [
      { id: 'yes', text: 'Yes — I have a service account & keystore', icon: ICONS.check, next: 'final_android_have' },
      { id: 'no', text: "No / I'm not sure", icon: ICONS.sparkle, next: 'final_android_none' },
    ],
  },
  final_ios_adhoc: {
    type: 'final',
    question: 'Set up ad-hoc distribution',
    text: "Ad-hoc builds use their own provisioning profile and don't need an App Store Connect API key. The iOS guide walks through the ad-hoc profile and the <code>--ios-distribution ad_hoc</code> flag.",
    cta: { text: '📖 Read the iOS guide — Ad-Hoc Distribution', href: '/docs/builder/ios/#ad-hoc-distribution-mode' },
  },
  final_ios_have: {
    type: 'final',
    question: 'Save your existing credentials',
    text: 'You already have your certificate and provisioning profile, so save them to Capgo directly. (Recommended for now when you bring your own iOS credentials.)',
    code: 'bunx @capgo/cli@latest build credentials save --platform ios',
    cta: { text: 'See all credential options →', href: '/docs/builder/credentials/' },
  },
  final_ios_none: {
    type: 'final',
    question: 'Run the interactive onboarding',
    text: 'No certificate wrangling — <code>build init</code> creates your distribution certificate and provisioning profile for you, interactively:',
    code: 'bunx @capgo/cli@latest build init --platform ios',
    cta: { text: '📖 Prefer a manual walkthrough? Read the full iOS guide', href: '/docs/builder/ios/' },
  },
  final_android_have: {
    type: 'final',
    question: 'Run the interactive onboarding',
    text: 'Even if you configured builds elsewhere, <code>build init</code> is the recommended path on Android — it wires up your keystore and Google Play service account correctly:',
    code: 'bunx @capgo/cli@latest build init --platform android',
    warning:
      "You <em>can</em> import existing credentials with <code>build credentials save --platform android</code>, but it is <b>strongly discouraged</b> — prefer the onboarding above.",
  },
  final_android_none: {
    type: 'final',
    question: 'Run the interactive onboarding',
    text: "Capgo's onboarding sets up your signing keystore and Google Play service account for you. Run:",
    code: 'bunx @capgo/cli@latest build init --platform android',
    cta: { text: '📖 Prefer a manual walkthrough? Read the full Android guide', href: '/docs/builder/android/' },
  },
}
---

<div class="sl-steps build-creds-questionnaire" id="bcq">
  <ol>
    <li id="bcq-step-1">
      <strong id="bcq-step-1-question"></strong>
      <div id="bcq-step-1-buttons" class="question-buttons"></div>
      <div id="bcq-step-1-content"></div>
    </li>
    <li id="bcq-step-2" style="display: none;">
      <strong id="bcq-step-2-question"></strong>
      <div id="bcq-step-2-buttons" class="question-buttons"></div>
      <div id="bcq-step-2-content"></div>
    </li>
    <li id="bcq-step-3" style="display: none;">
      <strong id="bcq-step-3-question"></strong>
      <div id="bcq-step-3-buttons" class="question-buttons"></div>
      <div id="bcq-step-3-content"></div>
    </li>
    <li id="bcq-step-4" style="display: none;">
      <strong id="bcq-step-4-question"></strong>
      <div id="bcq-step-4-buttons" class="question-buttons"></div>
      <div id="bcq-step-4-content"></div>
    </li>
  </ol>
</div>

<script is:inline define:vars={{ questionFlow }}>
  document.addEventListener('DOMContentLoaded', function () {
    const MAX_STEPS = 4

    function escapeHtml(text) {
      const div = document.createElement('div')
      div.textContent = text
      return div.innerHTML
    }

    function hideStepsAfter(stepNumber) {
      for (let i = stepNumber + 1; i <= MAX_STEPS; i++) {
        const li = document.getElementById(`bcq-step-${i}`)
        if (li) li.style.display = 'none'
        const buttons = document.getElementById(`bcq-step-${i}-buttons`)
        const content = document.getElementById(`bcq-step-${i}-content`)
        if (buttons) buttons.innerHTML = ''
        if (content) content.innerHTML = ''
      }
    }

    function showStep(stepId, stepNumber) {
      const step = questionFlow[stepId]
      if (!step || stepNumber > MAX_STEPS) return

      const li = document.getElementById(`bcq-step-${stepNumber}`)
      const questionEl = document.getElementById(`bcq-step-${stepNumber}-question`)
      const buttonsEl = document.getElementById(`bcq-step-${stepNumber}-buttons`)
      const contentEl = document.getElementById(`bcq-step-${stepNumber}-content`)

      if (li) li.style.display = 'list-item'
      if (questionEl) questionEl.innerHTML = step.question || ''
      if (buttonsEl) buttonsEl.innerHTML = ''
      if (contentEl) contentEl.innerHTML = ''

      if (step.type === 'buttons') {
        step.answers.forEach(function (answer) {
          const button = document.createElement('button')
          button.className = 'question-btn'
          if (answer.icon) {
            button.style.display = 'inline-flex'
            button.style.alignItems = 'center'
            button.style.gap = '0.55rem'
            button.innerHTML = `${answer.icon}<span>${answer.text}</span>`
          } else {
            button.innerHTML = answer.text
          }
          button.addEventListener('click', function () {
            buttonsEl.querySelectorAll('.question-btn').forEach(function (b) {
              b.classList.remove('selected')
            })
            button.classList.add('selected')
            hideStepsAfter(stepNumber)
            showStep(answer.next, stepNumber + 1)
          })
          buttonsEl.appendChild(button)
        })
      } else if (step.type === 'final') {
        let html = ''
        if (step.text) html += `<p>${step.text}</p>`
        if (step.code) {
          html += `<div class="questionnaire-code"><pre data-language="bash"><code>${escapeHtml(step.code)}</code></pre></div>`
        }
        if (step.warning) {
          html += `<div class="sl-markdown-content questionnaire-warning"><aside aria-label="Caution" class="starlight-aside starlight-aside--caution"><p class="starlight-aside__title" aria-hidden="true">Caution</p><section class="starlight-aside__content"><p>${step.warning}</p></section></aside></div>`
        }
        if (step.cta) {
          html += `<p style="margin-top:1rem"><a href="${step.cta.href}" style="display:inline-block;padding:.5rem .9rem;border:1px solid var(--sl-color-accent);border-radius:.5rem;color:var(--sl-color-text-accent);font-weight:600;text-decoration:none">${step.cta.text}</a></p>`
        }
        if (contentEl) contentEl.innerHTML = html
      }
    }

    showStep('q_platform', 1)
  })
</script>
