{
  "name": "capgo-docs",
  "main": "./src/worker/index.ts",
  "compatibility_date": "2026-03-29",
  "compatibility_flags": ["nodejs_compat", "disable_nodejs_process_v2"],
  "dependencies_instrumentation": {
    "enabled": true,
  },
  "assets": {
    "directory": "./dist",
    "binding": "ASSETS",
    "not_found_handling": "single-page-application",
    "run_worker_first": true,
  },
  "workers_dev": false,
  "routes": [
    { "pattern": "capgo.app/llms.txt", "zone_name": "capgo.app" },
    { "pattern": "capgo.app/llms-full.txt", "zone_name": "capgo.app" },
    { "pattern": "capgo.app/docs*", "zone_name": "capgo.app" },
    { "pattern": "capgo.app/_docs*", "zone_name": "capgo.app" },
  ],
  "env": {
    "development": {
      "routes": [
        { "pattern": "development.capgo.app/llms.txt", "zone_name": "capgo.app" },
        { "pattern": "development.capgo.app/llms-full.txt", "zone_name": "capgo.app" },
        { "pattern": "development.capgo.app/docs*", "zone_name": "capgo.app" },
        { "pattern": "development.capgo.app/_docs*", "zone_name": "capgo.app" },
      ],
    },
  },
}
