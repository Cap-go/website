          <div class="rounded-2xl border border-gray-700 bg-gray-900 p-8 text-center">
            <div class="mx-auto mb-6 flex h-16 w-16 items-center justify-center rounded-full bg-purple-500/20">
              <svg class="h-8 w-8 text-purple-400" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  stroke-width="2"
                  d="M18.364 5.636l-3.536 3.536m0 5.656l3.536 3.536M9.172 9.172L5.636 5.636m3.536 9.192l-3.536 3.536M21 12a9 9 0 11-18 0 9 9 0 0118 0zm-5 0a4 4 0 11-8 0 4 4 0 018 0z"
                ></path>
              </svg>
            </div>
            <h3 class="mb-4 text-xl font-bold text-white">{m.solutions_agencies_perk2_title({}, { locale })}</h3>
            <p class="text-gray-400">{m.solutions_agencies_perk2_desc({}, { locale })}</p>
