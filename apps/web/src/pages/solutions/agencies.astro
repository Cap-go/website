---
import Layout from '@/layouts/Layout.astro'
import m from '@/copy/messages'
import { getRelativeLocaleUrl } from 'astro:i18n'
import AgencyDashboardIllustration from '@/components/solutions/AgencyDashboardIllustration.astro'
import WhiteLabelIllustration from '@/components/solutions/WhiteLabelIllustration.astro'
import HandoffIllustration from '@/components/solutions/HandoffIllustration.astro'
import { createServiceLdJson, createLdJsonGraph } from '@/lib/ldJson'

const locale = Astro.locals.locale
const brand = Astro.locals.runtimeConfig.public.brand

const title = `${brand} | ${m.solutions_agencies_title({}, { locale })}`
const description = m.solutions_agencies_description({}, { locale })

const serviceLdJson = createServiceLdJson(Astro.locals.runtimeConfig.public, {
  name: title,
  description: description,
  url: Astro.url.href,
  serviceType: 'Software Development Service',
  areaServed: ['Worldwide'],
})

const ldJSON = createLdJsonGraph(Astro.locals.runtimeConfig.public, serviceLdJson, {
  includeOrganization: true,
})

const content = { title, description, ldJSON }
---

<Layout content={content}>
  <div>
    <!-- Hero Section -->
    <section class="relative overflow-hidden py-20 sm:py-28 lg:py-36">
      <div class="pointer-events-none absolute inset-0 overflow-hidden">
        <div class="absolute top-0 left-1/2 h-full w-full max-w-6xl -translate-x-1/2">
          <div class="absolute top-1/4 left-1/4 h-96 w-96 rounded-full bg-amber-500/10 blur-3xl"></div>
          <div class="absolute right-1/4 bottom-1/4 h-96 w-96 rounded-full bg-orange-500/10 blur-3xl"></div>
        </div>
      </div>

      <div class="relative mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
        <div class="mx-auto max-w-4xl text-center">
          <div class="mb-8 inline-flex items-center rounded-full border border-amber-400/40 bg-amber-500/10 px-4 py-2 text-sm font-medium text-amber-200">
            <svg class="mr-2 h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path
                stroke-linecap="round"
                stroke-linejoin="round"
                stroke-width="2"
                d="M19 21V5a2 2 0 00-2-2H7a2 2 0 00-2 2v16m14 0h2m-2 0h-5m-9 0H3m2 0h5M9 7h1m-1 4h1m4-4h1m-1 4h1m-5 10v-5a1 1 0 011-1h2a1 1 0 011 1v5m-4 0h4"></path>
            </svg>
            {m.solutions_agencies_badge({}, { locale })}
          </div>

          <h1 class="text-4xl leading-tight font-bold text-white sm:text-5xl lg:text-6xl">
            {m.solutions_agencies_hero_title({}, { locale })}
          </h1>

          <p class="mx-auto mt-8 max-w-3xl text-xl leading-relaxed text-gray-300">
            {m.solutions_agencies_hero_subtitle({}, { locale })}
          </p>

          <div class="mt-10 flex flex-col items-center justify-center gap-4 sm:flex-row">
            <a
              href={getRelativeLocaleUrl(locale, 'register')}
              class="rounded-xl bg-amber-600 px-8 py-4 text-base font-semibold text-white shadow-lg shadow-amber-500/25 transition-all duration-200 hover:bg-amber-700 focus:ring-2 focus:ring-amber-500 focus:ring-offset-2"
            >
              {m.solutions_start_free_trial({}, { locale })}
            </a>
            <a
              href="https://book.capgo.app/demo/"
              class="rounded-xl border border-gray-600 px-8 py-4 text-base font-semibold text-gray-300 transition-all duration-200 hover:bg-gray-800 hover:text-white"
            >
              {m.solutions_agencies_partner({}, { locale })}
            </a>
          </div>
        </div>
      </div>
    </section>

    <!-- The Agency Nightmare -->
    <section class="bg-gray-800 py-20">
      <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
        <div class="mx-auto mb-16 max-w-3xl text-center">
          <h2 class="mb-4 text-sm font-semibold tracking-wide text-red-400 uppercase">{m.solutions_agencies_nightmare_label({}, { locale })}</h2>
          <h3 class="text-3xl font-bold text-white sm:text-4xl">{m.solutions_agencies_nightmare_title({}, { locale })}</h3>
        </div>

        <div class="grid grid-cols-1 gap-8 md:grid-cols-2 lg:grid-cols-3">
          <div class="rounded-xl border border-red-500/20 bg-gray-900 p-6">
            <div class="mb-4 flex h-12 w-12 items-center justify-center rounded-lg bg-red-500/20">
              <svg class="h-6 w-6 text-red-400" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  stroke-width="2"
                  d="M19 11H5m14 0a2 2 0 012 2v6a2 2 0 01-2 2H5a2 2 0 01-2-2v-6a2 2 0 012-2m14 0V9a2 2 0 00-2-2M5 11V9a2 2 0 012-2m0 0V5a2 2 0 012-2h6a2 2 0 012 2v2M7 7h10"></path>
              </svg>
            </div>
            <h4 class="mb-2 text-lg font-bold text-white">{m.solutions_agencies_pain1_title({}, { locale })}</h4>
            <p class="text-gray-400">{m.solutions_agencies_pain1_desc({}, { locale })}</p>
          </div>

          <div class="rounded-xl border border-red-500/20 bg-gray-900 p-6">
            <div class="mb-4 flex h-12 w-12 items-center justify-center rounded-lg bg-red-500/20">
              <svg class="h-6 w-6 text-red-400" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"></path>
              </svg>
            </div>
            <h4 class="mb-2 text-lg font-bold text-white">{m.solutions_agencies_pain2_title({}, { locale })}</h4>
            <p class="text-gray-400">{m.solutions_agencies_pain2_desc({}, { locale })}</p>
          </div>

          <div class="rounded-xl border border-red-500/20 bg-gray-900 p-6">
            <div class="mb-4 flex h-12 w-12 items-center justify-center rounded-lg bg-red-500/20">
              <svg class="h-6 w-6 text-red-400" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  stroke-width="2"
                  d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0z"
                ></path>
              </svg>
            </div>
            <h4 class="mb-2 text-lg font-bold text-white">{m.solutions_agencies_pain3_title({}, { locale })}</h4>
            <p class="text-gray-400">{m.solutions_agencies_pain3_desc({}, { locale })}</p>
          </div>

          <div class="rounded-xl border border-red-500/20 bg-gray-900 p-6">
            <div class="mb-4 flex h-12 w-12 items-center justify-center rounded-lg bg-red-500/20">
              <svg class="h-6 w-6 text-red-400" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  stroke-width="2"
                  d="M12 8c-1.657 0-3 .895-3 2s1.343 2 3 2 3 .895 3 2-1.343 2-3 2m0-8c1.11 0 2.08.402 2.599 1M12 8V7m0 1v8m0 0v1m0-1c-1.11 0-2.08-.402-2.599-1M21 12a9 9 0 11-18 0 9 9 0 0118 0z"
                ></path>
              </svg>
            </div>
            <h4 class="mb-2 text-lg font-bold text-white">{m.solutions_agencies_pain4_title({}, { locale })}</h4>
            <p class="text-gray-400">{m.solutions_agencies_pain4_desc({}, { locale })}</p>
          </div>

          <div class="rounded-xl border border-red-500/20 bg-gray-900 p-6">
            <div class="mb-4 flex h-12 w-12 items-center justify-center rounded-lg bg-red-500/20">
              <svg class="h-6 w-6 text-red-400" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  stroke-width="2"
                  d="M8 12h.01M12 12h.01M16 12h.01M21 12c0 4.418-4.03 8-9 8a9.863 9.863 0 01-4.255-.949L3 20l1.395-3.72C3.512 15.042 3 13.574 3 12c0-4.418 4.03-8 9-8s9 3.582 9 8z"
                ></path>
              </svg>
            </div>
            <h4 class="mb-2 text-lg font-bold text-white">{m.solutions_agencies_pain5_title({}, { locale })}</h4>
            <p class="text-gray-400">{m.solutions_agencies_pain5_desc({}, { locale })}</p>
          </div>

          <div class="rounded-xl border border-red-500/20 bg-gray-900 p-6">
            <div class="mb-4 flex h-12 w-12 items-center justify-center rounded-lg bg-red-500/20">
              <svg class="h-6 w-6 text-red-400" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  stroke-width="2"
                  d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z"
                ></path>
              </svg>
            </div>
            <h4 class="mb-2 text-lg font-bold text-white">{m.solutions_agencies_pain6_title({}, { locale })}</h4>
            <p class="text-gray-400">{m.solutions_agencies_pain6_desc({}, { locale })}</p>
          </div>
        </div>
      </div>
    </section>

    <!-- How We Help Agencies -->
    <section class="bg-gray-900 py-20">
      <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
        <div class="mx-auto mb-16 max-w-3xl text-center">
          <h2 class="mb-4 text-sm font-semibold tracking-wide text-amber-400 uppercase">{m.solutions_agencies_solution_label({}, { locale })}</h2>
          <h3 class="text-3xl font-bold text-white sm:text-4xl">{m.solutions_agencies_solution_title({}, { locale })}</h3>
          <p class="mt-4 text-xl text-gray-400">{m.solutions_agencies_solution_subtitle({}, { locale })}</p>
        </div>

        <div class="space-y-8">
          <!-- Multi-Client Dashboard -->
          <div class="rounded-2xl border border-gray-700 bg-gray-800 p-8 lg:p-10">
            <div class="grid grid-cols-1 items-center gap-8 lg:grid-cols-2">
              <div>
                <div class="mb-4 flex items-center gap-3">
                  <div class="flex h-10 w-10 items-center justify-center rounded-lg bg-amber-500/20">
                    <svg class="h-5 w-5 text-amber-400" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                      <path
                        stroke-linecap="round"
                        stroke-linejoin="round"
                        stroke-width="2"
                        d="M4 6a2 2 0 012-2h2a2 2 0 012 2v2a2 2 0 01-2 2H6a2 2 0 01-2-2V6zM14 6a2 2 0 012-2h2a2 2 0 012 2v2a2 2 0 01-2 2h-2a2 2 0 01-2-2V6zM4 16a2 2 0 012-2h2a2 2 0 012 2v2a2 2 0 01-2 2H6a2 2 0 01-2-2v-2zM14 16a2 2 0 012-2h2a2 2 0 012 2v2a2 2 0 01-2 2h-2a2 2 0 01-2-2v-2z"
                      ></path>
                    </svg>
                  </div>
                  <h3 class="text-xl font-bold text-white">{m.solutions_agencies_sol1_title({}, { locale })}</h3>
                </div>
                <p class="mb-4 text-gray-300">{m.solutions_agencies_sol1_desc({}, { locale })}</p>
                <ul class="space-y-2">
                  <li class="flex items-start gap-2 text-gray-400">
                    <svg class="mt-0.5 h-5 w-5 shrink-0 text-green-400" fill="currentColor" viewBox="0 0 20 20">
                      <path
                        fill-rule="evenodd"
                        d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z"
                        clip-rule="evenodd"></path>
                    </svg>
                    {m.solutions_agencies_sol1_point1({}, { locale })}
                  </li>
                  <li class="flex items-start gap-2 text-gray-400">
                    <svg class="mt-0.5 h-5 w-5 shrink-0 text-green-400" fill="currentColor" viewBox="0 0 20 20">
                      <path
                        fill-rule="evenodd"
                        d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z"
                        clip-rule="evenodd"></path>
                    </svg>
                    {m.solutions_agencies_sol1_point2({}, { locale })}
                  </li>
                  <li class="flex items-start gap-2 text-gray-400">
                    <svg class="mt-0.5 h-5 w-5 shrink-0 text-green-400" fill="currentColor" viewBox="0 0 20 20">
                      <path
                        fill-rule="evenodd"
                        d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z"
                        clip-rule="evenodd"></path>
                    </svg>
                    {m.solutions_agencies_sol1_point3({}, { locale })}
                  </li>
                </ul>
              </div>
              <div class="flex items-center justify-center rounded-xl bg-gray-900 p-6">
                <div class="w-full max-w-sm">
                  <AgencyDashboardIllustration class="text-amber-500" />
                </div>
              </div>
            </div>
          </div>

          <!-- White Label -->
          <div class="rounded-2xl border border-gray-700 bg-gray-800 p-8 lg:p-10">
            <div class="grid grid-cols-1 items-center gap-8 lg:grid-cols-2">
              <div class="order-2 flex items-center justify-center rounded-xl bg-gray-900 p-6 lg:order-1">
                <div class="w-full max-w-sm">
                  <WhiteLabelIllustration class="text-purple-500" />
                </div>
              </div>
              <div class="order-1 lg:order-2">
                <div class="mb-4 flex items-center gap-3">
                  <div class="flex h-10 w-10 items-center justify-center rounded-lg bg-purple-500/20">
                    <svg class="h-5 w-5 text-purple-400" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                      <path
                        stroke-linecap="round"
                        stroke-linejoin="round"
                        stroke-width="2"
                        d="M7 21a4 4 0 01-4-4V5a2 2 0 012-2h4a2 2 0 012 2v12a4 4 0 01-4 4zm0 0h12a2 2 0 002-2v-4a2 2 0 00-2-2h-2.343M11 7.343l1.657-1.657a2 2 0 012.828 0l2.829 2.829a2 2 0 010 2.828l-8.486 8.485M7 17h.01"
                      ></path>
                    </svg>
                  </div>
                  <h3 class="text-xl font-bold text-white">{m.solutions_agencies_sol2_title({}, { locale })}</h3>
                </div>
                <p class="mb-4 text-gray-300">{m.solutions_agencies_sol2_desc({}, { locale })}</p>
                <ul class="space-y-2">
                  <li class="flex items-start gap-2 text-gray-400">
                    <svg class="mt-0.5 h-5 w-5 shrink-0 text-green-400" fill="currentColor" viewBox="0 0 20 20">
                      <path
                        fill-rule="evenodd"
                        d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z"
                        clip-rule="evenodd"></path>
                    </svg>
                    {m.solutions_agencies_sol2_point1({}, { locale })}
                  </li>
                  <li class="flex items-start gap-2 text-gray-400">
                    <svg class="mt-0.5 h-5 w-5 shrink-0 text-green-400" fill="currentColor" viewBox="0 0 20 20">
                      <path
                        fill-rule="evenodd"
                        d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z"
                        clip-rule="evenodd"></path>
                    </svg>
                    {m.solutions_agencies_sol2_point2({}, { locale })}
                  </li>
                  <li class="flex items-start gap-2 text-gray-400">
                    <svg class="mt-0.5 h-5 w-5 shrink-0 text-green-400" fill="currentColor" viewBox="0 0 20 20">
                      <path
                        fill-rule="evenodd"
                        d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z"
                        clip-rule="evenodd"></path>
                    </svg>
                    {m.solutions_agencies_sol2_point3({}, { locale })}
                  </li>
                </ul>
              </div>
            </div>
          </div>

          <!-- Handoff to Clients -->
          <div class="rounded-2xl border border-gray-700 bg-gray-800 p-8 lg:p-10">
            <div class="grid grid-cols-1 items-center gap-8 lg:grid-cols-2">
              <div>
                <div class="mb-4 flex items-center gap-3">
                  <div class="flex h-10 w-10 items-center justify-center rounded-lg bg-green-500/20">
                    <svg class="h-5 w-5 text-green-400" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7h12m0 0l-4-4m4 4l-4 4m0 6H4m0 0l4 4m-4-4l4-4"></path>
                    </svg>
                  </div>
                  <h3 class="text-xl font-bold text-white">{m.solutions_agencies_sol3_title({}, { locale })}</h3>
                </div>
                <p class="mb-4 text-gray-300">{m.solutions_agencies_sol3_desc({}, { locale })}</p>
                <ul class="space-y-2">
                  <li class="flex items-start gap-2 text-gray-400">
                    <svg class="mt-0.5 h-5 w-5 shrink-0 text-green-400" fill="currentColor" viewBox="0 0 20 20">
                      <path
                        fill-rule="evenodd"
                        d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z"
                        clip-rule="evenodd"></path>
                    </svg>
                    {m.solutions_agencies_sol3_point1({}, { locale })}
                  </li>
                  <li class="flex items-start gap-2 text-gray-400">
                    <svg class="mt-0.5 h-5 w-5 shrink-0 text-green-400" fill="currentColor" viewBox="0 0 20 20">
                      <path
                        fill-rule="evenodd"
                        d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z"
                        clip-rule="evenodd"></path>
                    </svg>
                    {m.solutions_agencies_sol3_point2({}, { locale })}
                  </li>
                  <li class="flex items-start gap-2 text-gray-400">
                    <svg class="mt-0.5 h-5 w-5 shrink-0 text-green-400" fill="currentColor" viewBox="0 0 20 20">
                      <path
                        fill-rule="evenodd"
                        d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z"
                        clip-rule="evenodd"></path>
                    </svg>
                    {m.solutions_agencies_sol3_point3({}, { locale })}
                  </li>
                </ul>
              </div>
              <div class="flex items-center justify-center rounded-xl bg-gray-900 p-6">
                <div class="w-full max-w-sm">
                  <HandoffIllustration class="text-green-500" />
                </div>
              </div>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- Agency Partner Program -->
    <section class="bg-gray-800 py-20">
      <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
        <div class="mx-auto mb-16 max-w-3xl text-center">
          <h2 class="text-3xl font-bold text-white sm:text-4xl">{m.solutions_agencies_partner_title({}, { locale })}</h2>
          <p class="mt-4 text-xl text-gray-400">{m.solutions_agencies_partner_subtitle({}, { locale })}</p>
        </div>

        <div class="grid grid-cols-1 gap-8 md:grid-cols-3">
          <div class="rounded-2xl border border-gray-700 bg-gray-900 p-8 text-center">
            <div class="mx-auto mb-6 flex h-16 w-16 items-center justify-center rounded-full bg-amber-500/20">
              <svg class="h-8 w-8 text-amber-400" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  stroke-width="2"
                  d="M12 8c-1.657 0-3 .895-3 2s1.343 2 3 2 3 .895 3 2-1.343 2-3 2m0-8c1.11 0 2.08.402 2.599 1M12 8V7m0 1v8m0 0v1m0-1c-1.11 0-2.08-.402-2.599-1M21 12a9 9 0 11-18 0 9 9 0 0118 0z"
                ></path>
              </svg>
            </div>
            <h3 class="mb-4 text-xl font-bold text-white">{m.solutions_agencies_perk1_title({}, { locale })}</h3>
