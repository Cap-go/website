---
import Layout from '@/layouts/Layout.astro'
import m from '@/copy/messages'
import { getRelativeLocaleUrl } from 'astro:i18n'
import { createServiceLdJson, createLdJsonGraph } from '@/lib/ldJson'

const locale = Astro.locals.locale
const brand = Astro.locals.runtimeConfig.public.brand
const baseUrl = Astro.locals.runtimeConfig.public.baseUrl

const title = `${brand} | ${m.solutions_set_and_forget_title({}, { locale })}`
const description = m.solutions_set_and_forget_description({}, { locale })

const serviceLdJson = createServiceLdJson(Astro.locals.runtimeConfig.public, {
  name: title,
  description,
  url: Astro.url.href,
  serviceType: 'Enterprise Software Service',
  areaServed: ['Worldwide'],
})

const ldJSON = createLdJsonGraph(Astro.locals.runtimeConfig.public, serviceLdJson, {
  includeOrganization: true,
})

const content = {
  title,
  description,
  image: `${baseUrl}/capgo_social.png`,
  ldJSON,
}

const proofPoints = [
  {
    label: m.solutions_set_and_forget_install_label({}, { locale }),
    description: m.solutions_set_and_forget_install_desc({}, { locale }),
  },
  {
    label: m.solutions_set_and_forget_update_label({}, { locale }),
    description: m.solutions_set_and_forget_update_desc({}, { locale }),
  },
  {
    label: m.solutions_set_and_forget_offline_label({}, { locale }),
    description: m.solutions_set_and_forget_offline_desc({}, { locale }),
  },
]

const workflowSteps = [
  {
    title: m.solutions_set_and_forget_workflow_1_title({}, { locale }),
    description: m.solutions_set_and_forget_workflow_1_desc({}, { locale }),
  },
  {
    title: m.solutions_set_and_forget_workflow_2_title({}, { locale }),
    description: m.solutions_set_and_forget_workflow_2_desc({}, { locale }),
  },
  {
    title: m.solutions_set_and_forget_workflow_3_title({}, { locale }),
    description: m.solutions_set_and_forget_workflow_3_desc({}, { locale }),
  },
  {
    title: m.solutions_set_and_forget_workflow_4_title({}, { locale }),
    description: m.solutions_set_and_forget_workflow_4_desc({}, { locale }),
  },
  {
    title: m.solutions_set_and_forget_workflow_5_title({}, { locale }),
    description: m.solutions_set_and_forget_workflow_5_desc({}, { locale }),
  },
]

const constraints = [
  {
    title: m.solutions_set_and_forget_constraint_1_title({}, { locale }),
    description: m.solutions_set_and_forget_constraint_1_desc({}, { locale }),
  },
  {
    title: m.solutions_set_and_forget_constraint_2_title({}, { locale }),
    description: m.solutions_set_and_forget_constraint_2_desc({}, { locale }),
  },
  {
    title: m.solutions_set_and_forget_constraint_3_title({}, { locale }),
    description: m.solutions_set_and_forget_constraint_3_desc({}, { locale }),
  },
  {
    title: m.solutions_set_and_forget_constraint_4_title({}, { locale }),
    description: m.solutions_set_and_forget_constraint_4_desc({}, { locale }),
  },
]

const boundaries = [
  m.solutions_set_and_forget_boundary_1({}, { locale }),
  m.solutions_set_and_forget_boundary_2({}, { locale }),
  m.solutions_set_and_forget_boundary_3({}, { locale }),
  m.solutions_set_and_forget_boundary_4({}, { locale }),
]
---

<Layout content={content}>
  <div class="bg-slate-950">
    <section class="border-b border-slate-800 py-16 sm:py-20 lg:py-24">
      <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
        <div class="grid items-center gap-12 lg:grid-cols-[11fr_9fr]">
          <div>
            <p class="inline-flex items-center gap-2 rounded-full border border-amber-300/35 bg-amber-300/10 px-4 py-2 text-sm font-medium text-amber-100">
              <svg class="size-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" aria-hidden="true" focusable="false">
                <path
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  stroke-width="2"
                  d="M4 4v5h.582m15.356 2A8.001 8.001 0 004.582 9m0 0H9m11 11v-5h-.581m0 0a8.003 8.003 0 01-15.357-2m15.357 2H15"></path>
              </svg>
              {m.solutions_set_and_forget({}, { locale })}
            </p>
            <h1 class="mt-6 max-w-[13ch] text-4xl font-semibold tracking-tight text-balance text-white sm:text-5xl lg:text-6xl">
              {m.solutions_set_and_forget_hero_title({}, { locale })}
            </h1>
            <p class="mt-6 max-w-[64ch] text-lg text-pretty text-slate-300 sm:text-xl">
              {m.solutions_set_and_forget_hero_subtitle({}, { locale })}
            </p>
            <div class="mt-8 flex flex-col gap-3 sm:flex-row">
              <a
                href="https://book.capgo.app/demo/"
                target="_blank"
                rel="noopener noreferrer"
                class="inline-flex min-h-12 items-center justify-center rounded-xl bg-amber-300 px-4 py-3 text-base font-semibold text-slate-950 transition-colors hover:bg-amber-200 focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-amber-200"
              >
                {m.solutions_set_and_forget_cta_primary({}, { locale })}
              </a>
              <a
                href={getRelativeLocaleUrl(locale, 'docs/live-updates/update-behavior')}
                class="inline-flex min-h-12 items-center justify-center rounded-xl border border-slate-600 px-4 py-3 text-base font-semibold text-slate-200 transition-colors hover:border-slate-400 hover:bg-slate-900 hover:text-white focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-slate-300"
              >
                {m.solutions_set_and_forget_cta_secondary({}, { locale })}
              </a>
            </div>
          </div>

          <figure class="overflow-hidden rounded-2xl border border-slate-700 bg-slate-900 shadow-2xl shadow-slate-950/50">
            <div class="flex items-center justify-between border-b border-slate-700 p-4">
              <div class="flex items-center gap-2">
                <span class="size-3 rounded-full bg-rose-400" aria-hidden="true"></span>
                <span class="size-3 rounded-full bg-amber-300" aria-hidden="true"></span>
                <span class="size-3 rounded-full bg-emerald-400" aria-hidden="true"></span>
              </div>
              <p class="text-sm font-medium text-slate-300">{m.solutions_set_and_forget_channels_label({}, { locale })}</p>
            </div>
            <img
              src="/channels.webp"
              alt="Capgo channels dashboard used to manage private enterprise app releases"
              width="3080"
              height="986"
              loading="eager"
              decoding="async"
              class="aspect-[16/7] w-full object-cover object-left"
            />
            <dl class="grid grid-cols-1 divide-y divide-slate-700 text-sm sm:grid-cols-3 sm:divide-x sm:divide-y-0">
              <div class="p-4">
                <dt class="font-medium text-slate-400">{m.solutions_set_and_forget_channels_label({}, { locale })}</dt>
                <dd class="mt-1 text-slate-100">{m.solutions_set_and_forget_channels_value({}, { locale })}</dd>
              </div>
              <div class="p-4">
                <dt class="font-medium text-slate-400">{m.solutions_set_and_forget_rollout_label({}, { locale })}</dt>
                <dd class="mt-1 text-slate-100">{m.solutions_set_and_forget_rollout_value({}, { locale })}</dd>
              </div>
              <div class="p-4">
                <dt class="font-medium text-slate-400">{m.solutions_set_and_forget_update_label({}, { locale })}</dt>
                <dd class="mt-1 text-slate-100">{m.solutions_set_and_forget_offline_label({}, { locale })}</dd>
              </div>
            </dl>
          </figure>
        </div>

        <dl class="mt-12 grid gap-4 sm:grid-cols-3">
          {
            proofPoints.map((item) => (
              <div class="rounded-2xl border border-slate-800 bg-slate-900 p-5">
                <dt class="text-lg font-semibold text-white">{item.label}</dt>
                <dd class="mt-2 text-base text-slate-400">{item.description}</dd>
              </div>
            ))
          }
        </dl>
      </div>
    </section>

    <section class="bg-slate-900 py-16 sm:py-20">
      <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
        <div class="grid gap-10 lg:grid-cols-[8fr_9fr] lg:items-center">
          <div>
            <h2 class="max-w-[18ch] text-3xl font-semibold tracking-tight text-balance text-white sm:text-4xl">
              {m.solutions_set_and_forget_problem_title({}, { locale })}
            </h2>
            <p class="mt-5 max-w-[62ch] text-lg text-pretty text-slate-300">
              {m.solutions_set_and_forget_problem_copy({}, { locale })}
            </p>
          </div>
          <dl class="grid gap-4 sm:grid-cols-3">
            <div class="rounded-2xl border border-sky-400/25 bg-sky-400/10 p-5">
              <dt class="text-sm font-medium text-sky-200">{m.solutions_set_and_forget_install_label({}, { locale })}</dt>
              <dd class="mt-3 text-2xl font-semibold tracking-tight text-white">1x</dd>
            </div>
            <div class="rounded-2xl border border-emerald-400/25 bg-emerald-400/10 p-5">
              <dt class="text-sm font-medium text-emerald-200">{m.solutions_set_and_forget_update_label({}, { locale })}</dt>
              <dd class="mt-3 text-2xl font-semibold tracking-tight text-white">{m.solutions_set_and_forget_ci_label({}, { locale })}</dd>
            </div>
            <div class="rounded-2xl border border-amber-300/25 bg-amber-300/10 p-5">
              <dt class="text-sm font-medium text-amber-100">{m.solutions_set_and_forget_offline_label({}, { locale })}</dt>
              <dd class="mt-3 text-2xl font-semibold tracking-tight text-white">cached</dd>
            </div>
          </dl>
        </div>
      </div>
    </section>

    <section class="py-16 sm:py-20">
      <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
        <h2 class="max-w-[18ch] text-3xl font-semibold tracking-tight text-balance text-white sm:text-4xl">
          {m.solutions_set_and_forget_workflow_title({}, { locale })}
        </h2>
        <ol class="mt-10 grid gap-4 md:grid-cols-2 lg:grid-cols-5">
          {
            workflowSteps.map((step, index) => (
              <li class="rounded-2xl border border-slate-800 bg-slate-900 p-5">
                <span class="flex size-10 items-center justify-center rounded-full bg-amber-300 text-sm font-semibold text-slate-950 tabular-nums">{index + 1}</span>
                <h3 class="mt-5 text-lg font-semibold text-white">{step.title}</h3>
                <p class="mt-3 text-base text-pretty text-slate-400">{step.description}</p>
              </li>
            ))
          }
        </ol>
      </div>
    </section>

    <section class="bg-slate-900 py-16 sm:py-20">
      <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
        <div class="grid gap-10 lg:grid-cols-[7fr_10fr]">
          <div>
            <h2 class="max-w-[19ch] text-3xl font-semibold tracking-tight text-balance text-white sm:text-4xl">
              {m.solutions_set_and_forget_constraints_title({}, { locale })}
            </h2>
            <p class="mt-5 max-w-[58ch] text-lg text-pretty text-slate-300">
              {m.solutions_set_and_forget_implementation_desc({}, { locale })}
            </p>
          </div>
          <dl class="grid gap-4 sm:grid-cols-2">
            {
              constraints.map((item) => (
                <div class="rounded-2xl border border-slate-800 bg-slate-950 p-6">
                  <dt class="text-lg font-semibold text-white">{item.title}</dt>
                  <dd class="mt-3 text-base text-pretty text-slate-400">{item.description}</dd>
                </div>
              ))
            }
          </dl>
        </div>
      </div>
    </section>

    <section class="py-16 sm:py-20">
      <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
        <div class="grid gap-8 lg:grid-cols-2">
          <div>
            <h2 class="max-w-[18ch] text-3xl font-semibold tracking-tight text-balance text-white sm:text-4xl">
              {m.solutions_set_and_forget_implementation_title({}, { locale })}
            </h2>
            <p class="mt-5 max-w-[62ch] text-lg text-pretty text-slate-300">
              {m.solutions_set_and_forget_implementation_desc({}, { locale })}
            </p>
          </div>
          <div class="grid gap-4">
            <div class="overflow-hidden rounded-2xl border border-slate-800 bg-slate-900">
              <div class="border-b border-slate-800 px-5 py-3 text-sm font-medium text-slate-300">{m.solutions_set_and_forget_ci_label({}, { locale })}</div>
              <pre
                class="overflow-x-auto p-5 text-sm text-slate-300"><code><span class="text-slate-500"># Build and publish the web layer</span>
npx @capgo/cli@latest bundle upload --channel site-eu

<span class="text-slate-500"># Promote after the first site validates it</span>
npx @capgo/cli@latest channel set production com.enterprise.app --latest</code></pre>
            </div>
            <div class="overflow-hidden rounded-2xl border border-slate-800 bg-slate-900">
              <div class="border-b border-slate-800 px-5 py-3 text-sm font-medium text-slate-300">{m.solutions_set_and_forget_config_label({}, { locale })}</div>
              <pre
                class="overflow-x-auto p-5 text-sm text-slate-300"><code>const config = {'{'}
  plugins: {'{'}
    CapacitorUpdater: {'{'}
      defaultChannel: 'production',
      autoUpdate: true,
    {'}'},
  {'}'},
{'}'}</code></pre>
            </div>
          </div>
        </div>
      </div>
    </section>

    <section class="border-y border-slate-800 bg-slate-900 py-16 sm:py-20">
      <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
        <div class="grid gap-10 lg:grid-cols-[7fr_10fr]">
          <h2 class="max-w-[18ch] text-3xl font-semibold tracking-tight text-balance text-white sm:text-4xl">
            {m.solutions_set_and_forget_boundary_title({}, { locale })}
          </h2>
          <ul class="grid gap-4">
            {
              boundaries.map((item) => (
                <li class="flex gap-4 rounded-2xl border border-slate-800 bg-slate-950 p-5 text-base text-pretty text-slate-300">
                  <svg class="mt-1 size-5 shrink-0 text-emerald-300" fill="none" viewBox="0 0 24 24" stroke="currentColor" aria-hidden="true" focusable="false">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12.75 11.25 15 15 9.75M21 12a9 9 0 1 1-18 0 9 9 0 0 1 18 0Z" />
                  </svg>
                  <span>{item}</span>
                </li>
              ))
            }
          </ul>
        </div>
      </div>
    </section>

    <section class="py-16 sm:py-20">
      <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
        <div class="rounded-2xl border border-amber-300/30 bg-amber-300/10 p-6 sm:p-8 lg:flex lg:items-center lg:justify-between lg:gap-8">
          <div>
            <h2 class="max-w-[22ch] text-3xl font-semibold tracking-tight text-balance text-white sm:text-4xl">
              {m.solutions_set_and_forget_cta_title({}, { locale })}
            </h2>
            <p class="mt-4 max-w-[64ch] text-lg text-pretty text-amber-50/80">
              {m.solutions_set_and_forget_cta_subtitle({}, { locale })}
            </p>
          </div>
          <a
            href="https://book.capgo.app/demo/"
            target="_blank"
            rel="noopener noreferrer"
            class="mt-8 inline-flex min-h-12 items-center justify-center rounded-xl border border-amber-200 px-4 py-3 text-base font-semibold text-amber-50 transition-colors hover:bg-amber-200 hover:text-slate-950 focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-amber-200 lg:mt-0"
          >
            {m.solutions_set_and_forget_cta_primary({}, { locale })}
          </a>
        </div>
      </div>
    </section>
  </div>
</Layout>
