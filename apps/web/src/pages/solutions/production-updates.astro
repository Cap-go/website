          <a href={getRelativeLocaleUrl(locale, 'solutions/agencies')} class="group rounded-xl border border-gray-700 bg-gray-900 p-6 transition-all hover:border-blue-500/50">
            <div class="mb-3 flex h-10 w-10 items-center justify-center rounded-lg bg-amber-500/20">
              <svg class="h-5 w-5 text-amber-400" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  stroke-width="2"
                  d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0zm6 3a2 2 0 11-4 0 2 2 0 014 0zM7 10a2 2 0 11-4 0 2 2 0 014 0z"
                ></path>
              </svg>
            </div>
            <h3 class="font-bold text-white transition-colors group-hover:text-blue-400">{m.solutions_agencies_short({}, { locale })}</h3>
            <p class="mt-1 text-sm text-gray-400">{m.solutions_agencies_tagline({}, { locale })}</p>
          </a>
        </div>
      </div>
    </section>

    <!-- Final CTA -->

    <SolutionAppExample solution="production-updates" />
    <section class="bg-gray-900 py-20">
      <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
        <div class="relative overflow-hidden rounded-3xl bg-linear-to-r from-blue-600 to-blue-800 px-8 py-16 sm:px-16">
          <div aria-hidden="true" class="absolute inset-0">
            <svg class="absolute inset-0 h-full w-full" preserveAspectRatio="xMidYMid slice" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 1463 360">
              <path class="text-opacity-40 text-blue-500" fill="currentColor" d="M-82.673 72l1761.849 472.086-134.327 501.315-1761.85-472.086z"></path>
              <path class="text-opacity-20 text-blue-400" fill="currentColor" d="M-217.088 544.086L1544.761 72l134.327 501.316-1761.849 472.086z"></path>
            </svg>
          </div>
          <div class="relative text-center">
            <h2 class="text-3xl font-bold text-white sm:text-4xl">{m.solutions_final_cta_title({}, { locale })}</h2>
            <p class="mx-auto mt-4 max-w-2xl text-lg text-blue-100">{m.solutions_final_cta_subtitle({}, { locale })}</p>
            <div class="mt-8 flex flex-col items-center justify-center gap-4 sm:flex-row">
              <a
                href={getRelativeLocaleUrl(locale, 'register')}
                class="rounded-xl bg-white px-8 py-4 text-base font-semibold text-blue-600 shadow-lg transition-all duration-200 hover:bg-gray-100"
              >
                {m.solutions_start_free_trial({}, { locale })}
              </a>
              <a
                href="https://book.capgo.app/demo/"
                target="_blank"
                rel="noopener noreferrer"
                class="rounded-xl border border-white/30 px-8 py-4 text-base font-semibold text-white transition-all duration-200 hover:bg-white/10"
              >
                {m.solutions_schedule_demo({}, { locale })}
              </a>
            </div>
            <p class="mt-6 text-sm text-blue-200">{m.solutions_final_cta_note({}, { locale })}</p>
          </div>
        </div>
      </div>
    </section>
  </div>
</Layout>
