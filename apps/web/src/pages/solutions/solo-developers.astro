---
import Layout from '@/layouts/Layout.astro'
import m from '@/copy/messages'
import SolutionAppExample from '@/components/solutions/SolutionAppExample.astro'
import { getRelativeLocaleUrl } from '@/services/links'
import RolloutIllustration from '@/components/solutions/RolloutIllustration.astro'
import { createServiceLdJson, createLdJsonGraph } from '@/lib/ldJson'

const locale = Astro.locals.locale
const brand = Astro.locals.runtimeConfig.public.brand

const title = `${brand} | ${m.solutions_solo_title({}, { locale })}`
const description = m.solutions_solo_description({}, { locale })

const serviceLdJson = createServiceLdJson(Astro.locals.runtimeConfig.public, {
  name: title,
  description: description,
  url: Astro.url.href,
  serviceType: 'Software Development Service',
  areaServed: ['Worldwide'],
})

const ldJSON = createLdJsonGraph(Astro.locals.runtimeConfig.public, serviceLdJson, {
  includeOrganization: true,
})

const content = { title, description, ldJSON }
---

<Layout content={content}>
  <div>
    <!-- Hero Section -->
    <section class="relative overflow-hidden py-20 sm:py-28 lg:py-36">
      <div class="pointer-events-none absolute inset-0 overflow-hidden">
        <div class="absolute top-0 left-1/2 h-full w-full max-w-6xl -translate-x-1/2">
          <div class="absolute top-1/4 left-1/4 h-96 w-96 rounded-full bg-violet-500/10 blur-3xl"></div>
          <div class="absolute right-1/4 bottom-1/4 h-96 w-96 rounded-full bg-purple-500/10 blur-3xl"></div>
        </div>
      </div>

      <div class="relative mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
        <div class="mx-auto max-w-4xl text-center">
          <div class="mb-8 inline-flex items-center rounded-full border border-violet-400/40 bg-violet-500/10 px-4 py-2 text-sm font-medium text-violet-200">
            <svg class="mr-2 h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z"></path>
            </svg>
            {m.solutions_solo_badge({}, { locale })}
          </div>

          <h1 class="text-4xl leading-tight font-bold text-white sm:text-5xl lg:text-6xl">
            {m.solutions_solo_hero_title({}, { locale })}
          </h1>

          <p class="mx-auto mt-8 max-w-3xl text-xl leading-relaxed text-gray-300">
            {m.solutions_solo_hero_subtitle({}, { locale })}
          </p>

          <div class="mt-10 flex flex-col items-center justify-center gap-4 sm:flex-row">
            <a
              href={getRelativeLocaleUrl(locale, 'register')}
              class="rounded-xl bg-violet-600 px-8 py-4 text-base font-semibold text-white shadow-lg shadow-violet-500/25 transition-all duration-200 hover:bg-violet-700 focus:ring-2 focus:ring-violet-500 focus:ring-offset-2"
            >
              {m.solutions_start_free_trial({}, { locale })}
            </a>
            <a
              href={getRelativeLocaleUrl(locale, 'docs')}
              class="rounded-xl border border-gray-600 px-8 py-4 text-base font-semibold text-gray-300 transition-all duration-200 hover:bg-gray-800 hover:text-white"
            >
              {m.solutions_solo_read_docs({}, { locale })}
            </a>
          </div>

          <!-- Solo-friendly highlight -->
          <div class="mt-8 inline-flex items-center gap-2 rounded-full bg-violet-500/10 px-4 py-2 text-violet-300">
            <svg class="h-5 w-5" fill="currentColor" viewBox="0 0 20 20">
              <path
                fill-rule="evenodd"
                d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z"
                clip-rule="evenodd"></path>
            </svg>
            {m.solutions_solo_highlight({}, { locale })}
          </div>
        </div>
      </div>
    </section>

    <!-- The Solo Developer Reality -->
    <section class="bg-gray-800 py-20">
      <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
        <div class="mx-auto mb-16 max-w-3xl text-center">
          <h2 class="mb-4 text-sm font-semibold tracking-wide text-red-400 uppercase">{m.solutions_solo_reality_label({}, { locale })}</h2>
          <h3 class="text-3xl font-bold text-white sm:text-4xl">{m.solutions_solo_reality_title({}, { locale })}</h3>
        </div>

        <div class="grid grid-cols-1 gap-8 md:grid-cols-2 lg:grid-cols-3">
          <div class="rounded-xl border border-red-500/20 bg-gray-900 p-6">
            <div class="mb-4 flex h-12 w-12 items-center justify-center rounded-lg bg-red-500/20">
              <svg class="h-6 w-6 text-red-400" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  stroke-width="2"
                  d="M19 11H5m14 0a2 2 0 012 2v6a2 2 0 01-2 2H5a2 2 0 01-2-2v-6a2 2 0 012-2m14 0V9a2 2 0 00-2-2M5 11V9a2 2 0 012-2m0 0V5a2 2 0 012-2h6a2 2 0 012 2v2M7 7h10"></path>
              </svg>
            </div>
            <h4 class="mb-2 text-lg font-bold text-white">{m.solutions_solo_pain1_title({}, { locale })}</h4>
            <p class="text-gray-400">{m.solutions_solo_pain1_desc({}, { locale })}</p>
          </div>

          <div class="rounded-xl border border-red-500/20 bg-gray-900 p-6">
            <div class="mb-4 flex h-12 w-12 items-center justify-center rounded-lg bg-red-500/20">
              <svg class="h-6 w-6 text-red-400" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"></path>
              </svg>
            </div>
            <h4 class="mb-2 text-lg font-bold text-white">{m.solutions_solo_pain2_title({}, { locale })}</h4>
            <p class="text-gray-400">{m.solutions_solo_pain2_desc({}, { locale })}</p>
          </div>

          <div class="rounded-xl border border-red-500/20 bg-gray-900 p-6">
            <div class="mb-4 flex h-12 w-12 items-center justify-center rounded-lg bg-red-500/20">
              <svg class="h-6 w-6 text-red-400" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9.172 16.172a4 4 0 015.656 0M9 10h.01M15 10h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"></path>
              </svg>
            </div>
            <h4 class="mb-2 text-lg font-bold text-white">{m.solutions_solo_pain3_title({}, { locale })}</h4>
            <p class="text-gray-400">{m.solutions_solo_pain3_desc({}, { locale })}</p>
          </div>

          <div class="rounded-xl border border-red-500/20 bg-gray-900 p-6">
            <div class="mb-4 flex h-12 w-12 items-center justify-center rounded-lg bg-red-500/20">
              <svg class="h-6 w-6 text-red-400" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  stroke-width="2"
                  d="M12 8c-1.657 0-3 .895-3 2s1.343 2 3 2 3 .895 3 2-1.343 2-3 2m0-8c1.11 0 2.08.402 2.599 1M12 8V7m0 1v8m0 0v1m0-1c-1.11 0-2.08-.402-2.599-1M21 12a9 9 0 11-18 0 9 9 0 0118 0z"
                ></path>
              </svg>
            </div>
            <h4 class="mb-2 text-lg font-bold text-white">{m.solutions_solo_pain4_title({}, { locale })}</h4>
            <p class="text-gray-400">{m.solutions_solo_pain4_desc({}, { locale })}</p>
          </div>

          <div class="rounded-xl border border-red-500/20 bg-gray-900 p-6">
            <div class="mb-4 flex h-12 w-12 items-center justify-center rounded-lg bg-red-500/20">
              <svg class="h-6 w-6 text-red-400" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  stroke-width="2"
                  d="M18.364 18.364A9 9 0 005.636 5.636m12.728 12.728A9 9 0 015.636 5.636m12.728 12.728L5.636 5.636"></path>
              </svg>
            </div>
            <h4 class="mb-2 text-lg font-bold text-white">{m.solutions_solo_pain5_title({}, { locale })}</h4>
            <p class="text-gray-400">{m.solutions_solo_pain5_desc({}, { locale })}</p>
          </div>

          <div class="rounded-xl border border-red-500/20 bg-gray-900 p-6">
            <div class="mb-4 flex h-12 w-12 items-center justify-center rounded-lg bg-red-500/20">
              <svg class="h-6 w-6 text-red-400" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 16h-1v-4h-1m1-4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"></path>
              </svg>
            </div>
            <h4 class="mb-2 text-lg font-bold text-white">{m.solutions_solo_pain6_title({}, { locale })}</h4>
            <p class="text-gray-400">{m.solutions_solo_pain6_desc({}, { locale })}</p>
          </div>
        </div>
      </div>
    </section>

    <!-- Your New Superpower -->
    <section class="bg-gray-900 py-20">
      <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
        <div class="mx-auto mb-16 max-w-3xl text-center">
          <h2 class="mb-4 text-sm font-semibold tracking-wide text-violet-400 uppercase">{m.solutions_solo_superpower_label({}, { locale })}</h2>
          <h3 class="text-3xl font-bold text-white sm:text-4xl">{m.solutions_solo_superpower_title({}, { locale })}</h3>
          <p class="mt-4 text-xl text-gray-400">{m.solutions_solo_superpower_subtitle({}, { locale })}</p>
        </div>

        <div class="grid grid-cols-1 gap-8 lg:grid-cols-2">
          <!-- Before/After -->
          <div class="rounded-2xl border border-gray-700 bg-gray-800 p-8">
            <h4 class="mb-6 flex items-center gap-2 text-lg font-bold text-red-400">
              <svg class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"></path>
              </svg>
              {m.solutions_solo_before_title({}, { locale })}
            </h4>
            <ul class="space-y-4">
              <li class="flex items-start gap-3 text-gray-400">
                <svg class="mt-0.5 h-5 w-5 shrink-0 text-red-400" fill="currentColor" viewBox="0 0 20 20">
                  <path
                    fill-rule="evenodd"
                    d="M10 18a8 8 0 100-16 8 8 0 000 16zM8.707 7.293a1 1 0 00-1.414 1.414L8.586 10l-1.293 1.293a1 1 0 101.414 1.414L10 11.414l1.293 1.293a1 1 0 001.414-1.414L11.414 10l1.293-1.293a1 1 0 00-1.414-1.414L10 8.586 8.707 7.293z"
                    clip-rule="evenodd"></path>
                </svg>
                {m.solutions_solo_before1({}, { locale })}
              </li>
              <li class="flex items-start gap-3 text-gray-400">
                <svg class="mt-0.5 h-5 w-5 shrink-0 text-red-400" fill="currentColor" viewBox="0 0 20 20">
                  <path
                    fill-rule="evenodd"
                    d="M10 18a8 8 0 100-16 8 8 0 000 16zM8.707 7.293a1 1 0 00-1.414 1.414L8.586 10l-1.293 1.293a1 1 0 101.414 1.414L10 11.414l1.293 1.293a1 1 0 001.414-1.414L11.414 10l1.293-1.293a1 1 0 00-1.414-1.414L10 8.586 8.707 7.293z"
                    clip-rule="evenodd"></path>
                </svg>
                {m.solutions_solo_before2({}, { locale })}
              </li>
              <li class="flex items-start gap-3 text-gray-400">
                <svg class="mt-0.5 h-5 w-5 shrink-0 text-red-400" fill="currentColor" viewBox="0 0 20 20">
                  <path
                    fill-rule="evenodd"
                    d="M10 18a8 8 0 100-16 8 8 0 000 16zM8.707 7.293a1 1 0 00-1.414 1.414L8.586 10l-1.293 1.293a1 1 0 101.414 1.414L10 11.414l1.293 1.293a1 1 0 001.414-1.414L11.414 10l1.293-1.293a1 1 0 00-1.414-1.414L10 8.586 8.707 7.293z"
                    clip-rule="evenodd"></path>
                </svg>
                {m.solutions_solo_before3({}, { locale })}
              </li>
              <li class="flex items-start gap-3 text-gray-400">
                <svg class="mt-0.5 h-5 w-5 shrink-0 text-red-400" fill="currentColor" viewBox="0 0 20 20">
                  <path
                    fill-rule="evenodd"
                    d="M10 18a8 8 0 100-16 8 8 0 000 16zM8.707 7.293a1 1 0 00-1.414 1.414L8.586 10l-1.293 1.293a1 1 0 101.414 1.414L10 11.414l1.293 1.293a1 1 0 001.414-1.414L11.414 10l1.293-1.293a1 1 0 00-1.414-1.414L10 8.586 8.707 7.293z"
                    clip-rule="evenodd"></path>
                </svg>
                {m.solutions_solo_before4({}, { locale })}
              </li>
            </ul>
          </div>

          <div class="rounded-2xl border border-violet-500/30 bg-gray-800 p-8">
            <h4 class="mb-6 flex items-center gap-2 text-lg font-bold text-violet-400">
              <svg class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path>
              </svg>
              {m.solutions_solo_after_title({}, { locale })}
            </h4>
            <div class="mb-6">
              <RolloutIllustration class="text-violet-500" />
            </div>
            <ul class="space-y-4">
              <li class="flex items-start gap-3 text-gray-300">
                <svg class="mt-0.5 h-5 w-5 shrink-0 text-green-400" fill="currentColor" viewBox="0 0 20 20">
                  <path
                    fill-rule="evenodd"
                    d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z"
                    clip-rule="evenodd"></path>
                </svg>
                {m.solutions_solo_after1({}, { locale })}
              </li>
              <li class="flex items-start gap-3 text-gray-300">
                <svg class="mt-0.5 h-5 w-5 shrink-0 text-green-400" fill="currentColor" viewBox="0 0 20 20">
                  <path
                    fill-rule="evenodd"
                    d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z"
                    clip-rule="evenodd"></path>
                </svg>
                {m.solutions_solo_after2({}, { locale })}
              </li>
              <li class="flex items-start gap-3 text-gray-300">
                <svg class="mt-0.5 h-5 w-5 shrink-0 text-green-400" fill="currentColor" viewBox="0 0 20 20">
                  <path
                    fill-rule="evenodd"
                    d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z"
                    clip-rule="evenodd"></path>
                </svg>
                {m.solutions_solo_after3({}, { locale })}
              </li>
              <li class="flex items-start gap-3 text-gray-300">
                <svg class="mt-0.5 h-5 w-5 shrink-0 text-green-400" fill="currentColor" viewBox="0 0 20 20">
                  <path
                    fill-rule="evenodd"
                    d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z"
                    clip-rule="evenodd"></path>
                </svg>
                {m.solutions_solo_after4({}, { locale })}
              </li>
            </ul>
          </div>
        </div>
      </div>
    </section>

    <!-- AI-Powered Development -->
    <section class="bg-gray-800 py-20">
      <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
        <div class="mx-auto mb-16 max-w-3xl text-center">
          <h2 class="mb-4 text-sm font-semibold tracking-wide text-violet-400 uppercase">{m.solutions_solo_ai_label({}, { locale })}</h2>
          <h3 class="text-3xl font-bold text-white sm:text-4xl">{m.solutions_solo_ai_title({}, { locale })}</h3>
          <p class="mt-4 text-xl text-gray-400">{m.solutions_solo_ai_subtitle({}, { locale })}</p>
        </div>

        <div class="grid grid-cols-1 items-center gap-8 lg:grid-cols-2">
          <!-- Visual -->
          <div class="rounded-2xl border border-violet-500/30 bg-gray-900 p-6">
            <div class="mb-4 flex items-center gap-2">
              <div class="h-3 w-3 rounded-full bg-gray-500"></div>
              <div class="h-3 w-3 rounded-full bg-gray-500"></div>
              <div class="h-3 w-3 rounded-full bg-gray-500"></div>
              <span class="ml-2 text-sm text-gray-500">{m.solutions_solo_ai_terminal({}, { locale })}</span>
            </div>
            <pre
              class="overflow-x-auto text-sm text-gray-300"><code><span class="text-gray-500"># Vibe code a new feature with AI</span>
<span class="text-violet-400">$</span> cursor "add dark mode toggle to settings"

<span class="text-green-400">✓</span> Feature implemented by AI

<span class="text-gray-500"># Ship it instantly - just like a website</span>
<span class="text-violet-400">$</span> npm run build && npx @capgo/cli bundle upload

<span class="text-green-400">✓</span> Bundle uploaded
<span class="text-green-400">✓</span> Users updated in minutes
<span class="text-green-400">✓</span> No app store. No waiting. Done.</code></pre>
          </div>

          <!-- Benefits -->
          <div class="space-y-6">
            <div class="flex items-start gap-4">
              <div class="flex h-12 w-12 shrink-0 items-center justify-center rounded-lg bg-violet-500/20">
                <svg class="h-6 w-6 text-violet-400" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                  <path
                    stroke-linecap="round"
                    stroke-linejoin="round"
                    stroke-width="2"
                    d="M9.663 17h4.673M12 3v1m6.364 1.636l-.707.707M21 12h-1M4 12H3m3.343-5.657l-.707-.707m2.828 9.9a5 5 0 117.072 0l-.548.547A3.374 3.374 0 0014 18.469V19a2 2 0 11-4 0v-.531c0-.895-.356-1.754-.988-2.386l-.548-.547z"
                  ></path>
                </svg>
              </div>
              <div>
                <h4 class="mb-2 text-lg font-bold text-white">{m.solutions_solo_ai_benefit1_title({}, { locale })}</h4>
                <p class="text-gray-400">{m.solutions_solo_ai_benefit1_desc({}, { locale })}</p>
              </div>
            </div>

            <div class="flex items-start gap-4">
              <div class="flex h-12 w-12 shrink-0 items-center justify-center rounded-lg bg-green-500/20">
                <svg class="h-6 w-6 text-green-400" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z"></path>
                </svg>
              </div>
              <div>
                <h4 class="mb-2 text-lg font-bold text-white">{m.solutions_solo_ai_benefit2_title({}, { locale })}</h4>
                <p class="text-gray-400">{m.solutions_solo_ai_benefit2_desc({}, { locale })}</p>
              </div>
            </div>

            <div class="flex items-start gap-4">
              <div class="flex h-12 w-12 shrink-0 items-center justify-center rounded-lg bg-blue-500/20">
                <svg class="h-6 w-6 text-blue-400" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                  <path
                    stroke-linecap="round"
                    stroke-linejoin="round"
                    stroke-width="2"
                    d="M21 12a9 9 0 01-9 9m9-9a9 9 0 00-9-9m9 9H3m9 9a9 9 0 01-9-9m9 9c1.657 0 3-4.03 3-9s-1.343-9-3-9m0 18c-1.657 0-3-4.03-3-9s1.343-9 3-9m-9 9a9 9 0 019-9"
                  ></path>
                </svg>
              </div>
              <div>
                <h4 class="mb-2 text-lg font-bold text-white">{m.solutions_solo_ai_benefit3_title({}, { locale })}</h4>
                <p class="text-gray-400">{m.solutions_solo_ai_benefit3_desc({}, { locale })}</p>
              </div>
            </div>
          </div>
        </div>

        <!-- Comparison -->
        <div class="mx-auto mt-16 max-w-4xl">
          <div class="grid grid-cols-1 gap-8 md:grid-cols-2">
            <div class="rounded-xl border border-red-500/30 bg-gray-900 p-6">
              <h4 class="mb-4 text-lg font-bold text-red-400">{m.solutions_solo_ai_old_way({}, { locale })}</h4>
              <ol class="space-y-3 text-sm text-gray-400">
                <li class="flex items-center gap-2">
                  <span class="text-red-400">1.</span>
                  {m.solutions_solo_ai_old1({}, { locale })}
                </li>
                <li class="flex items-center gap-2">
                  <span class="text-red-400">2.</span>
                  {m.solutions_solo_ai_old2({}, { locale })}
                </li>
                <li class="flex items-center gap-2">
                  <span class="text-red-400">3.</span>
                  {m.solutions_solo_ai_old3({}, { locale })}
                </li>
                <li class="flex items-center gap-2">
                  <span class="text-red-400">4.</span>
                  {m.solutions_solo_ai_old4({}, { locale })}
                </li>
              </ol>
              <p class="mt-4 font-bold text-red-300">{m.solutions_solo_ai_old_time({}, { locale })}</p>
            </div>

            <div class="rounded-xl border border-green-500/30 bg-gray-900 p-6">
              <h4 class="mb-4 text-lg font-bold text-green-400">{m.solutions_solo_ai_new_way({}, { locale })}</h4>
              <ol class="space-y-3 text-sm text-gray-400">
                <li class="flex items-center gap-2">
                  <span class="text-green-400">1.</span>
                  {m.solutions_solo_ai_new1({}, { locale })}
                </li>
                <li class="flex items-center gap-2">
                  <span class="text-green-400">2.</span>
                  {m.solutions_solo_ai_new2({}, { locale })}
