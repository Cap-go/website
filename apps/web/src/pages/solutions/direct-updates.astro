---
import Layout from '@/layouts/Layout.astro'
import m from '@/copy/messages'
import { getRelativeLocaleUrl } from 'astro:i18n'
import { createServiceLdJson, createLdJsonGraph } from '@/lib/ldJson'

const locale = Astro.locals.locale
const brand = Astro.locals.runtimeConfig.public.brand

const title = `${brand} | ${m.solutions_direct_updates_title({}, { locale })}`
const description = m.solutions_direct_updates_description({}, { locale })

const serviceLdJson = createServiceLdJson(Astro.locals.runtimeConfig.public, {
  name: title,
  description: description,
  url: Astro.url.href,
  serviceType: 'Software Development Service',
  areaServed: ['Worldwide'],
})

const ldJSON = createLdJsonGraph(Astro.locals.runtimeConfig.public, serviceLdJson, {
  includeOrganization: true,
})

const content = { title, description, ldJSON }
---

<Layout content={content}>
  <div>
    <!-- Hero Section with Urgency -->
    <section class="relative overflow-hidden py-20 sm:py-28 lg:py-36">
      <div class="pointer-events-none absolute inset-0 overflow-hidden">
        <div class="absolute top-0 left-1/2 h-full w-full max-w-6xl -translate-x-1/2">
          <div class="absolute top-1/4 left-1/4 h-96 w-96 rounded-full bg-emerald-500/10 blur-3xl"></div>
          <div class="absolute right-1/4 bottom-1/4 h-96 w-96 rounded-full bg-teal-500/10 blur-3xl"></div>
        </div>
      </div>

      <div class="relative mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
        <div class="mx-auto max-w-4xl text-center">
          <div class="mb-8 inline-flex items-center rounded-full border border-emerald-400/40 bg-emerald-500/10 px-4 py-2 text-sm font-medium text-emerald-200">
            <svg class="mr-2 h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z"></path>
            </svg>
            {m.solutions_direct_updates({}, { locale })}
          </div>

          <h1 class="text-4xl leading-tight font-bold text-white sm:text-5xl lg:text-6xl">
            {m.solutions_direct_updates_hero_title({}, { locale })}
          </h1>

          <p class="mx-auto mt-8 max-w-3xl text-xl leading-relaxed text-gray-300">
            {m.solutions_direct_updates_hero_subtitle({}, { locale })}
          </p>

          <div class="mt-10 flex flex-col items-center justify-center gap-4 sm:flex-row">
            <a
              href={getRelativeLocaleUrl(locale, 'register')}
              class="rounded-xl bg-emerald-600 px-8 py-4 text-base font-semibold text-white shadow-lg shadow-emerald-500/25 transition-all duration-200 hover:bg-emerald-700 focus:ring-2 focus:ring-emerald-500 focus:ring-offset-2"
            >
              {m.solutions_start_free_trial({}, { locale })}
            </a>
            <a
              href="https://cal.com/team/capgo/demo"
              class="rounded-xl border border-gray-600 px-8 py-4 text-base font-semibold text-gray-300 transition-all duration-200 hover:bg-gray-800 hover:text-white"
            >
              {m.solutions_talk_to_team({}, { locale })}
            </a>
          </div>

          <!-- Trust Badges -->
          <div class="mt-12 flex flex-wrap items-center justify-center gap-6 text-sm text-gray-400">
            <div class="flex items-center gap-2">
              <svg class="h-5 w-5 text-green-400" fill="currentColor" viewBox="0 0 20 20">
                <path
                  fill-rule="evenodd"
                  d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z"
                  clip-rule="evenodd"></path>
              </svg>
              {m.solutions_direct_instant_apply({}, { locale })}
            </div>
            <div class="flex items-center gap-2">
              <svg class="h-5 w-5 text-green-400" fill="currentColor" viewBox="0 0 20 20">
                <path
                  fill-rule="evenodd"
                  d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z"
                  clip-rule="evenodd"></path>
              </svg>
              {m.solutions_direct_zero_outdated({}, { locale })}
            </div>
            <div class="flex items-center gap-2">
              <svg class="h-5 w-5 text-green-400" fill="currentColor" viewBox="0 0 20 20">
                <path
                  fill-rule="evenodd"
                  d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z"
                  clip-rule="evenodd"></path>
              </svg>
              {m.solutions_direct_sub_second({}, { locale })}
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- The Problem: Why Waiting Isn't an Option -->
    <section class="bg-gray-800 py-20">
      <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
        <div class="mx-auto mb-16 max-w-3xl text-center">
          <h2 class="mb-4 text-sm font-semibold tracking-wide text-red-400 uppercase">{m.solutions_the_problem({}, { locale })}</h2>
          <h3 class="text-3xl font-bold text-white sm:text-4xl">{m.solutions_direct_problem_title({}, { locale })}</h3>
        </div>

        <div class="grid grid-cols-1 items-center gap-12 lg:grid-cols-2">
          <!-- Problem Visualization -->
          <div class="rounded-2xl border border-red-500/30 bg-gray-900 p-8">
            <h4 class="mb-6 text-xl font-bold text-white">{m.solutions_direct_background_problem({}, { locale })}</h4>

            <div class="space-y-6">
              <div class="flex items-start gap-4">
                <div class="flex h-10 w-10 shrink-0 items-center justify-center rounded-full bg-red-500/20">
                  <span class="font-bold text-red-400">1</span>
                </div>
                <div>
                  <p class="font-semibold text-white">{m.solutions_direct_problem_step1_title({}, { locale })}</p>
                  <p class="mt-1 text-sm text-gray-400">{m.solutions_direct_problem_step1_desc({}, { locale })}</p>
                </div>
              </div>

              <div class="flex items-start gap-4">
                <div class="flex h-10 w-10 shrink-0 items-center justify-center rounded-full bg-red-500/20">
                  <span class="font-bold text-red-400">2</span>
                </div>
                <div>
                  <p class="font-semibold text-white">{m.solutions_direct_problem_step2_title({}, { locale })}</p>
                  <p class="mt-1 text-sm text-gray-400">{m.solutions_direct_problem_step2_desc({}, { locale })}</p>
                </div>
              </div>

              <div class="flex items-start gap-4">
                <div class="flex h-10 w-10 shrink-0 items-center justify-center rounded-full bg-red-500/20">
                  <span class="font-bold text-red-400">3</span>
                </div>
                <div>
                  <p class="font-semibold text-white">{m.solutions_direct_problem_step3_title({}, { locale })}</p>
                  <p class="mt-1 text-sm text-gray-400">{m.solutions_direct_problem_step3_desc({}, { locale })}</p>
                </div>
              </div>
            </div>

            <div class="mt-8 rounded-xl border border-red-500/30 bg-red-500/10 p-4">
              <p class="font-medium text-red-300">{m.solutions_direct_problem_result({}, { locale })}</p>
            </div>
          </div>

          <!-- Critical Scenarios -->
          <div>
            <h4 class="mb-6 text-xl font-bold text-white">{m.solutions_direct_when_matters({}, { locale })}</h4>

            <div class="space-y-6">
              <div class="rounded-xl border border-gray-700 bg-gray-900 p-6">
                <div class="mb-3 flex items-center gap-4">
                  <div class="flex h-12 w-12 items-center justify-center rounded-full bg-red-500/20">
                    <svg class="h-6 w-6 text-red-400" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                      <path
                        stroke-linecap="round"
                        stroke-linejoin="round"
                        stroke-width="2"
                        d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-3L13.732 4c-.77-1.333-2.694-1.333-3.464 0L3.34 16c-.77 1.333.192 3 1.732 3z"></path>
                    </svg>
                  </div>
                  <div>
                    <p class="text-lg font-bold text-white">{m.solutions_direct_scenario1_title({}, { locale })}</p>
                    <p class="text-gray-400">{m.solutions_direct_scenario1_desc({}, { locale })}</p>
                  </div>
                </div>
              </div>

              <div class="rounded-xl border border-gray-700 bg-gray-900 p-6">
                <div class="mb-3 flex items-center gap-4">
                  <div class="flex h-12 w-12 items-center justify-center rounded-full bg-amber-500/20">
                    <svg class="h-6 w-6 text-amber-400" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                      <path
                        stroke-linecap="round"
                        stroke-linejoin="round"
                        stroke-width="2"
                        d="M12 8c-1.657 0-3 .895-3 2s1.343 2 3 2 3 .895 3 2-1.343 2-3 2m0-8c1.11 0 2.08.402 2.599 1M12 8V7m0 1v8m0 0v1m0-1c-1.11 0-2.08-.402-2.599-1M21 12a9 9 0 11-18 0 9 9 0 0118 0z"
                      ></path>
                    </svg>
                  </div>
                  <div>
                    <p class="text-lg font-bold text-white">{m.solutions_direct_scenario2_title({}, { locale })}</p>
                    <p class="text-gray-400">{m.solutions_direct_scenario2_desc({}, { locale })}</p>
                  </div>
                </div>
              </div>

              <div class="rounded-xl border border-gray-700 bg-gray-900 p-6">
                <div class="mb-3 flex items-center gap-4">
                  <div class="flex h-12 w-12 items-center justify-center rounded-full bg-purple-500/20">
                    <svg class="h-6 w-6 text-purple-400" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                      <path
                        stroke-linecap="round"
                        stroke-linejoin="round"
                        stroke-width="2"
                        d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z"
                      ></path>
                    </svg>
                  </div>
                  <div>
                    <p class="text-lg font-bold text-white">{m.solutions_direct_scenario3_title({}, { locale })}</p>
                    <p class="text-gray-400">{m.solutions_direct_scenario3_desc({}, { locale })}</p>
                  </div>
                </div>
              </div>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- The Solution: How Direct Updates Work -->
    <section class="bg-gray-900 py-20">
      <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
        <div class="mx-auto mb-16 max-w-3xl text-center">
          <h2 class="mb-4 text-sm font-semibold tracking-wide text-green-400 uppercase">{m.solutions_the_solution({}, { locale })}</h2>
          <h3 class="text-3xl font-bold text-white sm:text-4xl">{m.solutions_direct_solution_title({}, { locale })}</h3>
          <p class="mt-4 text-xl text-gray-400">{m.solutions_direct_solution_subtitle({}, { locale })}</p>
        </div>

        <!-- Comparison -->
        <div class="mb-16 grid grid-cols-1 gap-8 lg:grid-cols-2">
          <!-- Background Updates -->
          <div class="rounded-2xl border border-gray-700 bg-gray-800 p-8">
            <h4 class="mb-6 flex items-center gap-2 text-lg font-bold text-gray-400">
              <svg class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"></path>
              </svg>
              {m.solutions_direct_background_mode({}, { locale })}
            </h4>
            <div class="space-y-4">
              <div class="flex items-center gap-3 text-gray-400">
                <div class="flex h-6 w-6 items-center justify-center rounded-full bg-gray-700 text-xs">1</div>
                <span>{m.solutions_direct_bg_step1({}, { locale })}</span>
              </div>
              <div class="flex items-center gap-3 text-gray-400">
                <div class="flex h-6 w-6 items-center justify-center rounded-full bg-gray-700 text-xs">2</div>
                <span>{m.solutions_direct_bg_step2({}, { locale })}</span>
              </div>
              <div class="flex items-center gap-3 text-gray-400">
                <div class="flex h-6 w-6 items-center justify-center rounded-full bg-gray-700 text-xs">3</div>
                <span>{m.solutions_direct_bg_step3({}, { locale })}</span>
              </div>
              <div class="flex items-center gap-3 text-gray-400">
                <div class="flex h-6 w-6 items-center justify-center rounded-full bg-gray-700 text-xs">4</div>
                <span>{m.solutions_direct_bg_step4({}, { locale })}</span>
              </div>
            </div>
            <div class="mt-6 rounded-xl bg-gray-900 p-4">
              <p class="text-sm text-gray-500">{m.solutions_direct_bg_result({}, { locale })}</p>
            </div>
          </div>

          <!-- Direct Updates -->
          <div class="rounded-2xl border border-emerald-500/30 bg-gray-800 p-8">
            <h4 class="mb-6 flex items-center gap-2 text-lg font-bold text-emerald-400">
              <svg class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z"></path>
              </svg>
              {m.solutions_direct_direct_mode({}, { locale })}
            </h4>
            <div class="space-y-4">
              <div class="flex items-center gap-3 text-white">
                <div class="flex h-6 w-6 items-center justify-center rounded-full bg-emerald-500/30 text-xs text-emerald-400">1</div>
                <span>{m.solutions_direct_d_step1({}, { locale })}</span>
              </div>
              <div class="flex items-center gap-3 text-white">
                <div class="flex h-6 w-6 items-center justify-center rounded-full bg-emerald-500/30 text-xs text-emerald-400">2</div>
                <span>{m.solutions_direct_d_step2({}, { locale })}</span>
              </div>
              <div class="flex items-center gap-3 text-white">
                <div class="flex h-6 w-6 items-center justify-center rounded-full bg-emerald-500/30 text-xs text-emerald-400">3</div>
                <span>{m.solutions_direct_d_step3({}, { locale })}</span>
              </div>
            </div>
            <div class="mt-6 rounded-xl border border-emerald-500/30 bg-emerald-500/10 p-4">
              <p class="text-sm font-medium text-emerald-300">{m.solutions_direct_d_result({}, { locale })}</p>
            </div>
          </div>
        </div>

        <!-- Code Example -->
        <div class="mx-auto max-w-3xl">
          <div class="rounded-2xl border border-gray-700 bg-gray-800 p-6">
            <div class="mb-4 flex items-center gap-2">
              <div class="h-3 w-3 rounded-full bg-red-500"></div>
              <div class="h-3 w-3 rounded-full bg-yellow-500"></div>
              <div class="h-3 w-3 rounded-full bg-green-500"></div>
              <span class="ml-2 text-sm text-gray-500">capacitor.config.ts</span>
            </div>
            <pre
              class="overflow-x-auto text-sm text-gray-300"><code><span class="text-gray-500">// Enable Direct Updates - one config change</span>
CapacitorUpdater: {'{'}
  <span class="text-emerald-400">autoUpdate</span>: true,
  <span class="text-emerald-400">directUpdate</span>: true, <span class="text-gray-500">// Updates apply immediately on app open</span>
{'}'}

<span class="text-gray-500">// That's it. When users open your app:</span>
<span class="text-gray-500">// 1. Capgo checks for updates (~50ms)</span>
<span class="text-gray-500">// 2. If available, downloads immediately (~200-500ms)</span>
<span class="text-gray-500">// 3. Applies before your app renders</span>
<span class="text-gray-500">// Users always see the latest version. Zero exceptions.</span></code></pre>
          </div>
        </div>
      </div>
    </section>

    <!-- Real Business Scenario -->
    <section class="bg-gray-800 py-20">
      <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
        <div class="mx-auto mb-16 max-w-3xl text-center">
          <h2 class="mb-4 text-sm font-semibold tracking-wide text-emerald-400 uppercase">{m.solutions_real_world({}, { locale })}</h2>
          <h3 class="text-3xl font-bold text-white sm:text-4xl">{m.solutions_direct_scenario_title({}, { locale })}</h3>
        </div>

        <div class="mx-auto max-w-5xl rounded-2xl border border-gray-700 bg-gray-900 p-8 lg:p-12">
          <div class="grid grid-cols-1 gap-12 lg:grid-cols-2">
            <!-- The Story -->
            <div>
              <div class="mb-6 flex items-center gap-3">
                <div class="flex h-12 w-12 items-center justify-center rounded-full bg-emerald-500/20">
                  <svg class="h-6 w-6 text-emerald-400" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                    <path
                      stroke-linecap="round"
                      stroke-linejoin="round"
                      stroke-width="2"
                      d="M3 3h2l.4 2M7 13h10l4-8H5.4M7 13L5.4 5M7 13l-2.293 2.293c-.63.63-.184 1.707.707 1.707H17m0 0a2 2 0 100 4 2 2 0 000-4zm-8 2a2 2 0 11-4 0 2 2 0 014 0z"
                    ></path>
                  </svg>
                </div>
                <div>
                  <h4 class="text-xl font-bold text-white">{m.solutions_direct_case_company({}, { locale })}</h4>
                  <p class="text-gray-400">{m.solutions_direct_case_industry({}, { locale })}</p>
                </div>
              </div>

              <div class="space-y-6 text-gray-300">
                <p>{m.solutions_direct_case_para1({}, { locale })}</p>
                <p>{m.solutions_direct_case_para2({}, { locale })}</p>
                <p>{m.solutions_direct_case_para3({}, { locale })}</p>
              </div>
            </div>

            <!-- The Results -->
            <div class="rounded-xl bg-gray-800 p-6">
              <h4 class="mb-6 text-lg font-bold text-white">{m.solutions_direct_case_results({}, { locale })}</h4>

              <div class="space-y-4">
                <div class="flex items-center justify-between rounded-lg bg-gray-900 p-4">
                  <span class="text-gray-400">{m.solutions_direct_case_metric1_label({}, { locale })}</span>
                  <span class="text-2xl font-bold text-emerald-400">{m.solutions_direct_case_metric1_value({}, { locale })}</span>
                </div>
                <div class="flex items-center justify-between rounded-lg bg-gray-900 p-4">
                  <span class="text-gray-400">{m.solutions_direct_case_metric2_label({}, { locale })}</span>
                  <span class="text-2xl font-bold text-emerald-400">{m.solutions_direct_case_metric2_value({}, { locale })}</span>
                </div>
                <div class="flex items-center justify-between rounded-lg bg-gray-900 p-4">
                  <span class="text-gray-400">{m.solutions_direct_case_metric3_label({}, { locale })}</span>
                  <span class="text-2xl font-bold text-emerald-400">{m.solutions_direct_case_metric3_value({}, { locale })}</span>
                </div>
                <div class="flex items-center justify-between rounded-lg bg-gray-900 p-4">
                  <span class="text-gray-400">{m.solutions_direct_case_metric4_label({}, { locale })}</span>
                  <span class="text-2xl font-bold text-emerald-400">{m.solutions_direct_case_metric4_value({}, { locale })}</span>
                </div>
              </div>

              <div class="mt-6 rounded-lg border border-emerald-500/30 bg-emerald-500/10 p-4">
                <p class="text-sm text-emerald-300 italic">"{m.solutions_direct_case_quote({}, { locale })}"</p>
                <p class="mt-2 text-sm text-gray-400">— {m.solutions_direct_case_quote_author({}, { locale })}</p>
              </div>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- Key Benefits -->
    <section class="bg-gray-900 py-20">
      <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
        <div class="mx-auto mb-16 max-w-3xl text-center">
          <h2 class="text-3xl font-bold text-white sm:text-4xl">{m.solutions_direct_benefits_title({}, { locale })}</h2>
          <p class="mt-4 text-xl text-gray-400">{m.solutions_direct_benefits_subtitle({}, { locale })}</p>
        </div>

        <div class="space-y-8">
          <!-- Benefit 1: Zero Outdated Sessions -->
          <div class="rounded-2xl border border-gray-700 bg-gray-800 p-8 lg:p-10">
            <div class="grid grid-cols-1 gap-8 lg:grid-cols-3">
              <div class="lg:col-span-2">
                <div class="mb-4 flex items-center gap-3">
                  <div class="flex h-10 w-10 items-center justify-center rounded-lg bg-emerald-500/20">
                    <svg class="h-5 w-5 text-emerald-400" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"></path>
                    </svg>
                  </div>
                  <h3 class="text-xl font-bold text-white">{m.solutions_direct_benefit1_title({}, { locale })}</h3>
                </div>
                <p class="mb-4 text-gray-300">{m.solutions_direct_benefit1_desc({}, { locale })}</p>
                <ul class="space-y-2">
                  <li class="flex items-start gap-2 text-gray-400">
                    <svg class="mt-0.5 h-5 w-5 shrink-0 text-green-400" fill="currentColor" viewBox="0 0 20 20">
                      <path
                        fill-rule="evenodd"
                        d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z"
                        clip-rule="evenodd"></path>
                    </svg>
                    {m.solutions_direct_benefit1_point1({}, { locale })}
                  </li>
                  <li class="flex items-start gap-2 text-gray-400">
                    <svg class="mt-0.5 h-5 w-5 shrink-0 text-green-400" fill="currentColor" viewBox="0 0 20 20">
                      <path
                        fill-rule="evenodd"
                        d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z"
                        clip-rule="evenodd"></path>
                    </svg>
                    {m.solutions_direct_benefit1_point2({}, { locale })}
                  </li>
                  <li class="flex items-start gap-2 text-gray-400">
                    <svg class="mt-0.5 h-5 w-5 shrink-0 text-green-400" fill="currentColor" viewBox="0 0 20 20">
                      <path
                        fill-rule="evenodd"
