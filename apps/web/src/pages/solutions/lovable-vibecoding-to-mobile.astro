---
import Layout from '@/layouts/Layout.astro'
import m, { type MessageKey, type MessageValues } from '@/copy/messages'
import SolutionAppExample from '@/components/solutions/SolutionAppExample.astro'
import { getRelativeLocaleUrl } from 'astro:i18n'
import { createServiceLdJson, createLdJsonGraph } from '@/lib/ldJson'

const locale = Astro.locals.locale
const brand = Astro.locals.runtimeConfig.public.brand

function copy(key: MessageKey, values: MessageValues = {}) {
  return m[key](values, { locale })
}

const title = brand + ' | ' + copy('solutions_lovable_to_mobile_title')
const description = copy('solutions_lovable_to_mobile_description')

const serviceLdJson = createServiceLdJson(Astro.locals.runtimeConfig.public, {
  name: title,
  description,
  url: Astro.url.href,
  serviceType: 'Lovable to mobile app launch workflow',
  areaServed: ['Worldwide'],
})

const ldJSON = createLdJsonGraph(Astro.locals.runtimeConfig.public, serviceLdJson, {
  includeOrganization: true,
})

const content = { title, description, ldJSON }
const registerUrl = getRelativeLocaleUrl(locale, 'register')
const tutorialUrl = getRelativeLocaleUrl(locale, 'blog/transform-lovable-dev-app-to-mobile-with-capacitor')

const stats: { value: MessageKey; label: MessageKey }[] = [
  { value: 'solutions_lovable_to_mobile_stat1_value', label: 'solutions_lovable_to_mobile_stat1_label' },
  { value: 'solutions_lovable_to_mobile_stat2_value', label: 'solutions_lovable_to_mobile_stat2_label' },
  { value: 'solutions_lovable_to_mobile_stat3_value', label: 'solutions_lovable_to_mobile_stat3_label' },
]

const pains: { title: MessageKey; desc: MessageKey }[] = [
  { title: 'solutions_lovable_to_mobile_pain1_title', desc: 'solutions_lovable_to_mobile_pain1_desc' },
  { title: 'solutions_lovable_to_mobile_pain2_title', desc: 'solutions_lovable_to_mobile_pain2_desc' },
  { title: 'solutions_lovable_to_mobile_pain3_title', desc: 'solutions_lovable_to_mobile_pain3_desc' },
]

const examples: { title: MessageKey; desc: MessageKey; accent: string }[] = [
  { title: 'solutions_lovable_to_mobile_example1_title', desc: 'solutions_lovable_to_mobile_example1_desc', accent: 'border-pink-400/25 bg-pink-500/10 text-pink-100' },
  { title: 'solutions_lovable_to_mobile_example2_title', desc: 'solutions_lovable_to_mobile_example2_desc', accent: 'border-cyan-400/25 bg-cyan-500/10 text-cyan-100' },
  { title: 'solutions_lovable_to_mobile_example3_title', desc: 'solutions_lovable_to_mobile_example3_desc', accent: 'border-emerald-400/25 bg-emerald-500/10 text-emerald-100' },
]

const playbook: { title: MessageKey; desc: MessageKey }[] = [
  { title: 'solutions_lovable_to_mobile_playbook1_title', desc: 'solutions_lovable_to_mobile_playbook1_desc' },
  { title: 'solutions_lovable_to_mobile_playbook2_title', desc: 'solutions_lovable_to_mobile_playbook2_desc' },
  { title: 'solutions_lovable_to_mobile_playbook3_title', desc: 'solutions_lovable_to_mobile_playbook3_desc' },
  { title: 'solutions_lovable_to_mobile_playbook4_title', desc: 'solutions_lovable_to_mobile_playbook4_desc' },
]

const workflow: { title: MessageKey; desc: MessageKey }[] = [
  { title: 'solutions_lovable_to_mobile_workflow1_title', desc: 'solutions_lovable_to_mobile_workflow1_desc' },
  { title: 'solutions_lovable_to_mobile_workflow2_title', desc: 'solutions_lovable_to_mobile_workflow2_desc' },
  { title: 'solutions_lovable_to_mobile_workflow3_title', desc: 'solutions_lovable_to_mobile_workflow3_desc' },
  { title: 'solutions_lovable_to_mobile_workflow4_title', desc: 'solutions_lovable_to_mobile_workflow4_desc' },
]

const lovableAiPrompt = `I want this Lovable project to become a Capacitor mobile app using Capgo from the start.

Set up the project so an AI agent can use Capgo's MCP release tools through install-mcp:

1. Install the Capgo CLI MCP server for the active AI client. For Codex, run:
   - npx @capgo/cli@latest login
   - npx install-mcp 'npx @capgo/cli@latest mcp' --client codex
   Replace codex with cursor, claude-code, gemini-cli, or windsurf if that is the client this project uses.
2. Read Capgo's public MCP metadata when tool details are needed:
   - https://capgo.app/.well-known/mcp/server-card.json
   - https://capgo.app/.well-known/agent-skills/capgo-cli-mcp/SKILL.md
3. Add a short docs/agent-mobile-release.md file that tells the agent to use the Capgo CLI MCP server as a local stdio server, not a remote HTTP endpoint.
4. Add Capacitor for iOS and Android using the package manager already used by this project.
5. Configure capacitor.config.ts with:
   - appName: the current Lovable app name
   - appId: a production-style bundle ID I can edit later, such as com.company.app
   - webDir: the production build output folder
   - plugins.CapacitorUpdater.defaultChannel: production
6. Install and configure @capgo/capacitor-updater.
7. Add package scripts for:
   - building the web app
   - syncing Capacitor
   - uploading a production Capgo bundle
   - starting Capgo Builder setup for iOS
   - requesting an iOS cloud build
8. Create a first production channel plan:
   - production for users
   - preview for stakeholder review
   - staging for internal testing
9. Keep normal docs and README commands copy-pasteable with npm/npx unless this project already uses another package manager. Keep the Capgo MCP install command exactly as shown above.
10. Do not fake native signing credentials. Leave clear TODOs for the Capgo API key, Apple team details, and bundle ID.
11. After making changes, summarize exactly what changed and what command I should run next.`

const mobileCommands = `# From the GitHub repo exported by Lovable
npm install @capacitor/core @capacitor/cli @capacitor/ios @capacitor/android
npx cap init "Your Lovable App" "com.company.app"
npx cap add ios
npx cap add android

# Build web output, sync native projects, and ship updates
npm run build
npx cap sync
npx @capgo/cli@latest init
npx @capgo/cli@latest bundle upload --channel production

# When you need a signed binary
npx @capgo/cli@latest build init --platform ios
npx @capgo/cli@latest build request --platform ios`
---

<Layout content={content}>
  <div class="bg-gray-950">
    <section class="border-b border-white/10 bg-gray-900 py-16 sm:py-20 lg:py-28">
      <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
        <div class="grid gap-12 lg:grid-cols-[1fr_0.95fr] lg:items-center">
          <div>
            <p class="inline-flex min-h-11 items-center rounded-lg border border-pink-400/30 bg-pink-500/10 px-4 text-sm font-semibold text-pink-100">
              {copy('solutions_lovable_to_mobile_badge')}
            </p>
            <h1 class="mt-6 max-w-4xl text-4xl leading-tight font-bold text-white sm:text-5xl lg:text-6xl">
              {copy('solutions_lovable_to_mobile_h1')}
            </h1>
            <p class="mt-6 max-w-3xl text-lg leading-8 text-slate-300 sm:text-xl">
              {copy('solutions_lovable_to_mobile_lead')}
            </p>
            <div class="mt-8 flex flex-col gap-3 sm:flex-row">
              <a
                class="inline-flex min-h-12 items-center justify-center rounded-lg bg-pink-500 px-6 font-semibold text-white transition-colors hover:bg-pink-400 focus:ring-2 focus:ring-pink-300 focus:ring-offset-2 focus:ring-offset-gray-950 focus:outline-none"
                href={registerUrl}
              >
                {copy('solutions_start_free_trial')}
              </a>
              <a
                class="inline-flex min-h-12 items-center justify-center rounded-lg border border-white/15 px-6 font-semibold text-slate-200 transition-colors hover:bg-white/10 focus:ring-2 focus:ring-slate-300 focus:ring-offset-2 focus:ring-offset-gray-950 focus:outline-none"
                href={tutorialUrl}
              >
                {copy('solutions_lovable_to_mobile_tutorial_cta')}
              </a>
            </div>
            <div class="mt-10 grid gap-3 sm:grid-cols-3">
              {
                stats.map((stat) => (
                  <div class="rounded-lg border border-white/10 bg-white/[0.04] p-4">
                    <div class="text-2xl font-bold text-white">{copy(stat.value)}</div>
                    <div class="mt-1 text-sm leading-6 text-slate-400">{copy(stat.label)}</div>
                  </div>
                ))
              }
            </div>
          </div>

          <div class="rounded-lg border border-white/10 bg-slate-950 p-5 shadow-2xl shadow-pink-950/25">
            <div class="grid gap-3">
              <div class="rounded-lg border border-pink-400/20 bg-pink-500/10 p-4">
                <p class="text-sm font-semibold text-pink-100">{copy('solutions_lovable_to_mobile_flow1_title')}</p>
                <p class="mt-1 text-sm leading-6 text-slate-300">{copy('solutions_lovable_to_mobile_flow1_desc')}</p>
              </div>
              <div class="grid grid-cols-[auto_1fr] items-center gap-3">
                <div class="h-px bg-white/20"></div>
                <p class="text-xs font-semibold text-slate-500 uppercase">{copy('solutions_lovable_to_mobile_flow_bridge')}</p>
              </div>
              <div class="rounded-lg border border-cyan-400/20 bg-cyan-500/10 p-4">
                <p class="text-sm font-semibold text-cyan-100">{copy('solutions_lovable_to_mobile_flow2_title')}</p>
                <p class="mt-1 text-sm leading-6 text-slate-300">{copy('solutions_lovable_to_mobile_flow2_desc')}</p>
              </div>
              <div class="grid grid-cols-[auto_1fr] items-center gap-3">
                <div class="h-px bg-white/20"></div>
                <p class="text-xs font-semibold text-slate-500 uppercase">{copy('solutions_lovable_to_mobile_flow_build')}</p>
              </div>
              <div class="rounded-lg border border-emerald-400/20 bg-emerald-500/10 p-4">
                <p class="text-sm font-semibold text-emerald-100">{copy('solutions_lovable_to_mobile_flow3_title')}</p>
                <p class="mt-1 text-sm leading-6 text-slate-300">{copy('solutions_lovable_to_mobile_flow3_desc')}</p>
              </div>
            </div>
          </div>
        </div>
      </div>
    </section>

    <section class="bg-gray-950 py-16 sm:py-20">
      <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
        <div class="max-w-3xl">
          <p class="text-sm font-semibold text-red-300 uppercase">{copy('solutions_the_problem')}</p>
          <h2 class="mt-3 text-3xl font-bold text-white sm:text-4xl">{copy('solutions_lovable_to_mobile_problem_title')}</h2>
        </div>
        <div class="mt-10 grid gap-5 lg:grid-cols-3">
          {
            pains.map((pain) => (
              <article class="rounded-lg border border-red-400/20 bg-red-950/20 p-6">
                <h3 class="text-xl font-bold text-white">{copy(pain.title)}</h3>
                <p class="mt-3 leading-7 text-slate-300">{copy(pain.desc)}</p>
              </article>
            ))
          }
        </div>
      </div>
    </section>

    <section class="border-y border-white/10 bg-slate-900 py-16 sm:py-20">
      <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
        <div class="max-w-3xl">
          <p class="text-sm font-semibold text-pink-200 uppercase">{copy('solutions_lovable_to_mobile_example_label')}</p>
          <h2 class="mt-3 text-3xl font-bold text-white sm:text-4xl">{copy('solutions_lovable_to_mobile_example_title')}</h2>
        </div>
        <div class="mt-10 grid gap-5 lg:grid-cols-3">
          {
            examples.map((example) => (
              <article class={`rounded-lg border p-6 ${example.accent}`}>
                <h3 class="text-xl font-bold text-white">{copy(example.title)}</h3>
                <p class="mt-3 leading-7 text-slate-300">{copy(example.desc)}</p>
              </article>
            ))
          }
        </div>
      </div>
    </section>

    <section class="bg-gray-950 py-16 sm:py-20">
      <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
        <div class="grid gap-8 lg:grid-cols-[0.9fr_1.1fr] lg:items-start">
          <div>
            <p class="text-sm font-semibold text-cyan-200 uppercase">{copy('solutions_lovable_to_mobile_code_label')}</p>
            <h2 class="mt-3 text-3xl font-bold text-white sm:text-4xl">{copy('solutions_lovable_to_mobile_code_title')}</h2>
            <p class="mt-4 text-lg leading-8 text-slate-300">{copy('solutions_lovable_to_mobile_code_lead')}</p>
          </div>
          <pre class="overflow-x-auto rounded-lg border border-white/10 bg-black/50 p-5 text-sm leading-7 text-slate-200"><code>{mobileCommands}</code></pre>
        </div>
      </div>
    </section>

    <section class="border-y border-pink-400/20 bg-slate-900 py-16 sm:py-20">
      <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
        <div class="grid gap-8 lg:grid-cols-[0.85fr_1.15fr] lg:items-start">
          <div>
            <p class="text-sm font-semibold text-pink-200 uppercase">{copy('solutions_lovable_to_mobile_prompt_label')}</p>
            <h2 class="mt-3 text-3xl font-bold text-white sm:text-4xl">{copy('solutions_lovable_to_mobile_prompt_title')}</h2>
            <p class="mt-4 text-lg leading-8 text-slate-300">{copy('solutions_lovable_to_mobile_prompt_lead')}</p>
          </div>
          <div class="rounded-lg border border-white/10 bg-black/50">
            <div class="flex items-center justify-between gap-4 border-b border-white/10 px-4 py-3">
              <p class="text-sm font-semibold text-slate-300">{copy('solutions_lovable_to_mobile_prompt_card_title')}</p>
              <button
                type="button"
                class="inline-flex min-h-10 items-center rounded-lg border border-pink-400/30 px-3 text-sm font-semibold text-pink-100 transition-colors hover:bg-pink-500/10 focus:ring-2 focus:ring-pink-300 focus:ring-offset-2 focus:ring-offset-slate-950 focus:outline-none"
                data-copy-prompt={lovableAiPrompt}
              >
                {copy('solutions_lovable_to_mobile_prompt_copy')}
              </button>
            </div>
            <pre class="max-h-[32rem] overflow-auto p-5 text-sm leading-7 whitespace-pre-wrap text-slate-200"><code>{lovableAiPrompt}</code></pre>
          </div>
        </div>
      </div>
    </section>

    <section class="border-y border-white/10 bg-slate-900 py-16 sm:py-20">
      <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
        <div class="max-w-3xl">
          <p class="text-sm font-semibold text-pink-200 uppercase">{copy('solutions_the_solution')}</p>
          <h2 class="mt-3 text-3xl font-bold text-white sm:text-4xl">{copy('solutions_lovable_to_mobile_playbook_title')}</h2>
          <p class="mt-4 text-lg leading-8 text-slate-300">{copy('solutions_lovable_to_mobile_playbook_lead')}</p>
        </div>
        <div class="mt-10 grid gap-5 md:grid-cols-2">
          {
            playbook.map((item) => (
              <article class="rounded-lg border border-white/10 bg-gray-950 p-6">
                <h3 class="text-xl font-bold text-white">{copy(item.title)}</h3>
                <p class="mt-3 leading-7 text-slate-300">{copy(item.desc)}</p>
              </article>
            ))
          }
        </div>
      </div>
    </section>

    <section class="bg-gray-950 py-16 sm:py-20">
      <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
        <div class="grid gap-10 lg:grid-cols-[0.8fr_1.2fr] lg:items-start">
          <div>
            <p class="text-sm font-semibold text-amber-200 uppercase">{copy('solutions_lovable_to_mobile_workflow_label')}</p>
            <h2 class="mt-3 text-3xl font-bold text-white sm:text-4xl">{copy('solutions_lovable_to_mobile_workflow_title')}</h2>
            <p class="mt-4 text-lg leading-8 text-slate-300">{copy('solutions_lovable_to_mobile_workflow_lead')}</p>
          </div>
          <div class="grid gap-4">
            {
              workflow.map((step, index) => (
                <article class="grid gap-4 rounded-lg border border-white/10 bg-white/[0.04] p-5 sm:grid-cols-[auto_1fr]">
                  <div class="flex h-11 w-11 items-center justify-center rounded-lg bg-amber-500/15 font-bold text-amber-200 ring-1 ring-amber-400/20">{index + 1}</div>
                  <div>
                    <h3 class="text-lg font-bold text-white">{copy(step.title)}</h3>
                    <p class="mt-2 leading-7 text-slate-300">{copy(step.desc)}</p>
                  </div>
                </article>
              ))
            }
          </div>
        </div>
      </div>
    </section>

    <section class="border-y border-pink-400/20 bg-pink-950/10 py-14">
      <div class="mx-auto max-w-5xl px-4 sm:px-6 lg:px-8">
        <p class="text-sm font-semibold text-pink-200 uppercase">{copy('solutions_lovable_to_mobile_quote_label')}</p>
        <blockquote class="mt-4 text-2xl leading-10 font-semibold text-white">{copy('solutions_lovable_to_mobile_quote_text')}</blockquote>
        <p class="mt-4 text-sm font-semibold text-slate-400">{copy('solutions_lovable_to_mobile_quote_author')}</p>
      </div>
    </section>

    <SolutionAppExample solution="lovable-vibecoding-to-mobile" />
    <section class="bg-slate-900 py-16 sm:py-20">
      <div class="mx-auto max-w-5xl px-4 text-center sm:px-6 lg:px-8">
        <h2 class="text-3xl font-bold text-white sm:text-4xl">{copy('solutions_lovable_to_mobile_cta_title')}</h2>
        <p class="mx-auto mt-4 max-w-3xl text-lg leading-8 text-slate-300">{copy('solutions_lovable_to_mobile_cta_subtitle')}</p>
        <div class="mt-8 flex flex-col justify-center gap-3 sm:flex-row">
          <a
            class="inline-flex min-h-12 items-center justify-center rounded-lg bg-pink-500 px-6 font-semibold text-white transition-colors hover:bg-pink-400 focus:ring-2 focus:ring-pink-300 focus:ring-offset-2 focus:ring-offset-slate-900 focus:outline-none"
            href={registerUrl}
          >
            {copy('solutions_start_free_trial')}
          </a>
          <a
            class="inline-flex min-h-12 items-center justify-center rounded-lg border border-white/15 px-6 font-semibold text-slate-200 transition-colors hover:bg-white/10 focus:ring-2 focus:ring-slate-300 focus:ring-offset-2 focus:ring-offset-slate-900 focus:outline-none"
            href={tutorialUrl}
          >
            {copy('solutions_lovable_to_mobile_tutorial_cta')}
          </a>
        </div>
      </div>
    </section>
  </div>
</Layout>

<script>
  async function copyPrompt(button: HTMLButtonElement): Promise<void> {
    const value = button.dataset.copyPrompt
    if (!value || !navigator.clipboard?.writeText) return

    const original = button.textContent || 'Copy prompt'

    try {
      await navigator.clipboard.writeText(value)
      button.textContent = 'Copied'
      window.setTimeout(() => {
        button.textContent = original
      }, 1800)
    } catch {
      button.textContent = original
    }
  }

  document.querySelectorAll<HTMLButtonElement>('[data-copy-prompt]').forEach((button) => {
    button.addEventListener('click', () => copyPrompt(button))
  })
</script>
