---
import Layout from '@/layouts/Layout.astro'
import m, { type MessageKey, type MessageValues } from '@/copy/messages'
import { getRelativeLocaleUrl } from 'astro:i18n'
import WhiteLabelIllustration from '@/components/solutions/WhiteLabelIllustration.astro'
import { createServiceLdJson, createLdJsonGraph } from '@/lib/ldJson'

const locale = Astro.locals.locale
const brand = Astro.locals.runtimeConfig.public.brand

function copy(key: MessageKey, values: MessageValues = {}) {
  return m[key](values, { locale })
}

const title = brand + ' | ' + copy('solutions_white_label_page_title')
const description = copy('solutions_white_label_page_description')

const serviceLdJson = createServiceLdJson(Astro.locals.runtimeConfig.public, {
  name: title,
  description,
  url: Astro.url.href,
  serviceType: 'White-label mobile app release platform',
  areaServed: ['Worldwide'],
})

const ldJSON = createLdJsonGraph(Astro.locals.runtimeConfig.public, serviceLdJson, {
  includeOrganization: true,
})

const content = { title, description, ldJSON }
const registerUrl = getRelativeLocaleUrl(locale, 'register')
const docsUrl = getRelativeLocaleUrl(locale, 'docs/plugins/updater/api') + '#setchannel'

const stats: { value: MessageKey; label: MessageKey }[] = [
  { value: 'solutions_white_label_stat1_value', label: 'solutions_white_label_stat1_label' },
  { value: 'solutions_white_label_stat2_value', label: 'solutions_white_label_stat2_label' },
  { value: 'solutions_white_label_stat3_value', label: 'solutions_white_label_stat3_label' },
]

const pains: { title: MessageKey; desc: MessageKey }[] = [
  { title: 'solutions_white_label_pain1_title', desc: 'solutions_white_label_pain1_desc' },
  { title: 'solutions_white_label_pain2_title', desc: 'solutions_white_label_pain2_desc' },
  { title: 'solutions_white_label_pain3_title', desc: 'solutions_white_label_pain3_desc' },
]

const examples: { title: MessageKey; desc: MessageKey; accent: string }[] = [
  { title: 'solutions_white_label_example1_title', desc: 'solutions_white_label_example1_desc', accent: 'border-cyan-400/25 bg-cyan-500/10 text-cyan-100' },
  { title: 'solutions_white_label_example2_title', desc: 'solutions_white_label_example2_desc', accent: 'border-amber-400/25 bg-amber-500/10 text-amber-100' },
  { title: 'solutions_white_label_example3_title', desc: 'solutions_white_label_example3_desc', accent: 'border-emerald-400/25 bg-emerald-500/10 text-emerald-100' },
]

const systemCards: { title: MessageKey; desc: MessageKey }[] = [
  { title: 'solutions_white_label_system1_title', desc: 'solutions_white_label_system1_desc' },
  { title: 'solutions_white_label_system2_title', desc: 'solutions_white_label_system2_desc' },
  { title: 'solutions_white_label_system3_title', desc: 'solutions_white_label_system3_desc' },
  { title: 'solutions_white_label_system4_title', desc: 'solutions_white_label_system4_desc' },
]

const workflow: { title: MessageKey; desc: MessageKey }[] = [
  { title: 'solutions_white_label_workflow1_title', desc: 'solutions_white_label_workflow1_desc' },
  { title: 'solutions_white_label_workflow2_title', desc: 'solutions_white_label_workflow2_desc' },
  { title: 'solutions_white_label_workflow3_title', desc: 'solutions_white_label_workflow3_desc' },
  { title: 'solutions_white_label_workflow4_title', desc: 'solutions_white_label_workflow4_desc' },
]

const tenantCli = `# Publish tenant-specific web bundles from the same app
npx @capgo/cli@latest bundle upload --channel acme
npx @capgo/cli@latest bundle upload --channel globex
npx @capgo/cli@latest bundle upload --channel north-branch`

const tenantSwitcher = `import { CapacitorUpdater } from '@capgo/capacitor-updater'

export async function switchTenant(channel: string) {
  await CapacitorUpdater.setChannel({ channel })

  const latest = await CapacitorUpdater.getLatest()
  const bundle = await CapacitorUpdater.download({
    url: latest.url,
    version: latest.version,
  })

  await CapacitorUpdater.set({ id: bundle.id })
}`
---

<Layout content={content}>
  <div class="bg-gray-950">
    <section class="border-b border-white/10 bg-gray-900 py-16 sm:py-20 lg:py-28">
      <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
        <div class="grid gap-12 lg:grid-cols-[1.05fr_0.95fr] lg:items-center">
          <div>
            <p class="inline-flex min-h-11 items-center rounded-lg border border-cyan-400/30 bg-cyan-500/10 px-4 text-sm font-semibold text-cyan-100">
              {copy('solutions_white_label_badge')}
            </p>
            <h1 class="mt-6 max-w-4xl text-4xl leading-tight font-bold text-white sm:text-5xl lg:text-6xl">
              {copy('solutions_white_label_page_h1')}
            </h1>
            <p class="mt-6 max-w-3xl text-lg leading-8 text-slate-300 sm:text-xl">
              {copy('solutions_white_label_page_lead')}
            </p>
            <div class="mt-8 flex flex-col gap-3 sm:flex-row">
              <a
                class="inline-flex min-h-12 items-center justify-center rounded-lg bg-cyan-500 px-6 font-semibold text-white transition-colors hover:bg-cyan-400 focus:ring-2 focus:ring-cyan-300 focus:ring-offset-2 focus:ring-offset-gray-950 focus:outline-none"
                href={registerUrl}
              >
                {copy('solutions_start_free_trial')}
              </a>
              <a
                class="inline-flex min-h-12 items-center justify-center rounded-lg border border-white/15 px-6 font-semibold text-slate-200 transition-colors hover:bg-white/10 focus:ring-2 focus:ring-slate-300 focus:ring-offset-2 focus:ring-offset-gray-950 focus:outline-none"
                href={docsUrl}
              >
                {copy('solutions_view_docs')}
              </a>
            </div>
            <div class="mt-10 grid gap-3 sm:grid-cols-3">
              {
                stats.map((stat) => (
                  <div class="rounded-lg border border-white/10 bg-white/[0.04] p-4">
                    <div class="text-2xl font-bold text-white">{copy(stat.value)}</div>
                    <div class="mt-1 text-sm leading-6 text-slate-400">{copy(stat.label)}</div>
                  </div>
                ))
              }
            </div>
          </div>

          <div class="rounded-lg border border-white/10 bg-slate-900 p-4 shadow-2xl shadow-cyan-950/30">
            <WhiteLabelIllustration class="text-cyan-400" aria-hidden="true" />
            <div class="grid gap-3 border-t border-white/10 pt-4 sm:grid-cols-3">
              <div class="rounded-lg bg-slate-800/80 p-3">
                <p class="text-xs font-semibold text-slate-400 uppercase">{copy('solutions_white_label_visual_cell1_label')}</p>
                <p class="mt-1 text-sm font-semibold text-white">{copy('solutions_white_label_visual_cell1_value')}</p>
              </div>
              <div class="rounded-lg bg-slate-800/80 p-3">
                <p class="text-xs font-semibold text-slate-400 uppercase">{copy('solutions_white_label_visual_cell2_label')}</p>
                <p class="mt-1 text-sm font-semibold text-white">{copy('solutions_white_label_visual_cell2_value')}</p>
              </div>
              <div class="rounded-lg bg-slate-800/80 p-3">
                <p class="text-xs font-semibold text-slate-400 uppercase">{copy('solutions_white_label_visual_cell3_label')}</p>
                <p class="mt-1 text-sm font-semibold text-white">{copy('solutions_white_label_visual_cell3_value')}</p>
              </div>
            </div>
          </div>
        </div>
      </div>
    </section>

    <section class="bg-gray-950 py-16 sm:py-20">
      <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
        <div class="max-w-3xl">
          <p class="text-sm font-semibold text-red-300 uppercase">{copy('solutions_the_problem')}</p>
          <h2 class="mt-3 text-3xl font-bold text-white sm:text-4xl">{copy('solutions_white_label_problem_title')}</h2>
        </div>
        <div class="mt-10 grid gap-5 lg:grid-cols-3">
          {
            pains.map((pain) => (
              <article class="rounded-lg border border-red-400/20 bg-red-950/20 p-6">
                <h3 class="text-xl font-bold text-white">{copy(pain.title)}</h3>
                <p class="mt-3 leading-7 text-slate-300">{copy(pain.desc)}</p>
              </article>
            ))
          }
        </div>
      </div>
    </section>

    <section class="border-y border-white/10 bg-slate-900 py-16 sm:py-20">
      <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
        <div class="max-w-3xl">
          <p class="text-sm font-semibold text-cyan-200 uppercase">{copy('solutions_white_label_example_label')}</p>
          <h2 class="mt-3 text-3xl font-bold text-white sm:text-4xl">{copy('solutions_white_label_example_title')}</h2>
        </div>
        <div class="mt-10 grid gap-5 lg:grid-cols-3">
          {
            examples.map((example) => (
              <article class={`rounded-lg border p-6 ${example.accent}`}>
                <h3 class="text-xl font-bold text-white">{copy(example.title)}</h3>
                <p class="mt-3 leading-7 text-slate-300">{copy(example.desc)}</p>
              </article>
            ))
          }
        </div>
      </div>
    </section>

    <section class="bg-gray-950 py-16 sm:py-20">
      <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
        <div class="grid gap-8 lg:grid-cols-[0.9fr_1.1fr] lg:items-start">
          <div>
            <p class="text-sm font-semibold text-emerald-200 uppercase">{copy('solutions_white_label_code_label')}</p>
            <h2 class="mt-3 text-3xl font-bold text-white sm:text-4xl">{copy('solutions_white_label_code_title')}</h2>
            <p class="mt-4 text-lg leading-8 text-slate-300">{copy('solutions_white_label_code_lead')}</p>
          </div>
          <div class="grid gap-4">
            <pre class="overflow-x-auto rounded-lg border border-white/10 bg-black/50 p-4 text-sm leading-7 text-slate-200"><code>{tenantCli}</code></pre>
            <pre class="overflow-x-auto rounded-lg border border-white/10 bg-black/50 p-4 text-sm leading-7 text-slate-200"><code>{tenantSwitcher}</code></pre>
          </div>
        </div>
      </div>
    </section>

    <section class="border-y border-white/10 bg-slate-900 py-16 sm:py-20">
      <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
        <div class="max-w-3xl">
          <p class="text-sm font-semibold text-cyan-200 uppercase">{copy('solutions_the_solution')}</p>
          <h2 class="mt-3 text-3xl font-bold text-white sm:text-4xl">{copy('solutions_white_label_system_title')}</h2>
          <p class="mt-4 text-lg leading-8 text-slate-300">{copy('solutions_white_label_system_lead')}</p>
        </div>
        <div class="mt-10 grid gap-5 md:grid-cols-2">
          {
            systemCards.map((card) => (
              <article class="rounded-lg border border-white/10 bg-gray-950 p-6">
                <h3 class="text-xl font-bold text-white">{copy(card.title)}</h3>
                <p class="mt-3 leading-7 text-slate-300">{copy(card.desc)}</p>
              </article>
            ))
          }
        </div>
      </div>
    </section>

    <section class="bg-gray-950 py-16 sm:py-20">
      <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
        <div class="grid gap-10 lg:grid-cols-[0.8fr_1.2fr] lg:items-start">
          <div>
            <p class="text-sm font-semibold text-amber-200 uppercase">{copy('solutions_white_label_workflow_label')}</p>
            <h2 class="mt-3 text-3xl font-bold text-white sm:text-4xl">{copy('solutions_white_label_workflow_title')}</h2>
            <p class="mt-4 text-lg leading-8 text-slate-300">{copy('solutions_white_label_workflow_lead')}</p>
          </div>
          <div class="grid gap-4">
            {
              workflow.map((step, index) => (
                <article class="grid gap-4 rounded-lg border border-white/10 bg-white/[0.04] p-5 sm:grid-cols-[auto_1fr]">
                  <div class="flex h-11 w-11 items-center justify-center rounded-lg bg-amber-500/15 font-bold text-amber-200 ring-1 ring-amber-400/20">{index + 1}</div>
                  <div>
                    <h3 class="text-lg font-bold text-white">{copy(step.title)}</h3>
                    <p class="mt-2 leading-7 text-slate-300">{copy(step.desc)}</p>
                  </div>
                </article>
              ))
            }
          </div>
        </div>
      </div>
    </section>

    <section class="border-y border-cyan-400/20 bg-cyan-950/10 py-14">
      <div class="mx-auto max-w-5xl px-4 sm:px-6 lg:px-8">
        <p class="text-sm font-semibold text-cyan-200 uppercase">{copy('solutions_white_label_quote_label')}</p>
        <blockquote class="mt-4 text-2xl leading-10 font-semibold text-white">{copy('solutions_white_label_quote_text')}</blockquote>
        <p class="mt-4 text-sm font-semibold text-slate-400">{copy('solutions_white_label_quote_author')}</p>
      </div>
    </section>

    <section class="bg-slate-900 py-16 sm:py-20">
      <div class="mx-auto max-w-5xl px-4 text-center sm:px-6 lg:px-8">
        <h2 class="text-3xl font-bold text-white sm:text-4xl">{copy('solutions_white_label_page_cta_title')}</h2>
        <p class="mx-auto mt-4 max-w-3xl text-lg leading-8 text-slate-300">{copy('solutions_white_label_page_cta_subtitle')}</p>
        <div class="mt-8 flex flex-col justify-center gap-3 sm:flex-row">
          <a
            class="inline-flex min-h-12 items-center justify-center rounded-lg bg-cyan-500 px-6 font-semibold text-white transition-colors hover:bg-cyan-400 focus:ring-2 focus:ring-cyan-300 focus:ring-offset-2 focus:ring-offset-slate-900 focus:outline-none"
            href={registerUrl}
          >
            {copy('solutions_start_free_trial')}
          </a>
          <a
            class="inline-flex min-h-12 items-center justify-center rounded-lg border border-white/15 px-6 font-semibold text-slate-200 transition-colors hover:bg-white/10 focus:ring-2 focus:ring-slate-300 focus:ring-offset-2 focus:ring-offset-slate-900 focus:outline-none"
            href="https://book.capgo.app/demo/"
            target="_blank"
            rel="noopener noreferrer"
          >
            {copy('solutions_talk_to_team')}
          </a>
        </div>
      </div>
    </section>
  </div>
</Layout>
