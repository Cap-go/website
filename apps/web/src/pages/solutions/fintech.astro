---
import Layout from '@/layouts/Layout.astro'
import m from '@/copy/messages'
import { getRelativeLocaleUrl } from 'astro:i18n'
import RolloutIllustration from '@/components/solutions/RolloutIllustration.astro'
import BugFixIllustration from '@/components/solutions/BugFixIllustration.astro'
import SecurityIllustration from '@/components/solutions/SecurityIllustration.astro'
import { createServiceLdJson, createLdJsonGraph } from '@/lib/ldJson'

const locale = Astro.locals.locale
const brand = Astro.locals.runtimeConfig.public.brand

const title = `${brand} | ${m.solutions_fintech_title({}, { locale })}`
const description = m.solutions_fintech_description({}, { locale })

const serviceLdJson = createServiceLdJson(Astro.locals.runtimeConfig.public, {
  name: title,
  description: description,
  url: Astro.url.href,
  serviceType: 'Software Development Service',
  areaServed: ['Worldwide'],
})

const ldJSON = createLdJsonGraph(Astro.locals.runtimeConfig.public, serviceLdJson, {
  includeOrganization: true,
})

const content = { title, description, ldJSON }
---

<Layout content={content}>
  <div>
    <!-- Hero Section -->
    <section class="relative overflow-hidden py-20 sm:py-28 lg:py-36">
      <div class="pointer-events-none absolute inset-0 overflow-hidden">
        <div class="absolute top-0 left-1/2 h-full w-full max-w-6xl -translate-x-1/2">
          <div class="absolute top-1/4 left-1/4 h-96 w-96 rounded-full bg-green-500/10 blur-3xl"></div>
          <div class="absolute right-1/4 bottom-1/4 h-96 w-96 rounded-full bg-emerald-500/10 blur-3xl"></div>
        </div>
      </div>

      <div class="relative mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
        <div class="mx-auto max-w-4xl text-center">
          <div class="mb-8 inline-flex items-center rounded-full border border-green-400/40 bg-green-500/10 px-4 py-2 text-sm font-medium text-green-200">
            <svg class="mr-2 h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path
                stroke-linecap="round"
                stroke-linejoin="round"
                stroke-width="2"
                d="M12 8c-1.657 0-3 .895-3 2s1.343 2 3 2 3 .895 3 2-1.343 2-3 2m0-8c1.11 0 2.08.402 2.599 1M12 8V7m0 1v8m0 0v1m0-1c-1.11 0-2.08-.402-2.599-1M21 12a9 9 0 11-18 0 9 9 0 0118 0z"
              ></path>
            </svg>
            {m.solutions_fintech_badge({}, { locale })}
          </div>

          <h1 class="text-4xl leading-tight font-bold text-white sm:text-5xl lg:text-6xl">
            {m.solutions_fintech_hero_title({}, { locale })}
          </h1>

          <p class="mx-auto mt-8 max-w-3xl text-xl leading-relaxed text-gray-300">
            {m.solutions_fintech_hero_subtitle({}, { locale })}
          </p>

          <div class="mt-10 flex flex-col items-center justify-center gap-4 sm:flex-row">
            <a
              href={getRelativeLocaleUrl(locale, 'register')}
              class="rounded-xl bg-green-600 px-8 py-4 text-base font-semibold text-white shadow-lg shadow-green-500/25 transition-all duration-200 hover:bg-green-700 focus:ring-2 focus:ring-green-500 focus:ring-offset-2"
            >
              {m.solutions_start_free_trial({}, { locale })}
            </a>
            <a
              href="https://book.capgo.app/demo/"
              target="_blank"
              rel="noopener noreferrer"
              class="rounded-xl border border-gray-600 px-8 py-4 text-base font-semibold text-gray-300 transition-all duration-200 hover:bg-gray-800 hover:text-white"
            >
              {m.solutions_talk_to_team({}, { locale })}
            </a>
          </div>

          <!-- Compliance badges -->
          <div class="mt-12 flex flex-wrap items-center justify-center gap-6 text-sm text-gray-400">
            <div class="flex items-center gap-2">
              <svg class="h-5 w-5 text-green-400" fill="currentColor" viewBox="0 0 20 20">
                <path
                  fill-rule="evenodd"
                  d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z"
                  clip-rule="evenodd"></path>
              </svg>
              {m.solutions_fintech_badge_soc2({}, { locale })}
            </div>
            <div class="flex items-center gap-2">
              <svg class="h-5 w-5 text-green-400" fill="currentColor" viewBox="0 0 20 20">
                <path
                  fill-rule="evenodd"
                  d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z"
                  clip-rule="evenodd"></path>
              </svg>
              {m.solutions_fintech_badge_gdpr({}, { locale })}
            </div>
            <div class="flex items-center gap-2">
              <svg class="h-5 w-5 text-green-400" fill="currentColor" viewBox="0 0 20 20">
                <path
                  fill-rule="evenodd"
                  d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z"
                  clip-rule="evenodd"></path>
              </svg>
              {m.solutions_fintech_badge_e2e({}, { locale })}
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- The Fintech Reality -->
    <section class="bg-gray-800 py-20">
      <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
        <div class="mx-auto mb-16 max-w-3xl text-center">
          <h2 class="mb-4 text-sm font-semibold tracking-wide text-red-400 uppercase">{m.solutions_fintech_reality_label({}, { locale })}</h2>
          <h3 class="text-3xl font-bold text-white sm:text-4xl">{m.solutions_fintech_reality_title({}, { locale })}</h3>
        </div>

        <div class="grid grid-cols-1 items-start gap-12 lg:grid-cols-2">
          <!-- Nightmare Scenario -->
          <div class="rounded-2xl border border-red-500/30 bg-gray-900 p-8">
            <h4 class="mb-6 flex items-center gap-2 text-xl font-bold text-red-400">
              <svg class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  stroke-width="2"
                  d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-3L13.732 4c-.77-1.333-2.694-1.333-3.464 0L3.34 16c-.77 1.333.192 3 1.732 3z"></path>
              </svg>
              {m.solutions_fintech_nightmare_title({}, { locale })}
            </h4>
            <div class="space-y-4 text-gray-300">
              <p>{m.solutions_fintech_nightmare_para1({}, { locale })}</p>
              <p>{m.solutions_fintech_nightmare_para2({}, { locale })}</p>
              <p class="font-medium text-red-300">{m.solutions_fintech_nightmare_para3({}, { locale })}</p>
            </div>
          </div>

          <!-- Pain Points -->
          <div class="space-y-4">
            <div class="rounded-xl border border-gray-700 bg-gray-900 p-6">
              <div class="flex items-start gap-4">
                <div class="flex h-10 w-10 shrink-0 items-center justify-center rounded-lg bg-red-500/20">
                  <svg class="h-5 w-5 text-red-400" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"></path>
                  </svg>
                </div>
                <div>
                  <h4 class="mb-1 text-lg font-bold text-white">{m.solutions_fintech_pain1_title({}, { locale })}</h4>
                  <p class="text-sm text-gray-400">{m.solutions_fintech_pain1_desc({}, { locale })}</p>
                </div>
              </div>
            </div>

            <div class="rounded-xl border border-gray-700 bg-gray-900 p-6">
              <div class="flex items-start gap-4">
                <div class="flex h-10 w-10 shrink-0 items-center justify-center rounded-lg bg-red-500/20">
                  <svg class="h-5 w-5 text-red-400" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                    <path
                      stroke-linecap="round"
                      stroke-linejoin="round"
                      stroke-width="2"
                      d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z"
                    ></path>
                  </svg>
                </div>
                <div>
                  <h4 class="mb-1 text-lg font-bold text-white">{m.solutions_fintech_pain2_title({}, { locale })}</h4>
                  <p class="text-sm text-gray-400">{m.solutions_fintech_pain2_desc({}, { locale })}</p>
                </div>
              </div>
            </div>

            <div class="rounded-xl border border-gray-700 bg-gray-900 p-6">
              <div class="flex items-start gap-4">
                <div class="flex h-10 w-10 shrink-0 items-center justify-center rounded-lg bg-red-500/20">
                  <svg class="h-5 w-5 text-red-400" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                    <path
                      stroke-linecap="round"
                      stroke-linejoin="round"
                      stroke-width="2"
                      d="M12 8c-1.657 0-3 .895-3 2s1.343 2 3 2 3 .895 3 2-1.343 2-3 2m0-8c1.11 0 2.08.402 2.599 1M12 8V7m0 1v8m0 0v1m0-1c-1.11 0-2.08-.402-2.599-1M21 12a9 9 0 11-18 0 9 9 0 0118 0z"
                    ></path>
                  </svg>
                </div>
                <div>
                  <h4 class="mb-1 text-lg font-bold text-white">{m.solutions_fintech_pain3_title({}, { locale })}</h4>
                  <p class="text-sm text-gray-400">{m.solutions_fintech_pain3_desc({}, { locale })}</p>
                </div>
              </div>
            </div>

            <div class="rounded-xl border border-gray-700 bg-gray-900 p-6">
              <div class="flex items-start gap-4">
                <div class="flex h-10 w-10 shrink-0 items-center justify-center rounded-lg bg-red-500/20">
                  <svg class="h-5 w-5 text-red-400" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z"></path>
                    <path
                      stroke-linecap="round"
                      stroke-linejoin="round"
                      stroke-width="2"
                      d="M2.458 12C3.732 7.943 7.523 5 12 5c4.478 0 8.268 2.943 9.542 7-1.274 4.057-5.064 7-9.542 7-4.477 0-8.268-2.943-9.542-7z"></path>
                  </svg>
                </div>
                <div>
                  <h4 class="mb-1 text-lg font-bold text-white">{m.solutions_fintech_pain4_title({}, { locale })}</h4>
                  <p class="text-sm text-gray-400">{m.solutions_fintech_pain4_desc({}, { locale })}</p>
                </div>
              </div>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- How We Solve It -->
    <section class="bg-gray-900 py-20">
      <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
        <div class="mx-auto mb-16 max-w-3xl text-center">
          <h2 class="mb-4 text-sm font-semibold tracking-wide text-green-400 uppercase">{m.solutions_fintech_solution_label({}, { locale })}</h2>
          <h3 class="text-3xl font-bold text-white sm:text-4xl">{m.solutions_fintech_solution_title({}, { locale })}</h3>
          <p class="mt-4 text-xl text-gray-400">{m.solutions_fintech_solution_subtitle({}, { locale })}</p>
        </div>

        <div class="grid grid-cols-1 gap-8 md:grid-cols-2">
          <!-- Solution 1: Instant Security Patches -->
          <div class="rounded-2xl border border-gray-700 bg-gray-800 p-8">
            <div class="mb-6 flex items-center gap-3">
              <div class="flex h-12 w-12 items-center justify-center rounded-lg bg-green-500/20">
                <svg class="h-6 w-6 text-green-400" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                  <path
                    stroke-linecap="round"
                    stroke-linejoin="round"
                    stroke-width="2"
                    d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z"
                  ></path>
                </svg>
              </div>
              <h3 class="text-xl font-bold text-white">{m.solutions_fintech_sol1_title({}, { locale })}</h3>
            </div>
            <p class="mb-6 text-gray-300">{m.solutions_fintech_sol1_desc({}, { locale })}</p>
            <div class="flex items-center justify-center rounded-xl bg-gray-900 p-6">
              <div class="w-full max-w-sm">
                <BugFixIllustration class="text-green-500" />
              </div>
            </div>
          </div>

          <!-- Solution 2: Compliance-Ready -->
          <div class="rounded-2xl border border-gray-700 bg-gray-800 p-8">
            <div class="mb-6 flex items-center gap-3">
              <div class="flex h-12 w-12 items-center justify-center rounded-lg bg-blue-500/20">
                <svg class="h-6 w-6 text-blue-400" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                  <path
                    stroke-linecap="round"
                    stroke-linejoin="round"
                    stroke-width="2"
                    d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2m-3 7h3m-3 4h3m-6-4h.01M9 16h.01"
                  ></path>
                </svg>
              </div>
              <h3 class="text-xl font-bold text-white">{m.solutions_fintech_sol2_title({}, { locale })}</h3>
            </div>
            <p class="mb-6 text-gray-300">{m.solutions_fintech_sol2_desc({}, { locale })}</p>
            <ul class="space-y-2">
              <li class="flex items-center gap-2 text-gray-400">
                <svg class="h-5 w-5 text-green-400" fill="currentColor" viewBox="0 0 20 20">
                  <path
                    fill-rule="evenodd"
                    d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z"
                    clip-rule="evenodd"></path>
                </svg>
                {m.solutions_fintech_sol2_point1({}, { locale })}
              </li>
              <li class="flex items-center gap-2 text-gray-400">
                <svg class="h-5 w-5 text-green-400" fill="currentColor" viewBox="0 0 20 20">
                  <path
                    fill-rule="evenodd"
                    d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z"
                    clip-rule="evenodd"></path>
                </svg>
                {m.solutions_fintech_sol2_point2({}, { locale })}
              </li>
              <li class="flex items-center gap-2 text-gray-400">
                <svg class="h-5 w-5 text-green-400" fill="currentColor" viewBox="0 0 20 20">
                  <path
                    fill-rule="evenodd"
                    d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z"
                    clip-rule="evenodd"></path>
                </svg>
                {m.solutions_fintech_sol2_point3({}, { locale })}
              </li>
            </ul>
          </div>

          <!-- Solution 3: End-to-End Encryption -->
          <div class="rounded-2xl border border-gray-700 bg-gray-800 p-8">
            <div class="mb-6 flex items-center gap-3">
              <div class="flex h-12 w-12 items-center justify-center rounded-lg bg-purple-500/20">
                <svg class="h-6 w-6 text-purple-400" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                  <path
                    stroke-linecap="round"
                    stroke-linejoin="round"
                    stroke-width="2"
                    d="M12 15v2m-6 4h12a2 2 0 002-2v-6a2 2 0 00-2-2H6a2 2 0 00-2 2v6a2 2 0 002 2zm10-10V7a4 4 0 00-8 0v4h8z"></path>
                </svg>
              </div>
              <h3 class="text-xl font-bold text-white">{m.solutions_fintech_sol3_title({}, { locale })}</h3>
            </div>
            <p class="mb-6 text-gray-300">{m.solutions_fintech_sol3_desc({}, { locale })}</p>
            <div class="flex items-center justify-center rounded-xl bg-gray-900 p-6">
              <div class="w-full max-w-sm">
                <SecurityIllustration class="text-purple-500" />
              </div>
            </div>
          </div>

          <!-- Solution 4: Instant Rollback -->
          <div class="rounded-2xl border border-gray-700 bg-gray-800 p-8">
            <div class="mb-6 flex items-center gap-3">
              <div class="flex h-12 w-12 items-center justify-center rounded-lg bg-amber-500/20">
                <svg class="h-6 w-6 text-amber-400" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 10h10a8 8 0 018 8v2M3 10l6 6m-6-6l6-6"></path>
                </svg>
              </div>
              <h3 class="text-xl font-bold text-white">{m.solutions_fintech_sol4_title({}, { locale })}</h3>
            </div>
            <p class="mb-6 text-gray-300">{m.solutions_fintech_sol4_desc({}, { locale })}</p>
            <div class="flex items-center justify-center rounded-xl bg-gray-900 p-6">
              <div class="w-full max-w-sm">
                <RolloutIllustration class="text-amber-500" />
              </div>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- Trust & Compliance -->
    <section class="bg-gray-800 py-20">
      <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
        <div class="mx-auto mb-16 max-w-3xl text-center">
          <h2 class="text-3xl font-bold text-white sm:text-4xl">{m.solutions_fintech_trust_title({}, { locale })}</h2>
          <p class="mt-4 text-xl text-gray-400">{m.solutions_fintech_trust_subtitle({}, { locale })}</p>
        </div>

        <div class="mb-12 grid grid-cols-1 gap-8 md:grid-cols-3">
          <div class="rounded-2xl border border-gray-700 bg-gray-900 p-8 text-center">
            <img src="/soc2.svg" alt="SOC 2" class="mx-auto mb-4 h-16 opacity-80" />
            <h4 class="mb-2 text-lg font-bold text-white">{m.solutions_fintech_cert1_title({}, { locale })}</h4>
            <p class="text-sm text-gray-400">{m.solutions_fintech_cert1_desc({}, { locale })}</p>
          </div>
          <div class="rounded-2xl border border-gray-700 bg-gray-900 p-8 text-center">
            <img src="/gdpr.svg" alt="GDPR" class="mx-auto mb-4 h-16 opacity-80" />
            <h4 class="mb-2 text-lg font-bold text-white">{m.solutions_fintech_cert2_title({}, { locale })}</h4>
            <p class="text-sm text-gray-400">{m.solutions_fintech_cert2_desc({}, { locale })}</p>
          </div>
          <div class="rounded-2xl border border-gray-700 bg-gray-900 p-8 text-center">
            <svg class="mx-auto mb-4 h-16 w-16 text-green-400" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path
                stroke-linecap="round"
                stroke-linejoin="round"
                stroke-width="1.5"
                d="M12 15v2m-6 4h12a2 2 0 002-2v-6a2 2 0 00-2-2H6a2 2 0 00-2 2v6a2 2 0 002 2zm10-10V7a4 4 0 00-8 0v4h8z"></path>
            </svg>
            <h4 class="mb-2 text-lg font-bold text-white">{m.solutions_fintech_cert3_title({}, { locale })}</h4>
            <p class="text-sm text-gray-400">{m.solutions_fintech_cert3_desc({}, { locale })}</p>
          </div>
        </div>

        <!-- Open Source Advantage -->
        <div class="mx-auto max-w-3xl rounded-2xl border border-green-500/30 bg-gray-900 p-8">
          <div class="flex items-start gap-4">
            <div class="flex h-12 w-12 shrink-0 items-center justify-center rounded-lg bg-green-500/20">
              <svg class="h-6 w-6 text-green-400" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 20l4-16m4 4l4 4-4 4M6 16l-4-4 4-4"></path>
              </svg>
            </div>
            <div>
              <h4 class="mb-2 text-xl font-bold text-white">{m.solutions_fintech_opensource_title({}, { locale })}</h4>
              <p class="mb-4 text-gray-300">{m.solutions_fintech_opensource_desc({}, { locale })}</p>
              <a href="https://github.com/Cap-go/capgo" class="inline-flex items-center gap-2 text-green-400 hover:underline">
                {m.solutions_fintech_opensource_cta({}, { locale })}
                <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14"></path>
                </svg>
              </a>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- Final CTA -->
    <section class="bg-gray-900 py-20">
      <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
        <div class="relative overflow-hidden rounded-3xl bg-linear-to-r from-green-600 to-emerald-700 px-8 py-16 sm:px-16">
          <div aria-hidden="true" class="absolute inset-0">
            <svg class="absolute inset-0 h-full w-full" preserveAspectRatio="xMidYMid slice" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 1463 360">
              <path class="text-opacity-40 text-green-500" fill="currentColor" d="M-82.673 72l1761.849 472.086-134.327 501.315-1761.85-472.086z"></path>
              <path class="text-opacity-20 text-emerald-400" fill="currentColor" d="M-217.088 544.086L1544.761 72l134.327 501.316-1761.849 472.086z"></path>
            </svg>
          </div>
          <div class="relative text-center">
            <h2 class="text-3xl font-bold text-white sm:text-4xl">{m.solutions_fintech_cta_title({}, { locale })}</h2>
