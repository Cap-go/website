---
import Layout from '@/layouts/Layout.astro'
import * as m from '@/paraglide/messages'
import { getRelativeLocaleUrl } from 'astro:i18n'
import { createServiceLdJson, createLdJsonGraph } from '@/lib/ldJson'

const locale = Astro.locals.locale
const brand = Astro.locals.runtimeConfig.public.brand

const title = `${brand} | ${m.solutions_ionic_plugins_title({}, { locale })}`
const description = m.solutions_ionic_plugins_description({}, { locale })

const serviceLdJson = createServiceLdJson(Astro.locals.runtimeConfig.public, {
  name: title,
  description: description,
  url: Astro.url.href,
  serviceType: 'Software Development Service',
  areaServed: ['Worldwide'],
})

const ldJSON = createLdJsonGraph(Astro.locals.runtimeConfig.public, serviceLdJson, {
  includeOrganization: true,
})

const content = { title, description, ldJSON }
---

<Layout content={content}>
  <div>
    <!-- Hero Section -->
    <section class="relative py-16 sm:py-20 lg:py-28">
      <div class="pointer-events-none absolute inset-0 overflow-hidden">
        {
          Array.from({ length: 12 }).map((_, i) => (
            <div
              id={`${i}`}
              class="absolute h-2 w-2 animate-pulse rounded-full bg-emerald-400 opacity-20"
              style={{
                top: `${Math.random() * 100}%`,
                left: `${Math.random() * 100}%`,
                animationDelay: `${Math.random() * 3}s`,
                animationDuration: `${2 + Math.random() * 2}s`,
              }}
            />
          ))
        }
      </div>

      <div class="relative mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
        <div class="mx-auto max-w-4xl text-center">
          <p class="inline-flex rounded-full border border-emerald-400/40 bg-emerald-500/10 px-4 py-2 text-sm font-medium text-emerald-100">
            {m.solutions_ionic_plugins_badge({}, { locale })}
          </p>
          <h1 class="mt-6 text-4xl leading-tight font-bold text-white sm:text-5xl lg:text-6xl">
            {m.solutions_ionic_plugins_hero_title({}, { locale })}
          </h1>
          <p class="mx-auto mt-6 max-w-3xl text-xl leading-relaxed text-gray-300">
            {m.solutions_ionic_plugins_hero_subtitle({}, { locale })}
          </p>

          <div class="mt-10 flex flex-col items-center justify-center gap-4 sm:flex-row">
            <a
              href={getRelativeLocaleUrl(locale, 'register')}
              class="rounded-xl bg-emerald-600 px-8 py-4 text-base font-semibold text-white transition-all duration-200 hover:bg-emerald-700 focus:ring-2 focus:ring-emerald-500 focus:ring-offset-2"
            >
              {m.solutions_get_started({}, { locale })}
            </a>
            <a
              href={getRelativeLocaleUrl(locale, 'docs/upgrade/from-ionic-secure-storage/')}
              class="rounded-xl border border-gray-600 px-8 py-4 text-base font-semibold text-gray-300 transition-all duration-200 hover:bg-gray-800 hover:text-white"
            >
              {m.solutions_view_docs({}, { locale })}
            </a>
          </div>
        </div>
      </div>
    </section>

    <!-- Plugin Table -->
    <section id="plugin-migration" class="bg-gray-800 py-16 sm:py-20">
      <div class="mx-auto max-w-6xl px-4 sm:px-6 lg:px-8">
        <div class="max-w-3xl">
          <h2 class="text-3xl font-bold text-white sm:text-4xl">
            {m.solutions_ionic_plugins_section_title({}, { locale })}
          </h2>
          <p class="mt-4 text-lg text-gray-300">
            {m.solutions_ionic_plugins_section_desc({}, { locale })}
          </p>
        </div>

        <div class="mt-10 overflow-hidden rounded-2xl border border-gray-700 bg-gray-900/50">
          <table class="w-full text-left text-sm text-gray-300">
            <thead class="bg-gray-900/70 text-gray-400">
              <tr>
                <th class="px-6 py-4 font-semibold">{m.appflow_plugins_col_ionic({}, { locale })}</th>
                <th class="px-6 py-4 font-semibold">{m.appflow_plugins_col_capgo({}, { locale })}</th>
                <th class="px-6 py-4 font-semibold">{m.appflow_plugins_col_guide({}, { locale })}</th>
              </tr>
            </thead>
            <tbody class="divide-y divide-gray-700">
              <tr class="transition hover:bg-gray-800/60">
                <td class="px-6 py-4 font-medium text-gray-100">Ionic Secure Storage</td>
                <td class="px-6 py-4">
                  <a href={getRelativeLocaleUrl(locale, 'docs/plugins/fast-sql/')} class="text-emerald-300 hover:underline"> Fast SQL </a>
                  <span class="mx-2 text-gray-500">{m.appflow_plugins_or({}, { locale })}</span>
                  <a href={getRelativeLocaleUrl(locale, 'docs/plugins/data-storage-sqlite/')} class="text-emerald-300 hover:underline"> Data Storage SQLite </a>
                </td>
                <td class="px-6 py-4">
                  <a href={getRelativeLocaleUrl(locale, 'docs/upgrade/from-ionic-secure-storage/')} class="text-blue-300 hover:underline">
                    {m.appflow_plugins_link_text({}, { locale })}
                  </a>
                </td>
              </tr>
              <tr class="transition hover:bg-gray-800/60">
                <td class="px-6 py-4 font-medium text-gray-100">Ionic Auth Connect</td>
                <td class="px-6 py-4">
                  <a href={getRelativeLocaleUrl(locale, 'docs/plugins/social-login/')} class="text-emerald-300 hover:underline"> Social Login </a>
                </td>
                <td class="px-6 py-4">
                  <a href={getRelativeLocaleUrl(locale, 'docs/upgrade/from-ionic-auth-connect/')} class="text-blue-300 hover:underline">
                    {m.appflow_plugins_link_text({}, { locale })}
                  </a>
                </td>
              </tr>
              <tr class="transition hover:bg-gray-800/60">
                <td class="px-6 py-4 font-medium text-gray-100">Ionic Identity Vault</td>
                <td class="px-6 py-4">
                  <a href={getRelativeLocaleUrl(locale, 'docs/plugins/native-biometric/')} class="text-emerald-300 hover:underline"> Native Biometric </a>
                  <span class="mx-2 text-gray-500">+</span>
                  <a href={getRelativeLocaleUrl(locale, 'docs/plugins/fast-sql/')} class="text-emerald-300 hover:underline"> Fast SQL </a>
                  <span class="mx-2 text-gray-500">{m.appflow_plugins_or({}, { locale })}</span>
                  <a href={getRelativeLocaleUrl(locale, 'docs/plugins/data-storage-sqlite/')} class="text-emerald-300 hover:underline"> Data Storage SQLite </a>
                </td>
                <td class="px-6 py-4">
                  <a href={getRelativeLocaleUrl(locale, 'docs/upgrade/from-ionic-identity-vault/')} class="text-blue-300 hover:underline">
                    {m.appflow_plugins_link_text({}, { locale })}
                  </a>
                </td>
              </tr>
              <tr class="transition hover:bg-gray-800/60">
                <td class="px-6 py-4 font-medium text-gray-100">Ionic Intune</td>
                <td class="px-6 py-4">
                  <a href={getRelativeLocaleUrl(locale, 'docs/plugins/intune/')} class="text-emerald-300 hover:underline"> Intune </a>
                </td>
                <td class="px-6 py-4">
                  <a href={getRelativeLocaleUrl(locale, 'docs/plugins/intune/getting-started/')} class="text-blue-300 hover:underline">
                    {m.appflow_plugins_link_text({}, { locale })}
                  </a>
                </td>
              </tr>
              <tr class="transition hover:bg-gray-800/60">
                <td class="px-6 py-4 font-medium text-gray-100">Ionic Payments</td>
                <td class="px-6 py-4">
                  <a
                    href={getRelativeLocaleUrl(locale, 'docs/plugins/pay/')}
                    class="text-emerald-300 hover:underline"
                  >
                    @capgo/capacitor-pay
                  </a>
                </td>
                <td class="px-6 py-4">
                  <a
                    href={getRelativeLocaleUrl(locale, 'docs/plugins/pay/getting-started/')}
                    class="text-blue-300 hover:underline"
                  >
                    {m.appflow_plugins_link_text({}, { locale })}
                  </a>
                </td>
              </tr>
              <tr class="transition hover:bg-gray-800/60">
                <td class="px-6 py-4 font-medium text-gray-100">Ionic Zebra Scanner</td>
                <td class="px-6 py-4">
                  <a
                    href={getRelativeLocaleUrl(locale, 'docs/plugins/zebra-datawedge/')}
                    class="text-emerald-300 hover:underline"
                  >
                    Zebra DataWedge
                  </a>
                </td>
                <td class="px-6 py-4">
                  <a
                    href={getRelativeLocaleUrl(locale, 'docs/plugins/zebra-datawedge/')}
                    class="text-blue-300 hover:underline"
                  >
                    {m.appflow_plugins_link_text({}, { locale })}
                  </a>
                </td>
              </tr>
              <tr class="transition hover:bg-gray-800/60">
                <td class="px-6 py-4 font-medium text-gray-100">@ionic-enterprise/ssl-pinning</td>
                <td class="px-6 py-4">
                  <a
                    href="https://github.com/mchl18/Capacitor-SSL-Pinning"
                    class="text-emerald-300 hover:underline"
                    target="_blank"
                    rel="noreferrer"
                  >
                    capacitor-ssl-pinning
                  </a>
                </td>
                <td class="px-6 py-4">
                  <a
                    href="https://github.com/mchl18/Capacitor-SSL-Pinning"
                    class="text-blue-300 hover:underline"
                    target="_blank"
                    rel="noreferrer"
                  >
                    {m.appflow_plugins_link_text({}, { locale })}
                  </a>
                </td>
              </tr>
            </tbody>
          </table>
        </div>
      </div>
    </section>

    <!-- Migration Steps -->
    <section class="bg-gray-900 py-16 sm:py-20">
      <div class="mx-auto max-w-6xl px-4 sm:px-6 lg:px-8">
        <h2 class="text-3xl font-bold text-white sm:text-4xl">
          {m.solutions_ionic_plugins_steps_title({}, { locale })}
        </h2>
        <div class="mt-10 grid gap-6 md:grid-cols-3">
          <div class="rounded-2xl border border-gray-700 bg-gray-800/60 p-6">
            <div class="mb-4 flex h-10 w-10 items-center justify-center rounded-full bg-emerald-500/20 font-semibold text-emerald-300">1</div>
            <p class="text-gray-300">{m.solutions_ionic_plugins_step1({}, { locale })}</p>
          </div>
          <div class="rounded-2xl border border-gray-700 bg-gray-800/60 p-6">
            <div class="mb-4 flex h-10 w-10 items-center justify-center rounded-full bg-emerald-500/20 font-semibold text-emerald-300">2</div>
            <p class="text-gray-300">{m.solutions_ionic_plugins_step2({}, { locale })}</p>
          </div>
          <div class="rounded-2xl border border-gray-700 bg-gray-800/60 p-6">
            <div class="mb-4 flex h-10 w-10 items-center justify-center rounded-full bg-emerald-500/20 font-semibold text-emerald-300">3</div>
            <p class="text-gray-300">{m.solutions_ionic_plugins_step3({}, { locale })}</p>
          </div>
        </div>
      </div>
    </section>

    <!-- CTA -->
    <section class="bg-gray-800 py-16 sm:py-20">
      <div class="mx-auto max-w-6xl px-4 sm:px-6 lg:px-8">
        <div class="rounded-3xl border border-emerald-500/30 bg-emerald-500/10 p-10 text-center">
          <h2 class="text-3xl font-bold text-white sm:text-4xl">
            {m.solutions_ionic_plugins_cta_title({}, { locale })}
          </h2>
          <p class="mt-4 text-lg text-emerald-100">
            {m.solutions_ionic_plugins_cta_subtitle({}, { locale })}
          </p>
          <div class="mt-8 flex flex-col items-center justify-center gap-4 sm:flex-row">
            <a
              href={getRelativeLocaleUrl(locale, 'register')}
              class="rounded-xl bg-emerald-600 px-8 py-4 text-base font-semibold text-white transition-all duration-200 hover:bg-emerald-700"
            >
              {m.solutions_start_free_trial({}, { locale })}
            </a>
            <a
              href={getRelativeLocaleUrl(locale, 'docs/upgrade/from-ionic-secure-storage/')}
              class="rounded-xl border border-emerald-400/50 px-8 py-4 text-base font-semibold text-gray-200 transition-all duration-200 hover:bg-emerald-500/10"
            >
              {m.solutions_view_docs({}, { locale })}
            </a>
          </div>
        </div>
      </div>
    </section>
  </div>
</Layout>
