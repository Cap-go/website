---
import Layout from '@/layouts/Layout.astro'
import m, { type MessageKey, type MessageValues } from '@/copy/messages'
import { createLdJsonGraph, createServiceLdJson } from '@/lib/ldJson'

const locale = Astro.locals.locale
const brand = Astro.locals.runtimeConfig.public.brand

function copy(key: MessageKey, values: MessageValues = {}) {
  return m[key](values, { locale })
}

const title = brand + ' | ' + copy('solutions_webapp_to_mobile_title')
const description = copy('solutions_webapp_to_mobile_description')

const serviceLdJson = createServiceLdJson(Astro.locals.runtimeConfig.public, {
  name: title,
  description,
  url: Astro.url.href,
  serviceType: 'Web app to mobile release workflow',
  areaServed: ['Worldwide'],
})

const ldJSON = createLdJsonGraph(Astro.locals.runtimeConfig.public, serviceLdJson, {
  includeOrganization: true,
})

const content = { title, description, ldJSON, image: '/capgo_social.png' }
const aiPromptUrl = '#ai-instructions'
const handoffUrl = '#handoff-checklist'
const sourceUrl = '#source-requirements'

const stats: { value: MessageKey; label: MessageKey }[] = [
  { value: 'solutions_webapp_to_mobile_stat1_value', label: 'solutions_webapp_to_mobile_stat1_label' },
  { value: 'solutions_webapp_to_mobile_stat2_value', label: 'solutions_webapp_to_mobile_stat2_label' },
  { value: 'solutions_webapp_to_mobile_stat3_value', label: 'solutions_webapp_to_mobile_stat3_label' },
]

const pains: { title: MessageKey; desc: MessageKey }[] = [
  { title: 'solutions_webapp_to_mobile_pain1_title', desc: 'solutions_webapp_to_mobile_pain1_desc' },
  { title: 'solutions_webapp_to_mobile_pain2_title', desc: 'solutions_webapp_to_mobile_pain2_desc' },
  { title: 'solutions_webapp_to_mobile_pain3_title', desc: 'solutions_webapp_to_mobile_pain3_desc' },
]
const sources: { title: MessageKey; desc: MessageKey; image: string; alt: string; width: number; height: number }[] = [
  {
    title: 'solutions_webapp_to_mobile_source1_title',
    desc: 'solutions_webapp_to_mobile_source1_desc',
    image: '/lovable-app-running.webp',
    alt: 'AI-built web app running before the mobile release step',
    width: 3584,
    height: 2000,
  },
  {
    title: 'solutions_webapp_to_mobile_source2_title',
    desc: 'solutions_webapp_to_mobile_source2_desc',
    image: '/bolt-project-files.webp',
    alt: 'Repo-first web app project files ready for Capacitor',
    width: 3586,
    height: 832,
  },
  {
    title: 'solutions_webapp_to_mobile_source3_title',
    desc: 'solutions_webapp_to_mobile_source3_desc',
    image: '/base44-build-output.webp',
    alt: 'Web app build output ready to become a mobile app',
    width: 1536,
    height: 1024,
  },
]

const capabilities: { title: MessageKey; desc: MessageKey }[] = [
  { title: 'solutions_webapp_to_mobile_cap1_title', desc: 'solutions_webapp_to_mobile_cap1_desc' },
  { title: 'solutions_webapp_to_mobile_cap2_title', desc: 'solutions_webapp_to_mobile_cap2_desc' },
  { title: 'solutions_webapp_to_mobile_cap3_title', desc: 'solutions_webapp_to_mobile_cap3_desc' },
  { title: 'solutions_webapp_to_mobile_cap4_title', desc: 'solutions_webapp_to_mobile_cap4_desc' },
]

const workflow: { title: MessageKey; desc: MessageKey }[] = [
  { title: 'solutions_webapp_to_mobile_workflow1_title', desc: 'solutions_webapp_to_mobile_workflow1_desc' },
  { title: 'solutions_webapp_to_mobile_workflow2_title', desc: 'solutions_webapp_to_mobile_workflow2_desc' },
  { title: 'solutions_webapp_to_mobile_workflow3_title', desc: 'solutions_webapp_to_mobile_workflow3_desc' },
  { title: 'solutions_webapp_to_mobile_workflow4_title', desc: 'solutions_webapp_to_mobile_workflow4_desc' },
]

const aiInstructions = `You are preparing this existing web app to become an installable iOS and Android app.
Do not assume this builder can run local tooling. If this environment cannot create native projects or run local tools, create a clean handoff document instead.

Inspect the app and return:

1. The framework, package manager, production build process, and build output folder.
2. Whether the app can be exported or committed to a real Git repository.
3. The app name, bundle ID or package ID suggestion, app icon and splash-screen source, and any missing brand assets.
4. Auth, redirect, deep-link, storage, camera, push, payment, geolocation, file, or notification features that need native plugin planning.
5. Routing, environment variables, API URLs, and asset assumptions that could break inside a native WebView.
6. A proposed Capacitor configuration, including appId, appName, webDir, and required plugins, without inventing secrets.
7. A release-channel plan: production, staging, preview, and rollback expectations for web-layer updates.
8. A list of tasks that must happen outside the AI builder, such as Apple signing, Android keystore setup, native sync, store records, and signed builds.
9. A docs/mobile-release-handoff.md file with the exact checklist, open questions, and files that a developer or build service should handle next.
10. A short summary of what you changed, what you could not do in this environment, and the next human action.`
---

<Layout content={content}>
  <div class="bg-gray-950">
    <section class="border-b border-white/10 bg-gray-900 py-16 sm:py-20 lg:py-24">
      <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
        <div class="grid gap-12 lg:grid-cols-[1fr_0.95fr] lg:items-center">
          <div>
            <p class="inline-flex min-h-11 items-center rounded-lg border border-cyan-400/30 bg-cyan-500/10 px-4 text-base font-semibold text-cyan-100 sm:text-sm">
              {copy('solutions_webapp_to_mobile_badge')}
            </p>
            <h1 class="mt-6 max-w-4xl text-4xl font-semibold text-white sm:text-5xl lg:text-6xl">
              {copy('solutions_webapp_to_mobile_h1')}
            </h1>
            <p class="mt-6 max-w-3xl text-lg leading-8 text-slate-300 sm:text-xl">
              {copy('solutions_webapp_to_mobile_lead')}
            </p>
            <div class="mt-8 flex flex-col gap-3 sm:flex-row">
              <a
                class="inline-flex min-h-12 items-center justify-center rounded-lg bg-cyan-500 px-6 font-semibold text-gray-950 transition-colors hover:bg-cyan-300 focus:ring-2 focus:ring-cyan-300 focus:ring-offset-2 focus:ring-offset-gray-950 focus:outline-none"
                href={aiPromptUrl}
              >
                {copy('solutions_webapp_to_mobile_cta_primary')}
              </a>
              <a
                class="inline-flex min-h-12 items-center justify-center rounded-lg border border-white/15 px-6 font-semibold text-slate-200 transition-colors hover:bg-white/10 focus:ring-2 focus:ring-slate-300 focus:ring-offset-2 focus:ring-offset-gray-950 focus:outline-none"
                href={handoffUrl}
              >
                {copy('solutions_webapp_to_mobile_builder_cta')}
              </a>
            </div>
            <dl class="mt-10 grid gap-3 sm:grid-cols-3">
              {
                stats.map((stat) => (
                  <div class="rounded-lg border border-white/10 bg-white/[0.04] p-4">
                    <dt class="text-2xl font-semibold text-white">{copy(stat.value)}</dt>
                    <dd class="mt-1 text-base leading-6 text-slate-400 sm:text-sm">{copy(stat.label)}</dd>
                  </div>
                ))
              }
            </dl>
          </div>

          <div class="relative">
            <div class="overflow-hidden rounded-lg border border-white/10 bg-slate-950 shadow-2xl shadow-cyan-950/25">
              <img
                src="/lovable-app-running.webp"
                width="3584"
                height="2000"
                alt="AI-built web app running before it is packaged for mobile"
                class="aspect-[16/10] w-full bg-slate-950 object-contain p-4"
              />
              <div class="grid gap-0 border-t border-white/10 sm:grid-cols-2">
                <div class="border-white/10 bg-slate-950 p-4 sm:border-r">
                  <p class="text-base font-semibold text-cyan-100 sm:text-sm">{copy('solutions_webapp_to_mobile_visual_from')}</p>
                  <p class="mt-2 text-base leading-6 text-slate-300 sm:text-sm">{copy('solutions_webapp_to_mobile_visual_from_detail')}</p>
                </div>
                <div class="bg-emerald-950/30 p-4">
                  <p class="text-base font-semibold text-emerald-100 sm:text-sm">{copy('solutions_webapp_to_mobile_visual_to')}</p>
                  <p class="mt-2 text-base leading-6 text-slate-300 sm:text-sm">{copy('solutions_webapp_to_mobile_visual_to_detail')}</p>
                </div>
              </div>
            </div>
          </div>
        </div>
      </div>
    </section>

    <section class="bg-gray-950 py-16 sm:py-20">
      <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
        <div class="max-w-3xl">
          <p class="text-sm font-semibold text-red-300 uppercase">{copy('solutions_the_problem')}</p>
          <h2 class="mt-3 text-3xl font-semibold text-white sm:text-4xl">{copy('solutions_webapp_to_mobile_problem_title')}</h2>
        </div>
        <dl class="mt-10 grid gap-5 lg:grid-cols-3">
          {
            pains.map((pain) => (
              <div class="rounded-lg border border-red-400/20 bg-red-950/20 p-6">
                <dt class="text-xl font-semibold text-white">{copy(pain.title)}</dt>
                <dd class="mt-3 text-base leading-7 text-slate-300">{copy(pain.desc)}</dd>
              </div>
            ))
          }
        </dl>
      </div>
    </section>

    <section id="source-requirements" class="border-y border-white/10 bg-slate-900 py-16 sm:py-20">
      <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
        <div class="max-w-3xl">
          <p class="text-sm font-semibold text-amber-200 uppercase">{copy('solutions_webapp_to_mobile_source_label')}</p>
          <h2 class="mt-3 text-3xl font-semibold text-white sm:text-4xl">{copy('solutions_webapp_to_mobile_source_title')}</h2>
          <p class="mt-4 text-lg leading-8 text-slate-300">{copy('solutions_webapp_to_mobile_source_lead')}</p>
        </div>
        <div class="mt-10 grid gap-5 lg:grid-cols-3">
          {
            sources.map((source) => (
              <article class="overflow-hidden rounded-lg border border-white/10 bg-gray-950">
                <img
                  src={source.image}
                  width={source.width}
                  height={source.height}
                  alt={source.alt}
                  class="aspect-[16/9] w-full border-b border-white/10 bg-slate-950 object-contain p-3"
                />
                <div class="p-6">
                  <h3 class="text-xl font-semibold text-white">{copy(source.title)}</h3>
                  <p class="mt-3 text-base leading-7 text-slate-300">{copy(source.desc)}</p>
                </div>
              </article>
            ))
          }
        </div>
      </div>
    </section>

    <section class="bg-gray-950 py-16 sm:py-20">
      <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
        <div class="grid gap-10 lg:grid-cols-[0.8fr_1.2fr] lg:items-start">
          <div>
            <p class="text-sm font-semibold text-cyan-200 uppercase">{copy('solutions_the_solution')}</p>
            <h2 class="mt-3 text-3xl font-semibold text-white sm:text-4xl">{copy('solutions_webapp_to_mobile_cap_title')}</h2>
            <p class="mt-4 text-lg leading-8 text-slate-300">{copy('solutions_webapp_to_mobile_cap_lead')}</p>
          </div>
          <dl class="grid gap-4 md:grid-cols-2">
            {
              capabilities.map((capability) => (
                <div class="rounded-lg border border-white/10 bg-white/[0.04] p-5">
                  <dt class="text-lg font-semibold text-white">{copy(capability.title)}</dt>
                  <dd class="mt-3 text-base leading-7 text-slate-300">{copy(capability.desc)}</dd>
                </div>
              ))
            }
          </dl>
        </div>
      </div>
    </section>

    <section id="ai-instructions" class="border-y border-white/10 bg-slate-900 py-16 sm:py-20">
      <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
        <div class="grid gap-8 lg:grid-cols-[0.9fr_1.1fr] lg:items-start">
          <div>
            <p class="text-sm font-semibold text-emerald-200 uppercase">{copy('solutions_webapp_to_mobile_code_label')}</p>
            <h2 class="mt-3 text-3xl font-semibold text-white sm:text-4xl">{copy('solutions_webapp_to_mobile_code_title')}</h2>
            <p class="mt-4 text-lg leading-8 text-slate-300">{copy('solutions_webapp_to_mobile_code_lead')}</p>
          </div>
          <div class="rounded-lg border border-white/10 bg-black/50">
            <div class="flex items-center justify-between gap-4 border-b border-white/10 px-4 py-3">
              <p class="text-sm font-semibold text-slate-300">{copy('solutions_webapp_to_mobile_prompt_card_title')}</p>
              <button
                type="button"
                class="inline-flex min-h-10 items-center rounded-lg border border-emerald-400/30 px-3 text-sm font-semibold text-emerald-100 transition-colors hover:bg-emerald-500/10 focus:ring-2 focus:ring-emerald-300 focus:ring-offset-2 focus:ring-offset-slate-950 focus:outline-none"
                data-copy-prompt={aiInstructions}
              >
                {copy('solutions_webapp_to_mobile_prompt_copy')}
              </button>
            </div>
            <pre class="max-h-[42rem] overflow-auto p-5 text-sm leading-7 whitespace-pre-wrap text-slate-200"><code>{aiInstructions}</code></pre>
          </div>
        </div>
      </div>
    </section>

    <section id="handoff-checklist" class="bg-gray-950 py-16 sm:py-20">
      <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
        <div class="grid gap-10 lg:grid-cols-[0.85fr_1.15fr] lg:items-start">
          <div>
            <p class="text-sm font-semibold text-amber-200 uppercase">{copy('solutions_webapp_to_mobile_workflow_label')}</p>
            <h2 class="mt-3 text-3xl font-semibold text-white sm:text-4xl">{copy('solutions_webapp_to_mobile_workflow_title')}</h2>
            <p class="mt-4 text-lg leading-8 text-slate-300">{copy('solutions_webapp_to_mobile_workflow_lead')}</p>
          </div>
          <div class="grid gap-4">
            {
              workflow.map((step, index) => (
                <article class="grid gap-4 rounded-lg border border-white/10 bg-white/[0.04] p-5 sm:grid-cols-[auto_1fr]">
                  <div class="flex h-11 w-11 items-center justify-center rounded-lg bg-amber-500/15 font-semibold text-amber-200 ring-1 ring-amber-400/20">{index + 1}</div>
                  <div>
                    <h3 class="text-lg font-semibold text-white">{copy(step.title)}</h3>
                    <p class="mt-2 text-base leading-7 text-slate-300">{copy(step.desc)}</p>
                  </div>
                </article>
              ))
            }
          </div>
        </div>
      </div>
    </section>

    <section class="border-y border-cyan-400/20 bg-cyan-950/10 py-14">
      <div class="mx-auto max-w-5xl px-4 sm:px-6 lg:px-8">
        <p class="text-sm font-semibold text-cyan-200 uppercase">{copy('solutions_webapp_to_mobile_quote_label')}</p>
        <blockquote class="mt-4 text-2xl leading-10 font-semibold text-white">{copy('solutions_webapp_to_mobile_quote_text')}</blockquote>
        <p class="mt-4 text-sm font-semibold text-slate-400">{copy('solutions_webapp_to_mobile_quote_author')}</p>
      </div>
    </section>

    <section class="bg-slate-900 py-16 sm:py-20">
      <div class="mx-auto max-w-5xl px-4 text-center sm:px-6 lg:px-8">
        <h2 class="text-3xl font-semibold text-white sm:text-4xl">{copy('solutions_webapp_to_mobile_cta_title')}</h2>
        <p class="mx-auto mt-4 max-w-3xl text-lg leading-8 text-slate-300">{copy('solutions_webapp_to_mobile_cta_subtitle')}</p>
        <div class="mt-8 flex flex-col justify-center gap-3 sm:flex-row">
          <a
            class="inline-flex min-h-12 items-center justify-center rounded-lg border border-cyan-300/50 px-6 font-semibold text-cyan-100 transition-colors hover:bg-cyan-500/10 focus:ring-2 focus:ring-cyan-300 focus:ring-offset-2 focus:ring-offset-slate-900 focus:outline-none"
            href={aiPromptUrl}
          >
            {copy('solutions_webapp_to_mobile_cta_primary')}
          </a>
          <a
            class="inline-flex min-h-12 items-center justify-center rounded-lg border border-white/15 px-6 font-semibold text-slate-200 transition-colors hover:bg-white/10 focus:ring-2 focus:ring-slate-300 focus:ring-offset-2 focus:ring-offset-slate-900 focus:outline-none"
            href={handoffUrl}
          >
            {copy('solutions_webapp_to_mobile_lovable_cta')}
          </a>
          <a
            class="inline-flex min-h-12 items-center justify-center rounded-lg border border-white/15 px-6 font-semibold text-slate-200 transition-colors hover:bg-white/10 focus:ring-2 focus:ring-slate-300 focus:ring-offset-2 focus:ring-offset-slate-900 focus:outline-none"
            href={sourceUrl}
          >
            {copy('solutions_webapp_to_mobile_guide_cta')}
          </a>
        </div>
      </div>
    </section>
  </div>
</Layout>

<script>
  async function copyPrompt(button: HTMLButtonElement): Promise<void> {
    const value = button.dataset.copyPrompt
    if (!value || !navigator.clipboard?.writeText) return

    const original = button.textContent || 'Copy prompt'

    try {
      await navigator.clipboard.writeText(value)
      button.textContent = 'Copied'
      window.setTimeout(() => {
        button.textContent = original
      }, 1800)
    } catch {
      button.textContent = original
    }
  }

  document.querySelectorAll<HTMLButtonElement>('[data-copy-prompt]').forEach((button) => {
    button.addEventListener('click', () => copyPrompt(button))
  })
</script>
