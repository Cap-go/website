---
import Layout from '@/layouts/Layout.astro'
import m, { type MessageKey, type MessageValues } from '@/copy/messages'
import SolutionAppExample from '@/components/solutions/SolutionAppExample.astro'
import { getRelativeLocaleUrl } from 'astro:i18n'
import { createServiceLdJson, createLdJsonGraph } from '@/lib/ldJson'

const locale = Astro.locals.locale
const brand = Astro.locals.runtimeConfig.public.brand

function copy(key: MessageKey, values: MessageValues = {}) {
  return m[key](values, { locale })
}

const title = brand + ' | ' + copy('solutions_build_without_mac_title')
const description = copy('solutions_build_without_mac_description')

const serviceLdJson = createServiceLdJson(Astro.locals.runtimeConfig.public, {
  name: title,
  description,
  url: Astro.url.href,
  serviceType: 'Cloud iOS build service',
  areaServed: ['Worldwide'],
})

const ldJSON = createLdJsonGraph(Astro.locals.runtimeConfig.public, serviceLdJson, {
  includeOrganization: true,
})

const content = { title, description, ldJSON }
const registerUrl = getRelativeLocaleUrl(locale, 'register')
const nativeBuildUrl = getRelativeLocaleUrl(locale, 'native-build')

const stats: { value: MessageKey; label: MessageKey }[] = [
  { value: 'solutions_build_without_mac_stat1_value', label: 'solutions_build_without_mac_stat1_label' },
  { value: 'solutions_build_without_mac_stat2_value', label: 'solutions_build_without_mac_stat2_label' },
  { value: 'solutions_build_without_mac_stat3_value', label: 'solutions_build_without_mac_stat3_label' },
]

const pains: { title: MessageKey; desc: MessageKey }[] = [
  { title: 'solutions_build_without_mac_pain1_title', desc: 'solutions_build_without_mac_pain1_desc' },
  { title: 'solutions_build_without_mac_pain2_title', desc: 'solutions_build_without_mac_pain2_desc' },
  { title: 'solutions_build_without_mac_pain3_title', desc: 'solutions_build_without_mac_pain3_desc' },
]

const normalSteps: { title: MessageKey; desc: MessageKey }[] = [
  { title: 'solutions_build_without_mac_normal1_title', desc: 'solutions_build_without_mac_normal1_desc' },
  { title: 'solutions_build_without_mac_normal2_title', desc: 'solutions_build_without_mac_normal2_desc' },
  { title: 'solutions_build_without_mac_normal3_title', desc: 'solutions_build_without_mac_normal3_desc' },
]

const capabilities: { title: MessageKey; desc: MessageKey }[] = [
  { title: 'solutions_build_without_mac_cap1_title', desc: 'solutions_build_without_mac_cap1_desc' },
  { title: 'solutions_build_without_mac_cap2_title', desc: 'solutions_build_without_mac_cap2_desc' },
  { title: 'solutions_build_without_mac_cap3_title', desc: 'solutions_build_without_mac_cap3_desc' },
  { title: 'solutions_build_without_mac_cap4_title', desc: 'solutions_build_without_mac_cap4_desc' },
]

const trust: { title: MessageKey; desc: MessageKey }[] = [
  { title: 'solutions_build_without_mac_trust1_title', desc: 'solutions_build_without_mac_trust1_desc' },
  { title: 'solutions_build_without_mac_trust2_title', desc: 'solutions_build_without_mac_trust2_desc' },
  { title: 'solutions_build_without_mac_trust3_title', desc: 'solutions_build_without_mac_trust3_desc' },
]

const workflow: { title: MessageKey; desc: MessageKey }[] = [
  { title: 'solutions_build_without_mac_workflow1_title', desc: 'solutions_build_without_mac_workflow1_desc' },
  { title: 'solutions_build_without_mac_workflow2_title', desc: 'solutions_build_without_mac_workflow2_desc' },
  { title: 'solutions_build_without_mac_workflow3_title', desc: 'solutions_build_without_mac_workflow3_desc' },
  { title: 'solutions_build_without_mac_workflow4_title', desc: 'solutions_build_without_mac_workflow4_desc' },
]

const heroCommand = `npx @capgo/cli@latest build init --platform ios
npx @capgo/cli@latest build request --platform ios
# signed build runs on an ephemeral Mac runner
# logs stream back to your terminal`

const cliCommand = `# First-time iOS setup
npx @capgo/cli@latest build init --platform ios

# Then any teammate or CI runner can request the build
npx @capgo/cli@latest build request --platform ios`
---

<Layout content={content}>
  <div class="bg-gray-950">
    <section class="border-b border-white/10 bg-gray-900 py-16 sm:py-20 lg:py-28">
      <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
        <div class="grid gap-12 lg:grid-cols-[1fr_0.95fr] lg:items-center">
          <div>
            <p class="inline-flex min-h-11 items-center rounded-lg border border-blue-400/30 bg-blue-500/10 px-4 text-sm font-semibold text-blue-100">
              {copy('solutions_build_without_mac_badge')}
            </p>
            <h1 class="mt-6 max-w-4xl text-4xl leading-tight font-bold text-white sm:text-5xl lg:text-6xl">
              {copy('solutions_build_without_mac_h1')}
            </h1>
            <p class="mt-6 max-w-3xl text-lg leading-8 text-slate-300 sm:text-xl">
              {copy('solutions_build_without_mac_lead')}
            </p>
            <div class="mt-8 flex flex-col gap-3 sm:flex-row">
              <a
                class="inline-flex min-h-12 items-center justify-center rounded-lg bg-blue-500 px-6 font-semibold text-white transition-colors hover:bg-blue-400 focus:ring-2 focus:ring-blue-300 focus:ring-offset-2 focus:ring-offset-gray-950 focus:outline-none"
                href={registerUrl}
              >
                {copy('solutions_start_free_trial')}
              </a>
              <a
                class="inline-flex min-h-12 items-center justify-center rounded-lg border border-white/15 px-6 font-semibold text-slate-200 transition-colors hover:bg-white/10 focus:ring-2 focus:ring-slate-300 focus:ring-offset-2 focus:ring-offset-gray-950 focus:outline-none"
                href={nativeBuildUrl}
              >
                {copy('solutions_build_without_mac_secondary_cta')}
              </a>
            </div>
            <div class="mt-10 grid gap-3 sm:grid-cols-3">
              {
                stats.map((stat) => (
                  <div class="rounded-lg border border-white/10 bg-white/[0.04] p-4">
                    <div class="text-2xl font-bold text-white">{copy(stat.value)}</div>
                    <div class="mt-1 text-sm leading-6 text-slate-400">{copy(stat.label)}</div>
                  </div>
                ))
              }
            </div>
          </div>

          <div class="rounded-lg border border-white/10 bg-slate-950 shadow-2xl shadow-blue-950/30">
            <div class="border-b border-white/10 px-4 py-3">
              <div class="flex items-center gap-2">
                <span class="h-3 w-3 rounded-full bg-red-400/70"></span>
                <span class="h-3 w-3 rounded-full bg-amber-300/70"></span>
                <span class="h-3 w-3 rounded-full bg-emerald-300/70"></span>
                <span class="ml-3 text-sm font-semibold text-slate-300">Capgo Builder</span>
              </div>
            </div>
            <div class="p-5">
              <pre class="overflow-x-auto rounded-lg bg-black/40 p-4 text-sm leading-7 text-slate-200"><code>{heroCommand}</code></pre>
              <div class="mt-5 grid gap-3 sm:grid-cols-2">
                <div class="rounded-lg border border-white/10 bg-white/[0.04] p-4">
                  <p class="text-sm font-semibold text-blue-200">{copy('solutions_build_without_mac_visual1_title')}</p>
                  <p class="mt-2 text-sm leading-6 text-slate-400">{copy('solutions_build_without_mac_visual1_desc')}</p>
                </div>
                <div class="rounded-lg border border-white/10 bg-white/[0.04] p-4">
                  <p class="text-sm font-semibold text-emerald-200">{copy('solutions_build_without_mac_visual2_title')}</p>
                  <p class="mt-2 text-sm leading-6 text-slate-400">{copy('solutions_build_without_mac_visual2_desc')}</p>
                </div>
              </div>
            </div>
          </div>
        </div>
      </div>
    </section>

    <section class="bg-gray-950 py-16 sm:py-20">
      <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
        <div class="max-w-3xl">
          <p class="text-sm font-semibold text-red-300 uppercase">{copy('solutions_the_problem')}</p>
          <h2 class="mt-3 text-3xl font-bold text-white sm:text-4xl">{copy('solutions_build_without_mac_problem_title')}</h2>
        </div>
        <div class="mt-10 grid gap-5 lg:grid-cols-3">
          {
            pains.map((pain) => (
              <article class="rounded-lg border border-red-400/20 bg-red-950/20 p-6">
                <h3 class="text-xl font-bold text-white">{copy(pain.title)}</h3>
                <p class="mt-3 leading-7 text-slate-300">{copy(pain.desc)}</p>
              </article>
            ))
          }
        </div>
      </div>
    </section>

    <section class="border-y border-white/10 bg-slate-900 py-16 sm:py-20">
      <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
        <div class="grid gap-10 lg:grid-cols-[0.85fr_1.15fr] lg:items-start">
          <div>
            <p class="text-sm font-semibold text-amber-200 uppercase">{copy('solutions_build_without_mac_normal_label')}</p>
            <h2 class="mt-3 text-3xl font-bold text-white sm:text-4xl">{copy('solutions_build_without_mac_normal_title')}</h2>
            <p class="mt-4 text-lg leading-8 text-slate-300">{copy('solutions_build_without_mac_normal_lead')}</p>
          </div>
          <div class="grid gap-4">
            {
              normalSteps.map((step, index) => (
                <article class="grid gap-4 rounded-lg border border-amber-400/20 bg-amber-950/10 p-5 sm:grid-cols-[auto_1fr]">
                  <div class="flex h-10 w-10 items-center justify-center rounded-lg bg-amber-500/15 font-bold text-amber-200 ring-1 ring-amber-400/20">{index + 1}</div>
                  <div>
                    <h3 class="text-lg font-bold text-white">{copy(step.title)}</h3>
                    <p class="mt-2 leading-7 text-slate-300">{copy(step.desc)}</p>
                  </div>
                </article>
              ))
            }
          </div>
        </div>
      </div>
    </section>

    <section class="bg-gray-950 py-16 sm:py-20">
      <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
        <div class="grid gap-8 lg:grid-cols-[0.9fr_1.1fr] lg:items-start">
          <div>
            <p class="text-sm font-semibold text-blue-200 uppercase">{copy('solutions_build_without_mac_cli_label')}</p>
            <h2 class="mt-3 text-3xl font-bold text-white sm:text-4xl">{copy('solutions_build_without_mac_cli_title')}</h2>
            <p class="mt-4 text-lg leading-8 text-slate-300">{copy('solutions_build_without_mac_cli_lead')}</p>
          </div>
          <pre class="overflow-x-auto rounded-lg border border-white/10 bg-black/50 p-5 text-sm leading-7 text-slate-200"><code>{cliCommand}</code></pre>
        </div>
      </div>
    </section>

    <section class="border-y border-white/10 bg-slate-900 py-16 sm:py-20">
      <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
        <div class="max-w-3xl">
          <p class="text-sm font-semibold text-blue-200 uppercase">{copy('solutions_the_solution')}</p>
          <h2 class="mt-3 text-3xl font-bold text-white sm:text-4xl">{copy('solutions_build_without_mac_cap_title')}</h2>
          <p class="mt-4 text-lg leading-8 text-slate-300">{copy('solutions_build_without_mac_cap_lead')}</p>
        </div>
        <div class="mt-10 grid gap-5 md:grid-cols-2">
          {
            capabilities.map((item) => (
              <article class="rounded-lg border border-white/10 bg-gray-950 p-6">
                <h3 class="text-xl font-bold text-white">{copy(item.title)}</h3>
                <p class="mt-3 leading-7 text-slate-300">{copy(item.desc)}</p>
              </article>
            ))
          }
        </div>
      </div>
    </section>

    <section class="bg-gray-950 py-16 sm:py-20">
      <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
        <div class="grid gap-10 lg:grid-cols-[0.85fr_1.15fr] lg:items-start">
          <div>
            <p class="text-sm font-semibold text-emerald-200 uppercase">{copy('solutions_build_without_mac_trust_label')}</p>
            <h2 class="mt-3 text-3xl font-bold text-white sm:text-4xl">{copy('solutions_build_without_mac_trust_title')}</h2>
            <p class="mt-4 text-lg leading-8 text-slate-300">{copy('solutions_build_without_mac_trust_lead')}</p>
          </div>
          <div class="grid gap-4">
            {
              trust.map((item) => (
                <article class="rounded-lg border border-emerald-400/20 bg-emerald-950/10 p-5">
                  <h3 class="text-lg font-bold text-white">{copy(item.title)}</h3>
                  <p class="mt-2 leading-7 text-slate-300">{copy(item.desc)}</p>
                </article>
              ))
            }
          </div>
        </div>
      </div>
    </section>

    <section class="border-y border-white/10 bg-slate-900 py-16 sm:py-20">
      <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
        <div class="max-w-3xl">
          <p class="text-sm font-semibold text-amber-200 uppercase">{copy('solutions_build_without_mac_workflow_label')}</p>
          <h2 class="mt-3 text-3xl font-bold text-white sm:text-4xl">{copy('solutions_build_without_mac_workflow_title')}</h2>
        </div>
        <div class="mt-10 grid gap-4 lg:grid-cols-4">
          {
            workflow.map((step, index) => (
              <article class="rounded-lg border border-white/10 bg-gray-950 p-5">
                <div class="flex h-10 w-10 items-center justify-center rounded-lg bg-amber-500/15 font-bold text-amber-200 ring-1 ring-amber-400/20">{index + 1}</div>
                <h3 class="mt-5 text-lg font-bold text-white">{copy(step.title)}</h3>
                <p class="mt-2 leading-7 text-slate-300">{copy(step.desc)}</p>
              </article>
            ))
          }
        </div>
      </div>
    </section>

    <section class="border-y border-blue-400/20 bg-blue-950/10 py-14">
      <div class="mx-auto max-w-5xl px-4 sm:px-6 lg:px-8">
        <p class="text-sm font-semibold text-blue-200 uppercase">{copy('solutions_build_without_mac_quote_label')}</p>
        <blockquote class="mt-4 text-2xl leading-10 font-semibold text-white">{copy('solutions_build_without_mac_quote_text')}</blockquote>
        <p class="mt-4 text-sm font-semibold text-slate-400">{copy('solutions_build_without_mac_quote_author')}</p>
      </div>
    </section>

    <SolutionAppExample solution="build-without-mac" />
    <section class="bg-gray-950 py-16 sm:py-20">
      <div class="mx-auto max-w-5xl px-4 text-center sm:px-6 lg:px-8">
        <h2 class="text-3xl font-bold text-white sm:text-4xl">{copy('solutions_build_without_mac_cta_title')}</h2>
        <p class="mx-auto mt-4 max-w-3xl text-lg leading-8 text-slate-300">{copy('solutions_build_without_mac_cta_subtitle')}</p>
        <div class="mt-8 flex flex-col justify-center gap-3 sm:flex-row">
          <a
            class="inline-flex min-h-12 items-center justify-center rounded-lg bg-blue-500 px-6 font-semibold text-white transition-colors hover:bg-blue-400 focus:ring-2 focus:ring-blue-300 focus:ring-offset-2 focus:ring-offset-gray-950 focus:outline-none"
            href={registerUrl}
          >
            {copy('solutions_start_free_trial')}
          </a>
          <a
            class="inline-flex min-h-12 items-center justify-center rounded-lg border border-white/15 px-6 font-semibold text-slate-200 transition-colors hover:bg-white/10 focus:ring-2 focus:ring-slate-300 focus:ring-offset-2 focus:ring-offset-gray-950 focus:outline-none"
            href="https://book.capgo.app/demo/"
            target="_blank"
            rel="noopener noreferrer"
          >
            {copy('solutions_talk_to_team')}
          </a>
        </div>
      </div>
    </section>
  </div>
</Layout>
