---
import Layout from '@/layouts/Layout.astro'
import m from '@/copy/messages'
import { getRelativeLocaleUrl } from 'astro:i18n'
import { createServiceLdJson, createLdJsonGraph } from '@/lib/ldJson'

const locale = Astro.locals.locale
const brand = Astro.locals.runtimeConfig.public.brand

const title = `${brand} | ${m.solutions_healthcare_title({}, { locale })}`
const description = m.solutions_healthcare_description({}, { locale })

const serviceLdJson = createServiceLdJson(Astro.locals.runtimeConfig.public, {
  name: title,
  description: description,
  url: Astro.url.href,
  serviceType: 'Software Development Service',
  areaServed: ['Worldwide'],
})

const ldJSON = createLdJsonGraph(Astro.locals.runtimeConfig.public, serviceLdJson, {
  includeOrganization: true,
})

const content = { title, description, ldJSON }
---

<Layout content={content}>
  <div>
    <!-- Hero Section -->
    <section class="relative overflow-hidden py-20 sm:py-28 lg:py-36">
      <div class="pointer-events-none absolute inset-0 overflow-hidden">
        <div class="absolute top-0 left-1/2 h-full w-full max-w-6xl -translate-x-1/2">
          <div class="absolute top-1/4 left-1/4 h-96 w-96 rounded-full bg-cyan-500/10 blur-3xl"></div>
          <div class="absolute right-1/4 bottom-1/4 h-96 w-96 rounded-full bg-teal-500/10 blur-3xl"></div>
        </div>
      </div>

      <div class="relative mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
        <div class="mx-auto max-w-4xl text-center">
          <div class="mb-8 inline-flex items-center rounded-full border border-cyan-400/40 bg-cyan-500/10 px-4 py-2 text-sm font-medium text-cyan-200">
            <svg class="mr-2 h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path
                stroke-linecap="round"
                stroke-linejoin="round"
                stroke-width="2"
                d="M4.318 6.318a4.5 4.5 0 000 6.364L12 20.364l7.682-7.682a4.5 4.5 0 00-6.364-6.364L12 7.636l-1.318-1.318a4.5 4.5 0 00-6.364 0z"></path>
            </svg>
            {m.solutions_healthcare_badge({}, { locale })}
          </div>

          <h1 class="text-4xl leading-tight font-bold text-white sm:text-5xl lg:text-6xl">
            {m.solutions_healthcare_hero_title({}, { locale })}
          </h1>

          <p class="mx-auto mt-8 max-w-3xl text-xl leading-relaxed text-gray-300">
            {m.solutions_healthcare_hero_subtitle({}, { locale })}
          </p>

          <div class="mt-10 flex flex-col items-center justify-center gap-4 sm:flex-row">
            <a
              href={getRelativeLocaleUrl(locale, 'register')}
              class="rounded-xl bg-cyan-600 px-8 py-4 text-base font-semibold text-white shadow-lg shadow-cyan-500/25 transition-all duration-200 hover:bg-cyan-700 focus:ring-2 focus:ring-cyan-500 focus:ring-offset-2"
            >
              {m.solutions_start_free_trial({}, { locale })}
            </a>
            <a
              href="https://book.capgo.app/demo/"
              class="rounded-xl border border-gray-600 px-8 py-4 text-base font-semibold text-gray-300 transition-all duration-200 hover:bg-gray-800 hover:text-white"
            >
              {m.solutions_talk_to_team({}, { locale })}
            </a>
          </div>

          <!-- Compliance badges -->
          <div class="mt-12 flex flex-wrap items-center justify-center gap-6 text-sm text-gray-400">
            <div class="flex items-center gap-2">
              <svg class="h-5 w-5 text-green-400" fill="currentColor" viewBox="0 0 20 20">
                <path
                  fill-rule="evenodd"
                  d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z"
                  clip-rule="evenodd"></path>
              </svg>
              {m.solutions_healthcare_badge_hipaa({}, { locale })}
            </div>
            <div class="flex items-center gap-2">
              <svg class="h-5 w-5 text-green-400" fill="currentColor" viewBox="0 0 20 20">
                <path
                  fill-rule="evenodd"
                  d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z"
                  clip-rule="evenodd"></path>
              </svg>
              {m.solutions_healthcare_badge_soc2({}, { locale })}
            </div>
            <div class="flex items-center gap-2">
              <svg class="h-5 w-5 text-green-400" fill="currentColor" viewBox="0 0 20 20">
                <path
                  fill-rule="evenodd"
                  d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z"
                  clip-rule="evenodd"></path>
              </svg>
              {m.solutions_healthcare_badge_e2e({}, { locale })}
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- The Healthcare Reality -->
    <section class="bg-gray-800 py-20">
      <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
        <div class="mx-auto mb-16 max-w-3xl text-center">
          <h2 class="mb-4 text-sm font-semibold tracking-wide text-red-400 uppercase">{m.solutions_healthcare_reality_label({}, { locale })}</h2>
          <h3 class="text-3xl font-bold text-white sm:text-4xl">{m.solutions_healthcare_reality_title({}, { locale })}</h3>
        </div>

        <div class="grid grid-cols-1 items-start gap-12 lg:grid-cols-2">
          <!-- Critical Scenario -->
          <div class="rounded-2xl border border-red-500/30 bg-gray-900 p-8">
            <h4 class="mb-6 flex items-center gap-2 text-xl font-bold text-red-400">
              <svg class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  stroke-width="2"
                  d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-3L13.732 4c-.77-1.333-2.694-1.333-3.464 0L3.34 16c-.77 1.333.192 3 1.732 3z"></path>
              </svg>
              {m.solutions_healthcare_scenario_title({}, { locale })}
            </h4>
            <div class="space-y-4 text-gray-300">
              <p>{m.solutions_healthcare_scenario_para1({}, { locale })}</p>
              <p>{m.solutions_healthcare_scenario_para2({}, { locale })}</p>
              <p class="font-medium text-red-300">{m.solutions_healthcare_scenario_para3({}, { locale })}</p>
            </div>
          </div>

          <!-- Pain Points -->
          <div class="space-y-4">
            <div class="rounded-xl border border-gray-700 bg-gray-900 p-6">
              <div class="flex items-start gap-4">
                <div class="flex h-10 w-10 shrink-0 items-center justify-center rounded-lg bg-red-500/20">
                  <svg class="h-5 w-5 text-red-400" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"></path>
                  </svg>
                </div>
                <div>
                  <h4 class="mb-1 text-lg font-bold text-white">{m.solutions_healthcare_pain1_title({}, { locale })}</h4>
                  <p class="text-sm text-gray-400">{m.solutions_healthcare_pain1_desc({}, { locale })}</p>
                </div>
              </div>
            </div>

            <div class="rounded-xl border border-gray-700 bg-gray-900 p-6">
              <div class="flex items-start gap-4">
                <div class="flex h-10 w-10 shrink-0 items-center justify-center rounded-lg bg-red-500/20">
                  <svg class="h-5 w-5 text-red-400" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                    <path
                      stroke-linecap="round"
                      stroke-linejoin="round"
                      stroke-width="2"
                      d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z"
                    ></path>
                  </svg>
                </div>
                <div>
                  <h4 class="mb-1 text-lg font-bold text-white">{m.solutions_healthcare_pain2_title({}, { locale })}</h4>
                  <p class="text-sm text-gray-400">{m.solutions_healthcare_pain2_desc({}, { locale })}</p>
                </div>
              </div>
            </div>

            <div class="rounded-xl border border-gray-700 bg-gray-900 p-6">
              <div class="flex items-start gap-4">
                <div class="flex h-10 w-10 shrink-0 items-center justify-center rounded-lg bg-red-500/20">
                  <svg class="h-5 w-5 text-red-400" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                    <path
                      stroke-linecap="round"
                      stroke-linejoin="round"
                      stroke-width="2"
                      d="M4.318 6.318a4.5 4.5 0 000 6.364L12 20.364l7.682-7.682a4.5 4.5 0 00-6.364-6.364L12 7.636l-1.318-1.318a4.5 4.5 0 00-6.364 0z"></path>
                  </svg>
                </div>
                <div>
                  <h4 class="mb-1 text-lg font-bold text-white">{m.solutions_healthcare_pain3_title({}, { locale })}</h4>
                  <p class="text-sm text-gray-400">{m.solutions_healthcare_pain3_desc({}, { locale })}</p>
                </div>
              </div>
            </div>

            <div class="rounded-xl border border-gray-700 bg-gray-900 p-6">
              <div class="flex items-start gap-4">
                <div class="flex h-10 w-10 shrink-0 items-center justify-center rounded-lg bg-red-500/20">
                  <svg class="h-5 w-5 text-red-400" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                    <path
                      stroke-linecap="round"
                      stroke-linejoin="round"
                      stroke-width="2"
                      d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2"></path>
                  </svg>
                </div>
                <div>
                  <h4 class="mb-1 text-lg font-bold text-white">{m.solutions_healthcare_pain4_title({}, { locale })}</h4>
                  <p class="text-sm text-gray-400">{m.solutions_healthcare_pain4_desc({}, { locale })}</p>
                </div>
              </div>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- How We Solve It -->
    <section class="bg-gray-900 py-20">
      <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
        <div class="mx-auto mb-16 max-w-3xl text-center">
          <h2 class="mb-4 text-sm font-semibold tracking-wide text-cyan-400 uppercase">{m.solutions_healthcare_solution_label({}, { locale })}</h2>
          <h3 class="text-3xl font-bold text-white sm:text-4xl">{m.solutions_healthcare_solution_title({}, { locale })}</h3>
          <p class="mt-4 text-xl text-gray-400">{m.solutions_healthcare_solution_subtitle({}, { locale })}</p>
        </div>

        <div class="grid grid-cols-1 gap-8 md:grid-cols-2">
          <!-- Solution 1: Critical Updates -->
          <div class="rounded-2xl border border-gray-700 bg-gray-800 p-8">
            <div class="mb-6 flex items-center gap-3">
              <div class="flex h-12 w-12 items-center justify-center rounded-lg bg-cyan-500/20">
                <svg class="h-6 w-6 text-cyan-400" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z"></path>
                </svg>
              </div>
              <h3 class="text-xl font-bold text-white">{m.solutions_healthcare_sol1_title({}, { locale })}</h3>
            </div>
            <p class="mb-6 text-gray-300">{m.solutions_healthcare_sol1_desc({}, { locale })}</p>
            <div class="rounded-xl bg-gray-900 p-4">
              <pre
                class="overflow-x-auto text-sm text-gray-300"><code><span class="text-gray-500"># Staged rollout with audit logging</span>
npx @capgo/cli bundle upload --channel internal-qa
<span class="text-cyan-400">✔</span> Bundle v2.4.1 uploaded

<span class="text-gray-500"># After QA approval, promote to production</span>
npx @capgo/cli channel set production --bundle 2.4.1

<span class="text-cyan-400">✔</span> Audit log: bundle promoted by admin@hospital.org
<span class="text-cyan-400">✔</span> All devices receive update on next app open</code></pre>
            </div>
          </div>

          <!-- Solution 2: HIPAA Compliant -->
          <div class="rounded-2xl border border-gray-700 bg-gray-800 p-8">
            <div class="mb-6 flex items-center gap-3">
              <div class="flex h-12 w-12 items-center justify-center rounded-lg bg-green-500/20">
                <svg class="h-6 w-6 text-green-400" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                  <path
                    stroke-linecap="round"
                    stroke-linejoin="round"
                    stroke-width="2"
                    d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z"
                  ></path>
                </svg>
              </div>
              <h3 class="text-xl font-bold text-white">{m.solutions_healthcare_sol2_title({}, { locale })}</h3>
            </div>
            <p class="mb-6 text-gray-300">{m.solutions_healthcare_sol2_desc({}, { locale })}</p>
            <ul class="space-y-2">
              <li class="flex items-center gap-2 text-gray-400">
                <svg class="h-5 w-5 text-green-400" fill="currentColor" viewBox="0 0 20 20">
                  <path
                    fill-rule="evenodd"
                    d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z"
                    clip-rule="evenodd"></path>
                </svg>
                {m.solutions_healthcare_sol2_point1({}, { locale })}
              </li>
              <li class="flex items-center gap-2 text-gray-400">
                <svg class="h-5 w-5 text-green-400" fill="currentColor" viewBox="0 0 20 20">
                  <path
                    fill-rule="evenodd"
                    d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z"
                    clip-rule="evenodd"></path>
                </svg>
                {m.solutions_healthcare_sol2_point2({}, { locale })}
              </li>
              <li class="flex items-center gap-2 text-gray-400">
                <svg class="h-5 w-5 text-green-400" fill="currentColor" viewBox="0 0 20 20">
                  <path
                    fill-rule="evenodd"
                    d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z"
                    clip-rule="evenodd"></path>
                </svg>
                {m.solutions_healthcare_sol2_point3({}, { locale })}
              </li>
            </ul>
          </div>

          <!-- Solution 3: End-to-End Encryption -->
          <div class="rounded-2xl border border-gray-700 bg-gray-800 p-8">
            <div class="mb-6 flex items-center gap-3">
              <div class="flex h-12 w-12 items-center justify-center rounded-lg bg-purple-500/20">
                <svg class="h-6 w-6 text-purple-400" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                  <path
                    stroke-linecap="round"
                    stroke-linejoin="round"
                    stroke-width="2"
                    d="M12 15v2m-6 4h12a2 2 0 002-2v-6a2 2 0 00-2-2H6a2 2 0 00-2 2v6a2 2 0 002 2zm10-10V7a4 4 0 00-8 0v4h8z"></path>
                </svg>
              </div>
              <h3 class="text-xl font-bold text-white">{m.solutions_healthcare_sol3_title({}, { locale })}</h3>
            </div>
            <p class="mb-6 text-gray-300">{m.solutions_healthcare_sol3_desc({}, { locale })}</p>
            <div class="rounded-xl bg-gray-900 p-4">
              <pre
                class="overflow-x-auto text-sm text-gray-300"><code><span class="text-gray-500"># Bundle encrypted before upload</span>
npx @capgo/cli bundle upload --key private.pem

<span class="text-purple-400">🔐</span> Bundle encrypted with your private key
<span class="text-purple-400">🔐</span> Only devices with matching key can decrypt
<span class="text-purple-400">🔐</span> Capgo servers never see unencrypted code</code></pre>
            </div>
          </div>

          <!-- Solution 4: Staged Rollouts -->
          <div class="rounded-2xl border border-gray-700 bg-gray-800 p-8">
            <div class="mb-6 flex items-center gap-3">
              <div class="flex h-12 w-12 items-center justify-center rounded-lg bg-amber-500/20">
                <svg class="h-6 w-6 text-amber-400" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                  <path
                    stroke-linecap="round"
                    stroke-linejoin="round"
                    stroke-width="2"
                    d="M9 19v-6a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2a2 2 0 002-2zm0 0V9a2 2 0 012-2h2a2 2 0 012 2v10m-6 0a2 2 0 002 2h2a2 2 0 002-2m0 0V5a2 2 0 012-2h2a2 2 0 012 2v14a2 2 0 01-2 2h-2a2 2 0 01-2-2z"
                  ></path>
                </svg>
              </div>
              <h3 class="text-xl font-bold text-white">{m.solutions_healthcare_sol4_title({}, { locale })}</h3>
            </div>
            <p class="mb-6 text-gray-300">{m.solutions_healthcare_sol4_desc({}, { locale })}</p>
            <div class="space-y-2 rounded-xl bg-gray-900 p-4">
              <div class="flex items-center justify-between rounded bg-gray-800 p-2">
                <span class="text-gray-400">{m.solutions_healthcare_sol4_step1({}, { locale })}</span>
                <span class="text-green-400">5%</span>
              </div>
              <div class="flex items-center justify-between rounded bg-gray-800 p-2">
                <span class="text-gray-400">{m.solutions_healthcare_sol4_step2({}, { locale })}</span>
                <span class="text-blue-400">25%</span>
              </div>
              <div class="flex items-center justify-between rounded bg-gray-800 p-2">
                <span class="text-gray-400">{m.solutions_healthcare_sol4_step3({}, { locale })}</span>
                <span class="text-cyan-400">100%</span>
              </div>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- Audit Trail & Traceability -->
    <section class="bg-gray-800 py-20">
      <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
        <div class="mx-auto mb-16 max-w-3xl text-center">
          <h2 class="mb-4 text-sm font-semibold tracking-wide text-cyan-400 uppercase">{m.solutions_healthcare_audit_label({}, { locale })}</h2>
          <h3 class="text-3xl font-bold text-white sm:text-4xl">{m.solutions_healthcare_audit_title({}, { locale })}</h3>
          <p class="mt-4 text-xl text-gray-400">{m.solutions_healthcare_audit_subtitle({}, { locale })}</p>
        </div>

        <div class="grid grid-cols-1 gap-8 lg:grid-cols-2">
          <!-- Commit Linking -->
          <div class="rounded-2xl border border-gray-700 bg-gray-900 p-8">
            <div class="mb-6 flex items-center gap-3">
              <div class="flex h-12 w-12 items-center justify-center rounded-lg bg-blue-500/20">
                <svg class="h-6 w-6 text-blue-400" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                  <path
                    stroke-linecap="round"
                    stroke-linejoin="round"
                    stroke-width="2"
                    d="M13.828 10.172a4 4 0 00-5.656 0l-4 4a4 4 0 105.656 5.656l1.102-1.101m-.758-4.899a4 4 0 005.656 0l4-4a4 4 0 00-5.656-5.656l-1.1 1.1"></path>
                </svg>
              </div>
              <h3 class="text-xl font-bold text-white">{m.solutions_healthcare_commit_title({}, { locale })}</h3>
            </div>
            <p class="mb-6 text-gray-300">{m.solutions_healthcare_commit_desc({}, { locale })}</p>
            <div class="rounded-xl bg-gray-800 p-4">
              <pre
                class="overflow-x-auto text-sm text-gray-300"><code><span class="text-gray-500"># Every bundle links to exact source code</span>
npx @capgo/cli bundle upload

<span class="text-blue-400">📎</span> Commit: <span class="text-green-400">a1b2c3d</span>
<span class="text-blue-400">📎</span> Branch: main
<span class="text-blue-400">📎</span> Author: dev@hospital.org
<span class="text-blue-400">📎</span> Message: "Fix dosage rounding for pediatric patients"

<span class="text-gray-500"># Auditors can trace any bundle to its source</span></code></pre>
            </div>
          </div>

          <!-- In-App Bundle Info -->
          <div class="rounded-2xl border border-gray-700 bg-gray-900 p-8">
            <div class="mb-6 flex items-center gap-3">
              <div class="flex h-12 w-12 items-center justify-center rounded-lg bg-green-500/20">
                <svg class="h-6 w-6 text-green-400" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                  <path
                    stroke-linecap="round"
                    stroke-linejoin="round"
                    stroke-width="2"
                    d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"></path>
                </svg>
              </div>
              <h3 class="text-xl font-bold text-white">{m.solutions_healthcare_inapp_title({}, { locale })}</h3>
            </div>
            <p class="mb-6 text-gray-300">{m.solutions_healthcare_inapp_desc({}, { locale })}</p>
            <div class="rounded-xl bg-gray-800 p-4">
              <pre
                class="overflow-x-auto text-sm text-gray-300"><code><span class="text-gray-500">// Show version info to clinical staff</span>
const info = await CapacitorUpdater.current()

<span class="text-gray-500">// Display in app settings</span>
console.log(info.bundle.version)  <span class="text-gray-500">// "2.4.1"</span>
console.log(info.bundle.message)  <span class="text-gray-500">// "HIPAA audit passed"</span>
console.log(info.bundle.url)      <span class="text-gray-500">// Link to commit</span></code></pre>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- Trust & Compliance -->
    <section class="bg-gray-900 py-20">
      <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
