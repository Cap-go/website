            </svg>
            <h4 class="mb-2 text-lg font-bold text-white">{m.solutions_healthcare_cert3_title({}, { locale })}</h4>
            <p class="text-sm text-gray-400">{m.solutions_healthcare_cert3_desc({}, { locale })}</p>
          </div>
        </div>
