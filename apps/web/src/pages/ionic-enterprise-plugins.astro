---
import ProductTestimonials from '@/components/ProductTestimonials.astro'
import { productTestimonials } from '@/config/productTestimonials'
import Layout from '@/layouts/Layout.astro'
import SolutionAppExample from '@/components/solutions/SolutionAppExample.astro'
import TeamAvatars from '@/components/TeamAvatars.astro'
import m from '@/copy/messages'
import { pluginCountLabel } from '@/config/plugins'
import { getRelativeLocaleUrl } from 'astro:i18n'
import { createServiceLdJson, createLdJsonGraph } from '@/lib/ldJson'

const locale = Astro.locals.locale
const brand = Astro.locals.runtimeConfig.public.brand

const title = `${brand} | ${m.solutions_ionic_plugins_title({}, { locale })}`
const description = m.solutions_ionic_plugins_description({}, { locale })
const supportUrl = getRelativeLocaleUrl(locale, 'premium-support')
const pluginsUrl = getRelativeLocaleUrl(locale, 'plugins')
const pluginDocsUrl = getRelativeLocaleUrl(locale, 'docs/plugins/')
const builderUrl = getRelativeLocaleUrl(locale, 'native-build')
const consultingUrl = getRelativeLocaleUrl(locale, 'consulting')
const talkToTeamUrl = 'https://book.capgo.app/enterprise-inquiry/'
const serviceLdJson = createServiceLdJson(Astro.locals.runtimeConfig.public, {
  name: title,
  description: description,
  url: Astro.url.href,
  serviceType: 'Software Development Service',
  areaServed: ['Worldwide'],
})

const ldJSON = createLdJsonGraph(Astro.locals.runtimeConfig.public, serviceLdJson, {
  includeOrganization: true,
})

const content = { title, description, image: `${Astro.locals.runtimeConfig.public.baseUrl}/social/capgo-ionic-plugins.png`, ldJSON }
---

<Layout content={content}>
  <div>
    <!-- Hero Section -->
    <section class="relative overflow-hidden py-16 sm:py-20 lg:py-28">
      <div class="pointer-events-none absolute inset-0 overflow-hidden">
        <div class="absolute top-0 left-1/2 h-full w-full max-w-6xl -translate-x-1/2">
          <div class="absolute top-1/4 left-1/4 h-96 w-96 rounded-full bg-emerald-500/10 blur-3xl"></div>
          <div class="absolute right-1/4 bottom-1/4 h-96 w-96 rounded-full bg-cyan-500/10 blur-3xl"></div>
        </div>
      </div>

      <div class="relative mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
        <div class="mx-auto max-w-4xl text-center">
          <p class="inline-flex rounded-full border border-emerald-400/40 bg-emerald-500/10 px-4 py-2 text-sm font-medium text-emerald-100">
            {m.solutions_ionic_plugins_badge({}, { locale })}
          </p>
          <h1 class="mt-6 text-4xl leading-tight font-bold text-balance text-white sm:text-5xl lg:text-6xl">
            {m.solutions_ionic_plugins_hero_title({}, { locale })}
          </h1>
          <p class="mx-auto mt-6 max-w-3xl text-lg leading-relaxed text-pretty text-gray-300 sm:text-xl">
            {m.solutions_ionic_plugins_hero_subtitle({}, { locale })}
          </p>

          <div class="mt-10 flex flex-col items-stretch justify-center gap-3 sm:flex-row sm:items-center">
            <a
              href={getRelativeLocaleUrl(locale, 'register')}
              class="rounded-xl bg-emerald-600 px-8 py-4 text-base font-semibold text-white shadow-lg shadow-emerald-500/20 transition-all duration-200 hover:bg-emerald-700 focus:ring-2 focus:ring-emerald-500 focus:ring-offset-2"
            >
              {m.solutions_get_started({}, { locale })}
            </a>
            <a
              href={talkToTeamUrl}
              target="_blank"
              rel="noopener noreferrer"
              aria-label={m.enterprise_talk_to_team({}, { locale })}
              class="inline-flex items-center justify-center gap-2 rounded-xl border border-emerald-400/50 bg-emerald-500/10 px-8 py-4 text-base font-semibold text-emerald-100 transition-all duration-200 hover:bg-emerald-500/20 focus:ring-2 focus:ring-emerald-500 focus:ring-offset-2"
            >
              <TeamAvatars border="border-gray-950" />
              <span>{m.enterprise_talk_to_team({}, { locale })}</span>
            </a>
          </div>
          <p class="mt-6">
            <a
              href={getRelativeLocaleUrl(locale, 'docs/upgrade/from-ionic-secure-storage/')}
              class="text-sm font-semibold text-emerald-300 transition-colors hover:text-emerald-200"
            >
              {m.solutions_view_docs({}, { locale })} →
            </a>
          </p>
        </div>
      </div>
    </section>

    <!-- Value Proposition -->
    <section class="bg-gray-900 py-16 sm:py-20">
      <div class="mx-auto max-w-6xl px-4 sm:px-6 lg:px-8">
        <div class="max-w-3xl">
          <h2 class="text-3xl font-bold text-white sm:text-4xl">Why Capgo is different from an enterprise plugin contract</h2>
          <p class="mt-4 text-lg leading-8 text-gray-300">
            Ionic Enterprise plugins are sold as a commercial package. Capgo takes a different path: the plugins are open source, the migration guides are public, and paid help is
            there when your team needs guaranteed response times, expert migration work, or native build capacity.
          </p>
        </div>

        <div class="mt-10 grid gap-6 md:grid-cols-2 lg:grid-cols-4">
          <div class="rounded-2xl border border-gray-700 bg-gray-800/60 p-6">
            <h3 class="text-lg font-semibold text-white">Open source first</h3>
            <p class="mt-3 text-sm leading-6 text-gray-300">
              Capgo-maintained plugins are visible, auditable, and forkable. You can inspect the native code, patch it, or keep control if your security team asks what ships in the
              app.
            </p>
          </div>
          <div class="rounded-2xl border border-gray-700 bg-gray-800/60 p-6">
            <h3 class="text-lg font-semibold text-white">Use before you pay</h3>
            <p class="mt-3 text-sm leading-6 text-gray-300">
              You do not need a paid enterprise contract just to try the plugins. Pay when it is critical: migration help, guaranteed support, governance, or business-critical
              delivery.
            </p>
          </div>
          <div class="rounded-2xl border border-gray-700 bg-gray-800/60 p-6">
            <h3 class="text-lg font-semibold text-white">A broader Capacitor stack</h3>
            <p class="mt-3 text-sm leading-6 text-gray-300">
              The directory covers {pluginCountLabel} plugins across auth, storage, payments, MDM, analytics, device APIs, native UI, and live updates. Start from the exact native capability
              you need, not a bundle.
            </p>
          </div>
          <div class="rounded-2xl border border-gray-700 bg-gray-800/60 p-6">
            <h3 class="text-lg font-semibold text-white">Builder included in the path</h3>
            <p class="mt-3 text-sm leading-6 text-gray-300">
              When a migration touches native projects, Capgo Builder can produce iOS and Android builds with logs, signing, and store-ready artifacts instead of leaving CI work to
              your team.
            </p>
          </div>
        </div>

        <div class="mt-12 overflow-x-auto rounded-2xl border border-gray-700 bg-gray-950/50">
          <table class="w-full min-w-[720px] text-left text-sm text-gray-300">
            <thead class="bg-gray-950/80 text-gray-400">
              <tr>
                <th class="px-6 py-4 font-semibold">Decision</th>
                <th class="px-6 py-4 font-semibold">Capgo</th>
                <th class="px-6 py-4 font-semibold">Typical Ionic enterprise route</th>
              </tr>
            </thead>
            <tbody class="divide-y divide-gray-700">
              <tr>
                <td class="px-6 py-4 font-medium text-gray-100">Source code and auditability</td>
                <td class="px-6 py-4">Open source plugin code, public docs, and the option to fork or self-maintain if your policy requires it.</td>
                <td class="px-6 py-4">Commercial packages where access and fixes depend on the vendor relationship.</td>
              </tr>
              <tr>
                <td class="px-6 py-4 font-medium text-gray-100">When you pay</td>
                <td class="px-6 py-4">Use the plugin stack first. Pay for support, migration, enterprise guarantees, or native build capacity when those become important.</td>
                <td class="px-6 py-4">Enterprise value is commonly tied to a paid contract before teams can standardize on the package.</td>
              </tr>
              <tr>
                <td class="px-6 py-4 font-medium text-gray-100">Native delivery</td>
                <td class="px-6 py-4">Capgo pairs plugins with live updates and Builder, so teams can migrate code and still produce signed native builds.</td>
                <td class="px-6 py-4">Plugin licensing and CI/build delivery are often separate decisions.</td>
              </tr>
              <tr>
                <td class="px-6 py-4 font-medium text-gray-100">App composition products</td>
                <td class="px-6 py-4"
                  >Capgo does not ship an Ionic Portals or App Federation replacement yet. We focus on plugins, live updates, native builds, and custom native gaps.</td
                >
                <td class="px-6 py-4">If your main requirement is embedding multiple mini-apps in one native shell, keep evaluating dedicated portal or federation tools.</td>
              </tr>
            </tbody>
          </table>
        </div>

        <div class="mt-8 flex flex-col gap-4 text-sm text-gray-300 sm:flex-row sm:items-center">
          <a href={pluginsUrl} class="font-semibold text-emerald-300 hover:underline">Browse the plugin directory</a>
          <a href={pluginDocsUrl} class="font-semibold text-emerald-300 hover:underline">Read plugin docs</a>
          <a href={builderUrl} class="font-semibold text-emerald-300 hover:underline">See Capgo Builder</a>
        </div>
      </div>
    </section>

    <!-- Plugin Table -->
    <section id="plugin-migration" class="bg-gray-800 py-16 sm:py-20">
      <div class="mx-auto max-w-6xl px-4 sm:px-6 lg:px-8">
        <div class="max-w-3xl">
          <h2 class="text-3xl font-bold text-white sm:text-4xl">
            {m.solutions_ionic_plugins_section_title({}, { locale })}
          </h2>
          <p class="mt-4 text-lg text-gray-300">
            {m.solutions_ionic_plugins_section_desc({}, { locale })}
          </p>
        </div>

        <div class="mt-10 overflow-x-auto rounded-2xl border border-gray-700 bg-gray-900/50">
          <table class="w-full min-w-[720px] text-left text-sm text-gray-300">
            <thead class="bg-gray-900/70 text-gray-400">
              <tr>
                <th class="px-6 py-4 font-semibold">{m.appflow_plugins_col_ionic({}, { locale })}</th>
                <th class="px-6 py-4 font-semibold">{m.appflow_plugins_col_capgo({}, { locale })}</th>
                <th class="px-6 py-4 font-semibold">{m.appflow_plugins_col_guide({}, { locale })}</th>
              </tr>
            </thead>
            <tbody class="divide-y divide-gray-700">
              <tr class="transition hover:bg-gray-800/60">
                <td class="px-6 py-4 font-medium text-gray-100">Ionic Secure Storage</td>
                <td class="px-6 py-4">
                  <a href={getRelativeLocaleUrl(locale, 'docs/plugins/fast-sql/')} class="text-emerald-300 hover:underline"> Fast SQL </a>
                  <span class="mx-2 text-gray-500">{m.appflow_plugins_or({}, { locale })}</span>
                  <a href={getRelativeLocaleUrl(locale, 'docs/plugins/data-storage-sqlite/')} class="text-emerald-300 hover:underline"> Data Storage SQLite </a>
                </td>
                <td class="px-6 py-4">
                  <a href={getRelativeLocaleUrl(locale, 'docs/upgrade/from-ionic-secure-storage/')} class="text-blue-300 hover:underline">
                    {m.appflow_plugins_link_text({}, { locale })}
                  </a>
                </td>
              </tr>
              <tr class="transition hover:bg-gray-800/60">
                <td class="px-6 py-4 font-medium text-gray-100">Ionic Auth Connect</td>
                <td class="px-6 py-4">
                  <a href={getRelativeLocaleUrl(locale, 'docs/plugins/social-login/')} class="text-emerald-300 hover:underline"> Social Login </a>
                </td>
                <td class="px-6 py-4">
                  <a href={getRelativeLocaleUrl(locale, 'docs/upgrade/from-ionic-auth-connect/')} class="text-blue-300 hover:underline">
                    {m.appflow_plugins_link_text({}, { locale })}
                  </a>
                </td>
              </tr>
              <tr class="transition hover:bg-gray-800/60">
                <td class="px-6 py-4 font-medium text-gray-100">Ionic Identity Vault</td>
                <td class="px-6 py-4">
                  <a href={getRelativeLocaleUrl(locale, 'docs/plugins/native-biometric/')} class="text-emerald-300 hover:underline"> Native Biometric </a>
                  <span class="mx-2 text-gray-500">+</span>
                  <a href={getRelativeLocaleUrl(locale, 'docs/plugins/fast-sql/')} class="text-emerald-300 hover:underline"> Fast SQL </a>
                  <span class="mx-2 text-gray-500">{m.appflow_plugins_or({}, { locale })}</span>
                  <a href={getRelativeLocaleUrl(locale, 'docs/plugins/data-storage-sqlite/')} class="text-emerald-300 hover:underline"> Data Storage SQLite </a>
                </td>
                <td class="px-6 py-4">
                  <a href={getRelativeLocaleUrl(locale, 'docs/upgrade/from-ionic-identity-vault/')} class="text-blue-300 hover:underline">
                    {m.appflow_plugins_link_text({}, { locale })}
                  </a>
                </td>
              </tr>
              <tr class="transition hover:bg-gray-800/60">
                <td class="px-6 py-4 font-medium text-gray-100">Ionic Intune</td>
                <td class="px-6 py-4">
                  <a href={getRelativeLocaleUrl(locale, 'docs/plugins/intune/')} class="text-emerald-300 hover:underline"> Intune </a>
                </td>
                <td class="px-6 py-4">
                  <a href={getRelativeLocaleUrl(locale, 'docs/plugins/intune/getting-started/')} class="text-blue-300 hover:underline">
                    {m.appflow_plugins_link_text({}, { locale })}
                  </a>
                </td>
              </tr>
              <tr class="transition hover:bg-gray-800/60">
                <td class="px-6 py-4 font-medium text-gray-100">Ionic Payments</td>
                <td class="px-6 py-4">
                  <a href={getRelativeLocaleUrl(locale, 'docs/plugins/pay/')} class="text-emerald-300 hover:underline"> @capgo/capacitor-pay </a>
                </td>
                <td class="px-6 py-4">
                  <a href={getRelativeLocaleUrl(locale, 'docs/plugins/pay/getting-started/')} class="text-blue-300 hover:underline">
                    {m.appflow_plugins_link_text({}, { locale })}
                  </a>
                </td>
              </tr>
              <tr class="transition hover:bg-gray-800/60">
                <td class="px-6 py-4 font-medium text-gray-100">Ionic Zebra Scanner</td>
                <td class="px-6 py-4">
                  <a href={getRelativeLocaleUrl(locale, 'docs/plugins/zebra-datawedge/')} class="text-emerald-300 hover:underline"> Zebra DataWedge </a>
                </td>
                <td class="px-6 py-4">
                  <a href={getRelativeLocaleUrl(locale, 'docs/plugins/zebra-datawedge/')} class="text-blue-300 hover:underline">
                    {m.appflow_plugins_link_text({}, { locale })}
                  </a>
                </td>
              </tr>
              <tr class="transition hover:bg-gray-800/60">
                <td class="px-6 py-4 font-medium text-gray-100">@ionic-enterprise/ssl-pinning</td>
                <td class="px-6 py-4">
                  <a href="https://github.com/mchl18/Capacitor-SSL-Pinning" class="text-emerald-300 hover:underline" target="_blank" rel="noreferrer"> capacitor-ssl-pinning </a>
                </td>
                <td class="px-6 py-4">
                  <a href="https://github.com/mchl18/Capacitor-SSL-Pinning" class="text-blue-300 hover:underline" target="_blank" rel="noreferrer">
                    {m.appflow_plugins_link_text({}, { locale })}
                  </a>
                </td>
              </tr>
            </tbody>
          </table>
        </div>
      </div>
    </section>

    <!-- Migration Steps -->
    <section class="bg-gray-900 py-16 sm:py-20">
      <div class="mx-auto max-w-6xl px-4 sm:px-6 lg:px-8">
        <h2 class="text-3xl font-bold text-white sm:text-4xl">
          {m.solutions_ionic_plugins_steps_title({}, { locale })}
        </h2>
        <div class="mt-10 grid gap-6 md:grid-cols-3">
          <div class="rounded-2xl border border-gray-700 bg-gray-800/60 p-6">
            <div class="mb-4 flex h-10 w-10 items-center justify-center rounded-full bg-emerald-500/20 font-semibold text-emerald-300">1</div>
            <p class="text-gray-300">{m.solutions_ionic_plugins_step1({}, { locale })}</p>
          </div>
          <div class="rounded-2xl border border-gray-700 bg-gray-800/60 p-6">
            <div class="mb-4 flex h-10 w-10 items-center justify-center rounded-full bg-emerald-500/20 font-semibold text-emerald-300">2</div>
            <p class="text-gray-300">{m.solutions_ionic_plugins_step2({}, { locale })}</p>
          </div>
          <div class="rounded-2xl border border-gray-700 bg-gray-800/60 p-6">
            <div class="mb-4 flex h-10 w-10 items-center justify-center rounded-full bg-emerald-500/20 font-semibold text-emerald-300">3</div>
            <p class="text-gray-300">{m.solutions_ionic_plugins_step3({}, { locale })}</p>
          </div>
        </div>
      </div>
    </section>


    <!-- Coverage Boundaries -->
    <section class="bg-gray-800 py-16 sm:py-20">
      <div class="mx-auto max-w-6xl px-4 sm:px-6 lg:px-8">
        <div class="grid gap-8 lg:grid-cols-[0.95fr_1.45fr] lg:items-start">
          <div>
            <p class="text-base font-medium text-emerald-300">Where Capgo fits</p>
            <h2 class="mt-3 max-w-[12ch] text-3xl font-semibold tracking-tight text-balance text-white sm:text-4xl">What Capgo replaces today</h2>
            <p class="mt-5 max-w-[54ch] text-base leading-7 text-pretty text-gray-300 sm:text-lg sm:leading-8">
              Capgo is not trying to clone every Ionic enterprise product. It is the practical path when you need open source native plugins, live updates, native builds, and
              direct help for app-specific native gaps.
            </p>
          </div>

          <div class="overflow-hidden rounded-2xl border border-gray-700 bg-gray-800/40 lg:flex">
            <div class="border-b border-gray-700/80 bg-emerald-500/10 p-6 sm:p-8 lg:w-1/2 lg:border-r lg:border-b-0">
              <h3 class="text-xl font-semibold tracking-tight text-white">Strong fit today</h3>
              <dl class="mt-6 space-y-5 text-sm leading-6 text-gray-200 sm:text-base sm:leading-7">
                <div>
                  <dt class="font-semibold text-white">Enterprise plugin migration</dt>
                  <dd class="mt-1 text-gray-300">Secure storage, biometrics, social login, Intune, payments, Zebra scanning, SSL pinning, and related Capacitor-native needs.</dd>
                </div>
                <div>
                  <dt class="font-semibold text-white">Broader plugin coverage</dt>
                  <dd class="mt-1 text-gray-300">{pluginCountLabel} plugins across mobile capabilities, with public docs and package-level migration paths.</dd>
                </div>
                <div>
                  <dt class="font-semibold text-white">Native delivery</dt>
                  <dd class="mt-1 text-gray-300">
                    Use <a href={builderUrl} class="text-emerald-200 hover:underline">Capgo Builder</a> when native project changes need signed iOS and Android builds.
                  </dd>
                </div>
                <div>
                  <dt class="font-semibold text-white">Critical support</dt>
                  <dd class="mt-1 text-gray-300">
                    Keep the open source path for normal use, then add <a href={supportUrl} class="text-emerald-200 hover:underline">paid support</a> or
                    <a href={consultingUrl} class="text-emerald-200 hover:underline">migration services</a> when the business risk justifies it.
                  </dd>
                </div>
              </dl>
            </div>

            <div class="p-6 sm:p-8 lg:w-1/2">
              <h3 class="text-xl font-semibold tracking-tight text-white">Not a full Ionic platform clone</h3>
              <dl class="mt-6 space-y-5 text-sm leading-6 text-gray-300 sm:text-base sm:leading-7">
                <div>
                  <dt class="font-semibold text-white">No Ionic Portals replacement yet</dt>
                  <dd class="mt-1">Capgo does not yet productize embedded mini-app orchestration inside a host native app.</dd>
                </div>
                <div>
                  <dt class="font-semibold text-white">No App Federation product yet</dt>
                  <dd class="mt-1">If your priority is federated app composition, keep that evaluation separate from plugin migration.</dd>
                </div>
                <div>
                  <dt class="font-semibold text-white">No forced bundle</dt>
                  <dd class="mt-1">Capgo is strongest when you choose the plugin, live update, build, or support layer you need instead of buying a large suite.</dd>
                </div>
                <div>
                  <dt class="font-semibold text-white">Custom gaps are handled directly</dt>
                  <dd class="mt-1">If a feature is missing, we would rather scope the native work than imply it already exists.</dd>
                </div>
              </dl>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- Open Source + Optional Support -->
    <section class="bg-gray-900 py-16 sm:py-20">
      <div class="mx-auto max-w-6xl px-4 sm:px-6 lg:px-8">
        <div class="grid gap-8 lg:grid-cols-[1.1fr_0.9fr] lg:items-start">
          <div>
            <h2 class="text-3xl font-bold text-white sm:text-4xl">
              {m.appflow_support_open_title({}, { locale })}
            </h2>
            <p class="mt-4 text-lg leading-8 text-gray-200" set:html={m.appflow_support_open_desc({ url: supportUrl }, { locale })} />
            <p class="mt-4 text-gray-300">
              That means a prototype, internal tool, or noncritical plugin migration can start without procurement. If the feature becomes production critical, support becomes a
              risk-control decision instead of a license tax.
            </p>
          </div>

          <div class="rounded-2xl border border-emerald-500/30 bg-gray-900/60 p-6">
            <h3 class="text-xl font-semibold text-white">What paid help is for</h3>
            <ul class="mt-5 space-y-3 text-sm leading-6 text-gray-300">
              <li>Guaranteed response expectations when a native capability blocks a release.</li>
              <li>Migration review for storage, authentication, biometric, MDM, or payment flows.</li>
              <li>Custom native work through <a href={consultingUrl} class="text-emerald-300 hover:underline">Capgo Consulting</a> when a gap is specific to your app.</li>
              <li>Builder setup help for signing, build logs, and repeatable iOS or Android release artifacts.</li>
            </ul>
          </div>
        </div>
      </div>
    </section>

    <SolutionAppExample solution="ionic-enterprise-plugins" />

    <ProductTestimonials
      eyebrow="Plugin migration proof"
      title="Teams replacing plugin gaps need a release path that keeps working"
      description="Short reviews from developers using Capgo plugins and updater workflows in production apps."
      testimonials={productTestimonials.ionicEnterprisePlugins}
    />

    <!-- Next step -->
    <section class="bg-gray-900 py-16 sm:py-20">
      <div class="mx-auto max-w-6xl px-4 sm:px-6 lg:px-8">
        <div class="grid gap-10 lg:grid-cols-[0.8fr_1.2fr] lg:items-start">
          <div>
            <p class="text-sm font-medium text-emerald-300">Next step</p>
            <h2 class="mt-3 max-w-[14ch] text-3xl font-semibold tracking-tight text-balance text-white sm:text-4xl">Pick the migration path</h2>
            <p class="mt-5 max-w-[52ch] text-sm leading-6 text-pretty text-gray-300 sm:text-base sm:leading-7">
              Start with the plugin replacement, then add Builder or hands-on support only when native delivery becomes the bottleneck.
            </p>
          </div>

          <div class="divide-y divide-gray-700 overflow-hidden rounded-2xl border border-gray-700 bg-gray-800/40">
            <a href={pluginsUrl} class="block p-6 transition hover:bg-gray-800 sm:p-7">
              <div class="flex flex-col gap-3 sm:flex-row sm:items-start sm:justify-between">
                <div>
                  <h3 class="text-lg font-semibold tracking-tight text-white sm:text-xl">Find the replacement plugin</h3>
                  <p class="mt-2 text-sm leading-6 text-pretty text-gray-300">
                    Search the open source Capgo plugin directory and map each Ionic dependency to a maintained Capacitor package.
                  </p>
                </div>
                <span class="shrink-0 text-sm font-medium text-emerald-300">Browse plugins</span>
              </div>
            </a>
            <a href={pluginDocsUrl} class="block p-6 transition hover:bg-gray-800 sm:p-7">
              <div class="flex flex-col gap-3 sm:flex-row sm:items-start sm:justify-between">
                <div>
                  <h3 class="text-lg font-semibold tracking-tight text-white sm:text-xl">Install and migrate safely</h3>
                  <p class="mt-2 text-sm leading-6 text-pretty text-gray-300">
                    Use the docs to update native projects, migrate stored data, and remove closed plugin dependencies without guessing.
                  </p>
                </div>
                <span class="shrink-0 text-sm font-medium text-emerald-300">Open docs</span>
              </div>
            </a>
            <a href={builderUrl} class="block p-6 transition hover:bg-gray-800 sm:p-7">
              <div class="flex flex-col gap-3 sm:flex-row sm:items-start sm:justify-between">
                <div>
                  <h3 class="text-lg font-semibold tracking-tight text-white sm:text-xl">Build the native release</h3>
                  <p class="mt-2 text-sm leading-6 text-pretty text-gray-300">
                    When the migration changes iOS or Android code, use Capgo Builder for signed artifacts, logs, and repeatable delivery.
                  </p>
                </div>
                <span class="shrink-0 text-sm font-medium text-emerald-300">See Builder</span>
              </div>
            </a>
            <a href={consultingUrl} class="block p-6 transition hover:bg-gray-800 sm:p-7">
              <div class="flex flex-col gap-3 sm:flex-row sm:items-start sm:justify-between">
                <div>
                  <h3 class="text-lg font-semibold tracking-tight text-white sm:text-xl">Bring Capgo in when it is critical</h3>
                  <p class="mt-2 text-sm leading-6 text-pretty text-gray-300">
                    Get help for authentication, storage, MDM, payments, or custom native gaps that need production-grade review.
                  </p>
                </div>
                <span class="shrink-0 text-sm font-medium text-emerald-300">Plan migration</span>
              </div>
            </a>
          </div>
        </div>
      </div>
    </section>

    <!-- CTA -->
    <section class="bg-gray-800 py-16 sm:py-20">
      <div class="mx-auto max-w-6xl px-4 sm:px-6 lg:px-8">
        <div class="rounded-3xl border border-emerald-500/30 bg-emerald-500/10 p-10 text-center">
          <h2 class="text-3xl font-bold text-white sm:text-4xl">
            {m.solutions_ionic_plugins_cta_title({}, { locale })}
          </h2>
          <p class="mt-4 text-lg text-emerald-100">
            {m.solutions_ionic_plugins_cta_subtitle({}, { locale })}
          </p>
          <div class="mt-8 flex flex-col items-center justify-center gap-4 sm:flex-row">
            <a
              href={getRelativeLocaleUrl(locale, 'register')}
              class="rounded-xl bg-emerald-600 px-8 py-4 text-base font-semibold text-white transition-all duration-200 hover:bg-emerald-700"
            >
              {m.solutions_start_free_trial({}, { locale })}
            </a>
            <a
              href={talkToTeamUrl}
              target="_blank"
              rel="noopener noreferrer"
              aria-label={m.enterprise_talk_to_team({}, { locale })}
              class="inline-flex items-center justify-center gap-2 rounded-xl border border-emerald-400/50 px-8 py-4 text-base font-semibold text-gray-200 transition-all duration-200 hover:bg-emerald-500/10"
            >
              <TeamAvatars border="border-emerald-950" />
              <span>{m.enterprise_talk_to_team({}, { locale })}</span>
            </a>
          </div>
        </div>
      </div>
    </section>
  </div>
</Layout>
</Layout>
