</Layout>

<script>
  function fallbackCopyText(value: string): void {
    const helper = document.createElement('textarea')
    helper.value = value
    helper.setAttribute('readonly', 'true')
    helper.style.position = 'absolute'
    helper.style.opacity = '0'
    document.body.append(helper)
    helper.select()

    const legacyCopy = Reflect.get(document, 'execCommand')
    const copied = typeof legacyCopy === 'function' ? legacyCopy.call(document, 'copy') : false

    helper.remove()
    if (!copied) {
      throw new Error('Copy failed')
    }
  }

  async function copySkillsText(value: string): Promise<void> {
    if (!navigator.clipboard?.writeText) {
      fallbackCopyText(value)
      return
    }

    try {
      await navigator.clipboard.writeText(value)
    } catch {
      fallbackCopyText(value)
    }
  }

  document.querySelectorAll<HTMLButtonElement>('[data-skills-copy]').forEach((button) => {
    let resetTimer: number | undefined

    button.addEventListener('click', async () => {
      const value = button.getAttribute('data-skills-copy')
      if (!value) return

      const label = button.querySelector<HTMLElement>('[data-skills-copy-label]')
      const originalText = label?.textContent || 'Copy'

      try {
        await copySkillsText(value)
        if (label) label.textContent = 'Copied'
      } catch {
        if (label) label.textContent = 'Copy failed'
      }

      if (resetTimer) window.clearTimeout(resetTimer)
      resetTimer = window.setTimeout(() => {
        if (label) label.textContent = originalText
      }, 1600)
    })
  })
</script>
