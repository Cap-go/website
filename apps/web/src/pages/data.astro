---
import Layout from '@/layouts/Layout.astro'
import { createLdJsonGraph, createWebPageLdJson } from '@/lib/ldJson'

const config = Astro.locals.runtimeConfig
const title = 'Capgo delivery data | Live Update reliability'
const description = 'Anonymous, percentage-based reliability data for Capgo Live Updates, grouped by device and UTC day.'
const content = {
  title,
  description,
  image: `${config.public.baseUrl}/social/capgo-live-update.png`,
  ldJSON: createLdJsonGraph(config.public, createWebPageLdJson(config.public, { name: title, description, url: Astro.url.href }), { includeOrganization: true }),
}
---

<Layout content={content}>
  <main class="data-page" data-metrics-endpoint={`${config.public.baseApiUrl}/private/website_stats/live_updates`} aria-busy="true">
    <section class="data-hero">
      <div class="data-shell">
        <p class="data-eyebrow"><span aria-hidden="true"></span> Public aggregate data</p>
        <h1>Live Update reliability, measured clearly.</h1>
        <p class="data-summary">A privacy-safe 30-day view of install outcomes. Every result is grouped by app, device, and UTC day before percentages are calculated.</p>
        <p class="data-updated" data-updated aria-live="polite"><span class="data-spinner" aria-hidden="true"></span> Loading current reliability data…</p>
      </div>
    </section>

    <section class="data-section" aria-labelledby="reliability-title">
      <div class="data-shell">
        <div class="data-heading">
          <div>
            <p class="data-eyebrow">Install reliability</p>
            <h2 id="reliability-title">Daily success rate</h2>
          </div>
          <p>Counted per app, device, and UTC day. If that combination eventually installs successfully, it counts as success.</p>
        </div>

        <div class="data-kpis" aria-label="Reliability summary">
          <div><p>30-day success rate</p><strong data-kpi="success-rate">—</strong></div>
          <div><p>Reporting window</p><strong>30 days</strong></div>
          <div><p>Counting unit</p><strong>Device / day</strong></div>
        </div>

        <div class="data-loading data-chart-skeleton" aria-hidden="true">
          <div></div><div></div><div></div><div></div><div></div><div></div><div></div><div></div><div></div><div></div><div></div><div></div>
        </div>
        <div class="data-chart" data-daily-chart aria-label="Daily install success rate chart" hidden>
          <div class="data-chart-scale" aria-hidden="true"><span>100%</span><span>50%</span><span>0%</span></div>
          <div class="data-bars" data-daily-bars role="list" aria-label="Daily install success rates"></div>
          <div class="data-axis"><span data-daily-start></span><span data-daily-end></span></div>
        </div>
        <p class="data-empty" data-daily-empty aria-live="polite" hidden></p>
      </div>
    </section>

    <section class="data-section data-section-muted" aria-labelledby="platforms-title">
      <div class="data-shell data-split">
        <div>
          <p class="data-eyebrow">Platform mix</p>
          <h2 id="platforms-title">Share of active devices</h2>
          <p class="data-copy">Relative share of active devices across iOS, Android, and Electron.</p>
        </div>
        <dl class="data-platforms">
          {
            (['ios', 'android', 'electron'] as const).map((platform) => (
              <div data-platform={platform}>
                <dt>{platform === 'ios' ? 'iOS' : platform[0].toUpperCase() + platform.slice(1)}</dt>
                <dd data-platform-share>—</dd>
                <div aria-hidden="true">
                  <span data-platform-bar />
                </div>
              </div>
            ))
          }
        </dl>
      </div>
    </section>

    <section class="data-section" aria-labelledby="failures-title">
      <div class="data-shell data-split">
        <div>
          <p class="data-eyebrow">Failure distribution</p>
          <h2 id="failures-title">Top failure reasons</h2>
          <p class="data-copy">Each reason is deduplicated by app, device, and day.</p>
        </div>
        <ol class="data-failures" data-failures aria-live="polite">
          <li class="data-loading data-list-skeleton" aria-hidden="true"><span></span><div></div><b></b></li>
          <li class="data-loading data-list-skeleton" aria-hidden="true"><span></span><div></div><b></b></li>
          <li class="data-loading data-list-skeleton" aria-hidden="true"><span></span><div></div><b></b></li>
        </ol>
      </div>
    </section>

    <section class="data-section data-section-muted" aria-labelledby="versions-title">
      <div class="data-shell">
        <div class="data-heading">
          <div><p class="data-eyebrow">Adoption context</p><h2 id="versions-title">Leading updater version</h2></div>
          <p>The most-used updater version each day, shown as a share of active devices.</p>
        </div>
        <div class="data-loading data-chart-skeleton data-version-skeleton" aria-hidden="true">
          <div></div><div></div><div></div><div></div><div></div><div></div><div></div><div></div>
        </div>
        <div class="data-version-chart" data-version-chart role="list" aria-label="Leading updater version share by day" hidden></div>
        <p class="data-empty" data-version-empty aria-live="polite" hidden></p>
        <p class="data-sr-only" data-chart-status role="status" aria-live="polite"></p>
      </div>
    </section>
  </main>
</Layout>

<script>
  type DailyMetric = { date: string; success_rate: number }
  type FailureMetric = { reason: string; share: number }
  type VersionMetric = { date: string; version: string; share: number }
  type Metrics = {
    updated_at: string
    success_rate: number
    daily: DailyMetric[]
    failures: FailureMetric[]
    platforms: { ios: number; android: number; electron: number }
    updater_versions: VersionMetric[]
  }

  const page = document.querySelector<HTMLElement>('[data-metrics-endpoint]')

  if (page) {
    const endpoint = page.dataset.metricsEndpoint
    const updated = page.querySelector<HTMLElement>('[data-updated]')
    const successRateKpi = page.querySelector<HTMLElement>('[data-kpi="success-rate"]')
    const dailyChart = page.querySelector<HTMLElement>('[data-daily-chart]')
    const dailyBars = page.querySelector<HTMLElement>('[data-daily-bars]')
    const dailyStart = page.querySelector<HTMLElement>('[data-daily-start]')
    const dailyEnd = page.querySelector<HTMLElement>('[data-daily-end]')
    const dailyEmpty = page.querySelector<HTMLElement>('[data-daily-empty]')
    const failuresList = page.querySelector<HTMLOListElement>('[data-failures]')
    const versionChart = page.querySelector<HTMLElement>('[data-version-chart]')
    const versionEmpty = page.querySelector<HTMLElement>('[data-version-empty]')
    const chartStatus = page.querySelector<HTMLElement>('[data-chart-status]')
    const styleScopeAttributes = page.getAttributeNames().filter((attribute) => attribute.startsWith('data-astro-cid-'))

    function createScopedElement<K extends keyof HTMLElementTagNameMap>(tagName: K) {
      const element = document.createElement(tagName)
      for (const attribute of styleScopeAttributes) element.setAttribute(attribute, '')
      return element
    }

    function isRecord(value: unknown): value is Record<string, unknown> {
      return Boolean(value) && typeof value === 'object'
    }

    function percentage(value: unknown) {
      const parsed = Number(value)
      return Number.isFinite(parsed) ? Math.min(100, Math.max(0, parsed)) : 0
    }

    function normalizeMetrics(value: unknown): Metrics | null {
      if (
        !isRecord(value) ||
        typeof value.success_rate !== 'number' ||
        !Array.isArray(value.daily) ||
        !Array.isArray(value.failures) ||
        !Array.isArray(value.updater_versions) ||
        !isRecord(value.platforms)
      )
        return null

      const daily = value.daily
        .flatMap((item) =>
          !isRecord(item) || typeof item.date !== 'string' || typeof item.success_rate !== 'number' ? [] : [{ date: item.date, success_rate: percentage(item.success_rate) }],
        )
        .sort((a, b) => a.date.localeCompare(b.date))
      const failures = value.failures
        .flatMap((item) => (!isRecord(item) || typeof item.reason !== 'string' || typeof item.share !== 'number' ? [] : [{ reason: item.reason, share: percentage(item.share) }]))
        .sort((a, b) => b.share - a.share)
      const updater_versions = value.updater_versions
        .flatMap((item) =>
          !isRecord(item) || typeof item.date !== 'string' || typeof item.version !== 'string' || typeof item.share !== 'number'
            ? []
            : [{ date: item.date, version: item.version, share: percentage(item.share) }],
        )
        .sort((a, b) => a.date.localeCompare(b.date) || b.share - a.share)

      return {
        updated_at: typeof value.updated_at === 'string' ? value.updated_at : '',
        success_rate: percentage(value.success_rate),
        daily,
        failures,
        platforms: { ios: percentage(value.platforms.ios), android: percentage(value.platforms.android), electron: percentage(value.platforms.electron) },
        updater_versions,
      }
    }

    function readableReason(reason: string) {
      return reason
        .replace(/_/g, ' ')
        .replace(/([a-z])([A-Z])/g, '$1 $2')
        .replace(/\b\w/g, (letter) => letter.toUpperCase())
    }

    function formatPercentage(value: number) {
      return `${value > 0 ? Math.max(0.1, value).toFixed(1) : '0.0'}%`
    }

    function setPlatform(platform: keyof Metrics['platforms'], share: number) {
      const row = page?.querySelector<HTMLElement>(`[data-platform="${platform}"]`)
      const shareElement = row?.querySelector<HTMLElement>('[data-platform-share]')
      const bar = row?.querySelector<HTMLElement>('[data-platform-bar]')
      if (!shareElement || !bar) return
      shareElement.textContent = formatPercentage(share)
      bar.style.setProperty('--share', `${share}%`)
    }

    function renderDaily(metrics: Metrics) {
      if (!dailyChart || !dailyBars || !dailyStart || !dailyEnd || !dailyEmpty) return
      dailyBars.replaceChildren()
      for (const item of metrics.daily) {
        const bar = createScopedElement('div')
        const label = `${item.date}: ${formatPercentage(item.success_rate)} install success`
        bar.className = 'data-bar'
        bar.dataset.tooltip = label
        bar.tabIndex = 0
        bar.setAttribute('role', 'listitem')
        bar.setAttribute('aria-label', label)
        const fill = createScopedElement('span')
        fill.style.setProperty('--success-rate', `${item.success_rate}%`)
        bar.append(fill)
        dailyBars.append(bar)
      }
      dailyChart.hidden = metrics.daily.length === 0
      dailyEmpty.hidden = metrics.daily.length > 0
      dailyEmpty.textContent = 'Reliability telemetry is temporarily unavailable.'
      dailyStart.textContent = metrics.daily[0]?.date ?? ''
      dailyEnd.textContent = metrics.daily.at(-1)?.date ?? ''
    }

    function renderFailures(metrics: Metrics) {
      if (!failuresList) return
      failuresList.replaceChildren()
      for (const [index, item] of metrics.failures.entries()) {
        const row = createScopedElement('li')
        const rank = createScopedElement('span')
        rank.textContent = String(index + 1).padStart(2, '0')
        const reason = createScopedElement('strong')
        reason.textContent = readableReason(item.reason)
        const share = createScopedElement('b')
        share.textContent = formatPercentage(item.share)
        const track = createScopedElement('i')
        track.setAttribute('aria-hidden', 'true')
        const fill = createScopedElement('em')
        fill.style.setProperty('--share', `${item.share}%`)
        track.append(fill)
        row.append(rank, reason, share, track)
        failuresList.append(row)
      }
      if (!metrics.failures.length) failuresList.append(Object.assign(createScopedElement('li'), { className: 'data-empty', textContent: 'No failure reasons in this window.' }))
    }

    function renderVersions(metrics: Metrics) {
      if (!versionChart || !versionEmpty) return
      const leading = new Map<string, VersionMetric>()
      for (const item of metrics.updater_versions) if (!leading.has(item.date)) leading.set(item.date, item)
      const trend = [...leading.values()]
      versionChart.replaceChildren()
      for (const item of trend) {
        const bar = createScopedElement('div')
        const label = `${item.date}: ${item.version}, ${formatPercentage(item.share)} share`
        bar.dataset.tooltip = label
        bar.tabIndex = 0
        bar.setAttribute('role', 'listitem')
        bar.setAttribute('aria-label', label)
        const fill = createScopedElement('span')
        fill.style.setProperty('--share', `${item.share}%`)
        const labelElement = createScopedElement('small')
        labelElement.textContent = item.version
        bar.append(fill, labelElement)
        versionChart.append(bar)
      }
      versionChart.hidden = trend.length === 0
      versionEmpty.hidden = trend.length > 0
      versionEmpty.textContent = 'Updater adoption telemetry is temporarily unavailable.'
    }

    function renderMetrics(metrics: Metrics) {
      if (successRateKpi) successRateKpi.textContent = formatPercentage(metrics.success_rate)
      setPlatform('ios', metrics.platforms.ios)
      setPlatform('android', metrics.platforms.android)
      setPlatform('electron', metrics.platforms.electron)
      renderDaily(metrics)
      renderFailures(metrics)
      renderVersions(metrics)
      if (chartStatus) {
        const readyCharts = [metrics.daily.length ? 'Daily success chart' : '', metrics.updater_versions.length ? 'updater version chart' : ''].filter(Boolean)
        chartStatus.textContent = readyCharts.length ? readyCharts.join(' and ') + ' ready. Use Tab to focus bars and view values.' : ''
      }
      if (updated) {
        const timestamp = new Date(metrics.updated_at)
        const formatted = Number.isNaN(timestamp.getTime())
          ? 'Updated moments ago'
          : `Updated ${new Intl.DateTimeFormat('en-US', { dateStyle: 'medium', timeStyle: 'short', timeZone: 'UTC' }).format(timestamp)} UTC`
        updated.textContent = `${formatted} · Percentage-only public data.`
      }
    }

    function renderUnavailable() {
      if (updated) updated.textContent = 'Live reliability data is temporarily unavailable. Please check back shortly.'
      if (dailyChart) dailyChart.hidden = true
      if (dailyEmpty) {
        dailyEmpty.hidden = false
        dailyEmpty.textContent = 'Reliability telemetry is temporarily unavailable.'
      }
      if (failuresList)
        failuresList.replaceChildren(Object.assign(createScopedElement('li'), { className: 'data-empty', textContent: 'Failure telemetry is temporarily unavailable.' }))
      if (versionChart) versionChart.hidden = true
      if (versionEmpty) {
        versionEmpty.hidden = false
        versionEmpty.textContent = 'Updater adoption telemetry is temporarily unavailable.'
      }
    }

    async function loadMetrics() {
      const controller = new AbortController()
      const timeoutId = window.setTimeout(() => controller.abort(), 10_000)
      try {
        if (!endpoint) throw new Error('Missing metrics endpoint')
        const response = await fetch(endpoint, { headers: { Accept: 'application/json' }, signal: controller.signal })
        const metrics = response.ok ? normalizeMetrics(await response.json()) : null
        if (!metrics) throw new Error('Invalid metrics response')
        renderMetrics(metrics)
      } catch {
        renderUnavailable()
      } finally {
        window.clearTimeout(timeoutId)
        page?.setAttribute('aria-busy', 'false')
      }
    }

    void loadMetrics()
  }
</script>

<style>
  .data-sr-only {
    position: absolute;
    width: 1px;
    height: 1px;
    padding: 0;
    margin: -1px;
    overflow: hidden;
    clip: rect(0, 0, 0, 0);
    white-space: nowrap;
    border: 0;
  }
  .data-page {
    --line: rgb(255 255 255 / 11%);
    --muted: #bdc9da;
    color-scheme: only dark;
    background: #0b1220;
    color: white;
    overflow: clip;
  }
  .data-shell {
    width: min(1120px, calc(100% - 40px));
    margin-inline: auto;
  }
  .data-hero,
  .data-section {
    padding-block: 72px;
  }
  .data-hero {
    background: radial-gradient(circle at 76% 8%, rgb(37 99 235 / 20%), transparent 38%), #0b1220;
    border-bottom: 1px solid var(--line);
  }
  .data-eyebrow {
    display: flex;
    gap: 8px;
    align-items: center;
    margin: 0 0 16px;
    color: #8ec5ff;
    font-size: 0.875rem;
    font-weight: 600;
    letter-spacing: 0.02em;
  }
  .data-eyebrow span {
    width: 8px;
    height: 8px;
    border-radius: 999px;
    background: #34d399;
    box-shadow: 0 0 0 4px rgb(52 211 153 / 12%);
  }
  h1,
  h2 {
    margin: 0;
    font-weight: 600;
    letter-spacing: -0.025em;
    text-wrap: balance;
  }
  h1 {
    max-width: 20ch;
    font-size: clamp(2.5rem, 6vw, 4.75rem);
  }
  h2 {
    max-width: 32ch;
    font-size: clamp(1.75rem, 4vw, 2.5rem);
  }
  .data-summary {
    max-width: 58ch;
    margin: 20px 0 0;
    color: var(--muted);
    font-size: 1.125rem;
    line-height: 1.6;
    text-wrap: pretty;
  }
  .data-updated {
    display: flex;
    gap: 9px;
    align-items: center;
    margin: 24px 0 0;
    color: #91a2ba;
    font-size: 0.875rem;
  }
  .data-spinner {
    width: 14px;
    height: 14px;
    border: 2px solid rgb(147 197 253 / 25%);
    border-top-color: #93c5fd;
    border-radius: 50%;
    animation: spin 0.8s linear infinite;
  }
  .data-heading,
  .data-split {
    display: grid;
    gap: 48px;
  }
  .data-heading {
    grid-template-columns: minmax(0, 1.2fr) minmax(280px, 0.8fr);
    align-items: end;
    margin-bottom: 40px;
  }
  .data-heading > p,
  .data-copy {
    margin: 0;
    color: var(--muted);
    font-size: 1rem;
    line-height: 1.6;
    text-wrap: pretty;
  }
  .data-kpis {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    margin-bottom: 40px;
    border-block: 1px solid var(--line);
  }
  .data-kpis div {
    min-width: 0;
    padding: 20px 24px;
  }
  .data-kpis div + div {
    border-left: 1px solid var(--line);
  }
  .data-kpis p {
    margin: 0 0 8px;
    color: #91a2ba;
    font-size: 0.875rem;
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
  }
  .data-kpis strong {
    display: block;
    font-size: clamp(1.35rem, 3vw, 2rem);
    font-variant-numeric: tabular-nums;
    white-space: nowrap;
  }
  .data-chart {
    position: relative;
    padding-left: 48px;
    border-bottom: 1px solid var(--line);
  }
  .data-chart-scale {
    position: absolute;
    inset: 0 auto 12px 0;
    display: flex;
    flex-direction: column;
    justify-content: space-between;
    color: #6f819b;
    font-size: 0.75rem;
    font-variant-numeric: tabular-nums;
  }
  .data-bars,
  .data-version-chart {
    display: flex;
    gap: 4px;
    align-items: end;
    height: 240px;
    overflow: visible;
  }
  .data-bars {
    background: repeating-linear-gradient(to bottom, var(--line) 0 1px, transparent 1px 50%);
  }
  .data-bar {
    position: relative;
    flex: 1;
    min-width: 3px;
    height: 100%;
  }
  .data-bar::after,
  .data-version-chart > div::after {
    position: absolute;
    z-index: 2;
    top: 10px;
    left: 50%;
    width: max-content;
    max-width: min(240px, 80vw);
    padding: 7px 9px;
    border: 1px solid rgb(147 197 253 / 24%);
    border-radius: 6px;
    background: #111c2e;
    box-shadow: 0 8px 24px rgb(0 0 0 / 28%);
    color: #f8fafc;
    content: attr(data-tooltip);
    font-size: 0.75rem;
    line-height: 1.3;
    opacity: 0;
    pointer-events: none;
    transform: translate(-50%, 4px);
    transition:
      opacity 120ms ease,
      transform 120ms ease;
  }
  .data-bar:hover::after,
  .data-bar:focus-visible::after,
  .data-version-chart > div:hover::after,
  .data-version-chart > div:focus-visible::after {
    opacity: 1;
    transform: translate(-50%, 0);
  }
  .data-bar:first-child::after,
  .data-version-chart > div:first-child::after {
    left: 0;
    transform: translate(0, 4px);
  }
  .data-bar:first-child:hover::after,
  .data-bar:first-child:focus-visible::after,
  .data-version-chart > div:first-child:hover::after,
  .data-version-chart > div:first-child:focus-visible::after {
    transform: translate(0, 0);
  }
  .data-bar:last-child::after,
  .data-version-chart > div:last-child::after {
    right: 0;
    left: auto;
    transform: translate(0, 4px);
  }
  .data-bar:last-child:hover::after,
  .data-bar:last-child:focus-visible::after,
  .data-version-chart > div:last-child:hover::after,
  .data-version-chart > div:last-child:focus-visible::after {
    transform: translate(0, 0);
  }
  .data-bar:focus-visible,
  .data-version-chart > div:focus-visible {
    outline: 2px solid #93c5fd;
    outline-offset: 2px;
  }
  .data-bar span {
    position: absolute;
    inset: auto 0 0;
    height: var(--success-rate);
    min-height: 2px;
    border-radius: 3px 3px 0 0;
    background: linear-gradient(to top, #2563eb, #60a5fa);
    transition: filter 120ms ease;
  }
  .data-bar:hover span,
  .data-bar:focus-visible span {
    filter: brightness(1.22);
  }
  .data-axis {
    display: flex;
    justify-content: space-between;
    padding-block: 10px 12px;
    color: #91a2ba;
    font-size: 0.75rem;
    font-variant-numeric: tabular-nums;
  }
  .data-section-muted {
    background: rgb(15 23 42 / 72%);
    border-block: 1px solid var(--line);
  }
  .data-split {
    grid-template-columns: minmax(0, 0.85fr) minmax(0, 1.15fr);
    align-items: start;
  }
  .data-platforms {
    display: grid;
    gap: 24px;
    margin: 0;
  }
  .data-platforms dt {
    color: #d8e1ee;
    font-size: 1rem;
  }
  .data-platforms dd {
    margin: 5px 0 10px;
    color: white;
    font-size: 1.4rem;
    font-weight: 600;
    font-variant-numeric: tabular-nums;
  }
  .data-platforms > div > div {
    height: 6px;
    overflow: hidden;
    border-radius: 99px;
    background: rgb(255 255 255 / 8%);
  }
  .data-platforms > div > div span {
    display: block;
    width: var(--share, 0%);
    height: 100%;
    border-radius: inherit;
    background: #60a5fa;
  }
  .data-failures {
    display: grid;
    gap: 16px;
    padding: 0;
    margin: 0;
    list-style: none;
  }
  .data-failures li {
    display: grid;
    grid-template-columns: 34px minmax(0, 1fr) auto;
    gap: 12px;
    align-items: center;
    padding-bottom: 16px;
    border-bottom: 1px solid var(--line);
  }
  .data-failures li > span {
    color: #6f819b;
    font-size: 0.8rem;
    font-variant-numeric: tabular-nums;
  }
  .data-failures strong {
    min-width: 0;
    font-size: 1rem;
    font-weight: 600;
  }
  .data-failures b {
    color: #d8e1ee;
    font-size: 0.875rem;
    font-variant-numeric: tabular-nums;
  }
  .data-failures i {
    grid-column: 2 / -1;
    height: 4px;
    overflow: hidden;
    border-radius: 99px;
    background: rgb(255 255 255 / 7%);
  }
  .data-failures em {
    display: block;
    width: var(--share, 0%);
    height: 100%;
    border-radius: inherit;
    background: #f59e0b;
  }
  .data-version-chart {
    gap: 5px;
