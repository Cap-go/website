        <div class="wizard" id="wizard" data-platform="ios">
          <div class="wizard-steps" role="tablist">
            <button class="wizard-step active" data-platform="ios" type="button"
              ><span class="num">1</span><span><span class="lbl">{copy('native_build_v2_wiz_ios_s1_l')}</span><span class="dsc">{copy('native_build_v2_wiz_ios_s1_d')}</span></span
              ></button
            >
            <button class="wizard-step" data-platform="ios" type="button"
              ><span class="num">2</span><span><span class="lbl">{copy('native_build_v2_wiz_ios_s2_l')}</span><span class="dsc">{copy('native_build_v2_wiz_ios_s2_d')}</span></span
              ></button
            >
            <button class="wizard-step" data-platform="ios" type="button"
              ><span class="num">3</span><span><span class="lbl">{copy('native_build_v2_wiz_ios_s3_l')}</span><span class="dsc">{copy('native_build_v2_wiz_ios_s3_d')}</span></span
              ></button
            >
            <button class="wizard-step" data-platform="ios" type="button"
              ><span class="num">4</span><span><span class="lbl">{copy('native_build_v2_wiz_ios_s4_l')}</span><span class="dsc">{copy('native_build_v2_wiz_ios_s4_d')}</span></span
              ></button
            >
            <button class="wizard-step active" data-platform="android" type="button" hidden
              ><span class="num">1</span><span><span class="lbl">{copy('native_build_v2_wiz_and_s1_l')}</span><span class="dsc">{copy('native_build_v2_wiz_and_s1_d')}</span></span
              ></button
            >
            <button class="wizard-step" data-platform="android" type="button" hidden
              ><span class="num">2</span><span><span class="lbl">{copy('native_build_v2_wiz_and_s2_l')}</span><span class="dsc">{copy('native_build_v2_wiz_and_s2_d')}</span></span
              ></button
            >
            <button class="wizard-step" data-platform="android" type="button" hidden
              ><span class="num">3</span><span><span class="lbl">{copy('native_build_v2_wiz_and_s3_l')}</span><span class="dsc">{copy('native_build_v2_wiz_and_s3_d')}</span></span
              ></button
            >
            <button class="wizard-step" data-platform="android" type="button" hidden
              ><span class="num">4</span><span><span class="lbl">{copy('native_build_v2_wiz_and_s4_l')}</span><span class="dsc">{copy('native_build_v2_wiz_and_s4_d')}</span></span
              ></button
            >
          </div>
          <div class="wizard-stage" id="wizard-stage"></div>
        </div>

        <div class="wizard-before-after">
          <span class="ba b" id="ba-before">{copy('native_build_v2_wiz_ios_before')}</span>
          <span class="ba-arrow">→</span>
          <span class="ba a" id="ba-after">{copy('native_build_v2_wiz_ios_after')}</span>
        </div>
        <p class="wizard-macos-note" style="margin-top:18px;text-align:center;font-size:13px;opacity:.55">{copy('native_build_v2_wiz_macos_note')}</p>
      </div>
    </section>

    <!-- ============================================ ASK AI / MCP ============================================ -->
    <section class="section" id="ask-ai">
      <div class="shell">
        <div class="section-head section-head--wide">
          <div class="eyebrow eyebrow--violet">{copy('native_build_v2_mcp_eyebrow')}</div>
          <h2 class="h2-section">
            {copy('native_build_v2_mcp_title_prefix')}<span class="accent-violet">{copy('native_build_v2_mcp_title_accent')}</span>
          </h2>
          <p class="lead">{copy('native_build_v2_mcp_lead')}</p>
        </div>

        <div class="mcp-grid">
          <div class="mcp-card">
            <div class="mcp-step"><span class="mcp-step-n">1</span><span>{copy('native_build_v2_mcp_add_title')}</span></div>
            <div class="mcp-editors" role="tablist" aria-label="MCP client">
              {
                mcpClients.map((c, i) => (
                  <button class:list={['mcp-ed', i === 0 && 'is-active']} data-client={c.id} type="button" role="tab" aria-selected={i === 0 ? 'true' : 'false'}>
                    <Icon name={c.icon} class="mcp-ed-i" />
                    {c.name}
                  </button>
                ))
              }
              <span class="mcp-ed mcp-ed--more">{copy('native_build_v2_mcp_editors_more')}</span>
            </div>
            <div class="mcp-configs">
              {
                mcpClients.map((c, i) => (
                  <div class="mcp-config-panel" data-client={c.id} hidden={i !== 0}>
                    <div class="mcp-code">
                      <div class="mcp-code-head">
                        <span class="mcp-code-label">
                          {c.name} <span class="mcp-code-sep">·</span> <span class="mcp-code-path">{c.label}</span>
                        </span>
                        <button class="mcp-copy" type="button" data-copy={c.code} data-copied={copy('native_build_v2_mcp_copied')}>
                          {copy('native_build_v2_mcp_copy')}
                        </button>
                      </div>
                      <pre class="mcp-code-pre">
                        <CommandCode command={c.code} />
                      </pre>
                    </div>
                  </div>
                ))
              }
            </div>
          </div>

          <div class="mcp-card">
            <div class="mcp-step"><span class="mcp-step-n">2</span><span>{copy('native_build_v2_mcp_ask_title')}</span></div>
            <div class="mcp-ask">
              <span class="mcp-ask-who">you</span>
              <span class="mcp-ask-text">{copy('native_build_v2_mcp_ask_prompt')}</span>
              <button
                class="mcp-copy mcp-copy--icon"
                type="button"
                data-copy={copy('native_build_v2_mcp_ask_prompt')}
                data-copied={copy('native_build_v2_mcp_copied')}
                aria-label={copy('native_build_v2_mcp_copy')}>⧉</button
              >
            </div>
            <ul class="mcp-chk">
              <li>{copy('native_build_v2_mcp_chk_1')}</li>
              <li>{copy('native_build_v2_mcp_chk_2')}</li>
              <li>{copy('native_build_v2_mcp_chk_3')}</li>
            </ul>
            <p class="mcp-ask-note">{copy('native_build_v2_mcp_ask_note')}</p>
          </div>
        </div>
      </div>
    </section>

    <!-- ============================================ TRUST ============================================ -->
    <section class="section" id="trust">
      <div class="shell">
        <div class="section-head">
          <div class="eyebrow">{copy('native_build_v2_trust_eyebrow')}</div>
          <h2 class="h2-section">{copy('native_build_v2_trust_title')}</h2>
          <p class="lead">{copy('native_build_v2_trust_lead')}</p>
        </div>

        <div class="trust-grid" id="trust-grid">
          <div class="trust-cell" data-trust="storage">
            <div class="trust-icon" aria-hidden="true">
              <svg viewBox="0 0 32 32" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
                <rect x="6" y="13" width="20" height="14" rx="2"></rect>
                <path d="M10 13V9a6 6 0 0 1 12 0v4"></path>
                <circle cx="16" cy="20" r="1.5" fill="currentColor"></circle>
                <path d="M16 21.5v2.5"></path>
              </svg>
            </div>
            <div class="lbl">{copy('native_build_v2_trust_stor_lbl')}</div>
            <h3>{copy('native_build_v2_trust_stor_h')}</h3>
            <p>{copy('native_build_v2_trust_stor_p')}</p>
            <div class="trust-status" aria-hidden="true">
              <span class="trust-dot trust-dot--ok"></span>
              <span>{copy('native_build_v2_trust_stor_s')}</span>
            </div>
          </div>

          <div class="trust-cell" data-trust="transit">
            <div class="trust-icon" aria-hidden="true">
              <svg viewBox="0 0 32 32" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
                <path d="M4 24c0-7 5-12 12-12s12 5 12 12"></path>
                <path d="M9 24c0-4 3-7 7-7s7 3 7 7"></path>
                <circle cx="16" cy="24" r="1.5" fill="currentColor"></circle>
              </svg>
            </div>
            <div class="lbl">{copy('native_build_v2_trust_trans_lbl')}</div>
            <h3>{copy('native_build_v2_trust_trans_h')}</h3>
            <p>{copy('native_build_v2_trust_trans_p')}</p>
            <div class="trust-status" aria-hidden="true">
              <span class="trust-pulse"></span>
              <span>{copy('native_build_v2_trust_trans_s')}</span>
            </div>
          </div>

          <div class="trust-cell" data-trust="logs">
            <div class="trust-icon" aria-hidden="true">
              <svg viewBox="0 0 32 32" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
                <path d="M4 16c3-5 7-7 12-7s9 2 12 7c-3 5-7 7-12 7s-9-2-12-7z"></path>
                <circle cx="16" cy="16" r="3"></circle>
                <path d="M6 6l20 20" stroke-width="2"></path>
              </svg>
            </div>
            <div class="lbl">{copy('native_build_v2_trust_logs_lbl')}</div>
            <h3>{copy('native_build_v2_trust_logs_h')}</h3>
            <p>{copy('native_build_v2_trust_logs_p')}</p>
            <div class="trust-status trust-status--stream" aria-hidden="true">
              <span class="trust-stream"><span></span><span></span><span></span><span></span></span>
              <span>{copy('native_build_v2_trust_logs_s')}</span>
            </div>
          </div>

          <div class="trust-cell" data-trust="isolation">
            <div class="trust-icon" aria-hidden="true">
              <svg viewBox="0 0 32 32" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
                <path d="M16 4l10 5v9c0 6-4 9-10 10-6-1-10-4-10-10V9l10-5z"></path>
                <path d="M12 16l3 3 6-6"></path>
              </svg>
            </div>
            <div class="lbl">{copy('native_build_v2_trust_iso_lbl')}</div>
            <h3>{copy('native_build_v2_trust_iso_h')}</h3>
            <p>{copy('native_build_v2_trust_iso_p')}</p>
            <div class="trust-status" aria-hidden="true">
              <span class="trust-decay"></span>
              <span>{copy('native_build_v2_trust_iso_s')}</span>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- ============================================ COMPARISON ============================================ -->
    <section class="section" id="compare">
      <div class="shell">
        <div class="section-head">
          <div class="eyebrow">{copy('native_build_v2_comp_eyebrow')}</div>
          <h2 class="h2-section">{copy('native_build_v2_comp_title')}</h2>
          <p class="lead">{copy('native_build_v2_comp_lead')}</p>
        </div>

        <div class="comp-wrap">
          <table class="comp comp-prose">
            <thead>
              <tr>
                <th></th>
                <th class="us">Capgo Builder</th>
                <th>
                  {copy('native_build_v2_comp_h_diy')}
                  <span class="th-sub">{copy('native_build_v2_comp_h_diy_sub')}</span>
                </th>
                <th>{copy('native_build_v2_comp_h_capa')}</th>
              </tr>
            </thead>
            <tbody>
              {
                comparisonRows.map((row) => (
                  <tr>
                    <td class="label">{row.label}</td>
                    <td class="us">
                      <span class="hook">{row.hook}</span> {row.capgo}
                    </td>
                    <td>{row.diy}</td>
                    <td>{row.capa}</td>
                  </tr>
                ))
              }
            </tbody>
          </table>
        </div>

        <aside class="comp-callout" role="note">
          <p>{copy('native_build_v2_comp_callout')}</p>
        </aside>

        <p class="comp-footnote">{copy('native_build_v2_comp_footnote')}</p>
      </div>
    </section>

    <!-- ============================================ AI DEBUG ============================================ -->
    <section class="section" id="ai-debug">
      <div class="shell">
        <div class="section-head">
          <div class="eyebrow eyebrow--green">{copy('native_build_v2_aidebug_eyebrow')}</div>
          <h2 class="h2-section">{copy('native_build_v2_aidebug_title')}</h2>
          <p class="lead">{copy('native_build_v2_aidebug_lead')}</p>
        </div>

        <div class="aidebug-grid">
          <div class="aidebug-termcol">
            <div class="terminal-frame aidebug-term">
              <div class="terminal-bar">
                <span class="dot r"></span><span class="dot y"></span><span class="dot g"></span>
                <span class="title">capgo build request --platform ios</span>
              </div>
              <div class="terminal-body aidebug-body" aria-label="Example of an AI-assisted build failure diagnosis">
                <span class="row"
                  ><span class="pain-prompt">$ </span><span class="cmd">capgo build request</span> <span class="flag">--platform</span> <span class="val">ios</span></span
                >
                <span class="row"><span class="dim">[CapApp]</span> Creating App.xcarchive</span>
                <span class="row"><span class="err">✖ Archive failed: Command CodeSign failed with a nonzero exit code</span></span>
                <span class="row"><span class="err">&nbsp;&nbsp;error: No profile matching 'com.acme.app' found for team ABC123</span></span>
                <span class="row ai-head"><span class="kw">?</span> Choose AI analysis <span class="ghost">(optional)</span></span>
                <span class="row" data-menu-selected><span class="ok">✔</span> <span class="val">Capgo AI</span></span>
                <span class="row menu-extra"><span class="dim">&nbsp;&nbsp;Local AI · write the prompt to a file</span></span>
                <span class="row menu-extra" data-collapse><span class="dim">&nbsp;&nbsp;Skip</span></span>
                <span class="row ai-head" data-ai-spin><span class="ok">✔</span> <span class="ghost">Capgo AI finished</span></span>
                <span class="row"><span class="ok">◆ Likely cause</span></span>
                <span class="row"><span class="ghost">Your App Store provisioning profile doesn't include the bundle ID com.acme.app.</span></span>
                <span class="row ai-head"><span class="ok">◆ Fix</span></span>
                <span class="row"><span class="ghost">Regenerate the profile for that bundle ID, or run </span><span class="cmd">capgo build init --platform ios</span></span>
                <span class="row"><span class="ghost">to recreate certificate + profile automatically, then re-run the build.</span></span>
              </div>
            </div>
            <div class="demo-controls aidebug-controls">
              <span>Optional. Only runs if you choose Capgo AI.</span>
              <button class="demo-replay" id="aidebug-replay" type="button">⟲ Replay</button>
            </div>
          </div>

          <ul class="aidebug-points">
            <li>
              <h3>{copy('native_build_v2_aidebug_p1_t')}</h3>
              <p>{copy('native_build_v2_aidebug_p1_d')}</p>
            </li>
            <li>
              <h3>{copy('native_build_v2_aidebug_p2_t')}</h3>
              <p>{copy('native_build_v2_aidebug_p2_d')}</p>
            </li>
            <li>
              <h3>{copy('native_build_v2_aidebug_p3_t')}</h3>
              <p>{copy('native_build_v2_aidebug_p3_d')}</p>
            </li>
          </ul>
        </div>
      </div>
    </section>

    <!-- ============================================ PRICING (live plans) ============================================ -->
    {
      plans.length > 0 && (
        <section class="section" id="pricing">
          <div class="shell">
            <div class="section-head">
              <div class="eyebrow">{copy('native_build_builder_pricing_eyebrow')}</div>
              <h2 class="h2-section">{copy('native_build_builder_pricing_title')}</h2>
              <p class="lead">{copy('native_build_builder_pricing_text')}</p>
            </div>

            <div class="pricing-grid">
              {plans.map((plan) => (
                <div class:list={['tier', { pop: plan.name === 'Maker' }]}>
                  <div>
                    <div class="name">{plan.name === 'Maker' ? `${plan.name} · ${copy('most_popular')}` : plan.name}</div>
                    <div class="price">
                      {annualMonthlyPrice(plan)}
                      <small> / mo</small>
                    </div>
                  </div>
                  <p class="what">{planDescription(plan)}</p>
                  <p class="tier-billing">{yearlyBilling(plan)}</p>
                  <p class="tier-billing">{monthlyPrice(plan)}</p>
                  <a class:list={['btn btn-md', plan.name === 'Maker' ? 'btn-primary' : 'btn-ghost']} href={registerUrl}>
                    {copy('native_build_builder_plan_trial')}
                  </a>
                  <ul>
                    <li>{buildTimeDisplay(plan.build_time_unit, plan.name)}</li>
                    <li>{copy('native_build_v2_plan_ota')}</li>
                  </ul>
                </div>
              ))}
            </div>

            <div class="build-calc" aria-label="Build minutes calculator" data-tiers={JSON.stringify(calcTiers)}>
              <div class="build-calc-head">{copy('native_build_v2_calc_title')}</div>
              <input class="build-calc-range" type="range" min="30" max="600" step="10" value="60" id="bc-range" aria-label={copy('native_build_v2_calc_minutes')} />
              <div class="build-calc-readout">
                <span id="bc-min">60</span> {copy('native_build_v2_calc_minutes')}
              </div>
              <div class="build-calc-results">
                <div class="bc-res">
                  <span class="bc-ico" aria-hidden="true">
                    <svg viewBox="0 0 24 24" fill="currentColor">
                      <path d="M16.36 12.6c-.02-2.3 1.88-3.4 1.96-3.46-1.07-1.56-2.74-1.78-3.33-1.8-1.42-.14-2.77.83-3.49.83-.72 0-1.83-.81-3-.79-1.55.02-2.98.9-3.78 2.29-1.61 2.8-.41 6.95 1.16 9.23.77 1.11 1.69 2.36 2.89 2.31 1.16-.05 1.6-.75 3-.75s1.79.75 3.01.72c1.24-.02 2.03-1.13 2.79-2.25.88-1.29 1.24-2.54 1.26-2.6-.03-.01-2.41-.92-2.43-3.66zM14.04 5.5c.64-.78 1.07-1.86.95-2.94-.92.04-2.04.61-2.7 1.39-.59.69-1.11 1.79-.97 2.85 1.03.08 2.08-.52 2.72-1.3z" />
                    </svg>
                  </span>
                  <div>
                    <>
                      <span class="bc-num" id="bc-ios">
                        12
                      </span>
                      <span class="bc-lbl">{copy('native_build_v2_calc_ios')}</span>
                    </>
                  </div>
                </div>
                <div class="bc-res">
                  <span class="bc-ico" aria-hidden="true">
                    <svg viewBox="0 0 24 24" fill="currentColor">
                      <path d="M17.6 9.48l1.84-3.18a.4.4 0 0 0-.69-.4l-1.86 3.23a11.43 11.43 0 0 0-8.78 0L6.25 5.9a.4.4 0 1 0-.69.4L7.4 9.48A10.78 10.78 0 0 0 2 18h20a10.78 10.78 0 0 0-5.4-8.52zM7 15.25a1 1 0 1 1 1-1 1 1 0 0 1-1 1zm10 0a1 1 0 1 1 1-1 1 1 0 0 1-1 1z" />
                    </svg>
                  </span>
                  <div>
                    <>
                      <span class="bc-num" id="bc-and">
                        24
                      </span>
                      <span class="bc-lbl">{copy('native_build_v2_calc_android')}</span>
                    </>
                  </div>
                </div>
              </div>
              {calcTiers.length > 0 && (
                <div class="build-calc-price">
                  ≈ <span id="bc-price">$10</span> {copy('native_build_v2_calc_price_label')}
                </div>
              )}
              <p class="build-calc-note">{copy('native_build_v2_calc_note')}</p>
            </div>

            <p class="pricing-fineprint">
              {copy('native_build_v2_pricing_fine')} <a href={pricingUrl}>capgo.app/pricing</a>.
            </p>
          </div>
        </section>
      )
    }
    <!-- ============================================ FAQ ============================================ -->
    <section class="section" id="faq">
      <div class="shell">
        <div class="section-head section-head--narrow">
          <div class="eyebrow">{copy('native_build_builder_faq_eyebrow')}</div>
          <h2 class="h2-section">{copy('native_build_builder_faq_title')}</h2>
        </div>

        <div class="faq">
          {
            faqs.map((item) => (
              <details>
                <summary>
                  {item.q}
                  <span class="plus">+</span>
                </summary>
                <div class="ans">
                  <p>{item.a}</p>
                  {item.href && item.linkLabel && (
                    <a class="faq-doc-link" href={item.href}>
                      {item.linkLabel} →
                    </a>
                  )}
                </div>
              </details>
            ))
          }
        </div>
      </div>
    </section>

    <!-- ============================================ FINAL CTA ============================================ -->
    <section class="section final bg-grid grain" id="cta">
      <div class="shell">
        <h2>
          <span class="name">Capgo Builder</span><br />
          {copy('native_build_v2_cta_title')}
        </h2>
        <p class="tagline">{copy('native_build_v2_cta_tagline')}</p>
        <a class="btn btn-lg btn-primary btn-cta" href={registerUrl}>{copy('native_build_builder_start_trial')} →</a>
        <div class="hero-meta hero-meta--cta">
          <span><span class="check">✓</span> {copy('native_build_v2_cta_meta1')}</span>
          <span><span class="check">✓</span> {copy('native_build_v2_cta_meta2')}</span>
          <span><span class="check">✓</span> {copy('native_build_v2_cta_meta3')}</span>
        </div>
      </div>
    </section>
  </div>

