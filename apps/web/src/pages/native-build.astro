---
import Layout from '@/layouts/Layout.astro'
import { createLdJsonGraph, createServiceLdJson } from '@/lib/ldJson'
import type { Database } from '@/services/supabase.types'
import { getRelativeLocaleUrl } from 'astro:i18n'

type Plan = Database['public']['Tables']['plans']['Row']

type Credit = {
  id: number
  step_min: number
  step_max: number
  price_per_unit: number
  type: string
  unit_factor: number
}

const locale = Astro.locals.locale
const brand = Astro.locals.runtimeConfig.public.brand
const config = Astro.locals.runtimeConfig

const title = `${brand} | Capgo Builder`
const description = 'Build signed iOS and Android apps from any machine with Capgo Builder.'

const [plansResponse, creditsResponse] = await Promise.all([fetch(`${config.public.baseApiUrl}/private/plans`), fetch(`${config.public.baseApiUrl}/private/credits`)])

const plansAll: Plan[] = plansResponse.ok ? await plansResponse.json() : []
const credits: Credit[] = creditsResponse.ok ? await creditsResponse.json() : []

const plans = plansAll.filter((plan) => plan.name !== 'Free')
const buildCredits = credits.filter((credit) => credit.type === 'build_time').sort((a, b) => a.step_min - b.step_min)

const serviceLdJson = createServiceLdJson(Astro.locals.runtimeConfig.public, {
  name: title,
  description,
  url: Astro.url.href,
  serviceType: 'Cloud native mobile app build service',
  areaServed: ['Worldwide'],
})

const ldJSON = createLdJsonGraph(Astro.locals.runtimeConfig.public, serviceLdJson, {
  includeOrganization: true,
})

const content = {
  title,
  description,
  ldJSON,
}

const heroStats = [
  { value: '1 command', label: 'Local, CI, or teammate laptop' },
  { value: '0 stored', label: 'Credentials kept runtime-only' },
  { value: 'iOS + Android', label: 'Signed native builds' },
  { value: 'Stores', label: 'Submit after a clean build' },
]

const builderFeatures = [
  {
    title: 'Native builds without the native setup',
    text: 'Build iOS on dedicated Apple Silicon and Android in isolated containers without installing Xcode or Android Studio everywhere.',
    accent: 'text-emerald-300',
  },
  {
    title: 'Bring your own signing',
    text: 'Certificates, provisioning profiles, and keystores are supplied at build time from local env vars or CI secrets.',
    accent: 'text-cyan-300',
  },
  {
    title: 'Upload to the stores',
    text: 'Ship signed artifacts to App Store Connect and Google Play from the same command that produced the build.',
    accent: 'text-amber-300',
  },
  {
    title: 'Works in any CI',
    text: 'Run from GitHub Actions, GitLab CI, Jenkins, local scripts, or a teammate machine. No repo access required.',
    accent: 'text-sky-300',
  },
  {
    title: 'Live logs in your terminal',
    text: 'Stream every build step as it happens, so failures are visible where the command was started.',
    accent: 'text-fuchsia-300',
  },
  {
    title: 'Clean build artifacts',
    text: 'Download IPA, AAB, or APK output when you need it, while keeping the build environment disposable.',
    accent: 'text-violet-300',
  },
]

const setupSteps = [
  'Install the Capgo CLI in your project workflow.',
  'Point the command at your app id and target platform.',
  'Pass signing values from your secrets manager.',
  'Stream logs until the signed artifact is ready.',
]

const securityFeatures = [
  {
    title: 'Credentials stay runtime-only',
    text: 'Signing material is used during the build and is not kept as stored Capgo data.',
  },
  {
    title: 'Only native build inputs upload',
    text: 'Capgo Builder receives the platform folder and built web assets needed for the requested native target.',
  },
  {
    title: 'Ephemeral build environments',
    text: 'iOS and Android jobs run in isolated environments designed around short-lived build execution.',
  },
  {
    title: 'Logs stream back to you',
    text: 'Build output is delivered to the running command so teams can debug without a separate dashboard loop.',
  },
]

const comparisons = [
  {
    feature: 'First setup',
    capgo: 'One CLI command after signing values are available.',
    local: 'Install Xcode, Android Studio, SDKs, Ruby, Gradle, and signing files per machine.',
    ci: 'Maintain runners, images, certificates, and store upload scripts.',
  },
  {
    feature: 'iOS from any OS',
    capgo: 'Trigger iOS builds from macOS, Linux, Windows, or CI.',
    local: 'Requires macOS hardware for iOS output.',
    ci: 'Requires macOS runners and queue management.',
  },
  {
    feature: 'Credential handling',
    capgo: 'Use existing local or CI secrets at build time.',
    local: 'Each build machine needs secure local signing setup.',
    ci: 'Secrets must be wired into every pipeline path.',
  },
  {
    feature: 'Store delivery',
    capgo: 'Build and submit from the same workflow.',
    local: 'Manual export and upload steps are common.',
    ci: 'Possible, but you own the automation.',
  },
  {
    feature: 'Best fit',
    capgo: 'Capacitor teams that want signed native builds without babysitting native toolchains.',
    local: 'Native specialists working inside Xcode or Android Studio every day.',
    ci: 'Teams with dedicated DevOps ownership for mobile runners.',
  },
]

const faqs = [
  {
    question: 'Is Capgo Builder a replacement for live updates?',
    answer:
      'No. Use live updates for JavaScript, CSS, and asset changes that do not require store review. Use Capgo Builder when native code, plugins, permissions, icons, SDKs, or store binaries change.',
  },
  {
    question: 'Do you need access to my repository?',
    answer: 'No. The CLI uploads the build inputs from the machine or CI job where it runs. Private dependencies should already be installed before the build command starts.',
  },
  {
    question: 'How does signing work?',
    answer:
      'You provide certificates, provisioning profiles, keystores, and store credentials through CLI flags or environment variables. Teams usually source them from their CI secret manager.',
  },
  {
    question: 'How does pricing work?',
    answer:
      'Build minutes are included in paid Capgo plans, and extra minutes are available through prepaid credits. iOS uses Apple Silicon build capacity and Android uses containerized Linux builds.',
  },
  {
    question: 'What platforms are supported?',
    answer: 'Capgo Builder supports iOS and Android builds for Capacitor apps, including store submission workflows and downloadable signed artifacts.',
  },
]

function annualMonthlyPrice(plan: Plan) {
  const price = Math.round(plan.price_y / 12)
  return plan.name === 'Enterprise' ? `$${price}+` : `$${price}`
}

function monthlyPrice(plan: Plan) {
  return plan.name === 'Enterprise' ? `$${plan.price_m}+ month-to-month` : `$${plan.price_m} month-to-month`
}

function yearlyBilling(plan: Plan) {
  return plan.name === 'Enterprise' ? `Billed annually from $${formatNumber(plan.price_y)}` : `Billed annually at $${formatNumber(plan.price_y)}`
}

function planDescription(plan: Plan) {
  if (plan.name === 'Enterprise') return 'Best for enterprises with millions of users'
  return plan.market_desc
}

function formatNumber(value: number) {
  return new Intl.NumberFormat('en-US').format(value)
}

function buildTimeDisplay(buildTimeSeconds: number, name?: string) {
  if (!buildTimeSeconds) return '0 build minutes'

  const buildTimeHours = Math.floor(buildTimeSeconds / 3600)
  const buildTimeMinutes = Math.floor(buildTimeSeconds / 60)
  const suffix = name === 'Enterprise' ? '+' : ''

  if (buildTimeHours >= 1) {
    return `${buildTimeHours} build ${buildTimeHours === 1 ? 'hour' : 'hours'}${suffix}`
  }

  return `${buildTimeMinutes} build minutes${suffix}`
}

function compactNumber(value: number) {
  if (value >= 1000) return `${formatNumber(value / 1000).replace(/\.0$/, '')}k`
  return formatNumber(value)
}

function creditStepLabel(credit: Credit, index: number, total: number) {
  const normalizedMin = credit.step_min / credit.unit_factor
  const normalizedMax = credit.step_max / credit.unit_factor

  if (index === 0) return `First ${compactNumber(normalizedMax)}`
  if (index === total - 1) return `Over ${compactNumber(normalizedMin)}`

  return `Next ${compactNumber(normalizedMax - normalizedMin)}`
}

function creditPrice(credit: Credit) {
  return `$${parseFloat(credit.price_per_unit.toFixed(4))}/min`
}
---

<Layout content={content}>
  <main class="bg-[#070d18] text-white">
    <section class="relative overflow-hidden border-b border-white/10">
      <div class="absolute inset-0 bg-[radial-gradient(circle_at_50%_0%,rgba(34,197,94,0.18),transparent_34%),linear-gradient(180deg,rgba(8,18,34,0.4),rgba(7,13,24,1))]"></div>
      <div class="relative mx-auto max-w-6xl px-4 py-20 sm:px-6 sm:py-24 lg:px-8 lg:py-28">
        <div class="mx-auto max-w-3xl text-center">
          <p class="inline-flex items-center rounded-full border border-amber-300/40 bg-amber-300/10 px-4 py-2 text-xs font-semibold text-amber-100 uppercase">
            Native iOS and Android builds from any machine
          </p>
          <h1 class="mt-6 text-5xl leading-tight font-black text-white sm:text-6xl lg:text-7xl">Capgo Builder</h1>
          <p class="mx-auto mt-5 max-w-2xl text-lg leading-8 text-slate-300 sm:text-xl">
            One command for signed iOS and Android builds, store submission, and live build logs without maintaining native toolchains on every machine.
          </p>
          <div class="mt-9 flex flex-col items-center justify-center gap-3 sm:flex-row">
            <a
              href={getRelativeLocaleUrl(locale, 'register')}
              class="inline-flex min-h-11 items-center justify-center rounded-lg bg-blue-600 px-6 py-3 text-sm font-bold text-white shadow-lg shadow-blue-950/40 transition hover:bg-blue-500 focus:ring-2 focus:ring-blue-300 focus:outline-none"
            >
              Start 14-day free trial
            </a>
            <a
              href={getRelativeLocaleUrl(locale, 'docs/cli/cloud-build/getting-started')}
              class="inline-flex min-h-11 items-center justify-center rounded-lg border border-white/15 bg-white/5 px-6 py-3 text-sm font-bold text-white transition hover:border-white/30 hover:bg-white/10 focus:ring-2 focus:ring-white/30 focus:outline-none"
            >
              View docs
            </a>
          </div>
          <p class="mt-4 text-xs text-slate-400">No credit card required for the free trial.</p>
        </div>

        <div class="mt-12 grid gap-3 sm:grid-cols-2 lg:grid-cols-4">
          {
            heroStats.map((item) => (
              <div class="rounded-lg border border-white/10 bg-white/[0.04] p-4 text-center">
                <p class="text-sm font-bold text-white">{item.value}</p>
                <p class="mt-1 text-xs text-slate-400">{item.label}</p>
              </div>
            ))
          }
        </div>
      </div>
    </section>

    <section class="border-b border-white/10 bg-[#081322] py-20 sm:py-24">
      <div class="mx-auto max-w-6xl px-4 sm:px-6 lg:px-8">
        <div class="mx-auto max-w-3xl text-center">
          <p class="text-xs font-bold tracking-[0.24em] text-emerald-300 uppercase">One command</p>
          <h2 class="mt-4 text-3xl leading-tight font-black text-white sm:text-4xl">Signed native builds, straight to the stores.</h2>
          <p class="mt-4 text-base leading-7 text-slate-300">
            Run the same build command locally or in CI. Capgo Builder handles the native build job, streams logs, signs the artifact, and can submit it after success.
          </p>
        </div>

        <div class="mx-auto mt-12 max-w-4xl overflow-hidden rounded-lg border border-white/10 bg-[#050911] shadow-2xl shadow-blue-950/30">
          <div class="flex items-center justify-between border-b border-white/10 bg-black/30 px-4 py-3">
            <div class="flex items-center gap-2">
              <span class="h-2.5 w-2.5 rounded-full bg-red-400"></span>
              <span class="h-2.5 w-2.5 rounded-full bg-amber-300"></span>
              <span class="h-2.5 w-2.5 rounded-full bg-emerald-400"></span>
            </div>
            <div class="text-xs text-slate-500">capgo-builder.log</div>
          </div>
          <div class="terminal-animation overflow-x-auto p-5 font-mono text-sm leading-7 text-slate-300 sm:p-8" aria-label="Animated Capgo Builder terminal log">
            <div class="terminal-line text-slate-500" style="--delay: 0ms"># Build and submit a signed iOS app</div>
            <div class="terminal-line min-w-max" style="--delay: 450ms">
              <span class="text-emerald-300">bunx</span> @capgo/cli build <span class="text-cyan-300">com.example.app</span> \
            </div>
            <div class="terminal-line pl-4 text-sky-300" style="--delay: 900ms">--platform <span class="text-slate-300">ios</span> \</div>
            <div class="terminal-line pl-4 text-sky-300" style="--delay: 1350ms">--build-mode <span class="text-slate-300">release</span> \</div>
            <div class="terminal-line pl-4 text-sky-300" style="--delay: 1800ms">--submit</div>
            <div class="terminal-line h-4" style="--delay: 2250ms"></div>
            <div class="terminal-line" style="--delay: 2700ms"><span class="text-emerald-300">ok</span> Creating build job</div>
            <div class="terminal-line" style="--delay: 3300ms"><span class="text-emerald-300">ok</span> Uploading native project inputs</div>
            <div class="terminal-line" style="--delay: 3900ms"><span class="text-amber-300">run</span> Installing native dependencies</div>
            <div class="terminal-line" style="--delay: 4500ms"><span class="text-amber-300">run</span> Building with Xcode on Apple Silicon</div>
            <div class="terminal-line" style="--delay: 5100ms"><span class="text-amber-300">run</span> Signing IPA from runtime credentials</div>
            <div class="terminal-line" style="--delay: 5700ms"><span class="text-emerald-300">ok</span> Build succeeded</div>
            <div class="terminal-line" style="--delay: 6300ms">
              <span class="text-emerald-300">ok</span> Submitted to App Store Connect<span class="terminal-cursor ml-1"></span>
            </div>
            <div class="mt-6 h-1 overflow-hidden rounded-full bg-white/10" aria-hidden="true">
              <div class="terminal-progress h-full rounded-full bg-linear-to-r from-emerald-300 via-cyan-300 to-blue-400"></div>
            </div>
          </div>
        </div>
      </div>
    </section>

    <section class="border-b border-white/10 py-20 sm:py-24">
      <div class="mx-auto max-w-6xl px-4 sm:px-6 lg:px-8">
        <div class="mx-auto max-w-2xl text-center">
          <p class="text-xs font-bold tracking-[0.24em] text-slate-500 uppercase">Built for shipping</p>
          <h2 class="mt-4 text-3xl leading-tight font-black text-white sm:text-4xl">No native build babysitting.</h2>
          <p class="mt-4 text-base leading-7 text-slate-300">Capgo Builder focuses on the work between a native change and a store-ready artifact.</p>
        </div>

        <div class="mt-12 grid gap-4 md:grid-cols-2 lg:grid-cols-3">
          {
            builderFeatures.map((feature) => (
              <article class="rounded-lg border border-white/10 bg-white/[0.04] p-6 transition hover:border-white/20 hover:bg-white/[0.06]">
                <div class:list={['mb-4 flex h-10 w-10 items-center justify-center rounded-lg border border-current/30 bg-current/10', feature.accent]}>
                  <svg class="h-5 w-5" viewBox="0 0 24 24" fill="none" aria-hidden="true">
                    <path d="M5 12.5 9.5 17 19 7" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" />
                  </svg>
                </div>
                <h3 class="text-lg font-bold text-white">{feature.title}</h3>
                <p class="mt-3 text-sm leading-6 text-slate-400">{feature.text}</p>
              </article>
            ))
          }
        </div>
      </div>
    </section>

    <section class="border-b border-white/10 bg-[#081322] py-20 sm:py-24">
      <div class="mx-auto max-w-6xl px-4 sm:px-6 lg:px-8">
        <div class="grid gap-10 lg:grid-cols-[0.9fr_1.1fr] lg:items-center">
          <div>
            <p class="text-xs font-bold tracking-[0.24em] text-emerald-300 uppercase">Setup</p>
            <h2 class="mt-4 text-3xl leading-tight font-black text-white sm:text-4xl">
              Setup in <span class="text-emerald-300 italic">60 seconds</span>.
            </h2>
            <p class="mt-4 text-base leading-7 text-slate-300">
              Add the command to a local script or CI job, pass signing values from secrets, and keep native release builds reproducible.
            </p>
            <div class="mt-7 rounded-lg border border-emerald-300/20 bg-emerald-300/10 px-4 py-3 font-mono text-sm text-emerald-100">
              bunx @capgo/cli build com.example.app --platform android
            </div>
          </div>

          <div class="rounded-lg border border-white/10 bg-[#050911] p-5">
            <ol class="space-y-4">
              {
                setupSteps.map((step, index) => (
                  <li class="flex gap-4">
                    <span class="flex h-8 w-8 shrink-0 items-center justify-center rounded-lg border border-white/10 bg-white/5 text-sm font-bold text-emerald-300">
                      {index + 1}
                    </span>
                    <p class="pt-1 text-sm leading-6 text-slate-300">{step}</p>
                  </li>
                ))
              }
            </ol>
          </div>
        </div>
      </div>
    </section>

    <section class="border-b border-white/10 py-20 sm:py-24">
      <div class="mx-auto max-w-6xl px-4 sm:px-6 lg:px-8">
        <div class="mx-auto max-w-2xl text-center">
          <p class="text-xs font-bold tracking-[0.24em] text-slate-500 uppercase">Security model</p>
          <h2 class="mt-4 text-3xl leading-tight font-black text-white sm:text-4xl">Your secrets stay your secrets.</h2>
          <p class="mt-4 text-base leading-7 text-slate-300">Capgo Builder is designed for teams that already treat signing material as sensitive CI data.</p>
        </div>

        <div class="mt-12 grid gap-4 md:grid-cols-2">
          {
            securityFeatures.map((feature) => (
              <article class="rounded-lg border border-white/10 bg-white/[0.04] p-6">
                <div class="mb-4 flex h-10 w-10 items-center justify-center rounded-lg border border-emerald-300/30 bg-emerald-300/10 text-emerald-300">
                  <svg class="h-5 w-5" viewBox="0 0 24 24" fill="none" aria-hidden="true">
                    <path d="M7 11V8a5 5 0 0 1 10 0v3" stroke="currentColor" stroke-width="2" stroke-linecap="round" />
                    <path d="M6 11h12v9H6z" stroke="currentColor" stroke-width="2" stroke-linejoin="round" />
                  </svg>
                </div>
                <h3 class="text-lg font-bold text-white">{feature.title}</h3>
                <p class="mt-3 text-sm leading-6 text-slate-400">{feature.text}</p>
              </article>
            ))
          }
        </div>
      </div>
    </section>

    <section class="border-b border-white/10 bg-[#081322] py-20 sm:py-24">
      <div class="mx-auto max-w-6xl px-4 sm:px-6 lg:px-8">
        <div class="mx-auto max-w-2xl text-center">
          <p class="text-xs font-bold tracking-[0.24em] text-slate-500 uppercase">Comparison</p>
          <h2 class="mt-4 text-3xl leading-tight font-black text-white sm:text-4xl">Capgo Builder vs. alternatives.</h2>
          <p class="mt-4 text-base leading-7 text-slate-300">Keep the native build path simple when your team mainly ships Capacitor apps.</p>
        </div>

        <div class="mt-12 space-y-4 lg:hidden">
          {
            comparisons.map((row) => (
              <article class="rounded-lg border border-white/10 bg-[#050911] p-5">
                <h3 class="text-sm font-black text-white">{row.feature}</h3>
                <dl class="mt-4 space-y-4 text-sm">
                  <div>
                    <dt class="text-xs font-bold tracking-wide text-emerald-200 uppercase">Capgo Builder</dt>
                    <dd class="mt-1 leading-6 text-emerald-100">{row.capgo}</dd>
                  </div>
                  <div>
                    <dt class="text-xs font-bold tracking-wide text-slate-500 uppercase">Local native builds</dt>
                    <dd class="mt-1 leading-6 text-slate-400">{row.local}</dd>
                  </div>
                  <div>
                    <dt class="text-xs font-bold tracking-wide text-slate-500 uppercase">Generic CI</dt>
                    <dd class="mt-1 leading-6 text-slate-400">{row.ci}</dd>
                  </div>
                </dl>
              </article>
            ))
          }
        </div>

        <div class="mt-12 hidden overflow-x-auto rounded-lg border border-white/10 lg:block">
          <table class="min-w-[860px] divide-y divide-white/10 bg-[#050911] text-left text-sm">
            <thead class="bg-white/[0.04] text-xs tracking-wide text-slate-400 uppercase">
              <tr>
                <th class="px-5 py-4 font-bold">Workflow</th>
                <th class="px-5 py-4 font-bold text-emerald-200">Capgo Builder</th>
                <th class="px-5 py-4 font-bold">Local native builds</th>
                <th class="px-5 py-4 font-bold">Generic CI</th>
              </tr>
            </thead>
            <tbody class="divide-y divide-white/10">
              {
                comparisons.map((row) => (
                  <tr>
                    <th class="w-40 px-5 py-5 align-top font-bold text-white">{row.feature}</th>
                    <td class="px-5 py-5 align-top text-emerald-100">{row.capgo}</td>
                    <td class="px-5 py-5 align-top text-slate-400">{row.local}</td>
                    <td class="px-5 py-5 align-top text-slate-400">{row.ci}</td>
                  </tr>
                ))
              }
            </tbody>
          </table>
        </div>
      </div>
    </section>

    {
      plans.length > 0 && (
        <section class="border-b border-white/10 py-20 sm:py-24">
          <div class="mx-auto max-w-6xl px-4 sm:px-6 lg:px-8">
            <div class="mx-auto max-w-2xl text-center">
              <p class="text-xs font-bold tracking-[0.24em] text-slate-500 uppercase">Pricing</p>
              <h2 class="mt-4 text-3xl leading-tight font-black text-white sm:text-4xl">Pay for build minutes. That's it.</h2>
              <p class="mt-4 text-base leading-7 text-slate-300">
                The real Capgo plans include native build minutes. Start with a 14-day free trial, then choose monthly or annual billing.
              </p>
            </div>

            <div class="mt-12 grid gap-4 md:grid-cols-2 xl:grid-cols-4">
              {plans.map((plan) => (
                <article
                  class:list={[
                    'flex rounded-lg border bg-white/[0.04] p-6',
                    {
                      'border-blue-400/70 shadow-lg shadow-blue-950/30': plan.name === 'Maker',
                      'border-white/10': plan.name !== 'Maker',
                    },
                  ]}
                >
                  <div class="flex w-full flex-col">
                    {plan.name === 'Maker' && <p class="mb-4 w-fit rounded-md bg-blue-500 px-3 py-1 text-xs font-bold text-white uppercase">Most popular</p>}
                    <h3 class="text-lg font-black text-white uppercase">{plan.name}</h3>
                    <p class="mt-2 min-h-10 text-sm leading-5 text-slate-400">{planDescription(plan)}</p>
                    <div class="mt-6">
                      <span class="text-4xl font-black text-white">{annualMonthlyPrice(plan)}</span>
                      <span class="text-sm text-slate-400">/mo</span>
                    </div>
                    <p class="mt-2 text-xs text-slate-500">{yearlyBilling(plan)}</p>
                    <p class="mt-1 text-xs text-slate-500">{monthlyPrice(plan)}</p>
                    <a
                      href={getRelativeLocaleUrl(locale, 'register')}
                      class:list={[
                        'mt-6 inline-flex min-h-10 items-center justify-center rounded-lg px-4 py-2 text-sm font-bold transition focus:ring-2 focus:outline-none',
                        {
                          'bg-blue-600 text-white hover:bg-blue-500 focus:ring-blue-300': plan.name === 'Maker',
                          'border border-white/15 bg-white/5 text-white hover:bg-white/10 focus:ring-white/30': plan.name !== 'Maker',
                        },
                      ]}
                    >
                      14-day free trial
                    </a>
                    <ul class="mt-6 space-y-3 text-sm text-slate-300">
                      <li class="flex gap-2">
                        <span class="text-emerald-300">+</span>
                        <span>{buildTimeDisplay(plan.build_time_unit, plan.name)}</span>
                      </li>
                      <li class="flex gap-2">
                        <span class="text-emerald-300">+</span>
                        <span>{formatNumber(plan.mau)} monthly active users</span>
                      </li>
                      <li class="flex gap-2">
                        <span class="text-emerald-300">+</span>
                        <span>{formatNumber(plan.bandwidth)} GiB bandwidth/month</span>
                      </li>
                      <li class="flex gap-2">
                        <span class="text-emerald-300">+</span>
                        <span>{formatNumber(plan.storage)} GiB storage</span>
                      </li>
                    </ul>
                  </div>
                </article>
              ))}
            </div>

            {buildCredits.length > 0 && (
              <div class="mt-6 rounded-lg border border-cyan-300/20 bg-cyan-300/10 p-4">
                <div class="flex flex-col gap-3 lg:flex-row lg:items-center lg:justify-between">
                  <p class="text-sm font-bold text-cyan-100">Extra build minutes use prepaid credits.</p>
                  <div class="flex flex-wrap gap-2">
                    {buildCredits.map((credit, index) => (
                      <span class="rounded-md border border-cyan-200/20 bg-black/20 px-3 py-1 text-xs text-cyan-100">
                        {creditStepLabel(credit, index, buildCredits.length)}: {creditPrice(credit)}
                      </span>
                    ))}
                  </div>
                </div>
              </div>
            )}
          </div>
        </section>
      )
    }

    <section class="border-b border-white/10 bg-[#081322] py-20 sm:py-24">
      <div class="mx-auto max-w-4xl px-4 sm:px-6 lg:px-8">
        <div class="mx-auto max-w-2xl text-center">
          <p class="text-xs font-bold tracking-[0.24em] text-slate-500 uppercase">FAQ</p>
          <h2 class="mt-4 text-3xl leading-tight font-black text-white sm:text-4xl">Specific answers to specific worries.</h2>
        </div>

        <div class="mt-10 divide-y divide-white/10 rounded-lg border border-white/10 bg-[#050911]">
          {
            faqs.map((item) => (
              <details class="group p-5">
                <summary class="flex cursor-pointer list-none items-center justify-between gap-4 text-left text-base font-bold text-white">
                  {item.question}
                  <span class="flex h-7 w-7 shrink-0 items-center justify-center rounded-md border border-white/10 text-slate-400 transition group-open:rotate-45">+</span>
                </summary>
                <p class="mt-4 max-w-3xl text-sm leading-6 text-slate-400">{item.answer}</p>
              </details>
            ))
          }
        </div>
      </div>
    </section>

    <section class="py-20 sm:py-24">
      <div class="mx-auto max-w-5xl px-4 text-center sm:px-6 lg:px-8">
        <p class="text-2xl font-black text-emerald-300">Capgo Builder</p>
        <h2 class="mt-3 text-3xl leading-tight font-black text-white sm:text-4xl">Native builds without the pain.</h2>
        <p class="mx-auto mt-4 max-w-2xl text-base leading-7 text-slate-300">
          Build signed iOS and Android releases from your machine or CI while keeping Capgo's existing site header, docs, and pricing flow.
        </p>
        <div class="mt-8 flex flex-col items-center justify-center gap-3 sm:flex-row">
          <a
            href={getRelativeLocaleUrl(locale, 'register')}
            class="inline-flex min-h-11 items-center justify-center rounded-lg bg-blue-600 px-6 py-3 text-sm font-bold text-white shadow-lg shadow-blue-950/40 transition hover:bg-blue-500 focus:ring-2 focus:ring-blue-300 focus:outline-none"
          >
            Start 14-day free trial
          </a>
          <a
            href={getRelativeLocaleUrl(locale, 'pricing')}
            class="inline-flex min-h-11 items-center justify-center rounded-lg border border-white/15 bg-white/5 px-6 py-3 text-sm font-bold text-white transition hover:border-white/30 hover:bg-white/10 focus:ring-2 focus:ring-white/30 focus:outline-none"
          >
            View real pricing
          </a>
        </div>
      </div>
    </section>
  </main>

  <style>
    .terminal-line {
      opacity: 0;
      transform: translateY(0.35rem);
      animation: terminal-line-in 520ms ease forwards;
      animation-delay: var(--delay);
    }

    .terminal-cursor {
      display: inline-block;
      width: 0.58ch;
      height: 1em;
      background: currentColor;
      vertical-align: -0.15em;
      animation: terminal-cursor-blink 900ms steps(1) infinite;
    }

    .terminal-progress {
      width: 100%;
      transform: scaleX(0);
      transform-origin: left;
      animation: terminal-progress-fill 7s ease forwards;
    }

    @keyframes terminal-line-in {
      to {
        opacity: 1;
        transform: translateY(0);
      }
    }

    @keyframes terminal-cursor-blink {
      50% {
        opacity: 0;
      }
    }

    @keyframes terminal-progress-fill {
      to {
        transform: scaleX(1);
      }
    }

    @media (prefers-reduced-motion: reduce) {
      .terminal-line,
      .terminal-progress,
      .terminal-cursor {
        animation: none;
        opacity: 1;
        transform: none;
      }
    }
  </style>
</Layout>
