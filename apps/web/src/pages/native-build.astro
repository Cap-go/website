    .nb .trust-cell::before {
      content: '';
      position: absolute;
      inset: -1px;
      border-radius: inherit;
      pointer-events: none;
      /* Static corner glow — no longer follows the cursor. */
      background: radial-gradient(170px 130px at 18% 0%, rgba(74, 222, 128, 0.12), transparent 70%);
      opacity: 0;
      transition: opacity 0.35s;
