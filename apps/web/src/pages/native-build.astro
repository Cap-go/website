            <div class="terminal-line" style="--delay: 2700ms"><span class="text-emerald-300">ok</span> {copy('native_build_builder_terminal_create')}</div>
            <div class="terminal-line" style="--delay: 3300ms"><span class="text-emerald-300">ok</span> {copy('native_build_builder_terminal_upload')}</div>
            <div class="terminal-line" style="--delay: 3900ms"><span class="text-amber-300">run</span> {copy('native_build_builder_terminal_install')}</div>
            <div class="terminal-line" style="--delay: 4500ms"><span class="text-amber-300">run</span> {copy('native_build_builder_terminal_build')}</div>
