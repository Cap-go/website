    }
    .nb .trust-cell.in-view .trust-icon {
      animation: nbTrustIconPulse 3.6s ease-in-out infinite;
    }
    .nb .trust-icon svg {
      width: 22px;
      height: 22px;
    }
    @keyframes nbTrustIconPulse {
      0%,
      100% {
        box-shadow: 0 0 0 0 rgba(74, 222, 128, 0.2);
      }
      50% {
        box-shadow: 0 0 0 6px rgba(74, 222, 128, 0);
      }
    }
    .nb .trust-cell .lbl {
      font-size: 11px;
      font-weight: 700;
      letter-spacing: 0.14em;
      text-transform: uppercase;
      color: var(--relief-green);
      margin-bottom: 8px;
    }
    .nb .trust-cell h3 {
      margin: 0 0 6px;
      font-size: 18px;
      font-weight: 700;
      letter-spacing: -0.005em;
    }
    .nb .trust-cell p {
      margin: 0;
      color: rgba(255, 255, 255, 0.62);
      font-size: 14px;
      line-height: 1.55;
    }
    .nb .trust-status {
      margin-top: 16px;
      display: flex;
      align-items: center;
      gap: 8px;
      font-family: var(--nb-font-mono);
      font-size: 11px;
      color: rgba(255, 255, 255, 0.55);
      letter-spacing: 0.04em;
    }
    .nb .trust-dot {
      width: 8px;
      height: 8px;
      border-radius: 50%;
      background: var(--relief-green);
      box-shadow: 0 0 6px var(--relief-green);
      flex-shrink: 0;
    }
    .nb .trust-cell.in-view .trust-dot--ok {
      animation: nbTrustBlink 2.4s ease-in-out infinite;
    }
    @keyframes nbTrustBlink {
      0%,
      92%,
      100% {
        opacity: 1;
      }
      95% {
        opacity: 0.25;
      }
    }
    .nb .trust-pulse {
      width: 10px;
      height: 10px;
      border-radius: 50%;
      background: var(--relief-green);
      position: relative;
      flex-shrink: 0;
      box-shadow: 0 0 8px var(--relief-green);
    }
    .nb .trust-cell.in-view .trust-pulse::after {
      content: '';
      position: absolute;
      inset: 0;
      border-radius: 50%;
      border: 1px solid var(--relief-green);
      animation: nbTrustRing 1.8s ease-out infinite;
    }
    @keyframes nbTrustRing {
      0% {
        transform: scale(1);
        opacity: 0.7;
      }
      100% {
        transform: scale(2.6);
        opacity: 0;
      }
    }
    .nb .trust-stream {
      display: inline-flex;
      gap: 2px;
      align-items: center;
      flex-shrink: 0;
    }
    .nb .trust-stream span {
      display: inline-block;
      width: 3px;
      height: 12px;
      background: var(--relief-green);
      border-radius: 1px;
      opacity: 0.4;
    }
    .nb .trust-cell.in-view .trust-stream span {
      animation: nbTrustBars 1.4s ease-in-out infinite;
    }
    .nb .trust-cell.in-view .trust-stream span:nth-child(1) {
      animation-delay: 0s;
    }
    .nb .trust-cell.in-view .trust-stream span:nth-child(2) {
      animation-delay: 0.15s;
    }
    .nb .trust-cell.in-view .trust-stream span:nth-child(3) {
      animation-delay: 0.3s;
    }
    .nb .trust-cell.in-view .trust-stream span:nth-child(4) {
      animation-delay: 0.45s;
    }
    @keyframes nbTrustBars {
      0%,
      100% {
        opacity: 0.25;
        transform: scaleY(0.5);
      }
      50% {
        opacity: 1;
        transform: scaleY(1);
      }
    }
    .nb .trust-decay {
      width: 10px;
      height: 10px;
      border-radius: 2px;
      background: var(--relief-green);
      flex-shrink: 0;
      box-shadow: 0 0 6px var(--relief-green);
    }
    .nb .trust-cell.in-view .trust-decay {
      animation: nbTrustDecay 2.2s ease-in-out infinite;
    }
    @keyframes nbTrustDecay {
      0% {
        transform: scale(1);
        opacity: 1;
        border-radius: 2px;
      }
      60% {
        transform: scale(0.4);
        opacity: 0.3;
        border-radius: 50%;
      }
      100% {
        transform: scale(1);
        opacity: 1;
        border-radius: 2px;
      }
    }

