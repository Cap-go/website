    align-items: center;
    gap: 14px;
    flex-wrap: wrap;
    justify-content: center;
    padding: 10px 12px 10px 18px;
    background: var(--terminal-bg);
    border: 1px solid rgba(255, 255, 255, 0.08);
    border-radius: 12px;
    box-shadow:
      0 0 0 1px rgba(74, 222, 128, 0.06),
      0 0 40px rgba(74, 222, 128, 0.06);
  }
  .nb .onboarding-cmd {
    font-family: var(--nb-font-mono);
    font-size: 15px;
    color: var(--terminal-fg);
    letter-spacing: 0.01em;
  }
  .nb .onboarding-cmd .ocm-prompt {
    color: var(--relief-green);
    margin-right: 8px;
  }
  .nb .onboarding-cmd .ocm-pkg {
    color: #fff;
  }
  .nb .onboarding-cmd .ocm-flag {
    color: rgba(255, 255, 255, 0.55);
  }
  .nb .onboarding-cmd .ocm-val {
    color: var(--accent-cyan);
    transition: color 0.2s;
  }
  .nb .onboarding-platform-toggle {
    display: inline-flex;
    background: rgba(255, 255, 255, 0.04);
    border: 1px solid rgba(255, 255, 255, 0.08);
    border-radius: 8px;
