        <div class="grid gap-10 lg:grid-cols-[0.9fr_1.1fr] lg:items-start">
          <div>
            <p class="text-xs font-bold tracking-[0.24em] text-slate-500 uppercase">{copy('native_build_builder_infra_eyebrow')}</p>
            <h2 class="mt-4 text-3xl leading-tight font-black text-white sm:text-4xl">{copy('native_build_builder_infra_title')}</h2>
