          <div>
            <p class="text-xs font-bold tracking-[0.24em] text-cyan-300 uppercase">{copy('native_build_builder_buyer_guide_eyebrow')}</p>
            <h2 class="mt-4 text-3xl leading-tight font-black text-white sm:text-4xl">{copy('native_build_builder_buyer_guide_title')}</h2>
            <p class="mt-4 text-base leading-7 text-slate-300">
              {copy('native_build_builder_buyer_guide_text')}
            </p>
          </div>
          <div class="grid gap-4 md:grid-cols-3">
            {
