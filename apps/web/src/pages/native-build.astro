---
import Layout from '@/layouts/Layout.astro'
import m, { type MessageValues } from '@/copy/messages'
import { createLdJsonGraph, createServiceLdJson } from '@/lib/ldJson'
import type { Database } from '@/services/supabase.types'
import { getRelativeLocaleUrl } from 'astro:i18n'

type Plan = Database['public']['Tables']['plans']['Row']

type Credit = {
  id: number
  step_min: number
  step_max: number
  price_per_unit: number
  type: string
  unit_factor: number
}

const locale = Astro.locals.locale
const brand = Astro.locals.runtimeConfig.public.brand
const config = Astro.locals.runtimeConfig

function copy(key: string, values: MessageValues = {}) {
  return m[key](values, { locale })
}

const builderTitle = copy('native_build_builder_title')
const title = `${brand} | ${builderTitle}`
const description = copy('native_build_builder_description')

let plansAll: Plan[] = []
let credits: Credit[] = []

try {
  const [plansResponse, creditsResponse] = await Promise.all([fetch(`${config.public.baseApiUrl}/private/plans`), fetch(`${config.public.baseApiUrl}/private/credits`)])

  plansAll = plansResponse.ok ? await plansResponse.json() : []
  credits = creditsResponse.ok ? await creditsResponse.json() : []
} catch (error) {
  console.warn('Unable to load Capgo Builder pricing data', error)
}

const plans = plansAll.filter((plan) => plan.name !== 'Free')
const buildCredits = credits.filter((credit) => credit.type === 'build_time').sort((a, b) => a.step_min - b.step_min)

// Tiered build-minute credit pricing, normalized to minutes — drives the calculator's price estimate.
const calcTiers = buildCredits.map((credit) => ({
  from: credit.step_min / credit.unit_factor,
  to: credit.step_max ? credit.step_max / credit.unit_factor : 0,
  price: credit.price_per_unit,
}))

const serviceLdJson = createServiceLdJson(Astro.locals.runtimeConfig.public, {
  name: title,
  description,
  url: Astro.url.href,
  serviceType: 'Cloud native mobile app build service',
  areaServed: ['Worldwide'],
})

const ldJSON = createLdJsonGraph(Astro.locals.runtimeConfig.public, serviceLdJson, {
  includeOrganization: true,
})

const content = {
  title,
  description,
  ldJSON,
}

const registerUrl = getRelativeLocaleUrl(locale, 'register')
const docsUrl = getRelativeLocaleUrl(locale, 'docs/cli/cloud-build/getting-started')
const pricingUrl = getRelativeLocaleUrl(locale, 'pricing')

const heroMeta = [copy('native_build_v2_meta_ios'), copy('native_build_v2_meta_android'), copy('native_build_v2_meta_nosdk'), copy('native_build_v2_meta_speed')]

const heroStrip = [
  { k: copy('native_build_v2_strip_ios_k'), v: copy('native_build_v2_strip_ios_v') },
  { k: copy('native_build_v2_strip_android_k'), v: copy('native_build_v2_strip_android_v') },
  { k: copy('native_build_v2_strip_build_k'), v: copy('native_build_v2_strip_build_v') },
  { k: copy('native_build_v2_strip_setup_k'), v: copy('native_build_v2_strip_setup_v') },
]

const comparisonRows = [
  {
    label: copy('native_build_v2_comp_setup_l'),
    hook: copy('native_build_v2_comp_setup_capgo_hook'),
    capgo: copy('native_build_v2_comp_setup_capgo'),
    diy: copy('native_build_v2_comp_setup_diy'),
    capa: copy('native_build_v2_comp_setup_capa'),
  },
  {
    label: copy('native_build_v2_comp_source_l'),
    hook: copy('native_build_v2_comp_source_capgo_hook'),
    capgo: copy('native_build_v2_comp_source_capgo'),
    diy: copy('native_build_v2_comp_source_diy'),
    capa: copy('native_build_v2_comp_source_capa'),
  },
  {
    label: copy('native_build_v2_comp_cred_l'),
    hook: copy('native_build_v2_comp_cred_capgo_hook'),
    capgo: copy('native_build_v2_comp_cred_capgo'),
    diy: copy('native_build_v2_comp_cred_diy'),
    capa: copy('native_build_v2_comp_cred_capa'),
  },
  {
    label: copy('native_build_v2_comp_logs_l'),
    hook: copy('native_build_v2_comp_logs_capgo_hook'),
    capgo: copy('native_build_v2_comp_logs_capgo'),
    diy: copy('native_build_v2_comp_logs_diy'),
    capa: copy('native_build_v2_comp_logs_capa'),
  },
  {
    label: copy('native_build_v2_comp_try_l'),
    hook: copy('native_build_v2_comp_try_capgo_hook'),
    capgo: copy('native_build_v2_comp_try_capgo'),
    diy: copy('native_build_v2_comp_try_diy'),
    capa: copy('native_build_v2_comp_try_capa'),
  },
  {
    label: copy('native_build_v2_comp_cost_l'),
    hook: copy('native_build_v2_comp_cost_capgo_hook'),
    capgo: copy('native_build_v2_comp_cost_capgo'),
    diy: copy('native_build_v2_comp_cost_diy'),
    capa: copy('native_build_v2_comp_cost_capa'),
  },
  {
    label: copy('native_build_v2_comp_ota_l'),
    hook: copy('native_build_v2_comp_ota_capgo_hook'),
    capgo: copy('native_build_v2_comp_ota_capgo'),
    diy: copy('native_build_v2_comp_ota_diy'),
    capa: copy('native_build_v2_comp_ota_capa'),
  },
  {
    label: copy('native_build_v2_comp_maint_l'),
    hook: copy('native_build_v2_comp_maint_capgo_hook'),
    capgo: copy('native_build_v2_comp_maint_capgo'),
    diy: copy('native_build_v2_comp_maint_diy'),
    capa: copy('native_build_v2_comp_maint_capa'),
  },
  {
    label: copy('native_build_v2_comp_ai_l'),
    hook: copy('native_build_v2_comp_ai_capgo_hook'),
    capgo: copy('native_build_v2_comp_ai_capgo'),
    diy: copy('native_build_v2_comp_ai_diy'),
    capa: copy('native_build_v2_comp_ai_capa'),
  },
]

const faqs = [
  { q: copy('native_build_v2_faq_q1'), a: copy('native_build_v2_faq_a1') },
  { q: copy('native_build_v2_faq_q2'), a: copy('native_build_v2_faq_a2') },
  { q: copy('native_build_v2_faq_q3'), a: copy('native_build_v2_faq_a3') },
  { q: copy('native_build_v2_faq_q4'), a: copy('native_build_v2_faq_a4') },
  { q: copy('native_build_v2_faq_q5'), a: copy('native_build_v2_faq_a5') },
  { q: copy('native_build_v2_faq_q6'), a: copy('native_build_v2_faq_a6') },
]

function annualMonthlyPrice(plan: Plan) {
  const price = Math.round(plan.price_y / 12)
  return plan.name === 'Enterprise' ? `$${price}+` : `$${price}`
}

function monthlyPrice(plan: Plan) {
  return copy('native_build_builder_month_to_month', { price: `$${plan.price_m}`, suffix: plan.name === 'Enterprise' ? '+' : '' })
}

function yearlyBilling(plan: Plan) {
  const amount = `$${formatNumber(plan.price_y)}`
  return plan.name === 'Enterprise' ? copy('native_build_builder_yearly_billing_enterprise', { amount }) : copy('native_build_builder_yearly_billing', { amount })
}

function planDescription(plan: Plan) {
  if (plan.name === 'Solo') return copy('plan_solo_desc')
  if (plan.name === 'Maker') return copy('plan_maker_desc')
  if (plan.name === 'Team') return copy('plan_team_desc')
  if (plan.name === 'Enterprise') return copy('plan_payasyougo_desc')
  return plan.market_desc ?? plan.description ?? ''
}

function formatNumber(value: number) {
  return new Intl.NumberFormat(locale).format(value)
}

function buildTimeDisplay(buildTimeSeconds: number, name?: string) {
  if (!buildTimeSeconds) return copy('native_build_builder_build_minutes_zero')

  const buildTimeHours = Math.floor(buildTimeSeconds / 3600)
  const buildTimeMinutes = Math.floor(buildTimeSeconds / 60)
  const suffix = name === 'Enterprise' ? '+' : ''

  if (buildTimeHours >= 1) {
    return copy(buildTimeHours === 1 ? 'native_build_builder_build_hour' : 'native_build_builder_build_hours', { count: buildTimeHours, suffix })
  }

  return copy('native_build_builder_build_minutes', { count: buildTimeMinutes, suffix })
}
---

<Layout content={content}>
  <div class="nb bg-ad">
    <!-- ============================================ HERO ============================================ -->
    <section class="section hero bg-grid grain" id="top">
      <div class="shell">
        <div class="beta-badge">
          <span class="dot"></span>
          {copy('native_build_v2_hero_badge')}
        </div>
        <h1 class="hero-banner" aria-label="Capgo Builder">
          <span class="hbv-underlined">
            <span class="hbv-u-name">Capgo Builder</span>
            <span class="hbv-u-rule"></span>
          </span>
          <span class="hero-banner-tag">{copy('native_build_v2_hero_tagline')}</span>
        </h1>
        <p class="lead hero-lead">{copy('native_build_v2_hero_lead')}</p>
        <div class="hero-ctas">
          <a class="btn btn-lg btn-primary" href={registerUrl}>{copy('native_build_builder_start_trial')}</a>
          <a class="btn btn-lg btn-ghost" href="#how">{copy('native_build_v2_hero_secondary')} ↓</a>
        </div>
        <div class="hero-meta">
          {
            heroMeta.map((item) => (
              <span>
                <span class="check">✓</span>
                {item}
              </span>
            ))
          }
        </div>

        <div class="hero-strip" aria-hidden="true">
          {
            heroStrip.map((cell) => (
              <div class="hero-strip-cell">
                <div class="k">{cell.k}</div>
                <div class="v">{cell.v}</div>
              </div>
            ))
          }
        </div>
      </div>
    </section>

    <!-- ============================================ REVEAL + DEMO ============================================ -->
    <section class="section bg-grid grain" id="how">
      <div class="shell">
        <div class="rv-one">
          <div class="rv-one-mark">Capgo Builder</div>
          <p class="rv-one-line">{copy('native_build_v2_reveal_line')}</p>
        </div>

        <div class="demo-wrap">
          <div class="terminal-frame">
            <div class="terminal-bar">
              <span class="dot r"></span><span class="dot y"></span><span class="dot g"></span>
              <span class="title" id="demo-term-title">capgo build request --platform ios</span>
              <div class="demo-tabs">
                <button id="demo-tab-ios" class="demo-tab active" type="button">iOS</button>
                <button id="demo-tab-android" class="demo-tab" type="button">Android</button>
              </div>
            </div>
            <div class="terminal-body" id="demo-term-body" aria-live="polite"></div>
          </div>
          <div class="demo-controls">
            <span>{copy('native_build_v2_demo_hint')}</span>
            <button class="demo-replay" id="demo-replay" type="button">⟲ {copy('native_build_v2_demo_replay')}</button>
          </div>
        </div>
      </div>
    </section>

    <!-- ============================================ BENTO ============================================ -->
    <section class="section" id="features">
      <div class="shell">
        <div class="section-head">
          <div class="eyebrow">{copy('native_build_v2_bento_eyebrow')}</div>
          <h2 class="h2-section">{copy('native_build_v2_bento_title')}</h2>
          <p class="lead">{copy('native_build_v2_bento_lead')}</p>
        </div>

        <div class="bento" id="bento">
          <div class="tile tile-hero" data-accent="green" aria-label="Capgo Builder">
            <div>
              <div class="ttl">
                <span class="name">Capgo Builder</span><br />
                <span class="tile-hero-sub-ttl">{copy('native_build_v2_tile_hero_title')}</span>
              </div>
              <div class="sub">{copy('native_build_v2_tile_hero_sub')}</div>
            </div>
            <pre class="ascii">$ capgo build request --platform ios      ✔ 2m 41s
$ capgo build request --platform android  ✔ 1m 22s</pre>
          </div>

          <div class="tile" data-expandable data-accent="cyan">
            <span class="icon"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M6 8l4 4-4 4"/><path d="M13 16h5"/></svg></span>
            <h3 class="ttl"><span class="ttl-accent">{copy('native_build_v2_tile_cli_title')}</span></h3>
            <p class="sub">{copy('native_build_v2_tile_cli_sub')}</p>
            <div class="more">
              <code class="mono">capgo build request --platform ios</code> archives, signs and uploads to TestFlight. <code class="mono">--platform android</code> assembles, signs with your
              keystore and uploads to Play. One CLI, identical UX.
            </div>
          </div>

          <div class="tile" data-expandable data-accent="yellow">
            <span class="icon"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><rect x="7" y="7" width="10" height="10" rx="1.5"/><path d="M10 7V4M14 7V4M10 20v-3M14 20v-3M7 10H4M7 14H4M20 10h-3M20 14h-3"/></svg></span>
            <h3 class="ttl"><span class="ttl-accent">{copy('native_build_v2_tile_hw_title')}</span></h3>
            <p class="sub">{copy('native_build_v2_tile_hw_sub')}</p>
            <div class="more">
              iOS jobs run on M-series Mac runners — fast Xcode + Fastlane. Android jobs run on Linux Docker — fast Gradle, roughly half the cost of iOS, no Mac required. You don't
              pick the runner; we do, by platform flag.
            </div>
          </div>

          <div class="tile" data-expandable data-accent="green">
            <span class="icon"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M12 3l7 3v5c0 4.5-3 7.5-7 9-4-1.5-7-4.5-7-9V6z"/><path d="M9 12l2 2 4-4"/></svg></span>
            <h3 class="ttl"><span class="ttl-accent">{copy('native_build_v2_tile_sec_title')}</span></h3>
            <p class="sub">{copy('native_build_v2_tile_sec_sub')}</p>
            <div class="more">
              Credentials live locally at <code class="mono">~/.capgo-credentials/credentials.json</code>, are sent only to ephemeral build envs over HTTPS, and are wiped the instant
              the build ends. Logs stream straight to your terminal — never written to Capgo disk.
            </div>
          </div>

          <div class="tile" data-expandable data-accent="purple">
            <span class="icon"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M12 16V5"/><path d="M8 9l4-4 4 4"/><path d="M5 19h14"/></svg></span>
            <h3 class="ttl"><span class="ttl-accent">{copy('native_build_v2_tile_asc_title')}</span></h3>
            <p class="sub">{copy('native_build_v2_tile_asc_sub')}</p>
            <div class="more">
              Default <code class="mono">app_store</code> distribution uploads straight to App Store Connect / TestFlight via Fastlane; Android bundles go to the Play Console. Pick
              <code class="mono">ad_hoc</code> for internal-only iOS builds — skips ASC validation.
            </div>
          </div>

          <div class="tile" data-expandable data-accent="orange">
            <span class="icon"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M3 12h3l2.5-7 5 14 2.5-7H21"/></svg></span>
            <h3 class="ttl"><span class="ttl-accent">{copy('native_build_v2_tile_logs_title')}</span></h3>
            <p class="sub">{copy('native_build_v2_tile_logs_sub')}</p>
            <div class="more">
              Logs stream over WebSocket with heartbeat + ack. A <code class="mono">qr_download_link</code> message renders a scannable QR + URL for APK / IPA downloads right in your
              terminal.
            </div>
          </div>

          <div class="tile" data-expandable data-accent="pink">
            <span class="icon"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M12 3l9 5-9 5-9-5z"/><path d="M3 13l9 5 9-5"/></svg></span>
            <h3 class="ttl"><span class="ttl-accent">{copy('native_build_v2_tile_flavors_title')}</span></h3>
            <p class="sub">{copy('native_build_v2_tile_flavors_sub')}</p>
            <div class="more">
              <code class="mono">--android-flavor production</code> for any flavor your <code class="mono">build.gradle</code> declares. We auto-detect Cordova plugins from
              <code class="mono">capacitor-cordova-android-plugins/build.gradle</code> — no manual config. Keystore + Play service-account JSON passed by flag.
            </div>
          </div>

          <div class="tile" data-expandable data-accent="sky">
            <span class="icon"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><circle cx="12" cy="14" r="7"/><path d="M12 14V10"/><path d="M9.5 3h5"/><path d="M18.5 8l1.4-1.4"/></svg></span>
            <h3 class="ttl"><span class="ttl-accent">{copy('native_build_v2_tile_setup_title')}</span></h3>
            <p class="sub">{copy('native_build_v2_tile_setup_sub')}</p>
            <div class="more">
              <code class="mono">npx @capgo/cli@latest build init --platform ios|android</code> launches a wizard. iOS: drop a <code class="mono">.p8</code> → CSR, certificate, P12, bundle
              ID, provisioning profiles, all auto. Android: one OAuth click → Play Console project, service account, keystore, all auto. Resumable, Ctrl-C-safe, runs the same in CI.
            </div>
          </div>

          <div class="tile" data-expandable data-accent="violet">
            <span class="icon"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M4 12a8 8 0 0 1 13.7-5.6L20 8"/><path d="M20 4v4h-4"/><path d="M20 12a8 8 0 0 1-13.7 5.6L4 16"/><path d="M4 20v-4h4"/></svg></span>
            <h3 class="ttl"><span class="ttl-accent">{copy('native_build_v2_tile_ci_title')}</span></h3>
            <p class="sub">{copy('native_build_v2_tile_ci_sub')}</p>
            <div class="more">
              Single command, environment-variable-driven. No TTY, no prompts. Drop it into your existing pipeline and the same wizard-generated credentials work non-interactively.
            </div>
          </div>
        </div>

        <p class="bento-hint">{copy('native_build_v2_bento_hint')}</p>
      </div>
    </section>

    <!-- ============================================ ONBOARDING WIZARD ============================================ -->
    <section class="section bg-grid grain" id="onboarding">
      <div class="shell">
        <div class="section-head section-head--wide">
          <div class="eyebrow eyebrow--green">{copy('native_build_v2_wiz_eyebrow')}</div>
          <h2 class="h2-section">
            {copy('native_build_v2_wiz_title_prefix')}<span class="accent-green">{copy('native_build_v2_wiz_title_time')}.</span>
          </h2>
          <p class="lead">{copy('native_build_v2_wiz_lead')}</p>
          <div class="onboarding-cmd-row">
            <code class="onboarding-cmd"
              ><span class="ocm-prompt">$</span> npx <span class="ocm-pkg">@capgo/cli@latest</span> build init <span class="ocm-flag">--platform</span> <span class="ocm-val" id="ocm-platform"
                >ios</span
              ></code
            >
            <div class="onboarding-platform-toggle" role="tablist" aria-label="Platform">
              <button class="opt active" data-platform="ios" type="button" role="tab" aria-selected="true">iOS</button>
              <button class="opt" data-platform="android" type="button" role="tab" aria-selected="false">Android</button>
            </div>
          </div>
        </div>

        <div class="wizard" id="wizard" data-platform="ios">
          <div class="wizard-steps" role="tablist">
            <button class="wizard-step active" data-platform="ios" type="button"
              ><span class="num">1</span><span><span class="lbl">{copy('native_build_v2_wiz_ios_s1_l')}</span><span class="dsc">{copy('native_build_v2_wiz_ios_s1_d')}</span></span></button
            >
            <button class="wizard-step" data-platform="ios" type="button"
              ><span class="num">2</span><span><span class="lbl">{copy('native_build_v2_wiz_ios_s2_l')}</span><span class="dsc">{copy('native_build_v2_wiz_ios_s2_d')}</span></span></button
            >
            <button class="wizard-step" data-platform="ios" type="button"
              ><span class="num">3</span><span><span class="lbl">{copy('native_build_v2_wiz_ios_s3_l')}</span><span class="dsc">{copy('native_build_v2_wiz_ios_s3_d')}</span></span></button
            >
            <button class="wizard-step" data-platform="ios" type="button"
              ><span class="num">4</span><span><span class="lbl">{copy('native_build_v2_wiz_ios_s4_l')}</span><span class="dsc">{copy('native_build_v2_wiz_ios_s4_d')}</span></span></button
            >
            <button class="wizard-step active" data-platform="android" type="button" hidden
              ><span class="num">1</span><span><span class="lbl">{copy('native_build_v2_wiz_and_s1_l')}</span><span class="dsc">{copy('native_build_v2_wiz_and_s1_d')}</span></span></button
            >
            <button class="wizard-step" data-platform="android" type="button" hidden
              ><span class="num">2</span><span><span class="lbl">{copy('native_build_v2_wiz_and_s2_l')}</span><span class="dsc">{copy('native_build_v2_wiz_and_s2_d')}</span></span></button
            >
            <button class="wizard-step" data-platform="android" type="button" hidden
              ><span class="num">3</span><span><span class="lbl">{copy('native_build_v2_wiz_and_s3_l')}</span><span class="dsc">{copy('native_build_v2_wiz_and_s3_d')}</span></span></button
            >
            <button class="wizard-step" data-platform="android" type="button" hidden
              ><span class="num">4</span><span><span class="lbl">{copy('native_build_v2_wiz_and_s4_l')}</span><span class="dsc">{copy('native_build_v2_wiz_and_s4_d')}</span></span></button
            >
          </div>
          <div class="wizard-stage" id="wizard-stage"></div>
        </div>

        <div class="wizard-before-after">
          <span class="ba b" id="ba-before">{copy('native_build_v2_wiz_ios_before')}</span>
          <span class="ba-arrow">→</span>
          <span class="ba a" id="ba-after">{copy('native_build_v2_wiz_ios_after')}</span>
        </div>
      </div>
    </section>

    <!-- ============================================ TRUST ============================================ -->
    <section class="section bg-grid grain" id="trust">
      <div class="shell">
        <div class="section-head">
          <div class="eyebrow">{copy('native_build_v2_trust_eyebrow')}</div>
          <h2 class="h2-section">{copy('native_build_v2_trust_title')}</h2>
          <p class="lead">{copy('native_build_v2_trust_lead')}</p>
        </div>

        <div class="trust-grid" id="trust-grid">
          <div class="trust-cell" data-trust="storage">
            <div class="trust-icon" aria-hidden="true">
              <svg viewBox="0 0 32 32" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
                <rect x="6" y="13" width="20" height="14" rx="2"></rect>
                <path d="M10 13V9a6 6 0 0 1 12 0v4"></path>
                <circle cx="16" cy="20" r="1.5" fill="currentColor"></circle>
                <path d="M16 21.5v2.5"></path>
              </svg>
            </div>
            <div class="lbl">{copy('native_build_v2_trust_stor_lbl')}</div>
            <h3>{copy('native_build_v2_trust_stor_h')}</h3>
            <p>{copy('native_build_v2_trust_stor_p')}</p>
            <div class="trust-status" aria-hidden="true">
              <span class="trust-dot trust-dot--ok"></span>
              <span>{copy('native_build_v2_trust_stor_s')}</span>
            </div>
          </div>

          <div class="trust-cell" data-trust="transit">
            <div class="trust-icon" aria-hidden="true">
              <svg viewBox="0 0 32 32" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
                <path d="M4 24c0-7 5-12 12-12s12 5 12 12"></path>
                <path d="M9 24c0-4 3-7 7-7s7 3 7 7"></path>
                <circle cx="16" cy="24" r="1.5" fill="currentColor"></circle>
              </svg>
            </div>
            <div class="lbl">{copy('native_build_v2_trust_trans_lbl')}</div>
            <h3>{copy('native_build_v2_trust_trans_h')}</h3>
            <p>{copy('native_build_v2_trust_trans_p')}</p>
            <div class="trust-status" aria-hidden="true">
              <span class="trust-pulse"></span>
              <span>{copy('native_build_v2_trust_trans_s')}</span>
            </div>
          </div>

          <div class="trust-cell" data-trust="logs">
            <div class="trust-icon" aria-hidden="true">
              <svg viewBox="0 0 32 32" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
                <path d="M4 16c3-5 7-7 12-7s9 2 12 7c-3 5-7 7-12 7s-9-2-12-7z"></path>
                <circle cx="16" cy="16" r="3"></circle>
                <path d="M6 6l20 20" stroke-width="2"></path>
              </svg>
            </div>
            <div class="lbl">{copy('native_build_v2_trust_logs_lbl')}</div>
            <h3>{copy('native_build_v2_trust_logs_h')}</h3>
            <p>{copy('native_build_v2_trust_logs_p')}</p>
            <div class="trust-status trust-status--stream" aria-hidden="true">
              <span class="trust-stream"><span></span><span></span><span></span><span></span></span>
              <span>{copy('native_build_v2_trust_logs_s')}</span>
            </div>
          </div>

          <div class="trust-cell" data-trust="isolation">
            <div class="trust-icon" aria-hidden="true">
              <svg viewBox="0 0 32 32" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
                <path d="M16 4l10 5v9c0 6-4 9-10 10-6-1-10-4-10-10V9l10-5z"></path>
                <path d="M12 16l3 3 6-6"></path>
              </svg>
            </div>
            <div class="lbl">{copy('native_build_v2_trust_iso_lbl')}</div>
            <h3>{copy('native_build_v2_trust_iso_h')}</h3>
            <p>{copy('native_build_v2_trust_iso_p')}</p>
            <div class="trust-status" aria-hidden="true">
              <span class="trust-decay"></span>
              <span>{copy('native_build_v2_trust_iso_s')}</span>
            </div>
          </div>
        </div>

      </div>
    </section>

    <!-- ============================================ COMPARISON ============================================ -->
    <section class="section" id="compare">
      <div class="shell">
        <div class="section-head">
          <div class="eyebrow">{copy('native_build_v2_comp_eyebrow')}</div>
          <h2 class="h2-section">{copy('native_build_v2_comp_title')}</h2>
          <p class="lead">{copy('native_build_v2_comp_lead')}</p>
        </div>

        <div class="comp-wrap">
          <table class="comp comp-prose">
            <thead>
              <tr>
                <th></th>
                <th class="us">Capgo Builder</th>
                <th>
                  {copy('native_build_v2_comp_h_diy')}
                  <span class="th-sub">{copy('native_build_v2_comp_h_diy_sub')}</span>
                </th>
                <th>{copy('native_build_v2_comp_h_capa')}</th>
              </tr>
            </thead>
            <tbody>
              {
                comparisonRows.map((row) => (
                  <tr>
                    <td class="label">{row.label}</td>
                    <td class="us">
                      <span class="hook">{row.hook}</span> {row.capgo}
                    </td>
                    <td>{row.diy}</td>
                    <td>{row.capa}</td>
                  </tr>
                ))
              }
            </tbody>
          </table>
        </div>

        <aside class="comp-callout" role="note">
          <p>{copy('native_build_v2_comp_callout')}</p>
        </aside>

        <p class="comp-footnote">{copy('native_build_v2_comp_footnote')}</p>
      </div>
    </section>

    <!-- ============================================ AI DEBUG ============================================ -->
    <section class="section" id="ai-debug">
      <div class="shell">
        <div class="section-head">
          <div class="eyebrow eyebrow--green">{copy('native_build_v2_aidebug_eyebrow')}</div>
          <h2 class="h2-section">{copy('native_build_v2_aidebug_title')}</h2>
          <p class="lead">{copy('native_build_v2_aidebug_lead')}</p>
        </div>

        <div class="aidebug-grid">
          <div class="aidebug-termcol">
          <div class="terminal-frame aidebug-term">
            <div class="terminal-bar">
              <span class="dot r"></span><span class="dot y"></span><span class="dot g"></span>
              <span class="title">capgo build request --platform ios</span>
            </div>
            <div class="terminal-body aidebug-body" aria-label="Example of an AI-assisted build failure diagnosis">
              <span class="row"><span class="pain-prompt">$ </span><span class="cmd">capgo build request</span> <span class="flag">--platform</span> <span class="val">ios</span></span>
              <span class="row"><span class="dim">[CapApp]</span> Creating App.xcarchive</span>
              <span class="row"><span class="err">✖ Archive failed — Command CodeSign failed with a nonzero exit code</span></span>
              <span class="row"><span class="err">&nbsp;&nbsp;error: No profile matching 'com.acme.app' found for team ABC123</span></span>
              <span class="row ai-head"><span class="kw">?</span> Choose AI analysis <span class="ghost">— optional</span></span>
              <span class="row" data-menu-selected><span class="ok">✔</span> <span class="val">Capgo AI</span></span>
              <span class="row menu-extra"><span class="dim">&nbsp;&nbsp;Local AI · write the prompt to a file</span></span>
              <span class="row menu-extra" data-collapse><span class="dim">&nbsp;&nbsp;Skip</span></span>
              <span class="row ai-head" data-ai-spin><span class="ok">✔</span> <span class="ghost">Capgo AI finished</span></span>
              <span class="row"><span class="ok">◆ Likely cause</span></span>
              <span class="row"><span class="ghost">Your App Store provisioning profile doesn't include the bundle ID com.acme.app.</span></span>
              <span class="row ai-head"><span class="ok">◆ Fix</span></span>
              <span class="row"><span class="ghost">Regenerate the profile for that bundle ID, or run </span><span class="cmd">capgo build init --platform ios</span></span>
              <span class="row"><span class="ghost">to recreate certificate + profile automatically, then re-run the build.</span></span>
            </div>
          </div>
            <div class="demo-controls aidebug-controls">
              <span>Optional — only runs if you choose Capgo AI</span>
              <button class="demo-replay" id="aidebug-replay" type="button">⟲ Replay</button>
            </div>
          </div>

          <ul class="aidebug-points">
            <li>
              <h3>{copy('native_build_v2_aidebug_p1_t')}</h3>
              <p>{copy('native_build_v2_aidebug_p1_d')}</p>
            </li>
            <li>
              <h3>{copy('native_build_v2_aidebug_p2_t')}</h3>
              <p>{copy('native_build_v2_aidebug_p2_d')}</p>
            </li>
            <li>
              <h3>{copy('native_build_v2_aidebug_p3_t')}</h3>
              <p>{copy('native_build_v2_aidebug_p3_d')}</p>
            </li>
          </ul>
        </div>
      </div>
    </section>

    <!-- ============================================ PRICING (live plans) ============================================ -->
    {
      plans.length > 0 && (
        <section class="section bg-grid grain" id="pricing">
          <div class="shell">
            <div class="section-head">
              <div class="eyebrow">{copy('native_build_builder_pricing_eyebrow')}</div>
              <h2 class="h2-section">{copy('native_build_builder_pricing_title')}</h2>
              <p class="lead">{copy('native_build_builder_pricing_text')}</p>
            </div>

            <div class="pricing-grid">
              {plans.map((plan) => (
                <div class:list={['tier', { pop: plan.name === 'Maker' }]}>
                  <div>
                    <div class="name">{plan.name === 'Maker' ? `${plan.name} · ${copy('most_popular')}` : plan.name}</div>
                    <div class="price">
                      {annualMonthlyPrice(plan)}
                      <small> / mo</small>
                    </div>
                  </div>
                  <p class="what">{planDescription(plan)}</p>
                  <p class="tier-billing">{yearlyBilling(plan)}</p>
                  <p class="tier-billing">{monthlyPrice(plan)}</p>
                  <a class:list={['btn btn-md', plan.name === 'Maker' ? 'btn-primary' : 'btn-ghost']} href={registerUrl}>
                    {copy('native_build_builder_plan_trial')}
                  </a>
                  <ul>
                    <li>{buildTimeDisplay(plan.build_time_unit, plan.name)}</li>
                    <li>{copy('native_build_v2_plan_ota')}</li>
                  </ul>
                </div>
              ))}
            </div>

            <div class="build-calc" aria-label="Build minutes calculator" data-tiers={JSON.stringify(calcTiers)}>
              <div class="build-calc-head">{copy('native_build_v2_calc_title')}</div>
              <input class="build-calc-range" type="range" min="30" max="600" step="10" value="60" id="bc-range" aria-label={copy('native_build_v2_calc_minutes')} />
              <div class="build-calc-readout"><span id="bc-min">60</span> {copy('native_build_v2_calc_minutes')}</div>
              <div class="build-calc-results">
                <div class="bc-res">
                  <span class="bc-ico" aria-hidden="true"
                    ><svg viewBox="0 0 24 24" fill="currentColor"
                      ><path
                        d="M16.36 12.6c-.02-2.3 1.88-3.4 1.96-3.46-1.07-1.56-2.74-1.78-3.33-1.8-1.42-.14-2.77.83-3.49.83-.72 0-1.83-.81-3-.79-1.55.02-2.98.9-3.78 2.29-1.61 2.8-.41 6.95 1.16 9.23.77 1.11 1.69 2.36 2.89 2.31 1.16-.05 1.6-.75 3-.75s1.79.75 3.01.72c1.24-.02 2.03-1.13 2.79-2.25.88-1.29 1.24-2.54 1.26-2.6-.03-.01-2.41-.92-2.43-3.66zM14.04 5.5c.64-.78 1.07-1.86.95-2.94-.92.04-2.04.61-2.7 1.39-.59.69-1.11 1.79-.97 2.85 1.03.08 2.08-.52 2.72-1.3z"
                      /></svg
                    ></span>
                  <div><span class="bc-num" id="bc-ios">12</span><span class="bc-lbl">{copy('native_build_v2_calc_ios')}</span></div>
                </div>
                <div class="bc-res">
                  <span class="bc-ico" aria-hidden="true"
                    ><svg viewBox="0 0 24 24" fill="currentColor"
                      ><path
                        d="M17.6 9.48l1.84-3.18a.4.4 0 0 0-.69-.4l-1.86 3.23a11.43 11.43 0 0 0-8.78 0L6.25 5.9a.4.4 0 1 0-.69.4L7.4 9.48A10.78 10.78 0 0 0 2 18h20a10.78 10.78 0 0 0-5.4-8.52zM7 15.25a1 1 0 1 1 1-1 1 1 0 0 1-1 1zm10 0a1 1 0 1 1 1-1 1 1 0 0 1-1 1z"
                      /></svg
                    ></span>
                  <div><span class="bc-num" id="bc-and">24</span><span class="bc-lbl">{copy('native_build_v2_calc_android')}</span></div>
                </div>
              </div>
              {calcTiers.length > 0 && (
                <div class="build-calc-price">
                  ≈ <span id="bc-price">$10</span> {copy('native_build_v2_calc_price_label')}
                </div>
              )}
              <p class="build-calc-note">{copy('native_build_v2_calc_note')}</p>
            </div>

            <p class="pricing-fineprint">{copy('native_build_v2_pricing_fine')} <a href={pricingUrl}>capgo.app/pricing</a>.</p>
          </div>
        </section>
      )
    }

    <!-- ============================================ FAQ ============================================ -->
    <section class="section" id="faq">
      <div class="shell">
        <div class="section-head section-head--narrow">
          <div class="eyebrow">{copy('native_build_builder_faq_eyebrow')}</div>
          <h2 class="h2-section">{copy('native_build_builder_faq_title')}</h2>
        </div>

        <div class="faq">
          {
            faqs.map((item) => (
              <details>
                <summary>
                  {item.q}
                  <span class="plus">+</span>
                </summary>
                <div class="ans">{item.a}</div>
              </details>
            ))
          }
        </div>
      </div>
    </section>

    <!-- ============================================ FINAL CTA ============================================ -->
    <section class="section final bg-grid grain" id="cta">
      <div class="shell">
        <h2>
          <span class="name">Capgo Builder</span><br />
          {copy('native_build_v2_cta_title')}
        </h2>
        <p class="tagline">{copy('native_build_v2_cta_tagline')}</p>
        <a class="btn btn-lg btn-primary btn-cta" href={registerUrl}>{copy('native_build_builder_start_trial')} →</a>
        <div class="hero-meta hero-meta--cta">
          <span><span class="check">✓</span> {copy('native_build_v2_cta_meta1')}</span>
          <span><span class="check">✓</span> {copy('native_build_v2_cta_meta2')}</span>
          <span><span class="check">✓</span> {copy('native_build_v2_cta_meta3')}</span>
        </div>
      </div>
    </section>
  </div>

  <style is:global>
  /* ============================================================
     CAPGO BUILDER — /native-build/ redesign
     All rules scoped under .nb to avoid leaking into Header/Footer.
     ============================================================ */
  @font-face {
    font-family: 'Airbnb Cereal';
    src: url('/fonts/AirbnbCerealLight.woff') format('woff');
    font-weight: 300;
    font-style: normal;
    font-display: swap;
  }
  @font-face {
    font-family: 'Airbnb Cereal';
    src: url('/fonts/AirbnbCerealBook.woff') format('woff');
    font-weight: 400;
    font-style: normal;
    font-display: swap;
  }
  @font-face {
    font-family: 'Airbnb Cereal';
    src: url('/fonts/AirbnbCerealMedium.woff') format('woff');
    font-weight: 500;
    font-style: normal;
    font-display: swap;
  }
  @font-face {
    font-family: 'Airbnb Cereal';
    src: url('/fonts/AirbnbCerealBold.woff') format('woff');
    font-weight: 700;
    font-style: normal;
    font-display: swap;
  }
  @font-face {
    font-family: 'Airbnb Cereal';
    src: url('/fonts/AirbnbCerealExtraBold.woff') format('woff');
    font-weight: 800;
    font-style: normal;
    font-display: swap;
  }
  @font-face {
    font-family: 'Airbnb Cereal';
    src: url('/fonts/AirbnbCerealBlack.woff') format('woff');
    font-weight: 900;
    font-style: normal;
    font-display: swap;
  }

  .nb {
    /* ---- tokens ---- */
    --bg-deep: #080e1a;
    --bg-mid: #0d1525;
    --bg-near: #1a2a4a;
    --grid-line: rgba(96, 165, 250, 0.06);
    --relief-green: #4ade80;
    --relief-green-glow: rgba(74, 222, 128, 0.4);
    --accent-cyan: #22d3ee;
    --accent-yellow: #facc15;
    --accent-green: #4ade80;
    --accent-purple: #a78bfa;
    --accent-orange: #fb923c;
    --accent-pink: #f472b6;
    --accent-sky: #38bdf8;
    --accent-violet: #818cf8;
    --terminal-bg: #0a0d14;
    --terminal-fg: #c8d4e6;
    --terminal-dim: #5a6a82;
    --terminal-cmd: #93a4bd;
    --terminal-flag: #93a4bd;
    --terminal-val: #4ade80;
    --terminal-kw: #60a5fa;
    --terminal-err: #f87171;
    --cap-blue-600: #2563eb;
    --cap-blue-700: #1d4ed8;
    --nb-font-display: 'Airbnb Cereal', ui-sans-serif, system-ui, -apple-system, sans-serif;
    --nb-font-mono: ui-monospace, SFMono-Regular, 'SF Mono', Menlo, Consolas, 'Liberation Mono', monospace;

    position: relative;
    color: #fff;
    font-family: var(--nb-font-display);
    -webkit-font-smoothing: antialiased;
    -moz-osx-font-smoothing: grayscale;
    overflow-x: hidden;
  }
  .nb *,
  .nb *::before,
  .nb *::after {
    box-sizing: border-box;
  }
  .nb a {
    color: inherit;
    text-decoration: none;
  }
  .nb button {
    font-family: inherit;
    cursor: pointer;
  }
  .nb .mono {
    font-family: var(--nb-font-mono);
  }
  .nb .accent-green {
    color: var(--relief-green);
  }

  /* ---- page background ----
     Painted on <body> so it spans continuously behind the transparent site
     header AND the page content — no seam at the header/content boundary.
     Base stays gray-900 (the site's body + footer colour) so the top and
     bottom blend seamlessly into the rest of the site; only a soft blue halo
     sits behind the hero for atmosphere. */
  body:has(.nb) {
    background-color: var(--color-gray-900);
    background-image: radial-gradient(1200px 560px at 50% -40px, rgba(59, 130, 246, 0.16) 0%, rgba(59, 130, 246, 0.04) 45%, transparent 72%);
    background-repeat: no-repeat;
  }
  .nb.bg-ad {
    background: transparent;
  }

  /* On this page, hide the footer "Power your Capacitor apps…" plugins banner
     (first block inside the footer container: tagline + Install Plugin CTA). */
  body:has(.nb) footer > div > div:first-child {
    display: none !important;
  }
  .nb .bg-grid::before {
    content: '';
    position: absolute;
    inset: 0;
    background-image: linear-gradient(var(--grid-line) 1px, transparent 1px), linear-gradient(90deg, var(--grid-line) 1px, transparent 1px);
    background-size: 56px 56px;
    mask-image: radial-gradient(ellipse at 50% 40%, black 0%, transparent 75%);
    -webkit-mask-image: radial-gradient(ellipse at 50% 40%, black 0%, transparent 75%);
    pointer-events: none;
  }
  .nb .grain {
    position: relative;
  }
  .nb .grain::after {
    content: '';
    position: absolute;
    inset: 0;
    background-image: url("data:image/svg+xml;utf8,<svg xmlns='http://www.w3.org/2000/svg' width='120' height='120'><filter id='n'><feTurbulence type='fractalNoise' baseFrequency='0.9' numOctaves='2' stitchTiles='stitch'/><feColorMatrix values='0 0 0 0 0.7  0 0 0 0 0.8  0 0 0 0 1  0 0 0 0.06 0'/></filter><rect width='100%' height='100%' filter='url(%23n)'/></svg>");
    pointer-events: none;
    mix-blend-mode: overlay;
    opacity: 0.5;
  }

  /* ---- type ---- */
  .nb .eyebrow {
    font-size: 11px;
    font-weight: 700;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: rgba(255, 255, 255, 0.45);
  }
  .nb .eyebrow--green {
    color: var(--relief-green);
  }
  .nb .h2-section {
    font-weight: 800;
    letter-spacing: -0.025em;
    line-height: 1.05;
    font-size: clamp(2rem, 4.5vw, 3.5rem);
    color: #fff;
    margin: 14px 0 0;
  }
  .nb .lead {
    font-size: clamp(1rem, 1.4vw, 1.2rem);
    line-height: 1.55;
    color: rgba(255, 255, 255, 0.62);
    font-weight: 400;
    margin: 18px 0 0;
  }

  /* ---- layout ---- */
  .nb .shell {
    max-width: 1200px;
    margin: 0 auto;
    padding: 0 24px;
  }
  .nb .section {
    position: relative;
    padding: 96px 0;
    overflow: hidden;
    scroll-margin-top: 84px;
  }
  @media (max-width: 720px) {
    .nb .section {
      padding: 64px 0;
    }
  }
  .nb .section-head {
    text-align: center;
    max-width: 760px;
    margin: 0 auto;
  }
  .nb .section-head--wide {
    max-width: 820px;
  }
  .nb .section-head--narrow {
    max-width: 640px;
  }

  /* ---- buttons ---- */
  .nb .btn {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: 8px;
    font-weight: 600;
    border-radius: 12px;
    border: 0;
    transition: all 0.18s ease;
    white-space: nowrap;
  }
  .nb .btn-lg {
    padding: 14px 24px;
    font-size: 16px;
  }
  .nb .btn-md {
    padding: 10px 18px;
    font-size: 14px;
  }
  .nb .btn-primary {
    background: var(--cap-blue-600);
    color: #fff;
    box-shadow: 0 0 36px rgba(37, 99, 235, 0.42);
  }
  .nb .btn-primary:hover {
    background: var(--cap-blue-700);
    box-shadow: 0 0 50px rgba(37, 99, 235, 0.55);
    transform: translateY(-1px);
  }
  .nb .btn-ghost {
    background: rgba(255, 255, 255, 0.04);
    color: #fff;
    border: 1px solid rgba(255, 255, 255, 0.18);
  }
  .nb .btn-ghost:hover {
    background: rgba(255, 255, 255, 0.1);
    border-color: rgba(255, 255, 255, 0.3);
  }

  /* ---- hero ---- */
  .nb .hero {
    padding: 96px 0 80px;
    text-align: center;
  }
  @media (max-width: 720px) {
    .nb .hero {
      padding: 64px 0 56px;
    }
  }
  .nb .beta-badge {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    padding: 6px 12px;
    font-size: 12px;
    font-weight: 600;
    background: rgba(74, 222, 128, 0.08);
    border: 1px solid rgba(74, 222, 128, 0.3);
    color: var(--relief-green);
    border-radius: 999px;
    margin-bottom: 28px;
    letter-spacing: 0.04em;
  }
  .nb .beta-badge .dot {
