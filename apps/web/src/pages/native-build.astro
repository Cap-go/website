            lines: [
              '<span class="ok">✔</span> Play Developer ID linked',
              '<span class="ok">✔</span> Selected GCP project: <span class="kw">acme-prod</span>',
              '<span class="ok">✔</span> Enabled Android Publisher API',
              '<span class="ok">✔</span> Service account: <span class="kw">capgo-builder@acme.iam…</span>',
              '<span class="ok">✔</span> Invited into Play Console as Release Manager',
            ],
          },
          {
            title: 'Save & Build',
            lines: [
              '<span class="lock">🔒</span> Saved to <span class="kw">~/.capgo-credentials/credentials.json</span>',
              '<span class="ghost dim">  Keystore + service account stay on your machine.</span>',
              '<span class="dim">$ </span><span class="cmd">capgo build request</span> <span class="flag">--platform</span> <span class="val">android</span>',
              '<span class="ok">✔</span> Build complete in <span class="val">3m 02s</span>',
              '<span class="ok">✔</span> Uploaded to Play Console (internal) 🎉',
            ],
          },
        ],
      },
    }

    let currentPlatform = 'ios'
    let idx = 0
    let autoTimer: ReturnType<typeof setInterval> | null = null
    let started = false

    function getSteps() {
      return wizardEl!.querySelectorAll<HTMLElement>(`.wizard-step[data-platform="${currentPlatform}"]`)
    }

    function paint(i: number) {
      const c = PLATFORMS[currentPlatform].content[i]
      if (!c) return
      const total = PLATFORMS[currentPlatform].content.length
      stage!.innerHTML = `<h4>Step ${i + 1} / ${total} — ${c.title}</h4>${c.lines.map((l) => `<span class="row">${l}</span>`).join('')}`
      getSteps().forEach((s, j) => {
        s.classList.toggle('active', j === i)
        s.classList.toggle('done', j < i)
      })
    }

    function setPlatform(p: string) {
      if (!PLATFORMS[p] || p === currentPlatform) return
      if (autoTimer) {
        clearInterval(autoTimer)
        autoTimer = null
      }
      started = true
      currentPlatform = p
      wizardEl!.setAttribute('data-platform', p)
      wizardEl!.querySelectorAll<HTMLElement>('.wizard-step').forEach((s) => {
        s.hidden = s.getAttribute('data-platform') !== p
      })
      if (toggle) {
        toggle.querySelectorAll('.opt').forEach((b) => {
          const active = b.getAttribute('data-platform') === p
          b.classList.toggle('active', active)
          b.setAttribute('aria-selected', active ? 'true' : 'false')
        })
      }
      if (platformLabel) platformLabel.textContent = p
      if (baBefore) baBefore.textContent = PLATFORMS[p].before
      if (baAfter) baAfter.textContent = PLATFORMS[p].after
      getSteps().forEach((s, j) => {
        ;(s as HTMLElement).onclick = () => {
          idx = j
          paint(idx)
        }
      })
      idx = 0
      paint(0)
    }

    wizardEl.querySelectorAll<HTMLElement>('.wizard-step').forEach((s) => {
      s.hidden = s.getAttribute('data-platform') !== currentPlatform
    })
    getSteps().forEach((s, j) => {
      s.onclick = () => {
        idx = j
        paint(idx)
      }
    })
    paint(0)

    if (toggle) {
      toggle.querySelectorAll('.opt').forEach((b) => {
        b.addEventListener('click', () => setPlatform(b.getAttribute('data-platform') || 'ios'))
      })
    }

    const io = new IntersectionObserver(
      (entries) => {
        entries.forEach((e) => {
          if (e.isIntersecting && !started) {
            started = true
            autoTimer = setInterval(() => {
              idx++
              const len = PLATFORMS[currentPlatform].content.length
              if (idx >= len) {
                if (autoTimer) clearInterval(autoTimer)
                idx = len - 1
                return
              }
              paint(idx)
            }, 1700)
          }
        })
      },
      { threshold: 0.3 },
    )
    io.observe(stage)
  })()

  // ----------------------------------------------------------------
  // TRUST — toggle in-view animations (glow is static, not cursor-tracked)
  // ----------------------------------------------------------------
  ;(function trustInView() {
    const cells = document.querySelectorAll<HTMLElement>('.trust-cell')
    if (!cells.length) return

    if (!('IntersectionObserver' in window)) {
      cells.forEach((c) => c.classList.add('in-view'))
      return
    }
    const io = new IntersectionObserver(
      (entries) => {
        entries.forEach((e) => {
          if (e.isIntersecting) e.target.classList.add('in-view')
          else e.target.classList.remove('in-view')
        })
      },
      { threshold: 0.2 },
    )
    cells.forEach((c) => io.observe(c))
  })()

  // ----------------------------------------------------------------
  // BUILD-MINUTES CALCULATOR — rough "minutes → builds" estimate
  // ----------------------------------------------------------------
  ;(function buildCalc() {
    const root = document.querySelector('.build-calc')
    const range = document.getElementById('bc-range') as HTMLInputElement | null
    const minEl = document.getElementById('bc-min')
    const iosEl = document.getElementById('bc-ios')
    const andEl = document.getElementById('bc-and')
    const priceEl = document.getElementById('bc-price')
    if (!root || !range || !minEl || !iosEl || !andEl) return
    let tiers: { from: number; to: number; price: number }[] = []
    try {
      tiers = JSON.parse(root.getAttribute('data-tiers') || '[]')
    } catch (_) {}
    // Cost of `minutes` if bought as prepaid credits, summed across volume tiers.
    function priceFor(minutes: number) {
      let cost = 0
      for (const t of tiers) {
        const to = t.to && t.to > t.from ? t.to : Infinity
        if (minutes <= t.from) break
        cost += (Math.min(minutes, to) - t.from) * t.price
      }
      return cost
    }
    function update() {
      const m = parseInt(range!.value, 10) || 0
      minEl!.textContent = String(m)
      iosEl!.textContent = String(Math.max(0, Math.floor(m / 5))) // iOS ≈ 5 build-min
      andEl!.textContent = String(Math.max(0, Math.floor(m / 2.5))) // Android ≈ 2.5 build-min
      if (priceEl) priceEl.textContent = '$' + Math.round(priceFor(m))
    }
    range.addEventListener('input', update)
    update()
  })()

  // ----------------------------------------------------------------
  // AI-DEBUG TERMINAL — stream failure → choice → analysis once on view
  // ----------------------------------------------------------------
  ;(function aiDebugTerminal() {
    const body = document.querySelector<HTMLElement>('.aidebug-body')
    if (!body) return
    if (window.matchMedia('(prefers-reduced-motion: reduce)').matches) return // leave static
    const rows = Array.from(body.querySelectorAll<HTMLElement>('.row'))
    if (!rows.length) return
    const SPIN = ['⠋', '⠙', '⠹', '⠸', '⠼', '⠴', '⠦', '⠧', '⠇', '⠏']
    const selected = body.querySelector<HTMLElement>('[data-menu-selected]')
    const selCheck = selected ? selected.innerHTML : '' // "✔ Capgo AI" — confirmed
    const selCursor = '<span class="val">❯ Capgo AI</span>' // cursor while the menu is open
    let started = false
    let gen = 0

    rows.forEach((r) => {
      r.style.opacity = '0'
      r.style.transition = 'opacity 0.25s ease'
    })

    function run() {
      gen++
      const myGen = gen
      rows.forEach((r) => {
        r.style.opacity = '0'
        if (r.classList.contains('menu-extra')) r.style.display = '' // reset to CSS (hidden) for replay
      })
      let i = 0
      function step() {
        if (myGen !== gen) return
        if (i >= rows.length) return // pause at end
        const r = rows[i]
        // Reveal the other select options during the menu phase.
        if (r.classList.contains('menu-extra')) r.style.display = 'block'
        // While the menu is open, the chosen row shows the ❯ cursor (not yet confirmed).
        if (r.hasAttribute('data-menu-selected')) r.innerHTML = selCursor
        // The "Capgo AI finished" row plays a spinner first (build log analysis).
        if (r.hasAttribute('data-ai-spin')) {
          const finalHTML = r.innerHTML
          r.style.opacity = '1'
          let frame = 0
          const start = Date.now()
          const spin = () => {
            if (myGen !== gen) return
            r.innerHTML = `<span class="kw">${SPIN[frame % SPIN.length]}</span> <span class="ghost">Analyzing build log with Capgo AI…</span>`
            frame++
            if (Date.now() - start >= 1500) {
              r.innerHTML = finalHTML
              i++
              setTimeout(step, 320)
            } else {
              setTimeout(spin, 90)
            }
          }
          spin()
          return
        }
        r.style.opacity = '1'
        // After the last option, "submit" the select: collapse back to just the chosen one.
        if (r.hasAttribute('data-collapse')) {
          i++
          setTimeout(() => {
            if (myGen !== gen) return
            rows.forEach((x) => {
              if (x.classList.contains('menu-extra')) {
                x.style.opacity = '0'
                x.style.display = 'none'
              }
            })
            // Selection confirmed → ❯ becomes ✔.
            if (selected) selected.innerHTML = selCheck
            setTimeout(step, 360)
          }, 1100)
          return
        }
        i++
        // A longer beat before each "◆ / ?" heading so the menu + result land deliberately.
        const delay = r.classList.contains('ai-head') ? 560 : 240
        setTimeout(step, delay)
      }
      step()
    }

    const io = new IntersectionObserver(
      (entries) => {
        entries.forEach((e) => {
          if (e.isIntersecting && !started) {
            started = true
            setTimeout(run, 250)
          }
        })
      },
      { threshold: 0.35 },
    )
    io.observe(body)

    const replay = document.getElementById('aidebug-replay')
    if (replay) replay.addEventListener('click', run)
  })()
</script>

