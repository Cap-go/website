  .nb .wizard-stage h4 {
    margin: 0 0 10px;
    font-size: 13px;
    font-weight: 700;
    color: var(--relief-green);
    text-transform: uppercase;
    letter-spacing: 0.12em;
    font-family: var(--nb-font-display);
  }
  .nb .wizard-stage .row {
    display: block;
    margin: 4px 0;
  }
  .nb .wizard-stage .dim {
    color: var(--terminal-dim);
  }
  .nb .wizard-stage .cmd {
    color: var(--terminal-cmd);
  }
  .nb .wizard-stage .flag {
    color: var(--terminal-flag);
  }
  .nb .wizard-stage .val {
    color: var(--terminal-val);
  }
  .nb .wizard-stage .kw {
    color: var(--terminal-kw);
  }
  .nb .wizard-stage .ok {
    color: var(--relief-green);
  }
  .nb .wizard-stage .lock {
    color: #facc15;
  }
  .nb .wizard-stage .ghost {
    opacity: 0.6;
