            if (myGen === gen) next()
          })
          return
        }
        if (s.kind === 'spin') {
          runSpin(s.label || 'Working', s.done || '', s.ms || 1000, () => {
            if (myGen === gen) next()
          })
          return
        }
        if (s.kind === 'restart') {
          timer = setTimeout(() => {
            if (myGen !== gen) return
            buf = ''
            stepIdx = 0
            script = makeScript()
            render()
            next()
