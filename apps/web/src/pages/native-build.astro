            ],
          },
        ],
      },
      android: {
        before: 'Before: Play Console · service accounts · keystores · gradle wrangling',
        after: 'After: one Google sign-in',
        content: [
          {
            title: 'Keystore',
            lines: [
              '<span class="dim">$ </span><span class="cmd">npx @capgo/cli@latest build init</span> <span class="flag">--platform</span> <span class="val">android</span>',
              '',
