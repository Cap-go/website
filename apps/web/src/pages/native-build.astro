    is:inline
    src="https://cdn.jsdelivr.net/npm/gsap@3.12.5/dist/ScrollTrigger.min.js"
    integrity="sha384-Z3REaz79l2IaAZqJsSABtTbhjgOUYyV3p90XNnAPCSHg3EMTz1fouunq9WZRtj3d"
    crossorigin="anonymous"></script>
  <script is:inline>
    ;(function () {
      var gsap = window.gsap
      var ST = window.ScrollTrigger
      if (!gsap || !ST) return
      if (window.matchMedia && window.matchMedia('(prefers-reduced-motion: reduce)').matches) return
      gsap.registerPlugin(ST)

      // Reveal a group on scroll, with optional stagger. Clears inline styles
      // afterwards so CSS hover transforms keep working.
      function reveal(sel, opts) {
        opts = opts || {}
        var els = gsap.utils.toArray(sel)
        if (!els.length) return
        gsap.set(els, { opacity: 0, y: opts.y == null ? 24 : opts.y })
        ST.batch(els, {
          start: opts.start || 'top 86%',
          onEnter: function (b) {
            gsap.to(b, {
              opacity: 1,
              y: 0,
              duration: opts.duration || 0.6,
              ease: 'power3.out',
              stagger: opts.stagger || 0.08,
              overwrite: true,
              clearProps: 'opacity,transform',
            })
          },
        })
      }

      // Hero — animate in on load.
      var heroEls = gsap.utils.toArray(
        '.nb .hero .beta-badge, .nb .hero .hero-banner, .nb .hero .hero-lead, .nb .hero .hero-ctas, .nb .hero .hero-meta, .nb .hero .hero-strip',
      )
      if (heroEls.length) {
        gsap.set(heroEls, { opacity: 0, y: 22 })
        gsap.to(heroEls, { opacity: 1, y: 0, duration: 0.7, ease: 'power3.out', stagger: 0.09, delay: 0.05, clearProps: 'opacity,transform' })
      }

      // Section headings everywhere.
      reveal('.nb .section-head', { y: 20, stagger: 0.12 })

      // Reveal sentence + demo terminal.
      reveal('.nb #how .rv-one', { y: 20 })
      reveal('.nb #how .demo-wrap', { y: 28 })

      // Bento cards — the attention grabber (staggered pop-in).
      reveal('.nb #features .bento .tile', { y: 30, stagger: 0.07, duration: 0.55, start: 'top 88%' })

      // Onboarding.
      reveal('.nb #onboarding .onboarding-cmd-row', { y: 18 })
      reveal('.nb #onboarding .wizard', { y: 26 })

      // Trust.
      reveal('.nb #trust .trust-cell', { y: 24, stagger: 0.09 })

      // Comparison.
      reveal('.nb #compare .comp-wrap', { y: 26 })
      reveal('.nb #compare .comp-callout', { y: 18 })

      // AI debug — the terminal streams its own rows (see aiDebugTerminal), so only the side points fade in.
      reveal('.nb #ai-debug .aidebug-points li', { y: 18, stagger: 0.1 })

      // Pricing.
      reveal('.nb #pricing .tier', { y: 26, stagger: 0.08 })
      reveal('.nb #pricing .build-calc, .nb #pricing .pricing-fineprint', { y: 16 })

      // FAQ.
      reveal('.nb #faq .faq details', { y: 16, stagger: 0.06 })

      // Final CTA.
      reveal('.nb #cta .shell', { y: 24 })

      window.addEventListener('load', function () {
        ST.refresh()
      })
    })()
  </script>
</Layout>
