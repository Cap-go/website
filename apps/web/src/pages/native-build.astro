---
import CommandCode from '@/components/CommandCode.astro'
import ProductTestimonials from '@/components/ProductTestimonials.astro'
import ProductVideoSection from '@/components/ProductVideoSection.astro'
import { productVideos } from '@/config/productVideos'
import { productTestimonials } from '@/config/productTestimonials'
import Layout from '@/layouts/Layout.astro'
import { Icon } from 'astro-icon/components'
import m, { type MessageValues } from '@/copy/messages'
import { createLdJsonGraph, createServiceLdJson } from '@/lib/ldJson'
import type { Database } from '@/services/supabase.types'
import { getRelativeLocaleUrl } from '@/services/links'

type Plan = Database['public']['Tables']['plans']['Row']

type Credit = {
  id: number
  step_min: number
  step_max: number
  price_per_unit: number
  type: string
  unit_factor: number
}

const locale = Astro.locals.locale
const brand = Astro.locals.runtimeConfig.public.brand
const config = Astro.locals.runtimeConfig

function copy(key: string, values: MessageValues = {}) {
  return m[key](values, { locale })
}

const mcpInstallBaseCommand = "npx install-mcp 'npx @capgo/cli@latest mcp'"

// Per-client MCP setup for the "ask AI" section. The tabs only swap the
// install-mcp --client value, so users no longer hand-edit client config files.
const mcpClients = [
  {
    id: 'codex',
    name: 'Codex',
    icon: 'ai-codex',
    client: 'codex',
  },
  {
    id: 'cursor',
    name: 'Cursor',
    icon: 'ai-cursor',
    client: 'cursor',
  },
  {
    id: 'claude',
    name: 'Claude Code',
    icon: 'ai-claude',
    client: 'claude-code',
  },
  {
    id: 'windsurf',
    name: 'Windsurf',
    icon: 'ai-windsurf',
    client: 'windsurf',
  },
  {
    id: 'vscode',
    name: 'VS Code',
    icon: 'ai-vscode',
    client: 'vscode',
  },
  {
    id: 'zed',
    name: 'Zed',
    icon: 'ai-zed',
    client: 'zed',
  },
].map((client) => ({
  ...client,
  label: `--client ${client.client}`,
  code: `${mcpInstallBaseCommand} --client ${client.client}`,
}))

const builderTitle = copy('native_build_builder_title')
const title = `${brand} | ${builderTitle}`
const description = copy('native_build_builder_description')

let plansAll: Plan[] = []
let credits: Credit[] = []

try {
  const [plansResponse, creditsResponse] = await Promise.all([fetch(`${config.public.baseApiUrl}/private/plans`), fetch(`${config.public.baseApiUrl}/private/credits`)])

  plansAll = plansResponse.ok ? await plansResponse.json() : []
  credits = creditsResponse.ok ? await creditsResponse.json() : []
} catch (error) {
  console.warn('Unable to load Capgo Builder pricing data', error)
}

const plans = plansAll.filter((plan) => plan.name !== 'Free')
const buildCredits = credits.filter((credit) => credit.type === 'build_time').sort((a, b) => a.step_min - b.step_min)

// Tiered build-minute credit pricing, normalized to minutes — drives the calculator's price estimate.
const calcTiers = buildCredits.map((credit) => ({
  from: credit.step_min / credit.unit_factor,
  to: credit.step_max ? credit.step_max / credit.unit_factor : 0,
  price: credit.price_per_unit,
}))

const serviceLdJson = createServiceLdJson(Astro.locals.runtimeConfig.public, {
  name: title,
  description,
  url: Astro.url.href,
  serviceType: 'Cloud native mobile app build service',
  areaServed: ['Worldwide'],
})

const ldJSON = createLdJsonGraph(Astro.locals.runtimeConfig.public, serviceLdJson, {
  includeOrganization: true,
})

const content = {
  title,
  description,
  image: `${Astro.locals.runtimeConfig.public.baseUrl}/social/capgo-native-build.png`,
  ldJSON,
}

const nativeBuildFooterBlogSlugs = [
  'transform-lovable-dev-app-to-mobile-with-capacitor',
  'transform-base44-app-to-mobile-with-capacitor',
  'build-ios-app-from-windows-capacitor-capgo-build',
]
const nativeBuildFooterBlogCopy = {
  description: copy('footer_blog_builder_description'),
}

const registerUrl = getRelativeLocaleUrl(locale, 'register')
const pricingUrl = getRelativeLocaleUrl(locale, 'pricing')

const heroMeta = [copy('native_build_v2_meta_ios'), copy('native_build_v2_meta_android'), copy('native_build_v2_meta_nosdk'), copy('native_build_v2_meta_speed')]

const heroStrip = [
  { k: copy('native_build_v2_strip_ios_k'), v: copy('native_build_v2_strip_ios_v') },
  { k: copy('native_build_v2_strip_android_k'), v: copy('native_build_v2_strip_android_v') },
  { k: copy('native_build_v2_strip_build_k'), v: copy('native_build_v2_strip_build_v') },
  { k: copy('native_build_v2_strip_setup_k'), v: copy('native_build_v2_strip_setup_v') },
]

const comparisonRows = [
  {
    label: copy('native_build_v2_comp_setup_l'),
    hook: copy('native_build_v2_comp_setup_capgo_hook'),
    capgo: copy('native_build_v2_comp_setup_capgo'),
    diy: copy('native_build_v2_comp_setup_diy'),
    capa: copy('native_build_v2_comp_setup_capa'),
  },
  {
    label: copy('native_build_v2_comp_source_l'),
    hook: copy('native_build_v2_comp_source_capgo_hook'),
    capgo: copy('native_build_v2_comp_source_capgo'),
    diy: copy('native_build_v2_comp_source_diy'),
    capa: copy('native_build_v2_comp_source_capa'),
  },
  {
    label: copy('native_build_v2_comp_cred_l'),
    hook: copy('native_build_v2_comp_cred_capgo_hook'),
    capgo: copy('native_build_v2_comp_cred_capgo'),
    diy: copy('native_build_v2_comp_cred_diy'),
    capa: copy('native_build_v2_comp_cred_capa'),
  },
  {
    label: copy('native_build_v2_comp_logs_l'),
    hook: copy('native_build_v2_comp_logs_capgo_hook'),
    capgo: copy('native_build_v2_comp_logs_capgo'),
    diy: copy('native_build_v2_comp_logs_diy'),
    capa: copy('native_build_v2_comp_logs_capa'),
  },
  {
    label: copy('native_build_v2_comp_try_l'),
    hook: copy('native_build_v2_comp_try_capgo_hook'),
    capgo: copy('native_build_v2_comp_try_capgo'),
    diy: copy('native_build_v2_comp_try_diy'),
    capa: copy('native_build_v2_comp_try_capa'),
  },
  {
    label: copy('native_build_v2_comp_cost_l'),
    hook: copy('native_build_v2_comp_cost_capgo_hook'),
    capgo: copy('native_build_v2_comp_cost_capgo'),
    diy: copy('native_build_v2_comp_cost_diy'),
    capa: copy('native_build_v2_comp_cost_capa'),
  },
  {
    label: copy('native_build_v2_comp_ota_l'),
    hook: copy('native_build_v2_comp_ota_capgo_hook'),
    capgo: copy('native_build_v2_comp_ota_capgo'),
    diy: copy('native_build_v2_comp_ota_diy'),
    capa: copy('native_build_v2_comp_ota_capa'),
  },
  {
    label: copy('native_build_v2_comp_maint_l'),
    hook: copy('native_build_v2_comp_maint_capgo_hook'),
    capgo: copy('native_build_v2_comp_maint_capgo'),
    diy: copy('native_build_v2_comp_maint_diy'),
    capa: copy('native_build_v2_comp_maint_capa'),
  },
  {
    label: copy('native_build_v2_comp_ai_l'),
    hook: copy('native_build_v2_comp_ai_capgo_hook'),
    capgo: copy('native_build_v2_comp_ai_capgo'),
    diy: copy('native_build_v2_comp_ai_diy'),
    capa: copy('native_build_v2_comp_ai_capa'),
  },
]

const faqs = [
  { q: copy('native_build_v2_faq_q1'), a: copy('native_build_v2_faq_a1') },
  { q: copy('native_build_v2_faq_q2'), a: copy('native_build_v2_faq_a2') },
  { q: copy('native_build_v2_faq_q3'), a: copy('native_build_v2_faq_a3') },
  { q: copy('native_build_v2_faq_q4'), a: copy('native_build_v2_faq_a4') },
  { q: copy('native_build_v2_faq_q5'), a: copy('native_build_v2_faq_a5') },
  { q: copy('native_build_v2_faq_q6'), a: copy('native_build_v2_faq_a6') },
  {
    q: copy('native_build_v2_faq_q7'),
    a: copy('native_build_v2_faq_a7'),
    href: getRelativeLocaleUrl(locale, 'docs/builder/getting-started/'),
    linkLabel: copy('native_build_v2_faq_a7_link'),
  },
]

function annualMonthlyPrice(plan: Plan) {
  const price = Math.round(plan.price_y / 12)
  return plan.name === 'Enterprise' ? `$${price}+` : `$${price}`
}

function monthlyPrice(plan: Plan) {
  return copy('native_build_builder_month_to_month', { price: `$${plan.price_m}`, suffix: plan.name === 'Enterprise' ? '+' : '' })
}

function yearlyBilling(plan: Plan) {
  const amount = `$${formatNumber(plan.price_y)}`
  return plan.name === 'Enterprise' ? copy('native_build_builder_yearly_billing_enterprise', { amount }) : copy('native_build_builder_yearly_billing', { amount })
}

function planDescription(plan: Plan) {
  if (plan.name === 'Solo') return copy('plan_solo_desc')
  if (plan.name === 'Maker') return copy('plan_maker_desc')
  if (plan.name === 'Team') return copy('plan_team_desc')
  if (plan.name === 'Enterprise') return copy('plan_payasyougo_desc')
  return plan.market_desc ?? plan.description ?? ''
}

function formatNumber(value: number) {
  return new Intl.NumberFormat(locale).format(value)
}

function buildTimeDisplay(buildTimeSeconds: number, name?: string) {
  if (!buildTimeSeconds) return copy('native_build_builder_build_minutes_zero')

  const buildTimeHours = Math.floor(buildTimeSeconds / 3600)
  const buildTimeMinutes = Math.floor(buildTimeSeconds / 60)
  const suffix = name === 'Enterprise' ? '+' : ''

  if (buildTimeHours >= 1) {
    return copy(buildTimeHours === 1 ? 'native_build_builder_build_hour' : 'native_build_builder_build_hours', { count: buildTimeHours, suffix })
  }

  return copy('native_build_builder_build_minutes', { count: buildTimeMinutes, suffix })
}
---

<Layout content={content} footerBlogSlugs={nativeBuildFooterBlogSlugs} footerBlogCopy={nativeBuildFooterBlogCopy}>
  <div class="nb bg-ad">
    <!-- ============================================ HERO ============================================ -->
    <section class="section hero bg-grid grain" id="top">
      <div class="shell">
        <div class="beta-badge">
          <span class="dot"></span>
          {copy('native_build_v2_hero_badge')}
        </div>
        <h1 class="hero-banner" aria-label={copy('native_build_v2_hero_headline')}>
          <span class="hbv-underlined">
            <span class="hbv-u-name">{copy('native_build_v2_hero_headline')}</span>
            <span class="hbv-u-rule"></span>
          </span>
          <span class="hero-banner-tag">{copy('native_build_v2_hero_tagline')}</span>
        </h1>
        <p class="lead hero-lead">{copy('native_build_v2_hero_lead')}</p>
        <div class="hero-ctas">
          <div class="hero-cta-buttons">
            <a class="btn btn-lg btn-primary" href={registerUrl}>{copy('native_build_v2_hero_cta')}</a>
