    border-color: rgba(74, 222, 128, 0.4);
  }

  /* ---- bento ---- */
  .nb .bento {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    grid-auto-rows: minmax(180px, auto);
    gap: 14px;
    margin-top: 48px;
  }
  @media (max-width: 980px) {
    .nb .bento {
      grid-template-columns: repeat(2, 1fr);
    }
  }
  @media (max-width: 540px) {
    .nb .bento {
      grid-template-columns: 1fr;
    }
  }
  .nb .tile {
    position: relative;
    padding: 22px;
    background: rgba(26, 29, 36, 0.55);
    border: 1px solid rgba(255, 255, 255, 0.07);
    border-radius: 18px;
    overflow: hidden;
    cursor: pointer;
    transition:
      border-color 0.2s,
      transform 0.2s,
      background 0.2s;
  }
  .nb .tile:hover {
    border-color: rgba(255, 255, 255, 0.18);
    transform: translateY(-2px);
    background: rgba(26, 29, 36, 0.75);
  }
  .nb .tile::before {
    content: '';
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    height: 2px;
    background: var(--tile-c, #fff);
    opacity: 0.85;
  }
  .nb .tile .icon {
    width: 36px;
    height: 36px;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    font-size: 22px;
    border-radius: 10px;
    margin-bottom: 14px;
    color: var(--tile-c);
    border: 1px solid color-mix(in oklab, var(--tile-c) 30%, transparent);
    background: color-mix(in oklab, var(--tile-c) 10%, transparent);
  }
  .nb .tile .ttl {
    font-size: 17px;
    font-weight: 700;
    letter-spacing: -0.01em;
    margin: 0 0 6px;
  }
  .nb .tile .ttl-accent {
    color: var(--tile-c);
  }
  .nb .tile .sub {
    font-size: 13.5px;
    line-height: 1.5;
    color: rgba(255, 255, 255, 0.58);
  }
  .nb .tile .more {
    display: none;
    margin-top: 14px;
    padding-top: 14px;
    border-top: 1px solid rgba(255, 255, 255, 0.08);
    font-size: 13px;
    line-height: 1.55;
    color: rgba(255, 255, 255, 0.72);
  }
  .nb .tile.open .more {
    display: block;
  }
  .nb .tile.open {
    background: rgba(26, 29, 36, 0.85);
  }
  .nb .tile .more code,
  .nb .tile-hero .ascii {
    font-family: var(--nb-font-mono);
  }
  .nb .tile .more code {
    font-size: 12px;
    background: rgba(74, 222, 128, 0.08);
    color: var(--relief-green);
    padding: 1px 5px;
    border-radius: 4px;
  }
  .nb .tile-hero {
    grid-column: span 2;
    grid-row: span 2;
    display: flex;
    flex-direction: column;
    justify-content: space-between;
    cursor: default;
    background:
      radial-gradient(ellipse at 30% 20%, rgba(74, 222, 128, 0.18) 0%, transparent 60%),
      rgba(26, 29, 36, 0.85);
    border: 1px solid rgba(74, 222, 128, 0.3);
  }
  .nb .tile-hero::before {
    background: var(--relief-green);
    height: 3px;
  }
  .nb .tile-hero:hover {
    transform: none;
  }
  .nb .tile-hero .ttl {
    font-size: clamp(1.6rem, 2.8vw, 2.4rem);
    font-weight: 900;
    letter-spacing: -0.02em;
    line-height: 1.05;
  }
  .nb .tile-hero .ttl .name {
    color: var(--relief-green);
  }
  .nb .tile-hero-sub-ttl {
    color: rgba(255, 255, 255, 0.85);
  }
  .nb .tile-hero .sub {
    font-size: 15px;
    color: rgba(255, 255, 255, 0.7);
    margin-top: 12px;
    max-width: 38ch;
  }
  .nb .tile-hero .ascii {
    font-size: 11px;
    color: rgba(74, 222, 128, 0.55);
    white-space: pre;
    line-height: 1.2;
    margin: 14px 0 0;
    overflow-x: auto;
  }
  @media (max-width: 980px) {
    .nb .tile-hero {
      grid-column: span 2;
      grid-row: span 1;
    }
  }
  @media (max-width: 540px) {
    .nb .tile-hero {
      grid-column: span 1;
    }
  }
  .nb .bento-hint {
    text-align: center;
    margin-top: 24px;
    font-size: 13px;
    color: rgba(255, 255, 255, 0.45);
  }

  /* ---- bento tile icons ---- */
  .nb .bento .tile {
    --tile-c: var(--relief-green);
  }
  .nb .bento .tile .icon svg {
    width: 20px;
    height: 20px;
  }

  /* ---- SPOTLIGHT — the bento's style ----
     Calm monochrome tiles that light up with a green glow tracking the
     cursor, plus a lift + green accent on hover. The hero tile keeps its
     own green fill. */
  .nb .bento .tile:not(.tile-hero) {
    background: rgba(255, 255, 255, 0.05);
    border: 1px solid rgba(255, 255, 255, 0.11);
  }
  .nb .bento .tile:not(.tile-hero)::before {
    opacity: 0;
  }
  .nb .bento .tile::after {
    content: '';
    position: absolute;
    inset: 0;
    border-radius: inherit;
    pointer-events: none;
    background: radial-gradient(240px 200px at var(--mx, 50%) var(--my, -20%), rgba(74, 222, 128, 0.07), transparent 72%);
    opacity: 0;
    transition: opacity 0.3s;
  }
  .nb .bento .tile:hover::after {
    opacity: 1;
  }
  /* No glow once a tile is expanded */
  .nb .bento .tile.open::after {
    opacity: 0 !important;
  }
  .nb .bento .tile:not(.tile-hero):hover {
    border-color: rgba(74, 222, 128, 0.26);
    transform: translateY(-3px);
  }
  .nb .bento .tile.open:not(.tile-hero) {
    border-color: rgba(74, 222, 128, 0.22);
    background: rgba(255, 255, 255, 0.06);
  }
  .nb .bento .tile .icon {
    color: rgba(255, 255, 255, 0.5);
    border-color: rgba(255, 255, 255, 0.1);
    background: rgba(255, 255, 255, 0.04);
    transition:
      color 0.25s,
      background 0.25s,
      border-color 0.25s;
  }
  .nb .bento .tile:hover .icon {
    color: var(--relief-green);
    border-color: rgba(74, 222, 128, 0.3);
    background: rgba(74, 222, 128, 0.1);
  }
  .nb .bento .tile .ttl-accent {
    color: #fff;
  }
  .nb .bento .tile:hover .ttl-accent {
    color: var(--relief-green);
  }

  /* ---- onboarding wizard ---- */
  .nb .onboarding-cmd-row {
    margin: 28px auto 0;
