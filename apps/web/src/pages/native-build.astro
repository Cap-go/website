    .nb .trust-cell {
      position: relative;
      padding: 22px;
      background: rgba(26, 29, 36, 0.55);
      border: 1px solid rgba(255, 255, 255, 0.08);
      border-radius: 16px;
      overflow: hidden;
      transition:
        border-color 0.25s,
        transform 0.25s,
        box-shadow 0.25s;
