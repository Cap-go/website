    />

    <!-- ============================================ BENTO ============================================ -->
    <section class="section" id="features">
      <div class="shell">
        <div class="section-head">
          <div class="eyebrow">{copy('native_build_v2_bento_eyebrow')}</div>
          <h2 class="h2-section">{copy('native_build_v2_bento_title')}</h2>
          <p class="lead">{copy('native_build_v2_bento_lead')}</p>
        </div>

        <div class="bento" id="bento">
          <div class="tile tile-hero" data-accent="green" aria-label="Capgo Builder">
            <div>
              <div class="ttl">
                <span class="name">Capgo Builder</span><br />
                <span class="tile-hero-sub-ttl">{copy('native_build_v2_tile_hero_title')}</span>
              </div>
              <div class="sub">{copy('native_build_v2_tile_hero_sub')}</div>
            </div>
            <pre class="ascii">$ capgo build request --platform ios      ✔ 2m 41s
$ capgo build request --platform android  ✔ 1m 22s</pre>
          </div>

          <div class="tile" data-expandable data-accent="cyan">
            <span class="icon"
