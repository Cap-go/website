                  <svg class="h-5 w-5" viewBox="0 0 24 24" fill="none" aria-hidden="true">
                    <path d="M7 11V8a5 5 0 0 1 10 0v3" stroke="currentColor" stroke-width="2" stroke-linecap="round" />
                    <path d="M6 11h12v9H6z" stroke="currentColor" stroke-width="2" stroke-linejoin="round" />
                  </svg>
                </div>
                <h3 class="text-lg font-bold text-white">{feature.title}</h3>
                <p class="mt-3 text-sm leading-6 text-slate-400">{feature.text}</p>
              </article>
            ))
          }
        </div>
      </div>
    </section>

    <section class="border-b border-white/10 bg-[#081322] py-20 sm:py-24">
      <div class="mx-auto max-w-6xl px-4 sm:px-6 lg:px-8">
        <div class="mx-auto max-w-2xl text-center">
          <p class="text-xs font-bold tracking-[0.24em] text-slate-500 uppercase">{copy('native_build_builder_comparison_eyebrow')}</p>
          <h2 class="mt-4 text-3xl leading-tight font-black text-white sm:text-4xl">{copy('native_build_builder_comparison_title')}</h2>
          <p class="mt-4 text-base leading-7 text-slate-300">{copy('native_build_builder_comparison_text')}</p>
        </div>

        <div class="mt-12 space-y-4 lg:hidden">
          {
            comparisons.map((row) => (
              <article class="rounded-lg border border-white/10 bg-[#050911] p-5">
                <h3 class="text-sm font-black text-white">{row.feature}</h3>
                <dl class="mt-4 space-y-4 text-sm">
                  <div>
                    <dt class="text-xs font-bold tracking-wide text-emerald-200 uppercase">{builderTitle}</dt>
                    <dd class="mt-1 leading-6 text-emerald-100">{row.capgo}</dd>
                  </div>
                  <div>
                    <dt class="text-xs font-bold tracking-wide text-slate-500 uppercase">{copy('native_build_builder_comparison_local_header')}</dt>
                    <dd class="mt-1 leading-6 text-slate-400">{row.local}</dd>
                  </div>
                  <div>
                    <dt class="text-xs font-bold tracking-wide text-slate-500 uppercase">{copy('native_build_builder_comparison_ci_header')}</dt>
                    <dd class="mt-1 leading-6 text-slate-400">{row.ci}</dd>
                  </div>
                </dl>
              </article>
            ))
          }
        </div>

        <div class="mt-12 hidden overflow-x-auto rounded-lg border border-white/10 lg:block">
          <table class="min-w-[860px] divide-y divide-white/10 bg-[#050911] text-left text-sm">
            <thead class="bg-white/[0.04] text-xs tracking-wide text-slate-400 uppercase">
              <tr>
                <th class="px-5 py-4 font-bold">{copy('native_build_builder_comparison_workflow_header')}</th>
                <th class="px-5 py-4 font-bold text-emerald-200">{builderTitle}</th>
                <th class="px-5 py-4 font-bold">{copy('native_build_builder_comparison_local_header')}</th>
                <th class="px-5 py-4 font-bold">{copy('native_build_builder_comparison_ci_header')}</th>
              </tr>
            </thead>
            <tbody class="divide-y divide-white/10">
              {
                comparisons.map((row) => (
                  <tr>
                    <th class="w-40 px-5 py-5 align-top font-bold text-white">{row.feature}</th>
                    <td class="px-5 py-5 align-top text-emerald-100">{row.capgo}</td>
                    <td class="px-5 py-5 align-top text-slate-400">{row.local}</td>
                    <td class="px-5 py-5 align-top text-slate-400">{row.ci}</td>
                  </tr>
                ))
              }
            </tbody>
          </table>
        </div>
      </div>
    </section>

    {
      plans.length > 0 && (
        <section class="border-b border-white/10 py-20 sm:py-24">
          <div class="mx-auto max-w-6xl px-4 sm:px-6 lg:px-8">
            <div class="mx-auto max-w-2xl text-center">
              <p class="text-xs font-bold tracking-[0.24em] text-slate-500 uppercase">{copy('native_build_builder_pricing_eyebrow')}</p>
              <h2 class="mt-4 text-3xl leading-tight font-black text-white sm:text-4xl">{copy('native_build_builder_pricing_title')}</h2>
              <p class="mt-4 text-base leading-7 text-slate-300">{copy('native_build_builder_pricing_text')}</p>
            </div>

            <div class="mt-12 grid gap-4 md:grid-cols-2 xl:grid-cols-4">
              {plans.map((plan) => (
                <article
                  class:list={[
                    'flex rounded-lg border bg-white/[0.04] p-6',
                    {
                      'border-blue-400/70 shadow-lg shadow-blue-950/30': plan.name === 'Maker',
                      'border-white/10': plan.name !== 'Maker',
                    },
                  ]}
                >
                  <div class="flex w-full flex-col">
                    {plan.name === 'Maker' && <p class="mb-4 w-fit rounded-md bg-blue-500 px-3 py-1 text-xs font-bold text-white uppercase">{copy('most_popular')}</p>}
                    <h3 class="text-lg font-black text-white uppercase">{plan.name}</h3>
                    <p class="mt-2 min-h-10 text-sm leading-5 text-slate-400">{planDescription(plan)}</p>
                    <div class="mt-6">
                      <span class="text-4xl font-black text-white">{annualMonthlyPrice(plan)}</span>
                      <span class="text-sm text-slate-400">/mo</span>
                    </div>
                    <p class="mt-2 text-xs text-slate-500">{yearlyBilling(plan)}</p>
                    <p class="mt-1 text-xs text-slate-500">{monthlyPrice(plan)}</p>
                    <a
                      href={getRelativeLocaleUrl(locale, 'register')}
                      class:list={[
                        'mt-6 inline-flex min-h-10 items-center justify-center rounded-lg px-4 py-2 text-sm font-bold transition focus:ring-2 focus:outline-none',
                        {
                          'bg-blue-600 text-white hover:bg-blue-500 focus:ring-blue-300': plan.name === 'Maker',
                          'border border-white/15 bg-white/5 text-white hover:bg-white/10 focus:ring-white/30': plan.name !== 'Maker',
                        },
                      ]}
                    >
                      {copy('native_build_builder_plan_trial')}
                    </a>
                    <ul class="mt-6 space-y-3 text-sm text-slate-300">
                      <li class="flex gap-2">
                        <span class="text-emerald-300">+</span>
                        <span>{buildTimeDisplay(plan.build_time_unit, plan.name)}</span>
                      </li>
                      <li class="flex gap-2">
                        <span class="text-emerald-300">+</span>
                        <span>
                          {formatNumber(plan.mau)} {copy('native_build_builder_monthly_active_users')}
                        </span>
                      </li>
                      <li class="flex gap-2">
                        <span class="text-emerald-300">+</span>
                        <span>
                          {formatNumber(plan.bandwidth)} {copy('native_build_builder_bandwidth_month')}
                        </span>
                      </li>
                      <li class="flex gap-2">
                        <span class="text-emerald-300">+</span>
                        <span>
                          {formatNumber(plan.storage)} {copy('native_build_builder_storage')}
                        </span>
                      </li>
                    </ul>
                  </div>
                </article>
              ))}
            </div>

            {buildCredits.length > 0 && (
              <div class="mt-6 rounded-lg border border-cyan-300/20 bg-cyan-300/10 p-4">
                <div class="flex flex-col gap-3 lg:flex-row lg:items-center lg:justify-between">
                  <p class="text-sm font-bold text-cyan-100">{copy('native_build_builder_extra_minutes')}</p>
                  <div class="flex flex-wrap gap-2">
                    {buildCredits.map((credit, index) => (
                      <span class="rounded-md border border-cyan-200/20 bg-black/20 px-3 py-1 text-xs text-cyan-100">
                        {creditStepLabel(credit, index, buildCredits.length)}: {creditPrice(credit)}
                      </span>
                    ))}
                  </div>
                </div>
              </div>
            )}
          </div>
        </section>
      )
    }

    <section class="border-b border-white/10 bg-[#081322] py-20 sm:py-24">
      <div class="mx-auto max-w-4xl px-4 sm:px-6 lg:px-8">
        <div class="mx-auto max-w-2xl text-center">
          <p class="text-xs font-bold tracking-[0.24em] text-slate-500 uppercase">{copy('native_build_builder_faq_eyebrow')}</p>
          <h2 class="mt-4 text-3xl leading-tight font-black text-white sm:text-4xl">{copy('native_build_builder_faq_title')}</h2>
        </div>

        <div class="mt-10 divide-y divide-white/10 rounded-lg border border-white/10 bg-[#050911]">
          {
            faqs.map((item) => (
              <details class="group p-5">
                <summary class="flex cursor-pointer list-none items-center justify-between gap-4 text-left text-base font-bold text-white">
                  {item.question}
                  <span class="flex h-7 w-7 shrink-0 items-center justify-center rounded-md border border-white/10 text-slate-400 transition group-open:rotate-45">+</span>
                </summary>
                <p class="mt-4 max-w-3xl text-sm leading-6 text-slate-400">{item.answer}</p>
              </details>
            ))
          }
        </div>
      </div>
    </section>

    <section class="py-20 sm:py-24">
      <div class="mx-auto max-w-5xl px-4 text-center sm:px-6 lg:px-8">
        <p class="text-2xl font-black text-emerald-300">{builderTitle}</p>
        <h2 class="mt-3 text-3xl leading-tight font-black text-white sm:text-4xl">{copy('native_build_builder_cta_title')}</h2>
        <p class="mx-auto mt-4 max-w-2xl text-base leading-7 text-slate-300">
          {copy('native_build_builder_cta_text')}
        </p>
        <div class="mt-8 flex flex-col items-center justify-center gap-3 sm:flex-row">
          <a
            href={getRelativeLocaleUrl(locale, 'register')}
            class="inline-flex min-h-11 items-center justify-center rounded-lg bg-blue-600 px-6 py-3 text-sm font-bold text-white shadow-lg shadow-blue-950/40 transition hover:bg-blue-500 focus:ring-2 focus:ring-blue-300 focus:outline-none"
          >
            {copy('native_build_builder_start_trial')}
          </a>
          <a
            href={getRelativeLocaleUrl(locale, 'pricing')}
            class="inline-flex min-h-11 items-center justify-center rounded-lg border border-white/15 bg-white/5 px-6 py-3 text-sm font-bold text-white transition hover:border-white/30 hover:bg-white/10 focus:ring-2 focus:ring-white/30 focus:outline-none"
          >
            {copy('native_build_builder_view_pricing')}
          </a>
        </div>
      </div>
    </section>
  </main>

  <style>
    .terminal-line {
      opacity: 0;
      transform: translateY(0.35rem);
      animation: terminal-line-in 520ms ease forwards;
      animation-delay: var(--delay);
    }

    .terminal-cursor {
      display: inline-block;
      width: 0.58ch;
      height: 1em;
      background: currentColor;
      vertical-align: -0.15em;
      animation: terminal-cursor-blink 900ms steps(1) infinite;
    }

    .terminal-progress {
      width: 100%;
      transform: scaleX(0);
      transform-origin: left;
      animation: terminal-progress-fill 7s ease forwards;
    }

    @keyframes terminal-line-in {
      to {
        opacity: 1;
        transform: translateY(0);
      }
    }

    @keyframes terminal-cursor-blink {
      50% {
        opacity: 0;
      }
    }

    @keyframes terminal-progress-fill {
      to {
        transform: scaleX(1);
      }
    }

    @media (prefers-reduced-motion: reduce) {
      .terminal-line,
      .terminal-progress,
      .terminal-cursor {
        animation: none;
        opacity: 1;
        transform: none;
      }
    }
  </style>
  <section class="mx-auto max-w-5xl px-6 py-10 text-sm leading-6 text-gray-300 lg:px-8">
    <h2 class="text-2xl font-semibold text-white">Keep going from Capgo Native Builds</h2>
    <p class="mt-4">
      If you are using native builds to ship signed iOS and Android binaries, connect this page with <a href="/ci_cd/">Capgo CI/CD</a> for automation, <a
        href="/docs/getting-started/cicd-integration/">CI/CD Integration</a
      > for setup, <a href="/docs/live-updates/integrations/github-actions/">GitHub Actions</a> for update delivery, <a href="/plugins/">Capgo Plugin Directory</a> for native dependencies,
      and <a href="/live-update/">Capgo Live Updates</a> for changes that do not need a new binary.
    </p>
  </section>
</Layout>
