---
import Layout from '@/layouts/Layout.astro'
import { getRelativeLocaleUrl } from 'astro:i18n'
import m from '@/copy/messages'

const locale = Astro.locals.locale
const title = m.capflow_title({}, { locale })
const description = m.capflow_meta_description({}, { locale })

const content = {
  title,
  description,
  image: `${Astro.locals.runtimeConfig.public.baseUrl}/capgo_social.png`,
}

const migrationGuideUrl = getRelativeLocaleUrl(locale, 'docs/upgrade/from-appflow-to-capgo/')
const enterprisePluginsUrl = getRelativeLocaleUrl(locale, 'ionic-enterprise-plugins')
const supportUrl = getRelativeLocaleUrl(locale, 'premium-support')
const migrationServicesUrl = getRelativeLocaleUrl(locale, 'consulting')
---

<Layout content={content}>
  <section class="bg-gray-900 py-16 sm:py-20">
    <div class="mx-auto max-w-4xl px-6 lg:px-8">
      <!-- Hero -->
      <div class="mb-12 text-center">
        <h1 class="mb-4 text-4xl font-bold tracking-tight text-white sm:text-5xl">
          {m.appflow_hero_title({}, { locale })}
        </h1>
        <p class="mx-auto max-w-2xl text-xl text-gray-300">
          {m.appflow_hero_subtitle({}, { locale })}
        </p>
      </div>

      <!-- The Elephant in the Room -->
      <div class="mb-16 rounded-lg border border-gray-600 bg-gray-800/50 p-8">
        <h2 class="mb-4 text-2xl font-bold text-gray-100">
          {m.appflow_elephant_title({}, { locale })}
        </h2>
        <div class="space-y-4 text-gray-300">
          <p set:html={m.appflow_elephant_p1({}, { locale })} />
          <p>
            {m.appflow_elephant_p2({}, { locale })}
          </p>
        </div>
      </div>

      <!-- Credit Where Due -->
      <div class="mb-16">
        <h2 class="mb-6 text-3xl font-bold text-gray-100">
          {m.appflow_credit_title({}, { locale })}
        </h2>
        <div class="space-y-4 text-gray-300">
          <p set:html={m.appflow_credit_p1({}, { locale })} />
          <p>
            {m.appflow_credit_p2({}, { locale })}
          </p>
          <p class="text-gray-400">
            {m.appflow_credit_p3({}, { locale })}
          </p>
        </div>
      </div>

      <!-- What Makes Capgo Different -->
      <div class="mb-16">
        <h2 class="mb-8 text-3xl font-bold text-gray-100">
          {m.appflow_what_different_title({}, { locale })}
        </h2>

        <div class="space-y-6">
          <!-- Not Shutting Down -->
          <div class="rounded-lg border border-gray-700 bg-gray-800/50 p-6">
            <h3 class="mb-3 text-xl font-semibold text-gray-100">
              {m.appflow_not_shutting_title({}, { locale })}
            </h3>
            <p class="mb-2 text-gray-300" set:html={m.appflow_not_shutting_desc({}, { locale })} />
            <ul class="mb-2 ml-6 list-disc space-y-1 text-sm text-gray-400">
              <li>{m.appflow_not_shutting_li1({}, { locale })}</li>
              <li>{m.appflow_not_shutting_li2({}, { locale })}</li>
            </ul>
            <p class="text-sm text-gray-400">
              {m.appflow_not_shutting_note({}, { locale })}
            </p>
          </div>

          <!-- Pricing -->
          <div class="rounded-lg border border-gray-700 bg-gray-800/50 p-6">
            <h3 class="mb-3 text-xl font-semibold text-gray-100">
              {m.appflow_pricing_title({}, { locale })}
            </h3>
            <p class="mb-2 text-gray-300" set:html={m.appflow_pricing_comparison({}, { locale })} />
            <p class="text-sm text-gray-400">
              {m.appflow_pricing_note({}, { locale })}
            </p>
          </div>

          <!-- Open Source -->
          <div class="rounded-lg border border-gray-700 bg-gray-800/50 p-6">
            <h3 class="mb-3 text-xl font-semibold text-gray-100">
              {m.appflow_opensource_title({}, { locale })}
            </h3>
            <p class="mb-2 text-gray-300" set:html={m.appflow_opensource_desc({}, { locale })} />
            <ul class="ml-6 list-disc space-y-1 text-gray-400">
              <li set:html={m.appflow_opensource_li1({}, { locale })} />
              <li set:html={m.appflow_opensource_li2({}, { locale })} />
              <li>{m.appflow_opensource_li3({}, { locale })}</li>
            </ul>
            <p class="mt-3 text-sm text-gray-400">
              {m.appflow_opensource_note({}, { locale })}
            </p>
          </div>

          <!-- Experience -->
          <div class="rounded-lg border border-gray-700 bg-gray-800/50 p-6">
            <h3 class="mb-3 text-xl font-semibold text-gray-100">
              {m.appflow_experience_title({}, { locale })}
            </h3>
            <p class="text-gray-300">
              {m.appflow_experience_desc({}, { locale })}
            </p>
            <p class="mt-2 text-sm text-gray-400" set:html={m.appflow_experience_note({}, { locale })} />
          </div>

          <!-- Support -->
          <div class="rounded-lg border border-gray-700 bg-gray-800/50 p-6">
            <h3 class="mb-3 text-xl font-semibold text-gray-100">
              {m.appflow_support_title({}, { locale })}
            </h3>
            <p class="text-gray-300">
              {m.appflow_support_desc({}, { locale })}
            </p>
            <p class="mt-2 text-gray-400">
              {m.appflow_support_note({}, { locale })}
            </p>
          </div>

          <!-- What We Do -->
          <div class="rounded-lg border border-gray-700 bg-gray-800/50 p-6">
            <h3 class="mb-3 text-xl font-semibold text-gray-100">
              {m.appflow_focus_title({}, { locale })}
            </h3>
            <p class="text-gray-300" set:html={m.appflow_focus_desc({}, { locale })} />
            <p class="mt-2 text-sm text-gray-400">
              {m.appflow_focus_note({}, { locale })}
            </p>
          </div>
        </div>
      </div>

      <!-- What We're NOT -->
      <div class="mb-16 rounded-lg border border-gray-600 bg-gray-800/50 p-8">
        <h2 class="mb-4 text-2xl font-bold text-gray-100">
          {m.appflow_not_good_at_title({}, { locale })}
        </h2>
        <div class="space-y-3 text-gray-300">
          <p>
            <strong class="text-gray-100">{m.appflow_not_good_at_ci_cd_label({}, { locale })}</strong>
            {m.appflow_not_good_at_ci_cd({}, { locale })}
          </p>
          <p>
            <strong class="text-gray-100">{m.appflow_not_good_at_docs_label({}, { locale })}</strong>
            {m.appflow_not_good_at_docs({}, { locale })}
          </p>
        </div>
      </div>

      <!-- Migration -->
      <div class="mb-16">
        <h2 class="mb-6 text-3xl font-bold text-gray-100">
          {m.appflow_migration_how_title({}, { locale })}
        </h2>
        <div class="space-y-4 text-gray-300">
          <p set:html={m.appflow_migration_intro({}, { locale })} />
          <div class="mt-6 rounded-xl bg-gray-800 p-6">
            <h3 class="mb-3 text-lg font-semibold text-white">{m.appflow_migration_basics_title({}, { locale })}</h3>
            <ol class="space-y-2 text-gray-300">
              <li class="flex gap-3">
                <span class="font-semibold text-emerald-400">1.</span>
                <span set:html={m.appflow_migration_step1({}, { locale })} />
              </li>
              <li class="flex gap-3">
                <span class="font-semibold text-emerald-400">2.</span>
                <span set:html={m.appflow_migration_step2({}, { locale })} />
              </li>
              <li class="flex gap-3">
                <span class="font-semibold text-emerald-400">3.</span>
                <span>{m.appflow_migration_step3({}, { locale })}</span>
              </li>
            </ol>
            <p class="mt-4 text-sm text-emerald-300" set:html={m.appflow_migration_guide_text({ url: migrationGuideUrl }, { locale })} />
          </div>
          <p class="text-sm text-gray-400" set:html={m.appflow_migration_stuck({}, { locale })} />
        </div>
      </div>

      <!-- Enterprise Plugins -->
      <div class="mb-16">
        <h2 class="mb-6 text-3xl font-bold text-gray-100">
          {m.appflow_plugins_title({}, { locale })}
        </h2>
        <p class="mb-6 max-w-3xl text-gray-300">
          {m.appflow_plugins_desc({}, { locale })}
        </p>

        <div class="overflow-hidden rounded-2xl border border-gray-700 bg-gray-800/50">
          <table class="w-full text-left text-sm text-gray-300">
            <thead class="bg-gray-900/70 text-gray-400">
              <tr>
                <th class="px-6 py-4 font-semibold">{m.appflow_plugins_col_ionic({}, { locale })}</th>
                <th class="px-6 py-4 font-semibold">{m.appflow_plugins_col_capgo({}, { locale })}</th>
                <th class="px-6 py-4 font-semibold">{m.appflow_plugins_col_guide({}, { locale })}</th>
              </tr>
            </thead>
            <tbody class="divide-y divide-gray-700">
              <tr class="transition hover:bg-gray-800/60">
                <td class="px-6 py-4 font-medium text-gray-100">Ionic Secure Storage</td>
                <td class="px-6 py-4">
                  <a href={getRelativeLocaleUrl(locale, 'docs/plugins/fast-sql/')} class="text-emerald-300 hover:underline"> Fast SQL </a>
                  <span class="mx-2 text-gray-500">{m.appflow_plugins_or({}, { locale })}</span>
                  <a href={getRelativeLocaleUrl(locale, 'docs/plugins/data-storage-sqlite/')} class="text-emerald-300 hover:underline"> Data Storage SQLite </a>
                </td>
                <td class="px-6 py-4">
                  <a href={getRelativeLocaleUrl(locale, 'docs/upgrade/from-ionic-secure-storage/')} class="text-blue-300 hover:underline">
                    {m.appflow_plugins_link_text({}, { locale })}
                  </a>
                </td>
              </tr>
              <tr class="transition hover:bg-gray-800/60">
                <td class="px-6 py-4 font-medium text-gray-100">Ionic Auth Connect</td>
                <td class="px-6 py-4">
                  <a href={getRelativeLocaleUrl(locale, 'docs/plugins/social-login/')} class="text-emerald-300 hover:underline"> Social Login </a>
                </td>
                <td class="px-6 py-4">
                  <a href={getRelativeLocaleUrl(locale, 'docs/upgrade/from-ionic-auth-connect/')} class="text-blue-300 hover:underline">
                    {m.appflow_plugins_link_text({}, { locale })}
                  </a>
                </td>
              </tr>
              <tr class="transition hover:bg-gray-800/60">
                <td class="px-6 py-4 font-medium text-gray-100">Ionic Identity Vault</td>
                <td class="px-6 py-4">
                  <a href={getRelativeLocaleUrl(locale, 'docs/plugins/native-biometric/')} class="text-emerald-300 hover:underline"> Native Biometric </a>
                  <span class="mx-2 text-gray-500">+</span>
                  <a href={getRelativeLocaleUrl(locale, 'docs/plugins/fast-sql/')} class="text-emerald-300 hover:underline"> Fast SQL </a>
                  <span class="mx-2 text-gray-500">{m.appflow_plugins_or({}, { locale })}</span>
                  <a href={getRelativeLocaleUrl(locale, 'docs/plugins/data-storage-sqlite/')} class="text-emerald-300 hover:underline"> Data Storage SQLite </a>
                </td>
                <td class="px-6 py-4">
                  <a href={getRelativeLocaleUrl(locale, 'docs/upgrade/from-ionic-identity-vault/')} class="text-blue-300 hover:underline">
                    {m.appflow_plugins_link_text({}, { locale })}
                  </a>
                </td>
              </tr>
              <tr class="transition hover:bg-gray-800/60">
                <td class="px-6 py-4 font-medium text-gray-100">Ionic Zebra Scanner</td>
                <td class="px-6 py-4">
                  <a href={getRelativeLocaleUrl(locale, 'docs/plugins/zebra-datawedge/')} class="text-emerald-300 hover:underline"> Zebra DataWedge </a>
                </td>
                <td class="px-6 py-4">
                  <a href={getRelativeLocaleUrl(locale, 'docs/plugins/zebra-datawedge/')} class="text-blue-300 hover:underline">
                    {m.appflow_plugins_link_text({}, { locale })}
                  </a>
                </td>
              </tr>
            </tbody>
          </table>
        </div>

        <p class="mt-4 text-sm text-emerald-200" set:html={m.appflow_plugins_opensource_note({ url: supportUrl }, { locale })} />
      </div>

      <!-- Enterprise Plugins & Paid Help -->
      <div class="mb-16 rounded-2xl border border-emerald-500/30 bg-emerald-500/10 p-8">
        <h2 class="mb-4 text-2xl font-bold text-white sm:text-3xl">
          {m.appflow_enterprise_help_title({}, { locale })}
        </h2>
        <p
          class="leading-relaxed text-gray-200"
          set:html={m.appflow_enterprise_help_desc({ pluginsUrl: enterprisePluginsUrl, supportUrl, migrationUrl: migrationServicesUrl }, { locale })}
        />
      </div>

      <!-- Testimonials -->
      <div class="mb-16">
        <h2 class="mb-8 text-3xl font-bold text-gray-100">
          {m.appflow_testimonials_title({}, { locale })}
        </h2>
        <div class="grid gap-6 sm:grid-cols-2">
          <div class="rounded-lg border border-gray-700 bg-gray-800/50 p-6">
            <p class="mb-2 text-gray-300 italic">
              "{m.appflow_testimonial_1({}, { locale })}"
            </p>
            <p class="text-sm text-gray-400">{m.appflow_testimonial_1_author({}, { locale })}</p>
          </div>
          <div class="rounded-lg border border-gray-700 bg-gray-800/50 p-6">
            <p class="mb-2 text-gray-300 italic">
              "{m.appflow_testimonial_2({}, { locale })}"
            </p>
            <p class="text-sm text-gray-400">{m.appflow_testimonial_2_author({}, { locale })}</p>
          </div>
          <div class="rounded-lg border border-gray-700 bg-gray-800/50 p-6">
            <p class="mb-2 text-gray-300 italic">
              "{m.appflow_testimonial_3({}, { locale })}"
            </p>
            <p class="text-sm text-gray-400">{m.appflow_testimonial_3_author({}, { locale })}</p>
          </div>
          <div class="rounded-lg border border-gray-700 bg-gray-800/50 p-6">
            <p class="mb-2 text-gray-300 italic">
              "{m.appflow_testimonial_4({}, { locale })}"
            </p>
            <p class="text-sm text-gray-400">{m.appflow_testimonial_4_author({}, { locale })}</p>
          </div>
        </div>

        <div class="mt-8 rounded-xl bg-gray-800 p-6">
          <h3 class="mb-4 text-lg font-semibold text-white">{m.appflow_testimonials_more({}, { locale })}</h3>
          <iframe
            id="wall-of-love-Ngmn41b"
            src="https://senja.io/p/capgo/Ngmn41b?hideNavigation=true&embed=true"
            aria-label="Wall of Love"
            style="border: 0; overflow: hidden;"
            width="100%"
            class="min-h-100"></iframe>
          <script is:inline>
            document.addEventListener('DOMContentLoaded', function () {
              if (typeof iFrameResize === 'function') {
                iFrameResize({ log: false, checkOrigin: false }, '#wall-of-love-Ngmn41b')
              }
            })
          </script>
        </div>
      </div>

      <!-- FAQ -->
      <div class="mb-16">
        <h2 class="mb-6 text-3xl font-bold text-gray-100">
          {m.appflow_faq_title({}, { locale })}
        </h2>
        <dl class="space-y-6 text-gray-200">
          <div>
            <dt class="text-lg font-semibold text-white">{m.appflow_faq_q1({}, { locale })}</dt>
            <dd class="mt-2 text-gray-300">{m.appflow_faq_a1({}, { locale })}</dd>
          </div>
          <div>
            <dt class="text-lg font-semibold text-white">{m.appflow_faq_q2({}, { locale })}</dt>
            <dd class="mt-2 text-gray-300">{m.appflow_faq_a2({}, { locale })}</dd>
          </div>
          <div>
            <dt class="text-lg font-semibold text-white">{m.appflow_faq_q3({}, { locale })}</dt>
            <dd class="mt-2 text-gray-300">{m.appflow_faq_a3({}, { locale })}</dd>
          </div>
          <div>
            <dt class="text-lg font-semibold text-white">{m.appflow_faq_q4({}, { locale })}</dt>
            <dd class="mt-2 text-gray-300" set:html={m.appflow_faq_a4({}, { locale })} />
          </div>
        </dl>
      </div>

      <!-- CTA -->
      <div class="overflow-hidden rounded-3xl bg-linear-to-r from-[#44BCFF]/10 via-[#FF44EC]/10 to-[#FF675E]/10 p-1 ring-1 ring-white/10">
        <div class="relative overflow-hidden rounded-[1.45rem] bg-gray-900 px-8 py-12 sm:px-12 sm:py-16">
          <div class="pointer-events-none absolute -top-24 -left-10 h-48 w-48 rounded-full bg-[#44BCFF]/30 blur-3xl"></div>
          <div class="pointer-events-none absolute -right-16 -bottom-28 h-56 w-56 rounded-full bg-[#FF44EC]/20 blur-3xl"></div>
          <div class="relative text-center">
            <h2 class="mb-4 text-3xl font-bold text-white sm:text-4xl">
              {m.appflow_cta_title({}, { locale })}
            </h2>
            <p class="mx-auto mb-8 max-w-2xl text-gray-300">
              {m.appflow_cta_subtitle({}, { locale })}
            </p>
            <div class="flex flex-col items-center justify-center gap-4 sm:flex-row">
              <a
                href={getRelativeLocaleUrl(locale, 'register')}
                class="inline-flex items-center justify-center rounded-xl bg-emerald-600 px-8 py-4 text-lg font-bold text-white transition-all hover:bg-emerald-700"
              >
                {m.appflow_cta_start_trial({}, { locale })}
              </a>
              <a
                href="https://cal.com/team/capgo/appflow-migration"
                target="_blank"
                class="inline-flex items-center justify-center rounded-xl bg-white/10 px-8 py-4 text-lg font-semibold text-white ring-1 ring-white/20 hover:bg-white/15"
              >
                {m.appflow_cta_book_migration({}, { locale })}
              </a>
            </div>
            <p class="mt-6 text-sm text-gray-400" set:html={m.appflow_cta_questions({}, { locale })} />
          </div>
        </div>
      </div>

      <!-- Footer Note -->
      <div class="mt-12 text-center text-sm text-gray-400">
        <p>
          {m.appflow_footer_note({}, { locale })}
        </p>
      </div>
    </div>
  </section>
</Layout>
