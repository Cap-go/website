---
import Layout from '@/layouts/Layout.astro'
import { integrations } from '@/config/integrations'
import m from '@/copy/messages'

const locale = Astro.locals.locale
const brand = Astro.locals.runtimeConfig.public.brand

const title = `${brand} | ${m.integrations_title({}, { locale })}`
const description = m.integrations_subtitle({}, { locale })

const content = { title, description }

const trustedFreelancers = [
  {
    name: 'Adrien',
    clientApp: 'Steplee',
    image: '/adrien-profile.webp',
    bookUrl: 'https://book.capgo.app/adrien/',
  },
  {
    name: 'Jordan',
    clientApp: 'Amawé',
    image: '/jordan-avatar.jpg',
    bookUrl: 'https://book.capgo.app/jordan/',
  },
]
---

<Layout content={content}>
  <div class="min-h-screen bg-gray-900">
    <section class="mx-auto max-w-6xl px-4 py-20 sm:px-6 lg:px-8">
      <div class="space-y-8 text-center">
        <p class="inline-flex rounded-full border border-zinc-700 bg-zinc-800/80 px-4 py-2 text-xs font-medium text-zinc-300">{m.integrations_badge({}, { locale })}</p>
        <h1 class="text-4xl font-bold text-white sm:text-5xl">{m.integrations_title({}, { locale })}</h1>
        <p class="mx-auto max-w-2xl text-lg text-zinc-300">
          {description}
        </p>
      </div>

      <div class="mt-12 grid gap-8 sm:grid-cols-2 lg:grid-cols-3">
        {
          integrations.map((integration) => (
            <div class="flex h-full flex-col rounded-3xl border border-slate-200 bg-white p-8 shadow-sm transition-transform duration-200 hover:-translate-y-1 hover:shadow-xl">
              <img src={integration.logo} alt={`${integration.name} logo`} class="mb-6 h-14 w-auto self-start object-contain" />
              <h2 class="text-2xl font-semibold text-slate-900">{integration.name}</h2>
              <p class="mt-4 mb-8 text-slate-600">{integration.description}</p>
              <a
                href={integration.href}
                target={integration.target}
                rel={integration.rel}
                class="mt-auto inline-flex items-center rounded-xl border border-slate-200 bg-slate-100 px-4 py-2.5 text-sm font-semibold text-slate-900 transition-colors hover:bg-slate-200"
              >
                {m.learn_more({}, { locale })} {integration.name}
              </a>
            </div>
          ))
        }
      </div>

      <section class="mt-16 text-left" aria-labelledby="freelance-partners-heading">
        <div class="grid gap-8 lg:grid-cols-[0.8fr_1.2fr] lg:items-start">
          <div>
            <p class="text-sm font-semibold tracking-wide text-blue-200 uppercase">{m.integrations_partners_freelance_label({}, { locale })}</p>
            <h2 id="freelance-partners-heading" class="mt-4 text-3xl font-bold text-white sm:text-4xl">{m.integrations_partners_freelance_heading({}, { locale })}</h2>
            <p class="mt-4 text-lg leading-8 text-slate-300">{m.integrations_partners_freelance_description({ brand }, { locale })}</p>
            <p class="mt-4 text-base leading-7 text-slate-400">{m.integrations_partners_freelance_trust({ brand }, { locale })}</p>
          </div>

          <div class="grid gap-6 sm:grid-cols-2">
            {
              trustedFreelancers.map((freelancer) => (
                <article class="flex h-full flex-col rounded-2xl border border-white/10 bg-slate-950/80 p-6 shadow-xl shadow-black/20">
                  <div class="flex items-center gap-4">
                    <img
                      src={freelancer.image}
                      alt={`Profile photo of ${freelancer.name}`}
                      loading="lazy"
                      class="h-16 w-16 shrink-0 rounded-2xl object-cover ring-1 ring-white/10"
                    />
                    <div>
                      <h3 class="text-xl font-bold text-white">{freelancer.name}</h3>
                      <p class="mt-1 text-sm font-semibold text-blue-200">{m.integrations_partners_freelance_role({ brand }, { locale })}</p>
                    </div>
                  </div>

                  <div class="mt-5 space-y-3 text-base leading-7 text-slate-300">
                    <p>{m.integrations_partners_freelance_person_intro({ name: freelancer.name, brand, clientApp: freelancer.clientApp }, { locale })}</p>
                    <p>{m.integrations_partners_freelance_capgo_work({ brand }, { locale })}</p>
                  </div>

                  <a
                    href={freelancer.bookUrl}
                    target="_blank"
                    rel="noopener noreferrer"
                    class="mt-6 inline-flex w-full items-center justify-center gap-2 rounded-xl bg-blue-600 px-5 py-3 text-sm font-semibold text-white transition-colors hover:bg-blue-700 focus:ring-2 focus:ring-blue-400 focus:ring-offset-2 focus:ring-offset-slate-950"
                  >
                    {m.integrations_partners_freelance_contact({ name: freelancer.name }, { locale })}
                    <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" aria-hidden="true">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3" />
                    </svg>
                  </a>
                </article>
              ))
            }
          </div>
        </div>
      </section>
    </section>
  </div>
  <section class="mx-auto max-w-5xl px-6 py-10 text-sm leading-6 text-gray-300 lg:px-8">
    <h2 class="text-2xl font-semibold text-white">Keep going from Capgo Integrations</h2>
    <p class="mt-4">
      If you are connecting Capgo to your release stack, pair this page with <a href="/docs/live-updates/integrations/github-actions/">GitHub Actions</a> for automated deploys, <a
        href="/docs/live-updates/integrations/gitlab-ci/">GitLab CI/CD</a
      > for pipeline setup, <a href="/docs/live-updates/integrations/bitbucket-pipeline/">Bitbucket Pipelines</a> for repository automation, <a href="/ci_cd/">Capgo CI/CD</a> for the
      product workflow, and <a href="/native-build/">Capgo Native Builds</a> when native signing is part of the same pipeline.
    </p>
  </section>
</Layout>
