---
import '@/styles/lu-product.css'
import ProductTestimonials from '@/components/ProductTestimonials.astro'
import ProductVideoSection from '@/components/ProductVideoSection.astro'
import { productVideos } from '@/config/productVideos'
import { productTestimonials } from '@/config/productTestimonials'
import Layout from '@/layouts/Layout.astro'
import m, { type MessageValues } from '@/copy/messages'
import { getRelativeLocaleUrl } from '@/services/links'
import { createServiceLdJson, createLdJsonGraph } from '@/lib/ldJson'

const locale = Astro.locals.locale
const brand = Astro.locals.runtimeConfig.public.brand

function copy(key: string, values: MessageValues = {}) {
  return m[key](values, { locale })
}

const title = `${brand} | Ionic and Capacitor Live Updates`
const description = m.live_update_description({}, { locale })
const registerUrl = getRelativeLocaleUrl(locale, 'register')
const docsUrl = getRelativeLocaleUrl(locale, 'docs/live-updates')

const serviceLdJson = createServiceLdJson(Astro.locals.runtimeConfig.public, {
  name: title,
  description: description,
  url: Astro.url.href,
  serviceType: 'Software Development Service',
  areaServed: ['Worldwide'],
})

const ldJSON = createLdJsonGraph(Astro.locals.runtimeConfig.public, serviceLdJson, {
  includeOrganization: true,
})

const content = {
  title,
  description,
  image: `${Astro.locals.runtimeConfig.public.baseUrl}/social/capgo-live-update.png`,
  ldJSON,
}

const outcomeCards = [
  {
    title: m.live_update_outcome_card_recover_title({}, { locale }),
    text: m.live_update_outcome_card_recover_text({}, { locale }),
  },
  {
    title: m.live_update_outcome_card_control_title({}, { locale }),
    text: m.live_update_outcome_card_control_text({}, { locale }),
  },
  {
    title: m.live_update_outcome_card_prove_title({}, { locale }),
    text: m.live_update_outcome_card_prove_text({}, { locale }),
  },
]

const heroStats = [
  {
    value: m.live_update_hero_stat_recovery_value({}, { locale }),
    label: m.live_update_hero_stat_recovery_label({}, { locale }),
  },
  {
    value: m.home_uptime({}, { locale }),
    label: m.live_update_hero_stat_uptime_label({}, { locale }),
  },
  {
    value: m.live_update_hero_stat_channels_value({}, { locale }),
    label: m.live_update_hero_stat_channels_label({}, { locale }),
  },
  {
    value: m.live_update_hero_stat_global_value({}, { locale }),
    label: m.live_update_hero_stat_global_label({}, { locale }),
  },
  {
    value: m.live_update_hero_stat_latency_value({}, { locale }),
    label: m.live_update_hero_stat_latency_label({}, { locale }),
  },
  {
    value: m.live_update_hero_stat_logs_value({}, { locale }),
    label: m.live_update_hero_stat_logs_label({}, { locale }),
  },
]

const heroMeta = [m.home_uptime({}, { locale }), m.home_locations_active({}, { locale }), m.home_multi_provider_resilience({}, { locale })]

const decisionCriteria = [m.live_update_decision_1({}, { locale }), m.live_update_decision_2({}, { locale }), m.live_update_decision_3({}, { locale })]

const comparisonRows = [
  {
    label: copy('live_update_v2_comp_runtime_l'),
    hook: copy('live_update_v2_comp_runtime_capgo_hook'),
    capgo: copy('live_update_v2_comp_runtime_capgo'),
    diy: copy('live_update_v2_comp_runtime_diy'),
    capa: copy('live_update_v2_comp_runtime_capa'),
  },
  {
    label: copy('live_update_v2_comp_rollback_l'),
    hook: copy('live_update_v2_comp_rollback_capgo_hook'),
    capgo: copy('live_update_v2_comp_rollback_capgo'),
    diy: copy('live_update_v2_comp_rollback_diy'),
    capa: copy('live_update_v2_comp_rollback_capa'),
  },
  {
    label: copy('live_update_v2_comp_guard_l'),
    hook: copy('live_update_v2_comp_guard_capgo_hook'),
    capgo: copy('live_update_v2_comp_guard_capgo'),
    diy: copy('live_update_v2_comp_guard_diy'),
    capa: copy('live_update_v2_comp_guard_capa'),
  },
  {
    label: copy('live_update_v2_comp_compat_l'),
    hook: copy('live_update_v2_comp_compat_capgo_hook'),
    capgo: copy('live_update_v2_comp_compat_capgo'),
    diy: copy('live_update_v2_comp_compat_diy'),
    capa: copy('live_update_v2_comp_compat_capa'),
  },
  {
    label: copy('live_update_v2_comp_validate_l'),
    hook: copy('live_update_v2_comp_validate_capgo_hook'),
    capgo: copy('live_update_v2_comp_validate_capgo'),
    diy: copy('live_update_v2_comp_validate_diy'),
    capa: copy('live_update_v2_comp_validate_capa'),
  },
  {
    label: copy('live_update_v2_comp_channels_l'),
    hook: copy('live_update_v2_comp_channels_capgo_hook'),
    capgo: copy('live_update_v2_comp_channels_capgo'),
    diy: copy('live_update_v2_comp_channels_diy'),
    capa: copy('live_update_v2_comp_channels_capa'),
  },
  {
    label: copy('live_update_v2_comp_logs_l'),
    hook: copy('live_update_v2_comp_logs_capgo_hook'),
    capgo: copy('live_update_v2_comp_logs_capgo'),
    diy: copy('live_update_v2_comp_logs_diy'),
    capa: copy('live_update_v2_comp_logs_capa'),
  },
  {
    label: copy('live_update_v2_comp_try_l'),
    hook: copy('live_update_v2_comp_try_capgo_hook'),
    capgo: copy('live_update_v2_comp_try_capgo'),
    diy: copy('live_update_v2_comp_try_diy'),
    capa: copy('live_update_v2_comp_try_capa'),
  },
]

const guidanceChecks = [m.live_update_guidance_check1({}, { locale }), m.live_update_guidance_check2({}, { locale }), m.live_update_guidance_check3({}, { locale })]

const steps = [
  {
    title: m.live_update_step1_title({}, { locale }),
    text: m.live_update_step1_desc({}, { locale }),
  },
  {
    title: m.live_update_step2_title({}, { locale }),
    text: m.live_update_step2_desc({}, { locale }),
  },
  {
    title: m.live_update_step3_title({}, { locale }),
    text: m.live_update_step3_desc({}, { locale }),
  },
]


const platformCards = [
  {
    title: m.live_update_platform_capacitor_title({}, { locale }),
    text: m.live_update_platform_capacitor_text({}, { locale }),
    href: getRelativeLocaleUrl(locale, 'docs/plugins/updater/getting-started'),
    readMore: m.live_update_platform_read_more({}, { locale }),
  },
  {
    title: m.live_update_platform_cordova_title({}, { locale }),
    text: m.live_update_platform_cordova_text({}, { locale }),
    href: getRelativeLocaleUrl(locale, 'docs/plugins/cordova-updater/getting-started'),
    readMore: m.live_update_platform_read_more({}, { locale }),
  },
  {
    title: m.live_update_platform_electron_title({}, { locale }),
    text: m.live_update_platform_electron_text({}, { locale }),
    href: getRelativeLocaleUrl(locale, 'docs/plugins/electron-updater/getting-started'),
    readMore: m.live_update_platform_read_more({}, { locale }),
  },
]

const featureTiles = [
  {
    title: m.live_update_feature_breaking_detection({}, { locale }),
    sub: m.live_update_feature_breaking_detection_desc({}, { locale }),
  },
  {
    title: m.live_update_feature_auto_rollback({}, { locale }),
    sub: m.live_update_feature_auto_rollback_desc({}, { locale }),
  },
  {
    title: m.live_update_feature_preflight({}, { locale }),
    sub: m.live_update_feature_preflight_desc({}, { locale }),
  },
  {
    title: m.live_update_feature_encryption({}, { locale }),
    sub: m.live_update_feature_encryption_desc({}, { locale }),
  },
  {
    title: m.live_update_feature_self_healing({}, { locale }),
    sub: m.live_update_feature_self_healing_desc({}, { locale }),
  },
  {
    title: m.live_update_dynamic_title({}, { locale }),
    sub: m.live_update_dynamic_desc({}, { locale }),
  },
]
---

<Layout content={content}>
  <div class="lu bg-ad">
    <!-- HERO -->
    <section class="section hero bg-grid grain" id="top">
      <div class="shell">
        <div class="beta-badge">
          <span class="dot"></span>
          {m.live_update_hero_badge({}, { locale })}
        </div>
        <h1 class="hero-banner" aria-label={m.live_update_hero_headline({}, { locale })}>
          <span class="hbv-underlined">
            <span class="hbv-u-name">{m.live_update_hero_headline({}, { locale })}</span>
            <span class="hbv-u-rule"></span>
          </span>
          <span class="hero-banner-tag">{m.live_update_hero_tagline({}, { locale })}</span>
        </h1>
        <p class="lead hero-lead">{m.live_update_hero_subtitle({}, { locale })}</p>
        <div class="hero-ctas">
          <div class="hero-cta-buttons">
            <a class="btn btn-lg btn-primary" href={registerUrl}>{m.live_update_hero_cta({}, { locale })}</a>
            <a class="btn btn-lg btn-ghost" href={docsUrl}>{m.live_update_view_docs({}, { locale })}</a>
          </div>
          <p class="hero-cta-note">{m.product_trial_cta_note({}, { locale })}</p>
        </div>
        <div class="hero-meta">
          {
            heroMeta.map((item) => (
              <span>
                <span class="check">✓</span>
                {item}
              </span>
            ))
          }
        </div>
        <div class="hero-strip">
          {
            heroStats.map((item) => (
              <div class="hero-strip-cell">
                <p class="v">{item.value}</p>
                <p class="k">{item.label}</p>
              </div>
            ))
          }
        </div>
      </div>
    </section>


    <!-- SUPPORTED PLATFORMS -->
    <section class="section" id="platforms">
      <div class="shell">
        <div class="section-head section-head--wide">
          <div class="eyebrow eyebrow--blue">{m.live_update_platforms_kicker({}, { locale })}</div>
          <h2 class="h2-section">{m.live_update_platforms_title({}, { locale })}</h2>
          <p class="lead">{m.live_update_platforms_desc({}, { locale })}</p>
        </div>

        <div class="outcome-grid platform-grid">
          {
            platformCards.map((card) => (
              <article class="outcome-card platform-card">
                <h3>{card.title}</h3>
                <p>{card.text}</p>
                <a class="platform-link" href={card.href}>
                  {card.readMore} →
                </a>
              </article>
            ))
          }
        </div>
      </div>
    </section>

    <!-- OUTCOMES -->
    <section class="section" id="outcomes">
      <div class="shell">
        <div class="section-head section-head--wide">
          <div class="eyebrow eyebrow--blue">{m.live_update_outcome_kicker({}, { locale })}</div>
          <h2 class="h2-section">{m.live_update_outcome_title({}, { locale })}</h2>
          <p class="lead">{m.live_update_outcome_desc({}, { locale })}</p>
        </div>

        <div class="outcome-grid">
          {
            outcomeCards.map((card) => (
              <article class="outcome-card">
                <h3>{card.title}</h3>
                <p>{card.text}</p>
              </article>
            ))
          }
        </div>

        <div class="decision-box">
          <h3>{m.live_update_decision_title({}, { locale })}</h3>
          <ul class="decision-list">
            {decisionCriteria.map((item) => <li>{item}</li>)}
          </ul>
        </div>
      </div>
    </section>

    <ProductVideoSection
      variant="builder"
      accent="blue"
      youtubeId={productVideos.liveUpdate.youtubeId}
      title={productVideos.liveUpdate.title}
      description={productVideos.liveUpdate.description}
    />

    <!-- PROOF -->
    <ProductTestimonials
      variant="builder"
      accent="blue"
      eyebrow={copy('live_update_v2_proof_eyebrow')}
      title={copy('live_update_v2_proof_title')}
      description={copy('live_update_v2_proof_lead')}
      testimonials={productTestimonials.liveUpdate}
      maxItems={2}
    />

    <!-- BENTO FEATURES -->
    <section class="section bg-grid grain" id="features">
      <div class="shell">
        <div class="section-head">
          <div class="eyebrow eyebrow--blue">{copy('live_update_v2_bento_eyebrow')}</div>
          <h2 class="h2-section">{copy('live_update_v2_bento_title')}</h2>
          <p class="lead">{copy('live_update_v2_bento_lead')}</p>
        </div>

        <div class="bento">
          <div class="tile tile-hero" aria-label="Capgo Live Updates">
            <div>
              <div class="ttl">
                <span class="name">Capgo Live Updates</span><br />
                <span class="tile-hero-sub-ttl">{m.live_update_feature_native_engine({}, { locale })}</span>
              </div>
              <div class="sub">{m.live_update_feature_native_engine_desc({}, { locale })}</div>
            </div>
            <pre class="ascii">$ npx @capgo/cli bundle upload
✔ validated · ✔ published · ✔ rolling out</pre>
          </div>

          {
            featureTiles.map((tile) => (
              <div class="tile">
                <h3 class="ttl">
                  <span class="ttl-accent">{tile.title}</span>
                </h3>
                <p class="sub">{tile.sub}</p>
              </div>
            ))
          }
        </div>
      </div>
    </section>

    <!-- GUIDANCE -->
    <section class="section" id="guidance">
      <div class="shell">
        <div class="section-head section-head--wide">
          <div class="eyebrow eyebrow--blue">{m.live_update_guidance_kicker({}, { locale })}</div>
          <h2 class="h2-section">{m.live_update_guidance_title({}, { locale })}</h2>
          <p class="lead">{m.live_update_guidance_desc({}, { locale })}</p>
        </div>

        <div class="guidance-grid">
          <div>
            <ul class="guidance-checks">
              {guidanceChecks.map((check) => <li>{check}</li>)}
            </ul>
            <div class="hero-ctas" style="margin-top: 28px; align-items: flex-start;">
              <div class="hero-cta-buttons">
                <a class="btn btn-md btn-primary" href={getRelativeLocaleUrl(locale, 'docs/live-updates/compatibility')}>
                  {m.live_update_guidance_docs_cta({}, { locale })}
                </a>
                <a class="btn btn-md btn-ghost" href={registerUrl}>{m.live_update_hero_cta({}, { locale })}</a>
              </div>
            </div>
          </div>

          <div class="guidance-panel">
            <img
              src="/landing-demos/live-update-dashboard.webp"
              alt="Capgo live update dashboard showing release health and compatibility warnings"
              loading="lazy"
              decoding="async"
            />
            <div class="guidance-cli">
              <p class="guidance-cli-line"><span class="mono">$</span> {m.live_update_guidance_cli_command({}, { locale })}</p>
              <p class="guidance-cli-warn">{m.live_update_guidance_cli_warning({}, { locale })}</p>
              <p class="guidance-cli-dim">{m.live_update_guidance_cli_package({}, { locale })}</p>
              <p class="guidance-cli-action">{m.live_update_guidance_cli_action({}, { locale })}</p>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- HOW IT WORKS -->
    <section class="section" id="how">
      <div class="shell">
        <div class="section-head section-head--narrow">
          <div class="eyebrow eyebrow--blue">{copy('live_update_v2_how_eyebrow')}</div>
          <h2 class="h2-section">{m.live_update_how_it_works_title({}, { locale })}</h2>
          <p class="lead">{m.live_update_how_it_works_subtitle({}, { locale })}</p>
        </div>

        <div class="steps-grid">
          {
            steps.map((step, index) => (
              <article class="step-card">
                <div class="step-num">{index + 1}</div>
                <h3>{step.title}</h3>
                <p>{step.text}</p>
              </article>
            ))
          }
        </div>
      </div>
    </section>

    <!-- COMPARISON -->
    <section class="section" id="compare">
      <div class="shell">
        <div class="section-head">
          <div class="eyebrow eyebrow--blue">{copy('live_update_v2_comp_eyebrow')}</div>
          <h2 class="h2-section">{copy('live_update_v2_comp_title')}</h2>
          <p class="lead">{copy('live_update_v2_comp_lead')}</p>
        </div>

        <div class="comp-wrap">
          <table class="comp comp-prose">
            <thead>
              <tr>
                <th></th>
                <th class="us">Capgo Live Updates</th>
                <th>
                  {copy('live_update_v2_comp_h_diy')}
                  <span class="th-sub">{copy('live_update_v2_comp_h_diy_sub')}</span>
                </th>
                <th>{copy('live_update_v2_comp_h_capa')}</th>
              </tr>
            </thead>
            <tbody>
              {
                comparisonRows.map((row) => (
                  <tr>
                    <td class="label">{row.label}</td>
                    <td class="us">
                      <span class="hook">{row.hook}</span> {row.capgo}
                    </td>
                    <td>{row.diy}</td>
                    <td>{row.capa}</td>
                  </tr>
                ))
              }
            </tbody>
          </table>
        </div>

        <aside class="comp-callout" role="note">
          <p>{copy('live_update_v2_comp_callout')}</p>
        </aside>

        <p class="comp-footnote">{copy('live_update_v2_comp_footnote')}</p>
      </div>
    </section>

    <!-- FINAL CTA -->
    <section class="section final bg-grid grain" id="cta">
      <div class="shell">
        <h2>
          <span class="name">Capgo Live Updates</span><br />
          {m.live_update_cta_title({}, { locale })}
        </h2>
        <p class="tagline">{m.live_update_cta_subtitle({}, { locale })}</p>
        <a class="btn btn-lg btn-primary btn-cta" href={registerUrl}>{m.live_update_hero_cta({}, { locale })} →</a>
        <div class="hero-meta hero-meta--cta">
          <span><span class="check">✓</span> {copy('live_update_v2_cta_meta1')}</span>
          <span><span class="check">✓</span> {copy('live_update_v2_cta_meta2')}</span>
          <span><span class="check">✓</span> {copy('live_update_v2_cta_meta3')}</span>
        </div>
      </div>
    </section>

    <div class="shell seo-bridge">
      <h2 class="h2-section" style="font-size: 1.5rem; margin-bottom: 12px;">Keep going from Capgo Live Updates</h2>
      <p>
        Connect this Ionic and Capacitor live update page with <a href="/docs/live-updates/channels/">Channels</a>, <a href="/docs/live-updates/rollbacks/">Rollbacks</a>,
        <a href="/docs/live-updates/update-behavior/">Update Behavior</a>, <a href="/plugins/capacitor-updater/">Capacitor Updater</a>, and <a href="/native-build/"
          >Capgo Native Builds</a
        >
        for releases that still need store review.
      </p>
    </div>
  </div>
</Layout>
