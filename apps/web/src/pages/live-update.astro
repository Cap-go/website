---
import Layout from '@/layouts/Layout.astro'
import m from '@/copy/messages'
import { getRelativeLocaleUrl } from 'astro:i18n'
import { createServiceLdJson, createLdJsonGraph } from '@/lib/ldJson'

const locale = Astro.locals.locale
const brand = Astro.locals.runtimeConfig.public.brand

const title = `${brand} | ${m.live_update({}, { locale })}`
const description = m.live_update_description({}, { locale })

const serviceLdJson = createServiceLdJson(Astro.locals.runtimeConfig.public, {
  name: title,
  description: description,
  url: Astro.url.href,
  serviceType: 'Software Development Service',
  areaServed: ['Worldwide'],
})

const ldJSON = createLdJsonGraph(Astro.locals.runtimeConfig.public, serviceLdJson, {
  includeOrganization: true,
})

const content = {
  title,
  description,
  ldJSON,
}

const outcomeCards = [
  {
    title: m.live_update_outcome_card_recover_title({}, { locale }),
    text: m.live_update_outcome_card_recover_text({}, { locale }),
  },
  {
    title: m.live_update_outcome_card_control_title({}, { locale }),
    text: m.live_update_outcome_card_control_text({}, { locale }),
  },
  {
    title: m.live_update_outcome_card_prove_title({}, { locale }),
    text: m.live_update_outcome_card_prove_text({}, { locale }),
  },
]

const decisionCriteria = [m.live_update_decision_1({}, { locale }), m.live_update_decision_2({}, { locale }), m.live_update_decision_3({}, { locale })]
---

<Layout content={content} pageStyle="marketing-refresh">
  <div>
    <div class="relative">
      <!-- Animated background elements -->
      <div class="pointer-events-none absolute inset-0 overflow-hidden">
        {
          Array.from({ length: 12 }).map(() => (
            <div
              class="absolute h-2 w-2 animate-pulse rounded-full bg-blue-500 opacity-20"
              style={{
                top: `${Math.random() * 100}%`,
                left: `${Math.random() * 100}%`,
                animationDelay: `${Math.random() * 3}s`,
                animationDuration: `${2 + Math.random() * 2}s`,
              }}
            />
          ))
        }
      </div>

      <!-- Hero Section -->
      <section class="relative py-12 sm:py-16 lg:pt-20 xl:pb-0">
        <div class="relative mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
          <div class="relative z-10 mx-auto max-w-4xl text-center">
            <p class="font-pj inline-flex rounded-full border border-blue-400/40 bg-blue-500/10 px-4 py-2 text-base text-blue-100">
              <svg class="mr-2 h-5 w-5 text-white" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  stroke-width="2"
                  d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z"
                ></path>
              </svg>
              {m.iterate_faster({}, { locale })}
            </p>
            <h1 class="font-pj mt-5 text-3xl leading-tight font-bold text-white sm:text-4xl sm:leading-tight lg:leading-tight xl:text-5xl">
              {m.live_update_hero_title({}, { locale })}
            </h1>
            <h2 class="font-inter mx-auto mt-6 max-w-2xl text-base leading-7 text-gray-300">
              {m.live_update_hero_subtitle({}, { locale })}
            </h2>

            <!-- CTA buttons -->
            <div class="mt-10 flex flex-col items-center justify-center gap-4 sm:flex-row">
              <a
                href={getRelativeLocaleUrl(locale, 'register')}
                class="rounded-xl bg-blue-600 px-8 py-3 text-base font-semibold text-white transition-all duration-200 hover:bg-blue-700 focus:ring-2 focus:ring-blue-500 focus:ring-offset-2 focus:outline-none"
              >
                {m.live_update_get_started({}, { locale })}
              </a>
              <a
                href={getRelativeLocaleUrl(locale, 'docs/live-updates')}
                class="rounded-xl border border-gray-600 px-8 py-3 text-base font-semibold text-gray-300 transition-all duration-200 hover:bg-gray-800 hover:text-white"
              >
                {m.live_update_view_docs({}, { locale })}
              </a>
            </div>
          </div>
        </div>
      </section>

      <!-- Buyer Outcome Section -->
      <section class="bg-gray-950 py-14 sm:py-16">
        <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
          <div class="grid gap-10 lg:grid-cols-[0.9fr_1.1fr] lg:items-start">
            <div>
              <p class="inline-flex rounded-full border border-emerald-400/30 bg-emerald-500/10 px-3 py-1 text-xs font-semibold tracking-wide text-emerald-100 uppercase">
                {m.live_update_outcome_kicker({}, { locale })}
              </p>
              <h2 class="font-pj mt-4 text-3xl font-bold text-white sm:text-4xl">{m.live_update_outcome_title({}, { locale })}</h2>
              <p class="mt-4 text-lg leading-8 text-gray-300">
                {m.live_update_outcome_desc({}, { locale })}
              </p>
            </div>
            <div class="grid gap-4 md:grid-cols-3 lg:grid-cols-1">
              {
                outcomeCards.map((card) => (
                  <article class="rounded-2xl border border-white/10 bg-white/[0.04] p-5">
                    <h3 class="text-lg font-bold text-white">{card.title}</h3>
                    <p class="mt-3 text-sm leading-6 text-gray-300">{card.text}</p>
                  </article>
                ))
              }
            </div>
          </div>

          <div class="mt-10 rounded-2xl border border-blue-400/20 bg-blue-500/10 p-6">
            <h3 class="text-xl font-bold text-white">{m.live_update_decision_title({}, { locale })}</h3>
            <ul class="mt-5 grid gap-4 text-sm leading-6 text-blue-50 md:grid-cols-3">
              {
                decisionCriteria.map((item) => (
                  <li class="flex gap-3">
                    <span class="mt-2 h-2 w-2 shrink-0 rounded-full bg-blue-300" />
                    <span>{item}</span>
                  </li>
                ))
              }
            </ul>
          </div>
        </div>
      </section>

      <!-- Category Leadership Section -->
      <section class="bg-gray-900 px-4 py-12 sm:px-6 lg:px-8 lg:py-16">
        <div class="mx-auto max-w-7xl">
          <div class="grid gap-10 lg:grid-cols-[0.9fr_1.1fr] lg:items-start">
            <div>
              <p class="inline-flex rounded-full border border-blue-400/30 bg-blue-500/10 px-3 py-1 text-xs font-semibold tracking-wide text-sky-100 uppercase">
                {m.live_update_proof_kicker({}, { locale })}
              </p>
              <h2 class="font-pj mt-4 text-3xl leading-tight font-bold text-white sm:text-4xl">
                {m.live_update_proof_title({}, { locale })}
              </h2>
              <p class="mt-5 text-lg leading-8 text-gray-300">
                {m.live_update_proof_desc({}, { locale })}
              </p>
            </div>

            <div class="grid gap-4 sm:grid-cols-2">
              <div class="rounded-2xl border border-gray-700 bg-gray-800 p-5">
                <div class="mb-4 flex h-9 w-9 items-center justify-center rounded-lg bg-blue-500/15 text-sm font-bold text-blue-200 ring-1 ring-blue-300/30">01</div>
                <h3 class="font-pj text-lg font-bold text-white">{m.live_update_proof_card1_title({}, { locale })}</h3>
                <p class="mt-2 text-sm leading-6 text-gray-400">{m.live_update_proof_card1_desc({}, { locale })}</p>
              </div>
              <div class="rounded-2xl border border-gray-700 bg-gray-800 p-5">
                <div class="mb-4 flex h-9 w-9 items-center justify-center rounded-lg bg-emerald-500/15 text-sm font-bold text-emerald-200 ring-1 ring-emerald-300/30">02</div>
                <h3 class="font-pj text-lg font-bold text-white">{m.live_update_proof_card2_title({}, { locale })}</h3>
                <p class="mt-2 text-sm leading-6 text-gray-400">{m.live_update_proof_card2_desc({}, { locale })}</p>
              </div>
              <div class="rounded-2xl border border-gray-700 bg-gray-800 p-5">
                <div class="mb-4 flex h-9 w-9 items-center justify-center rounded-lg bg-amber-500/15 text-sm font-bold text-amber-200 ring-1 ring-amber-300/30">03</div>
                <h3 class="font-pj text-lg font-bold text-white">{m.live_update_proof_card3_title({}, { locale })}</h3>
                <p class="mt-2 text-sm leading-6 text-gray-400">{m.live_update_proof_card3_desc({}, { locale })}</p>
              </div>
              <div class="rounded-2xl border border-gray-700 bg-gray-800 p-5">
                <div class="mb-4 flex h-9 w-9 items-center justify-center rounded-lg bg-rose-500/15 text-sm font-bold text-rose-200 ring-1 ring-rose-300/30">04</div>
                <h3 class="font-pj text-lg font-bold text-white">{m.live_update_proof_card4_title({}, { locale })}</h3>
                <p class="mt-2 text-sm leading-6 text-gray-400">{m.live_update_proof_card4_desc({}, { locale })}</p>
              </div>
            </div>
          </div>
        </div>
      </section>

      <!-- Features Grid Section -->
      <section class="bg-gray-900 py-12 sm:py-16 lg:py-20">
        <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
          <div class="mb-12 text-center">
            <h2 class="font-pj text-3xl leading-tight font-bold text-white sm:text-4xl">
              {m.live_update_features_title({}, { locale })}
            </h2>
            <p class="mt-4 text-lg text-gray-300">
              {m.live_update_features_subtitle({}, { locale })}
            </p>
          </div>

          <div class="grid grid-cols-1 gap-8 md:grid-cols-2 lg:grid-cols-3">
            <!-- Breaking Update Detection -->
            <div class="rounded-2xl border border-gray-700 bg-gray-800 p-6 transition-all duration-300 hover:border-blue-500/50 hover:bg-gray-800/90">
              <div class="mb-4 flex h-12 w-12 items-center justify-center rounded-xl bg-blue-500/15 ring-1 ring-blue-300/40">
                <svg class="h-6 w-6 text-blue-400" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                  <path
                    stroke-linecap="round"
                    stroke-linejoin="round"
                    stroke-width="2"
                    d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-3L13.732 4c-.77-1.333-2.694-1.333-3.464 0L3.34 16c-.77 1.333.192 3 1.732 3z"></path>
                </svg>
              </div>
              <h3 class="font-pj mb-2 text-xl font-bold text-white">{m.live_update_feature_breaking_detection({}, { locale })}</h3>
              <p class="text-sm text-gray-300">
                {m.live_update_feature_breaking_detection_desc({}, { locale })}
              </p>
            </div>

            <!-- Pure Native Engine -->
            <div class="rounded-2xl border border-gray-700 bg-gray-800 p-6 transition-all duration-300 hover:border-blue-500/50 hover:bg-gray-800/90">
              <div class="mb-4 flex h-12 w-12 items-center justify-center rounded-xl bg-blue-500/15 ring-1 ring-blue-300/40">
                <svg class="h-6 w-6 text-blue-400" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                  <path
                    stroke-linecap="round"
                    stroke-linejoin="round"
                    stroke-width="2"
                    d="M9 3v2m6-2v2M9 19v2m6-2v2M5 9H3m2 6H3m18-6h-2m2 6h-2M7 19h10a2 2 0 002-2V7a2 2 0 00-2-2H7a2 2 0 00-2 2v10a2 2 0 002 2zM9 9h6v6H9V9z"></path>
                </svg>
              </div>
              <h3 class="font-pj mb-2 text-xl font-bold text-white">{m.live_update_feature_native_engine({}, { locale })}</h3>
              <p class="text-sm text-gray-300">
                {m.live_update_feature_native_engine_desc({}, { locale })}
              </p>
            </div>

            <!-- Automatic Rollback -->
            <div class="rounded-2xl border border-gray-700 bg-gray-800 p-6 transition-all duration-300 hover:border-blue-500/50 hover:bg-gray-800/90">
              <div class="mb-4 flex h-12 w-12 items-center justify-center rounded-xl bg-blue-500/15 ring-1 ring-blue-300/40">
                <svg class="h-6 w-6 text-blue-400" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 10h10a8 8 0 018 8v2M3 10l6 6m-6-6l6-6"></path>
                </svg>
              </div>
              <h3 class="font-pj mb-2 text-xl font-bold text-white">{m.live_update_feature_auto_rollback({}, { locale })}</h3>
              <p class="text-sm text-gray-300">
                {m.live_update_feature_auto_rollback_desc({}, { locale })}
              </p>
            </div>

            <!-- Self-Healing Updates -->
            <div class="rounded-2xl border border-gray-700 bg-gray-800 p-6 transition-all duration-300 hover:border-blue-500/50 hover:bg-gray-800/90">
              <div class="mb-4 flex h-12 w-12 items-center justify-center rounded-xl bg-blue-500/15 ring-1 ring-blue-300/40">
                <svg class="h-6 w-6 text-blue-400" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                  <path
                    stroke-linecap="round"
                    stroke-linejoin="round"
                    stroke-width="2"
                    d="M4.318 6.318a4.5 4.5 0 000 6.364L12 20.364l7.682-7.682a4.5 4.5 0 00-6.364-6.364L12 7.636l-1.318-1.318a4.5 4.5 0 00-6.364 0z"></path>
                </svg>
              </div>
              <h3 class="font-pj mb-2 text-xl font-bold text-white">{m.live_update_feature_self_healing({}, { locale })}</h3>
              <p class="text-sm text-gray-300">
                {m.live_update_feature_self_healing_desc({}, { locale })}
              </p>
            </div>

            <!-- Pre-flight Validation -->
            <div class="rounded-2xl border border-gray-700 bg-gray-800 p-6 transition-all duration-300 hover:border-blue-500/50 hover:bg-gray-800/90">
              <div class="mb-4 flex h-12 w-12 items-center justify-center rounded-xl bg-blue-500/15 ring-1 ring-blue-300/40">
                <svg class="h-6 w-6 text-blue-400" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"></path>
                </svg>
              </div>
              <h3 class="font-pj mb-2 text-xl font-bold text-white">{m.live_update_feature_preflight({}, { locale })}</h3>
              <p class="text-sm text-gray-300">
                {m.live_update_feature_preflight_desc({}, { locale })}
              </p>
            </div>

            <!-- End-to-End Encryption -->
            <div class="rounded-2xl border border-gray-700 bg-gray-800 p-6 transition-all duration-300 hover:border-blue-500/50 hover:bg-gray-800/90">
              <div class="mb-4 flex h-12 w-12 items-center justify-center rounded-xl bg-blue-500/15 ring-1 ring-blue-300/40">
                <svg class="h-6 w-6 text-blue-400" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                  <path
                    stroke-linecap="round"
                    stroke-linejoin="round"
                    stroke-width="2"
                    d="M12 15v2m-6 4h12a2 2 0 002-2v-6a2 2 0 00-2-2H6a2 2 0 00-2 2v6a2 2 0 002 2zm10-10V7a4 4 0 00-8 0v4h8z"></path>
                </svg>
              </div>
              <h3 class="font-pj mb-2 text-xl font-bold text-white">{m.live_update_feature_encryption({}, { locale })}</h3>
              <p class="text-sm text-gray-300">
                {m.live_update_feature_encryption_desc({}, { locale })}
              </p>
            </div>
          </div>
        </div>
      </section>

      <!-- Observability / Logs Section -->
      <section class="bg-gray-900 py-14">
        <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
          <div class="grid items-center gap-10 lg:grid-cols-[1.1fr_0.9fr]">
            <div>
              <p class="inline-flex rounded-full border border-blue-400/30 bg-blue-500/10 px-3 py-1 text-xs font-semibold tracking-wide text-sky-100 uppercase">
                {m.live_update_logs_kicker({}, { locale })}
              </p>
              <h2 class="font-pj mt-4 text-3xl font-bold text-white sm:text-4xl">
                {m.live_update_logs_title({}, { locale })}
              </h2>
              <p class="mt-4 text-lg text-gray-200">
                {m.live_update_logs_desc({}, { locale })}
              </p>
              <ul class="mt-6 space-y-3 text-gray-200">
                <li class="flex gap-3">
                  <span class="mt-1 h-2 w-2 rounded-full bg-emerald-400"></span>
                  {m.live_update_logs_bullet1({}, { locale })}
                </li>
                <li class="flex gap-3">
                  <span class="mt-1 h-2 w-2 rounded-full bg-amber-400"></span>
                  {m.live_update_logs_bullet2({}, { locale })}
                </li>
                <li class="flex gap-3">
                  <span class="mt-1 h-2 w-2 rounded-full bg-rose-400"></span>
                  {m.live_update_logs_bullet3({}, { locale })}
                </li>
                <li class="flex gap-3">
                  <span class="mt-1 h-2 w-2 rounded-full bg-sky-400"></span>
                  {m.live_update_logs_bullet4({}, { locale })}
                </li>
              </ul>
              <div class="mt-8 flex gap-3">
                <a
                  href={getRelativeLocaleUrl(locale, 'register')}
                  class="rounded-lg bg-blue-600 px-6 py-3 text-sm font-semibold text-white shadow-lg shadow-blue-600/30 transition hover:bg-blue-700"
                >
                  {m.live_update_logs_cta_primary({}, { locale })}
                </a>
                <a
                  href={getRelativeLocaleUrl(locale, 'docs/webapp/logs')}
                  class="rounded-lg border border-white/10 px-6 py-3 text-sm font-semibold text-blue-100 transition hover:border-blue-400/60"
                >
                  {m.live_update_logs_cta_secondary({}, { locale })}
                </a>
              </div>
            </div>
            <div class="relative rounded-2xl border border-white/5 bg-gray-800/80 p-6 shadow-2xl shadow-blue-900/40">
              <div class="space-y-3 font-mono text-xs text-gray-100">
                <div class="flex justify-between">
                  <span class="text-sky-300">14:30:02</span>
                  <span class="text-gray-300">device A1B2C3</span>
                  <span class="text-amber-200">download_start 2.6.0</span>
                </div>
                <div class="flex justify-between">
                  <span class="text-sky-300">14:30:07</span>
                  <span class="text-gray-300">device A1B2C3</span>
                  <span class="text-rose-300">update_fail (network_timeout)</span>
                </div>
                <div class="flex justify-between">
                  <span class="text-sky-300">14:30:08</span>
                  <span class="text-gray-300">device A1B2C3</span>
                  <span class="text-sky-200">auto-retry scheduled (30s)</span>
                </div>
                <div class="flex justify-between">
                  <span class="text-sky-300">14:31:15</span>
                  <span class="text-gray-300">device F0E1D2</span>
                  <span class="text-rose-300">update_fail (out_of_memory)</span>
                </div>
                <div class="flex justify-between">
                  <span class="text-sky-300">14:31:16</span>
                  <span class="text-gray-300">device F0E1D2</span>
                  <span class="text-emerald-300">rollback → builtin bundle</span>
                </div>
              </div>
              <p class="mt-6 text-sm text-gray-300">
                {m.live_update_logs_panel_footer({}, { locale })}
              </p>
            </div>
          </div>
        </div>
      </section>

      <!-- Dynamic Channels Section -->
      <section class="bg-gray-800/80 py-14">
        <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
          <div class="grid items-center gap-10 lg:grid-cols-[1fr_1fr]">
            <div class="order-2 lg:order-1">
              <p class="inline-flex rounded-full border border-amber-400/30 bg-amber-500/10 px-3 py-1 text-xs font-semibold tracking-wide text-amber-100 uppercase">
                {m.live_update_dynamic_kicker({}, { locale })}
              </p>
              <h2 class="font-pj mt-4 text-3xl font-bold text-white sm:text-4xl">
                {m.live_update_dynamic_title({}, { locale })}
              </h2>
              <p class="mt-4 text-lg text-gray-200">
                {m.live_update_dynamic_desc({}, { locale })}
              </p>
              <ul class="mt-6 space-y-3 text-gray-200">
                <li class="flex gap-3">
                  <span class="mt-1 h-2 w-2 rounded-full bg-emerald-400"></span>
                  <span class="inline-flex flex-wrap items-center gap-2 leading-relaxed">
                    {m.live_update_dynamic_bullet1_prefix({}, { locale })}
                    <span
                      class="inline-flex items-center rounded-lg border border-white/10 bg-gray-900/80 px-3 py-1 text-[13px] font-semibold shadow-[inset_0_1px_0_rgba(255,255,255,0.08)]"
                      >{m.live_update_dynamic_label_production({}, { locale })}</span
                    >
                    {m.live_update_dynamic_label_to({}, { locale })}
                    <span
                      class="inline-flex items-center rounded-lg border border-white/10 bg-gray-900/80 px-3 py-1 text-[13px] font-semibold shadow-[inset_0_1px_0_rgba(255,255,255,0.08)]"
                      >{m.live_update_dynamic_label_staging({}, { locale })}</span
                    >
                    {m.live_update_dynamic_bullet1_suffix({}, { locale })}
                  </span>
                </li>
                <li class="flex gap-3">
                  <span class="mt-1 h-2 w-2 rounded-full bg-sky-400"></span>
                  {m.live_update_dynamic_bullet2({}, { locale })}
                </li>
                <li class="flex gap-3">
                  <span class="mt-1 h-2 w-2 rounded-full bg-amber-400"></span>
                  {m.live_update_dynamic_bullet3({}, { locale })}
                </li>
                <li class="flex gap-3">
                  <span class="mt-1 h-2 w-2 rounded-full bg-rose-400"></span>
                  {m.live_update_dynamic_bullet4({}, { locale })}
                </li>
                <li class="flex gap-3">
                  <span class="mt-1 h-2 w-2 rounded-full bg-purple-400"></span>
                  {m.live_update_dynamic_bullet5({}, { locale })}
                </li>
                <li class="flex gap-3">
                  <span class="mt-1 h-2 w-2 rounded-full bg-cyan-400"></span>
                  {m.live_update_dynamic_bullet6({}, { locale })}
                </li>
              </ul>
              <div class="mt-8 flex gap-3">
                <a
                  href={getRelativeLocaleUrl(locale, 'docs/live-updates/channels')}
                  class="rounded-lg border border-white/10 px-6 py-3 text-sm font-semibold text-blue-100 transition hover:border-blue-400/60"
                >
                  {m.live_update_dynamic_cta_primary({}, { locale })}
                </a>
                <a
