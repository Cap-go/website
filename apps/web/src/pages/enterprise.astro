  m.enterprise_partnership_your_team_2({}, { locale }),
  m.enterprise_partnership_your_team_3({}, { locale }),
]
const partnershipCapgoTeam = [
  m.enterprise_partnership_capgo_team_1({}, { locale }),
  m.enterprise_partnership_capgo_team_2({}, { locale }),
  m.enterprise_partnership_capgo_team_3({}, { locale }),
]

const enterpriseLevers = [
  {
    title: m.enterprise_capacity_title({}, { locale }),
    metric: enterpriseMau,
    description: m.enterprise_capacity_desc({}, { locale }),
  },
  {
    title: m.enterprise_native_builds_title({}, { locale }),
