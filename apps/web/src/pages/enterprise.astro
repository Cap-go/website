---
import '@/styles/lu-product.css'
import Layout from '@/layouts/Layout.astro'
import { getRelativeLocaleUrl } from '@/services/links'
import m from '@/copy/messages'
import SolutionAppExample from '@/components/solutions/SolutionAppExample.astro'
import TeamAvatars from '@/components/TeamAvatars.astro'
import type { Database } from '@/services/supabase.types'
import { createLdJsonGraph, createServiceLdJson, createProductLdJson } from '@/lib/ldJson'
import { numberWithSpaces } from '@/services/misc'
import { pluginCountLabel } from '@/config/plugins'

const locale = Astro.locals.locale
const config = Astro.locals.runtimeConfig
const plansFetchTimeoutMs = 3000

let plansAll: Database['public']['Tables']['plans']['Row'][] = []
try {
  const response = await fetch(`${config.public.baseApiUrl}/private/plans`, {
    signal: AbortSignal.timeout(plansFetchTimeoutMs),
  })
  if (response.ok) {
    const payload = await response.json()
    if (Array.isArray(payload)) {
      plansAll = payload as Database['public']['Tables']['plans']['Row'][]
    }
  }
} catch {
  plansAll = []
}
const payg = plansAll.find((p) => p.name === 'Enterprise')
const enterprisePrice = typeof payg?.price_m === 'number' && Number.isFinite(payg.price_m) ? payg.price_m : undefined

const title = [Astro.locals.runtimeConfig.public.brand, 'Enterprise'].join(' | ')
const description = 'Enterprise-grade live updates for Capacitor apps. Built for teams that need advanced security, compliance, and dedicated support at scale.'

const baseUrl = Astro.locals.runtimeConfig.public.baseUrl
const enterpriseUrl = `${baseUrl}${getRelativeLocaleUrl(Astro.locals.locale, 'enterprise/')}`
const homeUrl = `${baseUrl}${getRelativeLocaleUrl(Astro.locals.locale, '/')}`

const enterpriseService = createServiceLdJson(Astro.locals.runtimeConfig.public, {
  name: 'Capgo Enterprise - Professional Live Updates',
  description: 'Enterprise-grade live update platform for Capacitor applications with advanced security, compliance features, and dedicated support for large-scale deployments.',
  url: enterpriseUrl,
  serviceType: 'Enterprise Software Service',
  areaServed: ['Worldwide'],
})

const enterpriseProduct = createProductLdJson(Astro.locals.runtimeConfig.public, {
  name: 'Capgo Enterprise Plan',
  description: 'Complete enterprise solution with advanced security, compliance, dedicated support, and unlimited scalability for professional teams.',
  url: enterpriseUrl,
  sku: 'capgo-enterprise',
  offers:
    enterprisePrice === undefined
      ? []
      : [
          {
            price: enterprisePrice.toString(),
            priceCurrency: 'USD',
            availability: 'https://schema.org/InStock',
            priceValidUntil: new Date(Date.now() + 365 * 24 * 60 * 60 * 1000).toISOString().split('T')[0],
          },
        ],
})

const enhancedEnterpriseProduct = {
  ...enterpriseProduct,
  category: 'Enterprise Software',
  audience: {
    '@type': 'BusinessAudience',
    audienceType: 'Enterprise Teams',
    geographicArea: 'Global',
  },
  hasOfferCatalog: {
    '@type': 'OfferCatalog',
    name: 'Enterprise Features',
    itemListElement: [
      {
        '@type': 'Offer',
        itemOffered: {
          '@type': 'Service',
          name: 'Advanced Security & Compliance',
          description: 'SOC 2 Type II compliance, end-to-end encryption, and enterprise-grade security controls.',
        },
      },
      {
        '@type': 'Offer',
        itemOffered: {
          '@type': 'Service',
          name: 'Dedicated Support',
          description: 'Dedicated Slack or Teams channel, onboarding, account management, and SLA-backed support.',
        },
      },
      {
        '@type': 'Offer',
        itemOffered: {
          '@type': 'Service',
          name: 'Custom Deployment Options',
          description: 'On-premise, hybrid cloud, or dedicated cloud deployments tailored to your infrastructure needs.',
        },
      },
      {
        '@type': 'Offer',
        itemOffered: {
          '@type': 'Service',
          name: 'Advanced Analytics & Reporting',
          description: 'Comprehensive deployment analytics, performance monitoring, and custom reporting dashboards.',
        },
      },
    ],
  },
}

const content = {
  title,
  description,
  image: `${baseUrl}/capgo_social.png`,
  ldJSON: createLdJsonGraph(Astro.locals.runtimeConfig.public, enhancedEnterpriseProduct as import('schema-dts').Thing, {
    includeOrganization: true,
    includeBreadcrumbs: true,
    breadcrumbs: [
      {
        name: 'Home',
        url: homeUrl,
      },
      {
        name: 'Enterprise',
        url: enterpriseUrl,
      },
    ],
    additionalEntities: [enterpriseService],
  }),
}

const enterpriseDecisionPoints = [m.enterprise_decision_point_1({}, { locale }), m.enterprise_decision_point_2({}, { locale }), m.enterprise_decision_point_3({}, { locale })]

const enterpriseMau = `${numberWithSpaces(payg?.mau ?? 1000000)}+`
const enterpriseBandwidth = `${numberWithSpaces(payg?.bandwidth ?? 5000)}+ GiB/month`
const enterpriseStorage = `${numberWithSpaces(payg?.storage ?? 100)}+ GiB`

const heroProofPoints = [
  { label: m.enterprise_audience_label({}, { locale }), value: enterpriseMau, detail: m.enterprise_audience_detail({}, { locale }) },
  { label: m.enterprise_delivery_label({}, { locale }), value: enterpriseBandwidth, detail: m.enterprise_delivery_detail({}, { locale }) },
  { label: m.enterprise_artifacts_label({}, { locale }), value: enterpriseStorage, detail: m.enterprise_artifacts_detail({}, { locale }) },
]

const enterpriseLevers = [
  {
    title: m.enterprise_capacity_title({}, { locale }),
    metric: enterpriseMau,
    description: m.enterprise_capacity_desc({}, { locale }),
  },
  {
    title: m.enterprise_native_builds_title({}, { locale }),
    metric: m.enterprise_native_builds_metric({}, { locale }),
    description: m.enterprise_native_builds_desc({}, { locale }),
  },
  {
    title: m.enterprise_compliance_procurement_title({}, { locale }),
    metric: m.enterprise_soc2_iso_metric({}, { locale }),
    description: m.enterprise_compliance_procurement_desc({}, { locale }),
  },
]

const approvalTracks = [
  {
    title: m.enterprise_security_review_title({}, { locale }),
    description: m.enterprise_security_review_desc({}, { locale }),
    items: [m.enterprise_soc2_certified_infrastructure({}, { locale }), m.enterprise_iso27001_in_progress({}, { locale }), m.enterprise_audit_signed_e2e({}, { locale })],
  },
  {
    title: m.enterprise_reliability_review_title({}, { locale }),
    description: m.enterprise_reliability_review_desc({}, { locale }),
    items: [m.enterprise_uptime_sla({}, { locale }), m.enterprise_updates_under_100ms({}, { locale }), m.enterprise_replication_rollback({}, { locale })],
  },
  {
    title: m.enterprise_procurement_review_title({}, { locale }),
    description: m.enterprise_procurement_review_desc({}, { locale }),
    items: [m.enterprise_signed_ndas_dpas({}, { locale }), m.enterprise_custom_payment_process({}, { locale }), m.enterprise_sap_po_procurement({}, { locale })],
  },
  {
    title: m.enterprise_migration_review_title({}, { locale }),
    description: m.enterprise_migration_review_desc({}, { locale }),
    items: [m.enterprise_platform_one_place({}, { locale }), m.enterprise_ionic_alternative_plugins({}, { locale }), m.enterprise_onboarding_training_team({}, { locale })],
  },
]

const customers = [
  { name: 'Nana', downloads: '2.5M', logo: '/nana-logo-transparent.webp' },
  { name: 'Snowqueen', downloads: '1.8M', logo: '/snowqueen.webp' },
  { name: 'Shelf', downloads: '950K', logo: '/shelf_app.webp' },
  { name: 'Suez', downloads: '3.2M', logo: '/suez.webp' },
  { name: 'Janitor', downloads: '750K', logo: '/janitor_app.webp' },
]

const pillars = [
  {
    eyebrow: m.enterprise_control_label({}, { locale }),
    title: m.solutions_enterprise_sol1_title({}, { locale }),
    description: m.solutions_enterprise_sol1_desc({}, { locale }),
    points: [m.solutions_enterprise_sol1_point1({}, { locale }), m.solutions_enterprise_sol1_point2({}, { locale }), m.solutions_enterprise_sol1_point3({}, { locale })],
  },
  {
    eyebrow: m.enterprise_release_safety_label({}, { locale }),
    title: m.solutions_enterprise_sol2_title({}, { locale }),
    description: m.solutions_enterprise_sol2_desc({}, { locale }),
    points: [m.solutions_enterprise_sol2_point1({}, { locale }), m.solutions_enterprise_sol2_point2({}, { locale }), m.solutions_enterprise_sol2_point3({}, { locale })],
  },
  {
    eyebrow: m.enterprise_audit_trail_label({}, { locale }),
    title: m.solutions_enterprise_sol3_title({}, { locale }),
    description: m.solutions_enterprise_sol3_desc({}, { locale }),
    points: [m.solutions_enterprise_sol3_point1({}, { locale }), m.enterprise_soc2_certified_infrastructure({}, { locale }), m.enterprise_iso27001_in_progress({}, { locale })],
  },
]

const includedGroups = [
  {
    title: m.enterprise_live_updates_at_scale({}, { locale }),
    items: [
      m.enterprise_feature_maus({ mau: enterpriseMau }, { locale }),
      enterpriseBandwidth,
      enterpriseStorage,
      m.enterprise_delta_updates({}, { locale }),
      m.enterprise_updates_under_100ms({}, { locale }),
      m.enterprise_7_continent_replication({}, { locale }),
      m.enterprise_signed_updates({}, { locale }),
      m.enterprise_updates_e2e_encrypted({}, { locale }),
    ],
  },
  {
    title: m.enterprise_control_title({}, { locale }),
    items: [
      m.enterprise_unlimited_apps_members_teams({}, { locale }),
      m.enterprise_unlimited_webhooks({}, { locale }),
      m.single_sign_on_sso({}, { locale }),
      m.custom_domain({}, { locale }),
      m.audit_logs({}, { locale }),
      m.enterprise_org_statistics_90_days({}, { locale }),
      m.enterprise_device_logs_90_days({}, { locale }),
    ],
  },
  {
    title: m.enterprise_native_builds_plugins({}, { locale }),
    items: [
      m.enterprise_large_macos_m4({}, { locale }),
      m.enterprise_6_concurrent_builds({}, { locale }),
      m.enterprise_app_store_publishing({}, { locale }),
      m.enterprise_130_plugins({ pluginCountLabel }, { locale }),
      m.enterprise_ionic_alternative_plugins({}, { locale }),
      m.enterprise_priority_plugin_fixes({}, { locale }),
    ],
  },
  {
    title: m.enterprise_compliance_procurement_group({}, { locale }),
    items: [
      m.enterprise_soc2_certified({}, { locale }),
      m.enterprise_iso27001_ongoing({}, { locale }),
      m.enterprise_signed_ndas_dpas({}, { locale }),
      m.enterprise_custom_payment_process({}, { locale }),
      m.enterprise_sap_procurement_workflows({}, { locale }),
      m.enterprise_stripe_payment_options({}, { locale }),
    ],
  },
  {
    title: m.enterprise_support_onboarding({}, { locale }),
    items: [
      m.enterprise_dedicated_slack_teams({}, { locale }),
      m.enterprise_dedicated_account_manager({}, { locale }),
      m.enterprise_onboarding_training({}, { locale }),
      m.enterprise_uptime_sla({}, { locale }),
      m.priority_support({}, { locale }),
      m.enterprise_discord_support({}, { locale }),
    ],
  },
]

const stats = [
  { value: '<100ms', label: m.enterprise_global_update_delivery({}, { locale }) },
  { value: '7', label: m.enterprise_continents_replicated({}, { locale }) },
  { value: '99.9%', label: m.solutions_enterprise_stat_uptime({}, { locale }) },
  { value: '500M+', label: m.solutions_enterprise_stat_updates({}, { locale }) },
]

const enterpriseTestimonial = {
  quote: m.solutions_enterprise_testimonial({}, { locale }),
  author: m.solutions_enterprise_testimonial_author({}, { locale }),
  role: m.solutions_enterprise_testimonial_role({}, { locale }),
}

const enterpriseProofNotes = [m.enterprise_proof_note_1({}, { locale }), m.enterprise_proof_note_2({}, { locale }), m.enterprise_proof_note_3({}, { locale })]

const enterprisePainPoints = [
  {
    label: m.enterprise_pain_incident_label({}, { locale }),
    title: m.enterprise_pain_incident_title({}, { locale }),
    description: m.enterprise_pain_incident_desc({}, { locale }),
  },
  {
    label: m.enterprise_pain_version_label({}, { locale }),
    title: m.enterprise_pain_version_title({}, { locale }),
    description: m.enterprise_pain_version_desc({}, { locale }),
  },
  {
    label: m.enterprise_pain_approval_label({}, { locale }),
    title: m.enterprise_pain_approval_title({}, { locale }),
    description: m.enterprise_pain_approval_desc({}, { locale }),
  },
  {
    label: m.enterprise_pain_coordination_label({}, { locale }),
    title: m.enterprise_pain_coordination_title({}, { locale }),
    description: m.enterprise_pain_coordination_desc({}, { locale }),
  },
]

const enterpriseBeforeAfterRows = [
  {
    area: m.enterprise_before_after_critical_area({}, { locale }),
    before: m.enterprise_before_after_critical_before({}, { locale }),
    after: m.enterprise_before_after_critical_after({}, { locale }),
  },
  {
    area: m.enterprise_before_after_portfolio_area({}, { locale }),
    before: m.enterprise_before_after_portfolio_before({}, { locale }),
    after: m.enterprise_before_after_portfolio_after({}, { locale }),
  },
  {
    area: m.enterprise_before_after_security_area({}, { locale }),
    before: m.enterprise_before_after_security_before({}, { locale }),
    after: m.enterprise_before_after_security_after({}, { locale }),
  },
  {
    area: m.enterprise_before_after_vendor_area({}, { locale }),
    before: m.enterprise_before_after_vendor_before({}, { locale }),
    after: m.enterprise_before_after_vendor_after({}, { locale }),
  },
]
---

<Layout content={content}>
  <div class="lu enterprise-product bg-ad">
    <section class="section hero bg-grid grain" id="top">
      <div class="shell">
        <div class="beta-badge">
          <span class="dot"></span>
          {m.enterprise_ready({}, { locale })}
        </div>
        <h1 class="hero-banner" aria-label={`${m.enterprise_title({}, { locale })}: ${m.deliver_updates({}, { locale })} ${m.at_scale({}, { locale })}`}>
          <span class="hbv-underlined">
            <span class="hbv-u-name">{m.enterprise_title({}, { locale })}</span>
            <span class="hbv-u-rule"></span>
          </span>
          <span class="hero-banner-tag">{m.deliver_updates({}, { locale })} {m.at_scale({}, { locale })}</span>
        </h1>
        <p class="lead hero-lead">{m.enterprise_hero_platform_desc({ pluginCountLabel }, { locale })}</p>
        <div class="hero-ctas">
          <div class="hero-cta-buttons">
            <a
              class="btn btn-lg btn-primary"
              href="https://book.capgo.app/enterprise-inquiry/"
              target="_blank"
              rel="noopener noreferrer"
              aria-label={m.enterprise_talk_to_team({}, { locale })}
            >
              <TeamAvatars />
              <span>{m.enterprise_talk_to_team({}, { locale })}</span>
            </a>
            <a class="btn btn-lg btn-ghost" href={getRelativeLocaleUrl(locale, 'pricing')}>{m.view_pricing({}, { locale })}</a>
          </div>
          <p class="hero-cta-note">{m.enterprise_custom_card_desc({}, { locale })}</p>
        </div>
        <div class="hero-meta">
          <span><span class="check">✓</span> {m.enterprise_uptime_sla({}, { locale })}</span>
          <span><span class="check">✓</span> {m.single_sign_on_sso({}, { locale })}</span>
          <span><span class="check">✓</span> {m.enterprise_signed_ndas_dpas({}, { locale })}</span>
        </div>
        <div class="hero-strip enterprise-hero-strip">
          {
            heroProofPoints.map((point) => (
              <div class="hero-strip-cell">
                <p class="v">{point.value}</p>
                <p class="k">{point.label}</p>
                <p class="enterprise-strip-detail">{point.detail}</p>
              </div>
            ))
          }
        </div>
      </div>
    </section>

    <section class="section enterprise-proof" id="proof">
      <div class="shell">
        <div class="section-head section-head--wide">
          <div class="eyebrow eyebrow--blue">{m.trusted_by_the_biggest_capacitor_apps({}, { locale })}</div>
          <h2 class="h2-section">{m.built_for_enterprise_teams({}, { locale })}</h2>
          <p class="lead">{m.advanced_collaboration_security_compliance({}, { locale })}</p>
        </div>

        <div class="enterprise-logo-grid">
          {
            customers.map((customer) => (
              <div class="enterprise-logo-card">
                <img src={customer.logo} alt={`${customer.name} logo`} width="40" height="40" loading="lazy" decoding="async" />
                <div>
                  <p>{customer.name}</p>
                  <span>
                    {customer.downloads} {m.downloads({}, { locale })}
                  </span>
                </div>
              </div>
            ))
          }
        </div>

        <div class="enterprise-proof-grid">
          <figure class="enterprise-quote">
            <p class="eyebrow eyebrow--blue">{m.enterprise_testimonial_label({}, { locale })}</p>
            <blockquote>"{enterpriseTestimonial.quote}"</blockquote>
            <figcaption>
              <strong>{enterpriseTestimonial.author}</strong>
              <span>{enterpriseTestimonial.role}</span>
            </figcaption>
          </figure>

          <div class="enterprise-note-list">
            {
              enterpriseProofNotes.map((note) => (
                <p>
                  <span aria-hidden="true">✓</span>
                  {note}
                </p>
              ))
            }
          </div>
        </div>
      </div>
    </section>

    <section class="section bg-grid grain" id="pain">
      <div class="shell">
        <div class="section-head section-head--wide">
          <div class="eyebrow eyebrow--blue">{m.enterprise_pain_label({}, { locale })}</div>
          <h2 class="h2-section">{m.enterprise_pain_title({}, { locale })}</h2>
          <p class="lead">{m.enterprise_pain_desc({}, { locale })}</p>
        </div>

        <div class="outcome-grid enterprise-pain-grid">
          {
            enterprisePainPoints.map((pain) => (
              <article class="outcome-card enterprise-pain-card">
                <p class="enterprise-card-label">{pain.label}</p>
                <h3>{pain.title}</h3>
                <p>{pain.description}</p>
              </article>
            ))
          }
        </div>
      </div>
    </section>

    <section class="section" id="scale">
      <div class="shell">
        <div class="section-head">
          <div class="eyebrow eyebrow--blue">{m.enterprise_scale_label({}, { locale })}</div>
          <h2 class="h2-section">{m.enterprise_limits_title({}, { locale })}</h2>
          <p class="lead">{m.enterprise_limits_desc({}, { locale })}</p>
        </div>

        <div class="enterprise-metric-grid">
          {
            enterpriseLevers.map((lever) => (
              <article class="enterprise-metric-card">
                <p class="enterprise-metric-value">{lever.metric}</p>
                <h3>{lever.title}</h3>
                <p>{lever.description}</p>
              </article>
            ))
          }
        </div>
      </div>
    </section>

    <section class="section bg-grid grain" id="approval">
      <div class="shell">
        <div class="enterprise-split">
          <div>
            <div class="eyebrow eyebrow--blue">{m.enterprise_approval_label({}, { locale })}</div>
            <h2 class="h2-section">{m.enterprise_approval_title({}, { locale })}</h2>
            <p class="lead">{m.enterprise_approval_desc({}, { locale })}</p>
          </div>

          <div class="enterprise-track-grid">
            {
              approvalTracks.map((track) => (
                <article class="enterprise-track-card">
                  <h3>{track.title}</h3>
                  <p>{track.description}</p>
                  <ul>
                    {track.items.map((item) => (
                      <li>
                        <span aria-hidden="true">✓</span>
                        {item}
                      </li>
                    ))}
                  </ul>
                </article>
              ))
            }
          </div>
        </div>
      </div>
    </section>

    <section class="section" id="comparison">
      <div class="shell">
        <div class="section-head section-head--wide">
          <div class="eyebrow eyebrow--blue">{m.enterprise_comparison_label({}, { locale })}</div>
          <h2 class="h2-section">{m.enterprise_comparison_title({}, { locale })}</h2>
          <p class="lead">{m.enterprise_comparison_desc({}, { locale })}</p>
        </div>

        <div class="enterprise-table-wrap">
          <div class="enterprise-table enterprise-table-head">
            <span>{m.enterprise_comparison_use_case({}, { locale })}</span>
            <span>{m.enterprise_comparison_before({}, { locale })}</span>
            <span>{m.enterprise_comparison_after({}, { locale })}</span>
          </div>
          {
            enterpriseBeforeAfterRows.map((row) => (
              <div class="enterprise-table">
                <strong>{row.area}</strong>
                <p>{row.before}</p>
                <p class="enterprise-after">{row.after}</p>
              </div>
            ))
          }
        </div>
      </div>
    </section>

    <section class="section bg-grid grain" id="decision">
      <div class="shell">
        <div class="enterprise-split enterprise-split--compact">
          <div>
            <div class="eyebrow eyebrow--blue">{m.enterprise_decision_criteria_eyebrow({}, { locale })}</div>
            <h2 class="h2-section">{m.enterprise_decision_criteria_title({}, { locale })}</h2>
            <p class="lead">{m.enterprise_decision_criteria_desc({}, { locale })}</p>
          </div>
          <div class="decision-box enterprise-decision-box">
            <h3>{m.enterprise_decision_questions_title({}, { locale })}</h3>
            <ol class="enterprise-decision-list">
              {enterpriseDecisionPoints.map((item) => <li>{item}</li>)}
            </ol>
          </div>
        </div>
      </div>
    </section>

    <section class="section" id="solution">
      <div class="shell">
        <div class="section-head section-head--wide">
          <div class="eyebrow eyebrow--blue">{m.solutions_enterprise_solution_label({}, { locale })}</div>
          <h2 class="h2-section">{m.solutions_enterprise_solution_title({}, { locale })}</h2>
          <p class="lead">{m.solutions_enterprise_solution_subtitle({}, { locale })}</p>
        </div>

        <div class="outcome-grid">
          {
            pillars.map((pillar) => (
              <article class="outcome-card enterprise-pillar-card">
                <p class="enterprise-card-label">{pillar.eyebrow}</p>
                <h3>{pillar.title}</h3>
                <p>{pillar.description}</p>
                <ul>
                  {pillar.points.map((point) => (
                    <li>
                      <span aria-hidden="true">✓</span>
                      {point}
                    </li>
                  ))}
                </ul>
              </article>
            ))
          }
        </div>
      </div>
    </section>

    <section class="section bg-grid grain" id="features">
      <div class="shell">
        <div class="section-head">
          <div class="eyebrow eyebrow--blue">{m.enterprise_features({}, { locale })}</div>
          <h2 class="h2-section">{m.built_for_enterprise_teams({}, { locale })}</h2>
          <p class="lead">{m.advanced_collaboration_security_compliance({}, { locale })}</p>
        </div>

        <div class="enterprise-feature-grid">
          {
            includedGroups.map((group) => (
              <article class="enterprise-feature-group">
                <h3>{group.title}</h3>
                <ul>
                  {group.items.map((item) => (
                    <li>
                      <span aria-hidden="true">✓</span>
                      {item}
                    </li>
                  ))}
                </ul>
              </article>
            ))
          }
        </div>
      </div>
    </section>

    <section class="section" id="infrastructure">
