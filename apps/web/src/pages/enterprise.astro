  },
]
const comparisonUseCaseLabel = m.enterprise_comparison_use_case({}, { locale })
const comparisonBeforeLabel = m.enterprise_comparison_before({}, { locale })
const comparisonAfterLabel = m.enterprise_comparison_after({}, { locale })
---

<Layout content={content}>
  <div class="lu enterprise-product bg-ad">
    <section class="section hero bg-grid grain" id="top">
      <div class="shell">
        <div class="beta-badge">
          <span class="dot"></span>
          {m.enterprise_hero_badge({}, { locale })}
        </div>
        <h1 class="hero-banner" aria-label={`${m.enterprise_hero_headline({}, { locale })}: ${m.enterprise_hero_title({}, { locale })}`}>
          <span class="hbv-underlined">
            <span class="hbv-u-name">{m.enterprise_hero_headline({}, { locale })}</span>
            <span class="hbv-u-rule"></span>
          </span>
          <span class="hero-banner-tag">{m.enterprise_hero_title({}, { locale })}</span>
        </h1>
        <p class="lead hero-lead">{m.enterprise_hero_desc({}, { locale })}</p>
        <div class="hero-ctas">
          <div class="hero-cta-buttons">
            <a
              class="btn btn-lg btn-primary"
              href="https://book.capgo.app/enterprise-inquiry/"
              target="_blank"
              rel="noopener noreferrer"
              aria-label={m.enterprise_talk_to_team({}, { locale })}
            >
              <TeamAvatars />
              <span>{m.enterprise_talk_to_team({}, { locale })}</span>
            </a>
            <a class="btn btn-lg btn-ghost" href={getRelativeLocaleUrl(locale, 'pricing')}>{m.view_pricing({}, { locale })}</a>
          </div>
          <p class="hero-cta-note">{m.enterprise_hero_note({}, { locale })}</p>
        </div>
        <div class="hero-meta">
          <span><span class="check" aria-hidden="true">✓</span> {m.enterprise_soc2_certified({}, { locale })}</span>
          <span><span class="check" aria-hidden="true">✓</span> {m.enterprise_uptime_sla({}, { locale })}</span>
          <span><span class="check" aria-hidden="true">✓</span> {m.single_sign_on_sso({}, { locale })}</span>
          <span><span class="check" aria-hidden="true">✓</span> {m.enterprise_hero_personalized_value({}, { locale })}</span>
        </div>
        <div class="hero-strip enterprise-hero-strip">
          {
            heroProofPoints.map((point) => (
              <div class="hero-strip-cell">
                <p class="v">{point.value}</p>
                <p class="k">{point.label}</p>
                <p class="enterprise-strip-detail">{point.detail}</p>
              </div>
            ))
          }
        </div>
      </div>
    </section>

    <section class="section enterprise-partnership bg-grid grain" id="partnership">
      <div class="shell">
        <div class="enterprise-partnership-panel">
          <div class="enterprise-partnership-copy">
            <div class="eyebrow eyebrow--blue">{m.enterprise_partnership_label({}, { locale })}</div>
            <h2 class="h2-section">{m.enterprise_partnership_title({}, { locale })}</h2>
            <p class="lead">{m.enterprise_partnership_desc({}, { locale })}</p>
            <ul class="enterprise-partnership-list">
              {
                partnershipProofPoints.map((point) => (
                  <li>
                    <span class="enterprise-partnership-check" aria-hidden="true">
                      ✓
                    </span>
                    <span>
                      <strong>{point.title}</strong>
                      <span class="enterprise-partnership-separator"> - </span>
                      {point.description}
                    </span>
                  </li>
                ))
              }
            </ul>
            <a
              class="enterprise-partnership-cta"
              href="https://book.capgo.app/enterprise-inquiry/"
              target="_blank"
              rel="noopener noreferrer"
              aria-label={m.enterprise_talk_to_team({}, { locale })}
            >
              <span>{m.enterprise_talk_to_team({}, { locale })}</span>
              <span aria-hidden="true">-&gt;</span>
            </a>
          </div>

          <div class="enterprise-partnership-visual" role="img" aria-label={m.enterprise_partnership_visual_label({}, { locale })}>
            <p class="enterprise-visual-label">{m.enterprise_partnership_your_team_label({}, { locale })}</p>
            <div class="enterprise-avatar-row enterprise-avatar-row--customer" aria-hidden="true">
              {partnershipYourTeam.map((initial) => <span>{initial}</span>)}
            </div>
            <div class="enterprise-channel-wrap" aria-hidden="true">
              <span class="enterprise-channel-line"></span>
              <span class="enterprise-channel-pill">{m.enterprise_partnership_channel_pill({}, { locale })}</span>
            </div>
            <div class="enterprise-avatar-row enterprise-avatar-row--capgo" aria-hidden="true">
              {partnershipCapgoTeam.map((initial) => <span>{initial}</span>)}
            </div>
            <p class="enterprise-visual-label enterprise-visual-label--brand">{m.enterprise_partnership_capgo_team_label({}, { locale })}</p>
          </div>
        </div>
      </div>
    </section>

    <section class="section enterprise-proof" id="proof">
      <div class="shell">
        <div class="section-head section-head--wide">
          <div class="eyebrow eyebrow--blue">{m.trusted_by_the_biggest_capacitor_apps({}, { locale })}</div>
          <h2 class="h2-section">{m.built_for_enterprise_teams({}, { locale })}</h2>
          <p class="lead">{m.advanced_collaboration_security_compliance({}, { locale })}</p>
        </div>

        <div class="enterprise-logo-grid">
          {
            customers.map((customer) => (
              <div class="enterprise-logo-card">
                <img src={customer.logo} alt={`${customer.name} logo`} width="40" height="40" loading="lazy" decoding="async" />
                <div>
                  <p>{customer.name}</p>
                  <span>
                    {customer.downloads} {m.downloads({}, { locale })}
                  </span>
                </div>
              </div>
            ))
          }
        </div>

        <div class="enterprise-proof-grid">
          <figure class="enterprise-quote">
            <p class="eyebrow eyebrow--blue">{m.enterprise_testimonial_label({}, { locale })}</p>
            <blockquote>"{enterpriseTestimonial.quote}"</blockquote>
            <figcaption>
              <strong>{enterpriseTestimonial.author}</strong>
              <span>{enterpriseTestimonial.role}</span>
            </figcaption>
          </figure>

          <div class="enterprise-note-list">
            {
              enterpriseProofNotes.map((note) => (
                <p>
                  <span aria-hidden="true">✓</span>
                  {note}
                </p>
              ))
            }
          </div>
        </div>
      </div>
    </section>

    <section class="section bg-grid grain" id="pain">
      <div class="shell">
        <div class="section-head section-head--wide">
          <div class="eyebrow eyebrow--blue">{m.enterprise_pain_label({}, { locale })}</div>
