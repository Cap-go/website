---
import Layout from '@/layouts/Layout.astro'
import { getRelativeLocaleUrl } from 'astro:i18n'
import m from '@/copy/messages'
import type { Database } from '@/services/supabase.types'
import { createLdJsonGraph, createServiceLdJson, createProductLdJson } from '@/lib/ldJson'
import { numberWithSpaces } from '@/services/misc'
import { pluginCountLabel } from '@/config/plugins'

const locale = Astro.locals.locale
const config = Astro.locals.runtimeConfig
const plansFetchTimeoutMs = 3000

let plansAll: Database['public']['Tables']['plans']['Row'][] = []
try {
  const response = await fetch(`${config.public.baseApiUrl}/private/plans`, {
    signal: AbortSignal.timeout(plansFetchTimeoutMs),
  })
  if (response.ok) {
    const payload = await response.json()
    if (Array.isArray(payload)) {
      plansAll = payload as Database['public']['Tables']['plans']['Row'][]
    }
  }
} catch {
  plansAll = []
}
const payg = plansAll.find((p) => p.name === 'Enterprise')
const enterprisePrice = typeof payg?.price_m === 'number' && Number.isFinite(payg.price_m) ? payg.price_m : undefined

const title = [Astro.locals.runtimeConfig.public.brand, 'Enterprise'].join(' | ')
const description = 'Enterprise-grade live updates for Capacitor apps. Built for teams that need advanced security, compliance, and dedicated support at scale.'

const baseUrl = Astro.locals.runtimeConfig.public.baseUrl
const enterpriseUrl = `${baseUrl}${getRelativeLocaleUrl(Astro.locals.locale, 'enterprise/')}`
const homeUrl = `${baseUrl}${getRelativeLocaleUrl(Astro.locals.locale, '/')}`

const enterpriseService = createServiceLdJson(Astro.locals.runtimeConfig.public, {
  name: 'Capgo Enterprise - Professional Live Updates',
  description: 'Enterprise-grade live update platform for Capacitor applications with advanced security, compliance features, and dedicated support for large-scale deployments.',
  url: enterpriseUrl,
  serviceType: 'Enterprise Software Service',
  areaServed: ['Worldwide'],
})

const enterpriseProduct = createProductLdJson(Astro.locals.runtimeConfig.public, {
  name: 'Capgo Enterprise Plan',
  description: 'Complete enterprise solution with advanced security, compliance, dedicated support, and unlimited scalability for professional teams.',
  url: enterpriseUrl,
  sku: 'capgo-enterprise',
  offers:
    enterprisePrice === undefined
      ? []
      : [
          {
            price: enterprisePrice.toString(),
            priceCurrency: 'USD',
            availability: 'https://schema.org/InStock',
            priceValidUntil: new Date(Date.now() + 365 * 24 * 60 * 60 * 1000).toISOString().split('T')[0],
          },
        ],
})

const enhancedEnterpriseProduct = {
  ...enterpriseProduct,
  category: 'Enterprise Software',
  audience: {
    '@type': 'BusinessAudience',
    audienceType: 'Enterprise Teams',
    geographicArea: 'Global',
  },
  hasOfferCatalog: {
    '@type': 'OfferCatalog',
    name: 'Enterprise Features',
    itemListElement: [
      {
        '@type': 'Offer',
        itemOffered: {
          '@type': 'Service',
          name: 'Advanced Security & Compliance',
          description: 'SOC 2 Type II compliance, end-to-end encryption, and enterprise-grade security controls.',
        },
      },
      {
        '@type': 'Offer',
        itemOffered: {
          '@type': 'Service',
          name: 'Dedicated Support',
          description: 'Dedicated Slack or Teams channel, onboarding, account management, and SLA-backed support.',
        },
      },
      {
        '@type': 'Offer',
        itemOffered: {
          '@type': 'Service',
          name: 'Custom Deployment Options',
          description: 'On-premise, hybrid cloud, or dedicated cloud deployments tailored to your infrastructure needs.',
        },
      },
      {
        '@type': 'Offer',
        itemOffered: {
          '@type': 'Service',
          name: 'Advanced Analytics & Reporting',
          description: 'Comprehensive deployment analytics, performance monitoring, and custom reporting dashboards.',
        },
      },
    ],
  },
}

const content = {
  title,
  description,
  image: `${baseUrl}/capgo_social.png`,
  ldJSON: createLdJsonGraph(Astro.locals.runtimeConfig.public, enhancedEnterpriseProduct as import('schema-dts').Thing, {
    includeOrganization: true,
    includeBreadcrumbs: true,
    breadcrumbs: [
      {
        name: 'Home',
        url: homeUrl,
      },
      {
        name: 'Enterprise',
        url: enterpriseUrl,
      },
    ],
    additionalEntities: [enterpriseService],
  }),
}

const enterpriseDecisionPoints = [m.enterprise_decision_point_1({}, { locale }), m.enterprise_decision_point_2({}, { locale }), m.enterprise_decision_point_3({}, { locale })]

const enterpriseMau = `${numberWithSpaces(payg?.mau ?? 1000000)}+`
const enterpriseBandwidth = `${numberWithSpaces(payg?.bandwidth ?? 5000)}+ GiB/month`
const enterpriseStorage = `${numberWithSpaces(payg?.storage ?? 100)}+ GiB`

const heroProofPoints = [
  { label: m.enterprise_audience_label({}, { locale }), value: enterpriseMau, detail: m.enterprise_audience_detail({}, { locale }) },
  { label: m.enterprise_delivery_label({}, { locale }), value: enterpriseBandwidth, detail: m.enterprise_delivery_detail({}, { locale }) },
  { label: m.enterprise_artifacts_label({}, { locale }), value: enterpriseStorage, detail: m.enterprise_artifacts_detail({}, { locale }) },
]

const enterpriseLevers = [
  {
    title: m.enterprise_capacity_title({}, { locale }),
    metric: enterpriseMau,
    description: m.enterprise_capacity_desc({}, { locale }),
  },
  {
    title: m.enterprise_native_builds_title({}, { locale }),
    metric: m.enterprise_native_builds_metric({}, { locale }),
    description: m.enterprise_native_builds_desc({}, { locale }),
  },
  {
    title: m.enterprise_compliance_procurement_title({}, { locale }),
    metric: m.enterprise_soc2_iso_metric({}, { locale }),
    description: m.enterprise_compliance_procurement_desc({}, { locale }),
  },
]

const approvalTracks = [
  {
    title: m.enterprise_security_review_title({}, { locale }),
    description: m.enterprise_security_review_desc({}, { locale }),
    items: [m.enterprise_soc2_certified_infrastructure({}, { locale }), m.enterprise_iso27001_in_progress({}, { locale }), m.enterprise_audit_signed_e2e({}, { locale })],
  },
  {
    title: m.enterprise_reliability_review_title({}, { locale }),
    description: m.enterprise_reliability_review_desc({}, { locale }),
    items: [m.enterprise_uptime_sla({}, { locale }), m.enterprise_updates_under_100ms({}, { locale }), m.enterprise_replication_rollback({}, { locale })],
  },
  {
    title: m.enterprise_procurement_review_title({}, { locale }),
    description: m.enterprise_procurement_review_desc({}, { locale }),
    items: [m.enterprise_signed_ndas_dpas({}, { locale }), m.enterprise_custom_payment_process({}, { locale }), m.enterprise_sap_po_procurement({}, { locale })],
  },
  {
    title: m.enterprise_migration_review_title({}, { locale }),
    description: m.enterprise_migration_review_desc({}, { locale }),
    items: [m.enterprise_platform_one_place({}, { locale }), m.enterprise_ionic_alternative_plugins({}, { locale }), m.enterprise_onboarding_training_team({}, { locale })],
  },
]

const customers = [
  { name: 'Nana', downloads: '2.5M', logo: '/nana-logo-transparent.webp' },
  { name: 'Snowqueen', downloads: '1.8M', logo: '/snowqueen.webp' },
  { name: 'Shelf', downloads: '950K', logo: '/shelf_app.webp' },
  { name: 'Suez', downloads: '3.2M', logo: '/suez.webp' },
  { name: 'Janitor', downloads: '750K', logo: '/janitor_app.webp' },
]

const pillars = [
  {
    eyebrow: m.enterprise_control_label({}, { locale }),
    title: m.solutions_enterprise_sol1_title({}, { locale }),
    description: m.solutions_enterprise_sol1_desc({}, { locale }),
    points: [m.solutions_enterprise_sol1_point1({}, { locale }), m.solutions_enterprise_sol1_point2({}, { locale }), m.solutions_enterprise_sol1_point3({}, { locale })],
  },
  {
    eyebrow: m.enterprise_release_safety_label({}, { locale }),
    title: m.solutions_enterprise_sol2_title({}, { locale }),
    description: m.solutions_enterprise_sol2_desc({}, { locale }),
    points: [m.solutions_enterprise_sol2_point1({}, { locale }), m.solutions_enterprise_sol2_point2({}, { locale }), m.solutions_enterprise_sol2_point3({}, { locale })],
  },
  {
    eyebrow: m.enterprise_audit_trail_label({}, { locale }),
    title: m.solutions_enterprise_sol3_title({}, { locale }),
    description: m.solutions_enterprise_sol3_desc({}, { locale }),
    points: [m.solutions_enterprise_sol3_point1({}, { locale }), m.enterprise_soc2_certified_infrastructure({}, { locale }), m.enterprise_iso27001_in_progress({}, { locale })],
  },
]

const includedGroups = [
  {
    title: m.enterprise_live_updates_at_scale({}, { locale }),
    items: [
      m.enterprise_feature_maus({ mau: enterpriseMau }, { locale }),
      enterpriseBandwidth,
      enterpriseStorage,
      m.enterprise_delta_updates({}, { locale }),
      m.enterprise_updates_under_100ms({}, { locale }),
      m.enterprise_7_continent_replication({}, { locale }),
      m.enterprise_signed_updates({}, { locale }),
      m.enterprise_updates_e2e_encrypted({}, { locale }),
    ],
  },
  {
    title: m.enterprise_control_title({}, { locale }),
    items: [
      m.enterprise_unlimited_apps_members_teams({}, { locale }),
      m.enterprise_unlimited_webhooks({}, { locale }),
      m.single_sign_on_sso({}, { locale }),
      m.custom_domain({}, { locale }),
      m.audit_logs({}, { locale }),
      m.enterprise_org_statistics_90_days({}, { locale }),
      m.enterprise_device_logs_90_days({}, { locale }),
    ],
  },
  {
    title: m.enterprise_native_builds_plugins({}, { locale }),
    items: [
      m.enterprise_large_macos_m4({}, { locale }),
      m.enterprise_6_concurrent_builds({}, { locale }),
      m.enterprise_app_store_publishing({}, { locale }),
      m.enterprise_130_plugins({ pluginCountLabel }, { locale }),
      m.enterprise_ionic_alternative_plugins({}, { locale }),
      m.enterprise_priority_plugin_fixes({}, { locale }),
    ],
  },
  {
    title: m.enterprise_compliance_procurement_group({}, { locale }),
    items: [
      m.enterprise_soc2_certified({}, { locale }),
      m.enterprise_iso27001_ongoing({}, { locale }),
      m.enterprise_signed_ndas_dpas({}, { locale }),
      m.enterprise_custom_payment_process({}, { locale }),
      m.enterprise_sap_procurement_workflows({}, { locale }),
      m.enterprise_stripe_payment_options({}, { locale }),
    ],
  },
  {
    title: m.enterprise_support_onboarding({}, { locale }),
    items: [
      m.enterprise_dedicated_slack_teams({}, { locale }),
      m.enterprise_dedicated_account_manager({}, { locale }),
      m.enterprise_onboarding_training({}, { locale }),
      m.enterprise_uptime_sla({}, { locale }),
      m.priority_support({}, { locale }),
      m.enterprise_discord_support({}, { locale }),
    ],
  },
]

const stats = [
  { value: '<100ms', label: m.enterprise_global_update_delivery({}, { locale }) },
  { value: '7', label: m.enterprise_continents_replicated({}, { locale }) },
  { value: '99.9%', label: m.solutions_enterprise_stat_uptime({}, { locale }) },
  { value: '500M+', label: m.solutions_enterprise_stat_updates({}, { locale }) },
]
---

<Layout content={content}>
  <main class="bg-gray-50 text-gray-950">
    <section class="mx-auto max-w-7xl px-4 pt-16 pb-12 sm:px-6 sm:pt-20 lg:px-8 lg:pt-24">
      <div class="grid gap-10 lg:grid-cols-[1.05fr_0.95fr] lg:items-stretch">
        <div class="flex flex-col justify-center">
          <p class="text-sm font-semibold tracking-wide text-blue-700 uppercase">{m.enterprise_ready()}</p>
          <h1 class="mt-4 max-w-4xl text-4xl leading-tight font-semibold tracking-tight text-gray-950 sm:text-5xl lg:text-6xl">
            {m.deliver_updates({}, { locale })}
            <span class="block text-gray-500">{m.at_scale({}, { locale })}</span>
          </h1>
          <p class="mt-6 max-w-2xl text-lg leading-8 text-gray-600">
            {m.enterprise_hero_platform_desc({ pluginCountLabel }, { locale })}
          </p>

          <div class="mt-8 flex flex-col gap-3 sm:flex-row">
            <a
              href="https://book.capgo.app/enterprise-inquiry/"
              target="_blank"
              rel="noopener noreferrer"
              aria-label={m.enterprise_talk_to_team({}, { locale })}
              class="inline-flex min-h-11 items-center justify-center gap-2 rounded-full bg-gray-950 px-6 py-3 text-sm font-semibold text-white transition-colors hover:bg-gray-800 focus:ring-2 focus:ring-blue-600 focus:ring-offset-2 focus:outline-none"
            >
              <span class="flex -space-x-2" aria-hidden="true">
                <img class="h-6 w-6 rounded-full border-2 border-white object-cover" src="/martin-avatar.png" alt="" width="24" height="24" loading="lazy" />
                <img class="h-6 w-6 rounded-full border-2 border-white object-cover" src="/valeria-avatar.jpg" alt="" width="24" height="24" loading="lazy" />
                <img class="h-6 w-6 rounded-full border-2 border-white object-cover" src="/jordan-avatar.jpg" alt="" width="24" height="24" loading="lazy" />
              </span>
              <span>{m.enterprise_talk_to_team({}, { locale })}</span>
            </a>
            <a
              href={getRelativeLocaleUrl(locale, 'pricing')}
              class="inline-flex min-h-11 items-center justify-center rounded-full border border-gray-300 bg-white px-6 py-3 text-sm font-semibold text-gray-950 transition-colors hover:border-blue-300 hover:text-blue-700 focus:ring-2 focus:ring-blue-600 focus:ring-offset-2 focus:outline-none"
            >
              {m.view_pricing({}, { locale })}
            </a>
          </div>

          <div class="mt-8 grid max-w-3xl gap-3 sm:grid-cols-3">
            {
              heroProofPoints.map((point) => (
                <div class="rounded-xl border border-gray-200 bg-white px-4 py-4 shadow-sm">
                  <p class="text-xs font-semibold tracking-wide text-gray-500 uppercase">{point.label}</p>
                  <p class="mt-2 text-2xl font-semibold tracking-tight text-gray-950">{point.value}</p>
                  <p class="mt-1 text-sm leading-5 text-gray-600">{point.detail}</p>
                </div>
              ))
            }
          </div>
        </div>

        <aside class="overflow-hidden rounded-2xl border border-gray-200 bg-white shadow-sm">
          <div class="border-b border-gray-200 p-6 sm:p-8">
            <div class="flex items-start justify-between gap-4">
              <div>
                <p class="text-sm font-semibold tracking-wide text-blue-700 uppercase">{m.enterprise_title({}, { locale })}</p>
                <h2 class="mt-3 text-3xl font-semibold tracking-tight text-gray-950">{m.custom({}, { locale })}</h2>
                <p class="mt-3 max-w-sm text-sm leading-6 text-gray-600">{m.enterprise_custom_card_desc({}, { locale })}</p>
              </div>
              <span class="rounded-full bg-blue-50 px-3 py-1 text-xs font-semibold text-blue-700">{m.enterprise_for_scale({}, { locale })}</span>
            </div>
          </div>
          <div class="divide-y divide-gray-100">
            {
              [
                m.enterprise_feature_maus({ mau: enterpriseMau }, { locale }),
                enterpriseBandwidth,
                enterpriseStorage,
                m.enterprise_6_concurrent_macos_m4({}, { locale }),
                m.enterprise_dedicated_slack_teams({}, { locale }),
                m.enterprise_sso_soc2_iso({}, { locale }),
                m.enterprise_onboarding_account_management({}, { locale }),
              ].map((item) => (
                <div class="flex items-center gap-3 px-6 py-4 text-sm font-medium text-gray-700 sm:px-8">
                  <svg class="h-5 w-5 shrink-0 text-blue-600" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.4" aria-hidden="true">
                    <path stroke-linecap="round" stroke-linejoin="round" d="m4.5 12.75 6 6 9-13.5" />
                  </svg>
                  <span>{item}</span>
                </div>
              ))
            }
          </div>
        </aside>
      </div>
    </section>

    <section class="border-y border-gray-200 bg-white py-10">
      <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
        <p class="text-center text-sm font-semibold tracking-wide text-gray-500 uppercase">{m.trusted_by_the_biggest_capacitor_apps({}, { locale })}</p>
        <div class="mt-8 grid grid-cols-2 gap-4 sm:grid-cols-3 lg:grid-cols-5">
          {
            customers.map((customer) => (
              <div class="flex items-center gap-3 rounded-xl border border-gray-200 bg-white p-4">
                <img class="h-10 w-10 rounded-lg object-contain grayscale" src={customer.logo} alt={`${customer.name} logo`} width="40" height="40" loading="lazy" />
                <div>
                  <p class="text-sm font-semibold text-gray-950">{customer.name}</p>
                  <p class="text-xs font-medium text-gray-500">
                    {customer.downloads} {m.downloads({}, { locale })}
                  </p>
                </div>
              </div>
            ))
          }
        </div>
      </div>
    </section>

    <section class="mx-auto max-w-7xl px-4 py-16 sm:px-6 sm:py-20 lg:px-8">
      <div class="mx-auto max-w-3xl text-center">
        <p class="text-sm font-semibold tracking-wide text-blue-700 uppercase">{m.enterprise_scale_label({}, { locale })}</p>
        <h2 class="mt-3 text-3xl font-semibold tracking-tight text-gray-950 sm:text-4xl">{m.enterprise_limits_title({}, { locale })}</h2>
        <p class="mt-4 text-base leading-7 text-gray-600">
          {m.enterprise_limits_desc({}, { locale })}
        </p>
      </div>

      <div class="mt-10 grid gap-4 lg:grid-cols-3">
        {
          enterpriseLevers.map((lever) => (
            <article class="rounded-2xl border border-gray-200 bg-white p-6 shadow-sm">
              <p class="text-3xl font-semibold tracking-tight text-blue-700">{lever.metric}</p>
              <h3 class="mt-5 text-xl font-semibold tracking-tight text-gray-950">{lever.title}</h3>
              <p class="mt-3 text-sm leading-6 text-gray-600">{lever.description}</p>
            </article>
          ))
        }
      </div>
    </section>

    <section class="bg-white py-16 sm:py-20">
      <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
        <div class="grid gap-8 lg:grid-cols-[0.82fr_1.18fr] lg:items-start">
          <div>
            <p class="text-sm font-semibold tracking-wide text-blue-700 uppercase">{m.enterprise_approval_label({}, { locale })}</p>
            <h2 class="mt-3 text-3xl font-semibold tracking-tight text-gray-950 sm:text-4xl">{m.enterprise_approval_title({}, { locale })}</h2>
            <p class="mt-4 text-base leading-7 text-gray-600">
              {m.enterprise_approval_desc({}, { locale })}
            </p>
          </div>

          <div class="grid gap-4 sm:grid-cols-2">
            {
              approvalTracks.map((track) => (
                <article class="rounded-2xl border border-gray-200 bg-gray-50 p-6">
                  <h3 class="text-lg font-semibold tracking-tight text-gray-950">{track.title}</h3>
                  <p class="mt-2 text-sm leading-6 text-gray-600">{track.description}</p>
                  <ul class="mt-5 space-y-3">
                    {track.items.map((item) => (
                      <li class="flex gap-3 text-sm leading-6 font-medium text-gray-700">
                        <svg class="mt-1 h-4 w-4 shrink-0 text-blue-600" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.4" aria-hidden="true">
                          <path stroke-linecap="round" stroke-linejoin="round" d="m4.5 12.75 6 6 9-13.5" />
                        </svg>
                        <span>{item}</span>
                      </li>
                    ))}
                  </ul>
                </article>
              ))
            }
          </div>
        </div>
      </div>
    </section>

    <section class="mx-auto max-w-7xl px-4 py-16 sm:px-6 sm:py-20 lg:px-8">
      <div class="grid gap-8 lg:grid-cols-[0.9fr_1.1fr] lg:items-start">
        <div>
          <p class="text-sm font-semibold tracking-wide text-blue-700 uppercase">{m.enterprise_decision_criteria_eyebrow({}, { locale })}</p>
          <h2 class="mt-3 max-w-2xl text-3xl leading-tight font-semibold tracking-tight text-gray-950 sm:text-4xl">
            {m.enterprise_decision_criteria_title({}, { locale })}
          </h2>
          <p class="mt-4 text-base leading-7 text-gray-600">{m.enterprise_decision_criteria_desc({}, { locale })}</p>
        </div>
        <div class="overflow-hidden rounded-2xl border border-gray-200 bg-white shadow-sm">
          <div class="border-b border-gray-200 px-6 py-4">
            <h3 class="text-base font-semibold text-gray-950">{m.enterprise_decision_questions_title({}, { locale })}</h3>
          </div>
          <div class="divide-y divide-gray-100">
            {
              enterpriseDecisionPoints.map((item, index) => (
                <div class="flex gap-4 px-6 py-5">
                  <span class="flex h-7 w-7 shrink-0 items-center justify-center rounded-full bg-blue-50 text-sm font-semibold text-blue-700">{index + 1}</span>
                  <p class="text-sm leading-6 font-medium text-gray-700">{item}</p>
                </div>
              ))
            }
          </div>
        </div>
      </div>
    </section>

    <section class="bg-white py-16 sm:py-20">
      <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
        <div class="mx-auto max-w-3xl text-center">
          <p class="text-sm font-semibold tracking-wide text-blue-700 uppercase">{m.solutions_enterprise_solution_label({}, { locale })}</p>
          <h2 class="mt-3 text-3xl font-semibold tracking-tight text-gray-950 sm:text-4xl">{m.solutions_enterprise_solution_title({}, { locale })}</h2>
          <p class="mt-4 text-base leading-7 text-gray-600">{m.solutions_enterprise_solution_subtitle({}, { locale })}</p>
        </div>

        <div class="mt-10 grid gap-4 lg:grid-cols-3">
          {
            pillars.map((pillar) => (
              <article class="rounded-2xl border border-gray-200 bg-white p-6 shadow-sm">
                <p class="text-xs font-semibold tracking-wide text-blue-700 uppercase">{pillar.eyebrow}</p>
                <h3 class="mt-3 text-xl font-semibold tracking-tight text-gray-950">{pillar.title}</h3>
                <p class="mt-3 text-sm leading-6 text-gray-600">{pillar.description}</p>
                <ul class="mt-6 space-y-3">
                  {pillar.points.map((point) => (
                    <li class="flex gap-3 text-sm leading-6 font-medium text-gray-700">
                      <svg class="mt-1 h-4 w-4 shrink-0 text-blue-600" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.4" aria-hidden="true">
                        <path stroke-linecap="round" stroke-linejoin="round" d="m4.5 12.75 6 6 9-13.5" />
                      </svg>
                      <span>{point}</span>
                    </li>
                  ))}
                </ul>
              </article>
            ))
          }
        </div>
      </div>
    </section>

    <section class="mx-auto max-w-7xl px-4 py-16 sm:px-6 sm:py-20 lg:px-8">
      <div class="mx-auto max-w-3xl text-center">
        <p class="text-sm font-semibold tracking-wide text-blue-700 uppercase">{m.enterprise_features({}, { locale })}</p>
        <h2 class="mt-3 text-3xl font-semibold tracking-tight text-gray-950 sm:text-4xl">{m.built_for_enterprise_teams({}, { locale })}</h2>
        <p class="mt-4 text-base leading-7 text-gray-600">{m.advanced_collaboration_security_compliance({}, { locale })}</p>
      </div>

      <div class="mt-10 overflow-hidden rounded-2xl border border-gray-200 bg-white shadow-sm">
        <div class="grid divide-y divide-gray-200 lg:grid-cols-2 lg:divide-x lg:divide-y-0">
          {
            includedGroups.map((group) => (
              <div class="p-6 sm:p-8">
                <h3 class="text-lg font-semibold tracking-tight text-gray-950">{group.title}</h3>
                <ul class="mt-5 grid gap-3 sm:grid-cols-2">
                  {group.items.map((item) => (
                    <li class="flex gap-3 text-sm leading-6 font-medium text-gray-700">
                      <svg class="mt-1 h-4 w-4 shrink-0 text-blue-600" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.4" aria-hidden="true">
                        <path stroke-linecap="round" stroke-linejoin="round" d="m4.5 12.75 6 6 9-13.5" />
                      </svg>
                      <span>{item}</span>
                    </li>
                  ))}
                </ul>
              </div>
            ))
          }
        </div>
      </div>
    </section>

    <section class="bg-white py-16 sm:py-20">
      <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
        <div class="grid gap-8 lg:grid-cols-[0.85fr_1.15fr] lg:items-start">
          <div>
            <p class="text-sm font-semibold tracking-wide text-blue-700 uppercase">{m.global_infrastructure({}, { locale })}</p>
            <h2 class="mt-3 text-3xl font-semibold tracking-tight text-gray-950 sm:text-4xl">
              {m.global_infrastructure_lowercase({}, { locale })}
              {m.that_grows_with_you({}, { locale })}
            </h2>
            <p class="mt-4 text-base leading-7 text-gray-600">{m.powered_by_serverless_edge_computing({}, { locale })}</p>
          </div>
          <div class="grid gap-4 sm:grid-cols-3">
            {
              stats.map((stat) => (
                <div class="rounded-2xl border border-gray-200 bg-white p-6 shadow-sm">
                  <p class="text-3xl font-semibold tracking-tight text-gray-950">{stat.value}</p>
                  <p class="mt-2 text-sm leading-6 font-medium text-gray-600">{stat.label}</p>
                </div>
              ))
            }
          </div>
        </div>
      </div>
    </section>

    <section class="mx-auto max-w-7xl px-4 py-16 sm:px-6 sm:py-20 lg:px-8">
      <div class="overflow-hidden rounded-2xl border border-gray-200 bg-gray-950 text-white shadow-sm">
        <div class="grid gap-8 p-6 sm:p-8 lg:grid-cols-[1fr_auto] lg:items-center lg:p-10">
          <div>
            <p class="text-sm font-semibold tracking-wide text-blue-300 uppercase">{m.ready_to_scale({}, { locale })}</p>
            <h2 class="mt-3 max-w-3xl text-3xl font-semibold tracking-tight sm:text-4xl">{m.ready_to_deliver({}, { locale })} {m.updates_at_scale({}, { locale })}</h2>
            <p class="mt-4 max-w-2xl text-base leading-7 text-gray-300">{m.join_leading_enterprises({}, { locale })}</p>
          </div>
          <a
            href="https://book.capgo.app/enterprise-inquiry/"
            target="_blank"
            rel="noopener noreferrer"
            aria-label={m.enterprise_talk_to_team({}, { locale })}
            class="inline-flex min-h-11 items-center justify-center gap-2 rounded-full bg-white px-6 py-3 text-sm font-semibold text-gray-950 transition-colors hover:bg-blue-50 hover:text-blue-700 focus:ring-2 focus:ring-white focus:ring-offset-2 focus:ring-offset-gray-950 focus:outline-none"
          >
            <span class="flex -space-x-2" aria-hidden="true">
              <img class="h-6 w-6 rounded-full border-2 border-white object-cover" src="/martin-avatar.png" alt="" width="24" height="24" loading="lazy" />
              <img class="h-6 w-6 rounded-full border-2 border-white object-cover" src="/valeria-avatar.jpg" alt="" width="24" height="24" loading="lazy" />
              <img class="h-6 w-6 rounded-full border-2 border-white object-cover" src="/jordan-avatar.jpg" alt="" width="24" height="24" loading="lazy" />
            </span>
            <span>{m.enterprise_talk_to_team({}, { locale })}</span>
          </a>
        </div>
      </div>
    </section>
  </main>
</Layout>
