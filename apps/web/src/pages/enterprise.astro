  },
  {
    title: m.enterprise_procurement_billing_title({}, { locale }),
    description: m.enterprise_procurement_billing_desc({}, { locale }),
  },
  {
    title: m.enterprise_procurement_onboarding_title({}, { locale }),
    description: m.enterprise_procurement_onboarding_desc({}, { locale }),
  },
]
const enterprisePluginProofPoints = [
  {
    title: m.enterprise_plugins_sla_title({}, { locale }),
    description: m.enterprise_plugins_sla_desc({}, { locale }),
  },
  {
    title: m.enterprise_plugins_maintained_title({}, { locale }),
