---
import Layout from '@/layouts/Layout.astro'
import m from '@/copy/messages'

const locale = Astro.locals.locale
const brand = Astro.locals.runtimeConfig.public.brand

const title = `${brand} | ${m.integrations_partners_freelance_title({}, { locale })}`
const description = m.integrations_partners_freelance_description({ brand }, { locale })

const content = { title, description }

const trustedFreelancers = [
  {
    name: 'Adrien',
    initials: 'A',
    clientApp: 'Steplee',
    image: '/adrien-profile.webp',
    bookUrl: 'https://book.capgo.app/adrien/',
  },
  {
    name: 'Jordan',
    initials: 'J',
    clientApp: 'Amawé',
    image: '/jordan-avatar.jpg',
    bookUrl: 'https://book.capgo.app/jordan/',
  },
]
---

<Layout content={content}>
  <div class="min-h-screen bg-gray-950">
    <section class="mx-auto max-w-7xl px-4 py-20 sm:px-6 lg:px-8">
      <div class="grid gap-12 lg:grid-cols-[0.85fr_1.15fr] lg:items-end">
        <div>
          <p class="mb-4 text-sm font-semibold tracking-wide text-blue-300 uppercase">{m.integrations_partners_freelance_label({}, { locale })}</p>
          <h1 class="max-w-3xl text-4xl font-bold text-white sm:text-5xl">{m.integrations_partners_freelance_heading({}, { locale })}</h1>
          <p class="mt-6 max-w-2xl text-lg leading-8 text-slate-300">{description}</p>
        </div>
        <div class="rounded-2xl border border-white/10 bg-white/[0.04] p-6">
          <p class="text-base leading-7 text-slate-300">{m.integrations_partners_freelance_trust({ brand }, { locale })}</p>
        </div>
      </div>

      <div class="mt-12 grid grid-cols-1 gap-6 lg:grid-cols-2">
        {
          trustedFreelancers.map((freelancer) => (
            <article class="flex h-full flex-col rounded-2xl border border-white/10 bg-slate-900 p-6 shadow-2xl shadow-black/20 sm:p-8">
              <div class="flex items-center gap-5">
                <img src={freelancer.image} alt={`Profile photo of ${freelancer.name}`} loading="lazy" class="h-20 w-20 shrink-0 rounded-2xl object-cover ring-1 ring-white/10" />
                <div>
                  <h2 class="text-2xl font-bold text-white">{freelancer.name}</h2>
                  <p class="mt-1 text-sm font-semibold text-blue-200">{m.integrations_partners_freelance_role({ brand }, { locale })}</p>
                </div>
              </div>

              <div class="mt-6 space-y-4 text-base leading-7 text-slate-300">
                <p>{m.integrations_partners_freelance_person_intro({ name: freelancer.name, brand, clientApp: freelancer.clientApp }, { locale })}</p>
                <p>{m.integrations_partners_freelance_capgo_work({ brand }, { locale })}</p>
              </div>

              <a
                href={freelancer.bookUrl}
                target="_blank"
                rel="noopener noreferrer"
                class="mt-8 inline-flex w-full items-center justify-center gap-2 rounded-xl bg-blue-600 px-5 py-3 text-sm font-semibold text-white transition-colors hover:bg-blue-700 focus:ring-2 focus:ring-blue-400 focus:ring-offset-2 focus:ring-offset-slate-900"
              >
                {m.integrations_partners_freelance_contact({ name: freelancer.name }, { locale })}
                <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" aria-hidden="true">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3" />
                </svg>
              </a>
            </article>
          ))
        }
      </div>
    </section>
  </div>
</Layout>
