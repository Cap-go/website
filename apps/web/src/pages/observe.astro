---
import '@/styles/lu-product.css'
import Layout from '@/layouts/Layout.astro'
import m from '@/copy/messages'
import { createLdJsonGraph, createServiceLdJson } from '@/lib/ldJson'
import { getRelativeLocaleUrl } from '@/services/links'

const locale = Astro.locals.locale
const brand = Astro.locals.runtimeConfig.public.brand
const title = brand + ' Observe | Version health after a rollout'
const description =
  'Compare reported native app health, launch and WebView timing, and version-level signals with release markers for version, channel, and deployment date. Use Logs Insights to investigate errors, versions, and devices.'
const registerUrl = getRelativeLocaleUrl(locale, 'register')
const logsDocsUrl = getRelativeLocaleUrl(locale, 'docs/webapp/logs')
const liveUpdateUrl = getRelativeLocaleUrl(locale, 'live-update')

const serviceLdJson = createServiceLdJson(Astro.locals.runtimeConfig.public, {
  name: title,
  description,
  url: Astro.url.href,
  serviceType: 'Software Development Service',
  areaServed: ['Worldwide'],
})

const content = {
  title,
  description,
  image: Astro.locals.runtimeConfig.public.baseUrl + '/social/capgo-observe.png',
  ldJSON: createLdJsonGraph(Astro.locals.runtimeConfig.public, serviceLdJson, { includeOrganization: true }),
}

const proofPoints = [
  ['Read release health', 'See issue-free devices, native issues, launch P90, and WebView P90 for the reported versions in one view.'],
  ['Keep rollout context', 'Use release markers for version, channel, and deployment date as you read the signals.'],
  ['Follow the evidence in Logs', 'Use grouped failures, affected versions, devices, and action logs to investigate a trend.'],
]

const screenSignals = [
  ['01', 'All versions summary', 'Read issue-free devices, native issues, launch P90, and WebView P90 before narrowing your investigation.'],
  ['02', 'Version breakdown', 'Compare reported app versions when health or timing differs from the overall picture.'],
  ['03', 'Action breakdown', 'Separate launches, WebView loads, native issues, and update activity while you investigate a trend in Logs Insights.'],
]
---

<Layout content={content}>
  <div class="lu observe bg-ad">
    <section class="section hero bg-grid grain" id="top">
      <div class="shell">
        <div class="observe-hero-grid">
          <div>
            <p class="observe-kicker"><span aria-hidden="true"></span> Capgo Observe, beta</p>
            <h1>Find the version that needs attention.</h1>
            <p class="observe-statement">
              Compare native health, launch and WebView timing, and version-level signals with release markers for version, channel, and deployment date.
            </p>
            <div class="observe-actions">
              <a class="btn btn-lg btn-primary" href={registerUrl}>{m.cta_start_free({}, { locale })}</a>
              <a class="observe-link" href="#signals">See the evidence flow <span aria-hidden="true">↓</span></a>
            </div>
          </div>

          <ol class="observe-rail" aria-label="Release health workflow">
            <li><span>01</span><div><strong>Deploy</strong><small>A bundle is deployed to a channel.</small></div></li>
            <li><span>02</span><div><strong>Observe</strong><small>Compare reported version health.</small></div></li>
            <li><span>03</span><div><strong>Investigate</strong><small>Use Logs Insights to investigate a trend.</small></div></li>
          </ol>
        </div>

        <figure class="observe-dashboard">
          <picture>
            <source media="(max-width: 720px)" srcset="/landing-demos/observe-dashboard-mobile.webp" />
            <img
              src="/landing-demos/observe-dashboard.webp"
              alt="Capgo Observe dashboard showing native health, launch timing, WebView timing, version breakdown, and release markers"
              width="1440"
              height="1100"
              loading="eager"
              decoding="async"
            />
          </picture>
        </figure>
      </div>
    </section>

    <section class="section observe-proof" id="signals">
      <div class="shell">
        <div class="observe-intro">
          <p class="eyebrow eyebrow--blue">Your rollout context is already here</p>
          <h2 class="h2-section">Know when a reported version needs attention.</h2>
          <p class="lead">Compare native health and timing across the selected period and each reported app version.</p>
        </div>

        <div class="observe-proof-grid">
          {
            proofPoints.map(([title, text], index) => (
              <article class="observe-proof-item">
                <span>0{index + 1}</span>
                <h3>{title}</h3>
                <p>{text}</p>
              </article>
            ))
          }
        </div>
      </div>
    </section>

    <section class="section observe-reading bg-grid grain" id="screen">
      <div class="shell observe-reading-grid">
        <div class="observe-intro observe-intro--left">
          <p class="eyebrow eyebrow--blue">Compare reported versions</p>
          <h2 class="h2-section">Find the version that needs attention.</h2>
          <p class="lead">Start with all-version health, then compare each reported native app version within the selected period.</p>
          <a class="observe-link" href={liveUpdateUrl}>Explore Live Updates <span aria-hidden="true">→</span></a>
        </div>

        <div class="observe-signal-list">
          {
            screenSignals.map(([index, title, text]) => (
              <article class="observe-signal-item">
                <span>{index}</span>
                <div>
                  <>
                    <h3>{title}</h3>
                    <p>{text}</p>
                  </>
                </div>
              </article>
            ))
          }
        </div>
      </div>
    </section>

    <section class="section observe-diagnose" id="logs">
      <div class="shell">
        <div class="observe-diagnose-head">
          <p class="eyebrow eyebrow--blue">From signal to evidence</p>
          <h2 class="h2-section">Find the errors, versions, and devices behind a trend.</h2>
        </div>

        <div class="observe-diagnose-grid">
          <article>
            <p class="observe-label">Observe</p>
            <h3>Compare the reported version that needs attention.</h3>
            <p>Compare a reported version's health and timing to decide what to investigate.</p>
          </article>
          <article class="observe-logs">
            <p class="observe-label">Logs Insights</p>
            <h3>Identify the errors, versions, and devices behind the trend.</h3>
            <p>
              Use Logs Insights to group errors by category, follow the daily trend, and identify affected versions and devices. Then open filtered raw action logs for the details.
            </p>
            <a class="observe-link" href={logsDocsUrl}>Read the Logs guide <span aria-hidden="true">→</span></a>
          </article>
        </div>

        <figure class="observe-dashboard observe-insights-dashboard">
          <picture>
            <source media="(max-width: 720px)" srcset="/landing-demos/logs-insights-dashboard-mobile.webp" />
            <img
              src="/landing-demos/logs-insights-dashboard.webp"
              alt="Capgo Logs Insights dashboard showing error categories, daily trends, affected versions, and affected devices"
              width="1440"
              height="1200"
              loading="lazy"
              decoding="async"
            />
          </picture>
        </figure>
      </div>
    </section>

    <section class="section final bg-grid grain" id="cta">
      <div class="shell">
        <p class="eyebrow eyebrow--blue">Observe every rollout</p>
        <h2><span class="name">Start observing</span><br />your next rollout.</h2>
        <p class="tagline">Keep deployment history, release health, and Logs Insights in one place.</p>
        <a class="btn btn-lg btn-primary btn-cta" href={registerUrl}>{m.cta_start_free({}, { locale })}</a>
        <div class="hero-meta hero-meta--cta">
          <span><span class="check">+</span> Deployment history</span>
          <span><span class="check">+</span> Native health</span>
          <span><span class="check">+</span> Error and device evidence</span>
        </div>
      </div>
    </section>

    <div class="shell seo-bridge">
      <h2 class="h2-section">Go from rollout to evidence</h2>
      <p>
        Pair <a href={liveUpdateUrl}>Capgo Live Updates</a> with <a href={logsDocsUrl}>Logs Insights</a> to move from reported version health to errors, devices, and filtered raw action
        logs.
      </p>
    </div>
  </div>
</Layout>

<style>
  .observe {
    --observe-line: rgba(255, 255, 255, 0.12);
    --observe-surface: rgba(255, 255, 255, 0.035);
  }

  .observe .hero {
    padding: 84px 0 74px;
    text-align: left;
  }

  .observe .observe-hero-grid,
  .observe .observe-reading-grid {
    display: grid;
    gap: 52px;
    align-items: end;
  }

  .observe .observe-hero-grid {
    grid-template-columns: minmax(0, 1.4fr) minmax(220px, 0.6fr);
  }

  .observe .observe-kicker,
  .observe .observe-label {
    display: flex;
    align-items: center;
    gap: 9px;
    margin: 0;
    color: var(--relief-blue);
    font-family: var(--lu-font-mono);
    font-size: 12px;
    font-weight: 700;
    letter-spacing: 0.08em;
    text-transform: uppercase;
  }

  .observe .observe-kicker span {
    width: 8px;
    height: 8px;
    border-radius: 999px;
    background: #4ade80;
    box-shadow: 0 0 14px rgba(74, 222, 128, 0.6);
  }

  .observe h1 {
    max-width: 760px;
    margin: 20px 0 0;
    color: #fff;
    font-size: clamp(3.2rem, 7.7vw, 6.9rem);
    font-weight: 900;
    letter-spacing: -0.052em;
    line-height: 0.9;
    text-wrap: balance;
  }

  .observe .observe-statement {
    max-width: 590px;
    margin: 27px 0 0;
    color: rgba(255, 255, 255, 0.9);
    font-size: clamp(1.3rem, 2.3vw, 1.9rem);
    font-weight: 600;
    letter-spacing: -0.022em;
    line-height: 1.16;
    text-wrap: balance;
  }

  .observe .observe-lead {
    max-width: 630px;
    margin: 20px 0 0;
  }

  .observe .observe-actions {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: 22px;
    margin-top: 34px;
  }

  .observe .btn {
    transition-property: background-color, border-color, box-shadow, color, transform;
    transition-duration: 180ms;
  }

  .observe .observe-link {
    display: inline-flex;
    gap: 8px;
    align-items: center;
    color: rgba(191, 219, 254, 0.88);
    font-size: 14px;
    font-weight: 700;
    transition-property: color, transform;
    transition-duration: 180ms;
  }

  @media (hover: hover) {
    .observe .observe-link:hover {
      color: #fff;
      transform: translateX(3px);
    }
  }

  .observe .observe-rail,
  .observe .observe-signal-list {
    display: grid;
    gap: 0;
    margin: 0;
    padding: 0;
    list-style: none;
    border-top: 1px solid var(--observe-line);
  }

  .observe .observe-rail li,
  .observe .observe-signal-item {
    display: grid;
    grid-template-columns: 40px 1fr;
    gap: 16px;
    padding: 18px 0;
    border-bottom: 1px solid var(--observe-line);
  }

  .observe .observe-rail > li > span,
  .observe .observe-signal-item > span,
  .observe .observe-proof-item > span {
    color: var(--relief-blue);
    font-family: var(--lu-font-mono);
    font-size: 11px;
    font-weight: 700;
    letter-spacing: 0.06em;
  }

  .observe .observe-rail strong,
  .observe .observe-rail small {
    display: block;
  }

  .observe .observe-rail strong {
    color: #fff;
    font-size: 14px;
  }

  .observe .observe-rail small {
    margin-top: 3px;
    color: rgba(255, 255, 255, 0.5);
    font-size: 12px;
    line-height: 1.45;
  }

  .observe .observe-dashboard {
    margin: 58px 0 0;
    overflow: hidden;
    border: 1px solid rgba(191, 219, 254, 0.32);
    border-radius: 18px;
    background: #0c1627;
    box-shadow:
      0 28px 80px rgba(0, 0, 0, 0.36),
      0 0 0 8px rgba(147, 197, 253, 0.04);
  }

  .observe .observe-dashboard picture {
    display: block;
  }

  .observe .observe-dashboard img {
    display: block;
    width: 100%;
    height: auto;
  }

  .observe .observe-intro {
    max-width: 720px;
    margin: 0 auto;
    text-align: center;
  }

  .observe .observe-intro--left {
    margin: 0;
    text-align: left;
  }

  .observe .observe-proof {
    padding-top: 108px;
  }

  .observe .observe-proof-grid,
  .observe .observe-diagnose-grid {
    display: grid;
    margin-top: 50px;
    border-top: 1px solid var(--observe-line);
  }

  .observe .observe-proof-item,
  .observe .observe-diagnose-grid article {
    padding: 26px;
    border-bottom: 1px solid var(--observe-line);
  }

  .observe .observe-proof-item h3,
  .observe .observe-signal-item h3,
  .observe .observe-diagnose-grid h3 {
    margin: 12px 0 0;
    color: #fff;
    font-size: clamp(1.2rem, 1.8vw, 1.5rem);
    font-weight: 700;
    letter-spacing: -0.018em;
    line-height: 1.15;
  }

  .observe .observe-proof-item p,
  .observe .observe-signal-item p,
  .observe .observe-diagnose-grid p:not(.observe-label) {
    margin: 10px 0 0;
    color: rgba(255, 255, 255, 0.6);
    font-size: 14px;
    line-height: 1.6;
    text-wrap: pretty;
  }

  .observe .observe-reading {
    background-color: rgba(13, 21, 37, 0.58);
  }

  .observe .observe-reading-grid {
    align-items: start;
  }

  .observe .observe-signal-item h3 {
    margin-top: 0;
  }

  .observe .observe-diagnose-head {
    max-width: 780px;
  }

  .observe .observe-logs {
    background: var(--observe-surface);
  }

  .observe .observe-logs .observe-link {
    margin-top: 20px;
  }

  .observe .observe-insights-dashboard {
    margin-top: 32px;
  }

  @media (min-width: 780px) {
    .observe .observe-proof-grid {
      grid-template-columns: repeat(3, minmax(0, 1fr));
    }

    .observe .observe-proof-item {
      border-right: 1px solid var(--observe-line);
      border-bottom: 0;
    }

    .observe .observe-proof-item:last-child {
      border-right: 0;
    }

    .observe .observe-reading-grid {
      grid-template-columns: minmax(0, 0.9fr) minmax(0, 1.1fr);
    }

    .observe .observe-diagnose-grid {
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }

    .observe .observe-diagnose-grid article {
      border-right: 1px solid var(--observe-line);
      border-bottom: 0;
    }

    .observe .observe-diagnose-grid article:last-child {
      border-right: 0;
    }
  }

  @media (max-width: 720px) {
    .observe .hero {
      padding: 56px 0 54px;
    }

    .observe .observe-hero-grid {
      gap: 38px;
      grid-template-columns: 1fr;
    }

    .observe h1 {
      font-size: clamp(3.2rem, 18vw, 5rem);
    }

    .observe .observe-dashboard {
      margin-top: 40px;
      border-radius: 12px;
    }

    .observe .observe-insights-dashboard {
      margin-top: 28px;
    }

    .observe .observe-insights-dashboard img {
      aspect-ratio: 860 / 1100;
    }

    .observe .observe-proof {
      padding-top: 70px;
    }
  }
</style>
