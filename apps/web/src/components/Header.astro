                      <svg class="h-5 w-5 text-blue-300" fill="none" viewBox="0 0 24 24" stroke="currentColor" aria-hidden="true" focusable="false">
                        <path
                          stroke-linecap="round"
                          stroke-linejoin="round"
                          stroke-width="2"
                          d="M9.75 17L9 20l-1-1-2.5 1 .75-3m5.5 0L12 20l1-1 2.5 1-.75-3M12 3l.8 2.4L15 6l-2.2.6L12 9l-.8-2.4L9 6l2.2-.6L12 3z"></path>
                      </svg>
                      {m.solutions_build_without_mac_short({}, { locale: Astro.locals.locale })}
                    </a>
                    <a
                      href={getRelativeLocaleUrl(Astro.locals.locale, 'solutions/lovable-vibecoding-to-mobile')}
                      class="flex items-center gap-3 rounded-lg px-2 py-2 text-sm text-gray-300 transition-colors hover:bg-gray-700 hover:text-white"
                    >
                      <svg class="h-5 w-5 text-pink-300" fill="none" viewBox="0 0 24 24" stroke="currentColor" aria-hidden="true" focusable="false">
                        <path
                          stroke-linecap="round"
                          stroke-linejoin="round"
                          stroke-width="2"
                          d="M12 3v3m0 12v3m9-9h-3M6 12H3m14.95-5.95-2.12 2.12M8.17 15.83l-2.12 2.12m11.9 0-2.12-2.12M8.17 8.17 6.05 6.05"></path>
                      </svg>
