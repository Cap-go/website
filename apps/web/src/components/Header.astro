<script>
  const menuToggle = document.getElementById('menu-toggle')
  const mobileMenu = document.getElementById('mobile-menu')
  const productsToggle = document.getElementById('products-toggle')
  const productsSubmenu = document.getElementById('products-submenu')
  const productsChevron = document.getElementById('products-chevron')
  const solutionsToggle = document.getElementById('solutions-toggle')
  const solutionsSubmenu = document.getElementById('solutions-submenu')
  const solutionsChevron = document.getElementById('solutions-chevron')

  function syncExpandedState(control: HTMLElement | null, target: HTMLElement | null) {
    if (!control || !target) return

    control.setAttribute('aria-expanded', String(!target.classList.contains('hidden')))
  }

  menuToggle?.addEventListener('click', () => {
    mobileMenu?.classList.toggle('hidden')
    syncExpandedState(menuToggle, mobileMenu)
  })

  productsToggle?.addEventListener('click', () => {
    productsSubmenu?.classList.toggle('hidden')
    productsChevron?.classList.toggle('rotate-180')
    syncExpandedState(productsToggle, productsSubmenu)
  })

  solutionsToggle?.addEventListener('click', () => {
    solutionsSubmenu?.classList.toggle('hidden')
    solutionsChevron?.classList.toggle('rotate-180')
    syncExpandedState(solutionsToggle, solutionsSubmenu)
  })
</script>
