---
import * as m from '@/paraglide/messages'
import { getRelativeLocaleUrl } from 'astro:i18n'
import { getTotalStars } from '@/services/github'

const brand = Astro.locals.runtimeConfig.public.brand
const totalStars = getTotalStars()
const locale = Astro.locals.locale
---

<header class="sticky top-0 z-50 border-b border-white/10 bg-gray-950/90 py-2 backdrop-blur-xl">
  <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
    <div class="relative flex min-h-14 items-center justify-between">
      <div class="flex shrink-0 items-center">
        <a
          href={getRelativeLocaleUrl(Astro.locals.locale)}
          aria-label={m.capgo_home({}, { locale: Astro.locals.locale })}
          class="font-prompt flex items-center pr-3 text-4xl font-medium"
        >
          <img class="h-14 w-auto pr-1" loading="eager" height="72" width="133" alt={`${brand} logo`} aria-label={`${brand} logo`} src="/capgo_logo.webp" />
        </a>
      </div>
      <div class="flex xl:hidden">
        <button
          type="button"
          class="relative rounded-lg p-2 text-white transition-colors hover:bg-white/10 focus-visible:ring-2 focus-visible:ring-blue-400 focus-visible:outline-none"
          aria-label={m.expand_menu({}, { locale: Astro.locals.locale })}
          aria-controls="mobile-menu"
          aria-expanded="false"
          id="menu-toggle"
        >
          <span class="absolute top-1/2 left-1/2 size-[max(100%,3rem)] -translate-1/2 pointer-fine:hidden" aria-hidden="true"></span>
          <svg class="size-7" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M4 6h16M4 12h16M4 18h16"></path>
          </svg>
        </button>
      </div>
      <div class="hidden xl:flex xl:flex-1 xl:items-center xl:gap-10">
        <nav class="flex items-center space-x-8">
          <!-- Docs -->
          <a
            href={getRelativeLocaleUrl(Astro.locals.locale, 'docs')}
            aria-label={m.docs({}, { locale: Astro.locals.locale })}
            class="border-b-2 border-transparent text-base font-medium transition-all duration-200 hover:border-blue-600 focus:border-blue-600"
          >
            {m.docs({}, { locale: Astro.locals.locale })}
          </a>
          <!-- Products Dropdown -->
          <div class="group relative">
            <button
              type="button"
              class="flex items-center border-b-2 border-transparent text-base font-medium transition-all duration-200 hover:border-blue-600 focus:border-blue-600"
              aria-label={m.products({}, { locale: Astro.locals.locale })}
            >
              {m.products({}, { locale: Astro.locals.locale })}
              <svg class="ml-1 h-4 w-4 transition-transform group-hover:rotate-180" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"></path>
              </svg>
            </button>
            <div class="invisible absolute left-0 z-50 w-48 pt-2 opacity-0 transition-all duration-200 group-hover:visible group-hover:opacity-100">
              <div class="rounded-lg border border-gray-700 bg-gray-800 py-2 shadow-xl">
                <a
                  href={getRelativeLocaleUrl(Astro.locals.locale, 'live-update')}
                  class="block px-4 py-2 text-sm text-gray-300 transition-colors hover:bg-gray-700 hover:text-white"
                >
                  {m.live_update({}, { locale: Astro.locals.locale })}
                </a>
                <a
                  href={getRelativeLocaleUrl(Astro.locals.locale, 'native-build')}
                  class="block px-4 py-2 text-sm text-gray-300 transition-colors hover:bg-gray-700 hover:text-white"
                >
                  {m.native_build({}, { locale: Astro.locals.locale })}
                </a>
                <a href={getRelativeLocaleUrl(Astro.locals.locale, 'plugins')} class="block px-4 py-2 text-sm text-gray-300 transition-colors hover:bg-gray-700 hover:text-white">
                  {m.plugins({}, { locale: Astro.locals.locale })}
                </a>
                <a
                  href={getRelativeLocaleUrl(Astro.locals.locale, 'ionic-enterprise-plugins')}
                  class="block px-4 py-2 text-sm text-gray-300 transition-colors hover:bg-gray-700 hover:text-white"
                >
                  {m.solutions_ionic_plugins_short({}, { locale: Astro.locals.locale })}
                </a>
              </div>
            </div>
          </div>
          <!-- Solutions Dropdown -->
          <div class="group relative">
            <button
              type="button"
              class="flex items-center border-b-2 border-transparent text-base font-medium transition-all duration-200 hover:border-blue-600 focus:border-blue-600"
              aria-label={m.solutions({}, { locale: Astro.locals.locale })}
            >
              {m.solutions({}, { locale: Astro.locals.locale })}
              <svg class="ml-1 h-4 w-4 transition-transform group-hover:rotate-180" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"></path>
              </svg>
            </button>
            <div class="invisible absolute left-0 z-50 w-[600px] pt-2 opacity-0 transition-all duration-200 group-hover:visible group-hover:opacity-100">
              <div class="rounded-lg border border-gray-700 bg-gray-800 p-4 shadow-xl">
                <div class="grid grid-cols-3 gap-4">
                  <!-- By Team Type Column -->
                  <div>
                    <p class="mb-2 px-2 text-xs font-semibold tracking-wider text-gray-500 uppercase">{m.solutions_by_team({}, { locale: Astro.locals.locale })}</p>
                    <a
                      href={getRelativeLocaleUrl(locale, 'enterprise')}
                      class="flex items-center gap-3 rounded-lg px-2 py-2 text-sm text-gray-300 transition-colors hover:bg-gray-700 hover:text-white"
                    >
                      <svg class="h-5 w-5 text-blue-400" fill="none" viewBox="0 0 24 24" stroke="currentColor" aria-hidden="true" focusable="false">
                        <path
                          stroke-linecap="round"
                          stroke-linejoin="round"
                          stroke-width="2"
                          d="M19 21V5a2 2 0 00-2-2H7a2 2 0 00-2 2v16m14 0h2m-2 0h-5m-9 0H3m2 0h5M9 7h1m-1 4h1m4-4h1m-1 4h1m-5 10v-5a1 1 0 011-1h2a1 1 0 011 1v5m-4 0h4"></path>
                      </svg>
                      {m.solutions_enterprise_short({}, { locale })}
                    </a>
                    <a
                      href={getRelativeLocaleUrl(Astro.locals.locale, 'solutions/startups')}
                      class="flex items-center gap-3 rounded-lg px-2 py-2 text-sm text-gray-300 transition-colors hover:bg-gray-700 hover:text-white"
                    >
                      <svg class="h-5 w-5 text-purple-400" fill="none" viewBox="0 0 24 24" stroke="currentColor" aria-hidden="true" focusable="false">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z"></path>
                      </svg>
                      {m.solutions_startups_short({}, { locale: Astro.locals.locale })}
                    </a>
                    <a
                      href={getRelativeLocaleUrl(Astro.locals.locale, 'solutions/solo-developers')}
                      class="flex items-center gap-3 rounded-lg px-2 py-2 text-sm text-gray-300 transition-colors hover:bg-gray-700 hover:text-white"
                    >
                      <svg class="h-5 w-5 text-green-400" fill="none" viewBox="0 0 24 24" stroke="currentColor" aria-hidden="true" focusable="false">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z"></path>
                      </svg>
                      {m.solutions_solo_short({}, { locale: Astro.locals.locale })}
                    </a>
                    <a
                      href={getRelativeLocaleUrl(Astro.locals.locale, 'solutions/agencies')}
                      class="flex items-center gap-3 rounded-lg px-2 py-2 text-sm text-gray-300 transition-colors hover:bg-gray-700 hover:text-white"
                    >
                      <svg class="h-5 w-5 text-amber-400" fill="none" viewBox="0 0 24 24" stroke="currentColor" aria-hidden="true" focusable="false">
                        <path
                          stroke-linecap="round"
                          stroke-linejoin="round"
                          stroke-width="2"
                          d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0zm6 3a2 2 0 11-4 0 2 2 0 014 0zM7 10a2 2 0 11-4 0 2 2 0 014 0z"
                        ></path>
                      </svg>
                      {m.solutions_agencies_short({}, { locale: Astro.locals.locale })}
                    </a>
                  </div>
                  <!-- By Industry Column -->
                  <div>
                    <p class="mb-2 px-2 text-xs font-semibold tracking-wider text-gray-500 uppercase">{m.solutions_by_industry({}, { locale: Astro.locals.locale })}</p>
                    <a
                      href={getRelativeLocaleUrl(Astro.locals.locale, 'solutions/fintech')}
                      class="flex items-center gap-3 rounded-lg px-2 py-2 text-sm text-gray-300 transition-colors hover:bg-gray-700 hover:text-white"
                    >
                      <svg class="h-5 w-5 text-emerald-400" fill="none" viewBox="0 0 24 24" stroke="currentColor" aria-hidden="true" focusable="false">
                        <path
                          stroke-linecap="round"
                          stroke-linejoin="round"
                          stroke-width="2"
                          d="M12 8c-1.657 0-3 .895-3 2s1.343 2 3 2 3 .895 3 2-1.343 2-3 2m0-8c1.11 0 2.08.402 2.599 1M12 8V7m0 1v8m0 0v1m0-1c-1.11 0-2.08-.402-2.599-1M21 12a9 9 0 11-18 0 9 9 0 0118 0z"
                        ></path>
                      </svg>
                      {m.solutions_fintech_short({}, { locale: Astro.locals.locale })}
                    </a>
                    <a
                      href={getRelativeLocaleUrl(Astro.locals.locale, 'solutions/ecommerce')}
                      class="flex items-center gap-3 rounded-lg px-2 py-2 text-sm text-gray-300 transition-colors hover:bg-gray-700 hover:text-white"
                    >
                      <svg class="h-5 w-5 text-orange-400" fill="none" viewBox="0 0 24 24" stroke="currentColor" aria-hidden="true" focusable="false">
                        <path
                          stroke-linecap="round"
                          stroke-linejoin="round"
                          stroke-width="2"
                          d="M3 3h2l.4 2M7 13h10l4-8H5.4M7 13L5.4 5M7 13l-2.293 2.293c-.63.63-.184 1.707.707 1.707H17m0 0a2 2 0 100 4 2 2 0 000-4zm-8 2a2 2 0 11-4 0 2 2 0 014 0z"
                        ></path>
                      </svg>
                      {m.solutions_ecommerce_short({}, { locale: Astro.locals.locale })}
                    </a>
                    <a
                      href={getRelativeLocaleUrl(Astro.locals.locale, 'solutions/healthcare')}
                      class="flex items-center gap-3 rounded-lg px-2 py-2 text-sm text-gray-300 transition-colors hover:bg-gray-700 hover:text-white"
                    >
                      <svg class="h-5 w-5 text-red-400" fill="none" viewBox="0 0 24 24" stroke="currentColor" aria-hidden="true" focusable="false">
                        <path
                          stroke-linecap="round"
                          stroke-linejoin="round"
                          stroke-width="2"
                          d="M4.318 6.318a4.5 4.5 0 000 6.364L12 20.364l7.682-7.682a4.5 4.5 0 00-6.364-6.364L12 7.636l-1.318-1.318a4.5 4.5 0 00-6.364 0z"></path>
                      </svg>
                      {m.solutions_healthcare_short({}, { locale: Astro.locals.locale })}
                    </a>
                    <a
                      href={getRelativeLocaleUrl(Astro.locals.locale, 'solutions/qsr')}
                      class="flex items-center gap-3 rounded-lg px-2 py-2 text-sm text-gray-300 transition-colors hover:bg-gray-700 hover:text-white"
                    >
                      <svg class="h-5 w-5 text-orange-400" fill="none" viewBox="0 0 24 24" stroke="currentColor" aria-hidden="true" focusable="false">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"></path>
                      </svg>
                      {m.solutions_qsr_short({}, { locale: Astro.locals.locale })}
                    </a>
                  </div>
                  <!-- By Use Case Column -->
                  <div>
                    <p class="mb-2 px-2 text-xs font-semibold tracking-wider text-gray-500 uppercase">{m.solutions_by_use_case({}, { locale: Astro.locals.locale })}</p>
                    <a
                      href={getRelativeLocaleUrl(Astro.locals.locale, 'solutions/production-updates')}
                      class="flex items-center gap-3 rounded-lg px-2 py-2 text-sm text-gray-300 transition-colors hover:bg-gray-700 hover:text-white"
                    >
                      <svg class="h-5 w-5 text-blue-400" fill="none" viewBox="0 0 24 24" stroke="currentColor" aria-hidden="true" focusable="false">
                        <path
                          stroke-linecap="round"
                          stroke-linejoin="round"
                          stroke-width="2"
                          d="M7 16a4 4 0 01-.88-7.903A5 5 0 1115.9 6L16 6a5 5 0 011 9.9M15 13l-3-3m0 0l-3 3m3-3v12"></path>
                      </svg>
                      {m.solutions_production_updates({}, { locale: Astro.locals.locale })}
                    </a>
                    <a
                      href={getRelativeLocaleUrl(Astro.locals.locale, 'solutions/direct-updates')}
                      class="flex items-center gap-3 rounded-lg px-2 py-2 text-sm text-gray-300 transition-colors hover:bg-gray-700 hover:text-white"
                    >
                      <svg class="h-5 w-5 text-emerald-400" fill="none" viewBox="0 0 24 24" stroke="currentColor" aria-hidden="true" focusable="false">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z"></path>
                      </svg>
                      {m.solutions_direct_updates({}, { locale: Astro.locals.locale })}
                    </a>
                    <a
                      href={getRelativeLocaleUrl(Astro.locals.locale, 'solutions/pr-preview')}
                      class="flex items-center gap-3 rounded-lg px-2 py-2 text-sm text-gray-300 transition-colors hover:bg-gray-700 hover:text-white"
                    >
                      <svg class="h-5 w-5 text-purple-400" fill="none" viewBox="0 0 24 24" stroke="currentColor" aria-hidden="true" focusable="false">
                        <path
                          stroke-linecap="round"
                          stroke-linejoin="round"
                          stroke-width="2"
                          d="M8 9l3 3-3 3m5 0h3M5 20h14a2 2 0 002-2V6a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z"></path>
                      </svg>
                      {m.solutions_pr_preview({}, { locale: Astro.locals.locale })}
                    </a>
                    <a
                      href={getRelativeLocaleUrl(Astro.locals.locale, 'solutions/beta-testing')}
                      class="flex items-center gap-3 rounded-lg px-2 py-2 text-sm text-gray-300 transition-colors hover:bg-gray-700 hover:text-white"
                    >
                      <svg class="h-5 w-5 text-cyan-400" fill="none" viewBox="0 0 24 24" stroke="currentColor" aria-hidden="true" focusable="false">
                        <path
                          stroke-linecap="round"
                          stroke-linejoin="round"
                          stroke-width="2"
                          d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z"
                        ></path>
                      </svg>
                      {m.solutions_beta_testing({}, { locale: Astro.locals.locale })}
                    </a>
                    <a
                      href={getRelativeLocaleUrl(locale, 'solutions/cordova-to-capacitor')}
                      class="flex items-center gap-3 rounded-lg px-2 py-2 text-sm text-gray-300 transition-colors hover:bg-gray-700 hover:text-white"
                    >
                      <svg class="h-5 w-5 text-sky-300" fill="none" viewBox="0 0 24 24" stroke="currentColor" aria-hidden="true" focusable="false">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3"></path>
                      </svg>
                      {m.solutions_cordova_to_capacitor_short({}, { locale })}
                    </a>
                    <a
                      href={getRelativeLocaleUrl(locale, 'solutions/cordova-to-capacitor-ai')}
                      class="flex items-center gap-3 rounded-lg px-2 py-2 text-sm text-gray-300 transition-colors hover:bg-gray-700 hover:text-white"
                    >
                      <svg class="h-5 w-5 text-orange-300" fill="none" viewBox="0 0 24 24" stroke="currentColor" aria-hidden="true" focusable="false">
                        <path
                          stroke-linecap="round"
                          stroke-linejoin="round"
                          stroke-width="2"
                          d="M9.75 17L9 20l-1-1-2.5 1 .75-3m5.5 0L12 20l1-1 2.5 1-.75-3M12 3l.8 2.4L15 6l-2.2.6L12 9l-.8-2.4L9 6l2.2-.6L12 3z"></path>
                      </svg>
                      {m.solutions_cordova_to_capacitor_ai_short({}, { locale })}
                    </a>
                    <a
                      href={getRelativeLocaleUrl(Astro.locals.locale, 'solutions/ionic-enterprise-plugins')}
                      class="flex items-center gap-3 rounded-lg px-2 py-2 text-sm text-gray-300 transition-colors hover:bg-gray-700 hover:text-white"
                    >
                      <svg class="h-5 w-5 text-emerald-400" fill="none" viewBox="0 0 24 24" stroke="currentColor" aria-hidden="true" focusable="false">
                        <path
                          stroke-linecap="round"
                          stroke-linejoin="round"
                          stroke-width="2"
                          d="M12 11c1.104 0 2-.896 2-2V7a2 2 0 10-4 0v2c0 1.104.896 2 2 2zm6 0h-1V9a5 5 0 00-10 0v2H6a2 2 0 00-2 2v7a2 2 0 002 2h12a2 2 0 002-2v-7a2 2 0 00-2-2z"
                        ></path>
                      </svg>
                      {m.solutions_ionic_plugins_short({}, { locale: Astro.locals.locale })}
                    </a>
                  </div>
                </div>
              </div>
            </div>
          </div>
          <!-- Enterprise -->
          <a
            href={getRelativeLocaleUrl(Astro.locals.locale, 'enterprise')}
            aria-label={m.enterprise_title({}, { locale: Astro.locals.locale })}
            class="border-b-2 border-transparent text-base font-medium transition-all duration-200 hover:border-blue-600 focus:border-blue-600"
          >
            {m.enterprise_title({}, { locale: Astro.locals.locale })}
          </a>
          <!-- Pricing -->
          <a
            href={getRelativeLocaleUrl(Astro.locals.locale, 'pricing')}
            aria-label={m.pricing({}, { locale: Astro.locals.locale })}
            class="border-b-2 border-transparent text-base font-medium transition-all duration-200 hover:border-blue-600 focus:border-blue-600"
          >
            {m.pricing({}, { locale: Astro.locals.locale })}
          </a>
          <!-- Blog -->
          <a
            href={getRelativeLocaleUrl(Astro.locals.locale, 'blog')}
            aria-label={m.blog({}, { locale: Astro.locals.locale })}
            class="border-b-2 border-transparent text-base font-medium transition-all duration-200 hover:border-blue-600 focus:border-blue-600"
          >
            {m.blog({}, { locale: Astro.locals.locale })}
          </a>
        </nav>
        <div class="ml-auto flex items-center space-x-4">
          <a
            href={getRelativeLocaleUrl(Astro.locals.locale, 'plugins')}
            aria-label={m.github_stars({}, { locale: Astro.locals.locale })}
            class="flex items-center gap-2 rounded-lg border border-white/5 bg-white/10 px-3 py-1.5 text-sm font-medium text-gray-200 transition-colors hover:bg-white/20"
          >
            <svg class="h-5 w-5" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true">
              <path
                fill-rule="evenodd"
                d="M12 2C6.477 2 2 6.484 2 12.017c0 4.425 2.865 8.18 6.839 9.504.5.092.682-.217.682-.483 0-.237-.008-.868-.013-1.703-2.782.605-3.369-1.343-3.369-1.343-.454-1.158-1.11-1.466-1.11-1.466-.908-.62.069-.608.069-.608 1.003.07 1.531 1.032 1.531 1.032.892 1.53 2.341 1.088 2.91.832.092-.647.35-1.088.636-1.338-2.22-.253-4.555-1.113-4.555-4.951 0-1.093.39-1.988 1.029-2.688-.103-.253-.446-1.272.098-2.65 0 0 .84-.27 2.75 1.026A9.564 9.564 0 0112 6.844c.85.004 1.705.115 2.504.337 1.909-1.296 2.747-1.027 2.747-1.027.546 1.379.202 2.398.1 2.651.64.7 1.028 1.595 1.028 2.688 0 3.848-2.339 4.695-4.566 4.943.359.309.678.92.678 1.855 0 1.338-.012 2.419-.012 2.747 0 .268.18.58.688.482A10.019 10.019 0 0022 12.017C22 6.484 17.522 2 12 2z"
                clip-rule="evenodd"></path>
            </svg>
            <span>{totalStars}+</span>
          </a>
          <a
            href="https://console.capgo.app/login/"
            aria-label={m.login({}, { locale: Astro.locals.locale })}
            target="_blank"
            class="border-b-2 border-transparent text-base font-medium transition-all duration-200 hover:border-blue-600 focus:border-blue-600"
          >
            {m.login({}, { locale: Astro.locals.locale })}
          </a>
          <a
            href={getRelativeLocaleUrl(Astro.locals.locale, 'register')}
            target="_blank"
            aria-label={m.register({}, { locale: Astro.locals.locale })}
            class="font-pj rounded-lg border border-white/30 bg-white/5 px-4 py-2 text-base font-semibold text-gray-100 transition-all duration-200 hover:border-white/50 hover:bg-white/10 focus-visible:ring-2 focus-visible:ring-blue-400 focus-visible:outline-none"
            role="button"
          >
            {m.register({}, { locale: Astro.locals.locale })}
          </a>
        </div>
      </div>
    </div>
  </div>
  <div id="mobile-menu" class="hidden px-4 pb-3 xl:hidden">
    <div class="mt-2 max-h-[calc(100dvh-5rem)] space-y-1 overflow-y-auto rounded-2xl border border-white/10 bg-gray-900/95 p-2 shadow-2xl shadow-black/30">
      <!-- GitHub Stars -->
      <a
        href={getRelativeLocaleUrl(Astro.locals.locale, 'plugins')}
        aria-label={m.github_stars({}, { locale: Astro.locals.locale })}
        class="flex items-center gap-2 rounded-xl px-3 py-2.5 text-base font-medium text-gray-300 hover:bg-white/10 hover:text-white"
      >
        <svg class="h-5 w-5" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true">
