---
import m from '@/copy/messages'

const featureGroups = [
  {
    title: m.security_and_compliance(),
    items: [m.single_sign_on_sso(), m.advanced_access_levels(), m.extended_security(), m.enterprise_security_automations(), m.soc2_compliance_short()],
  },
  {
    title: m.integration_and_api(),
    items: [m.custom_webhooks(), m.full_api_access(), m.ci_cd_integration(), m.custom_features()],
  },
  {
    title: m.infrastructure_and_support(),
    items: [m.deploy_on_cloud_providers(), m.per_country_hosting_gdpr(), m.self_hosted_storage_options(), m.priority_support_dedicated_sla()],
  },
]

const stats = [
  {
    value: '99.9%',
    label: m.uptime_sla(),
    href: 'https://status.capgo.app',
  },
  {
    value: '24/7',
    label: m.priority_support_24_7(),
  },
  {
    value: 'SOC 2',
    label: m.type_ii_certified(),
  },
]
---

<section id="enterprise-details" class="mt-10 mb-12 overflow-hidden rounded-2xl border border-gray-200 bg-white shadow-sm">
  <div class="grid lg:grid-cols-[0.92fr_1.08fr]">
    <div class="border-b border-gray-200 p-6 sm:p-8 lg:border-r lg:border-b-0 lg:p-10">
      <p class="text-sm font-semibold tracking-wide text-blue-700 uppercase">{m.enterprise_ready()}</p>
      <h2 class="mt-4 max-w-xl text-3xl leading-tight font-semibold tracking-tight text-gray-950 sm:text-4xl">
        {m.enterprise_title()}
      </h2>
      <p class="mt-5 max-w-xl text-base leading-7 text-gray-600">
        {m.enterprise_description()}
      </p>

      <div class="mt-8 flex flex-col gap-3 sm:flex-row">
        <a
          href="https://book.capgo.app/enterprise-inquiry/"
          target="_blank"
          rel="noopener noreferrer"
          class="inline-flex min-h-11 items-center justify-center rounded-full border border-gray-950 bg-gray-950 px-6 py-3 text-sm font-semibold text-white transition-colors hover:bg-gray-800 focus:ring-2 focus:ring-blue-600 focus:ring-offset-2 focus:outline-none"
        >
          {m.get_enterprise_quote()}
        </a>
        <a
          href="#compare-plans"
          class="inline-flex min-h-11 items-center justify-center rounded-full border border-gray-200 bg-gray-50 px-6 py-3 text-sm font-semibold text-gray-900 transition-colors hover:border-blue-200 hover:bg-blue-50 hover:text-blue-700 focus:ring-2 focus:ring-blue-600 focus:ring-offset-2 focus:outline-none"
        >
          View enterprise features
        </a>
      </div>

      <div class="mt-8 flex flex-wrap gap-x-6 gap-y-3 text-sm text-gray-600">
        <span class="inline-flex items-center gap-2">
          <svg class="h-4 w-4 text-gray-500" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.4" aria-hidden="true">
            <path stroke-linecap="round" stroke-linejoin="round" d="m4.5 12.75 6 6 9-13.5"></path>
          </svg>
          {m.custom_pricing()}
        </span>
        <span class="inline-flex items-center gap-2">
          <svg class="h-4 w-4 text-gray-500" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.4" aria-hidden="true">
            <path stroke-linecap="round" stroke-linejoin="round" d="m4.5 12.75 6 6 9-13.5"></path>
          </svg>
          {m.no_commitment_required()}
        </span>
      </div>
    </div>

    <div class="p-6 sm:p-8 lg:p-10">
      <div class="grid gap-8 md:grid-cols-3 lg:grid-cols-1 xl:grid-cols-3">
        {
          featureGroups.map((group) => (
            <div>
              <h3 class="text-sm font-semibold tracking-wide text-gray-950 uppercase">{group.title}</h3>
              <ul class="mt-5 space-y-3 text-sm leading-6 text-gray-700">
                {group.items.map((item) => (
                  <li class="flex gap-3">
                    <svg class="mt-1 h-4 w-4 shrink-0 text-gray-500" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.4" aria-hidden="true">
                      <path stroke-linecap="round" stroke-linejoin="round" d="m4.5 12.75 6 6 9-13.5" />
                    </svg>
                    <span>{item}</span>
                  </li>
                ))}
              </ul>
            </div>
          ))
        }
      </div>
    </div>
  </div>

  <div class="grid border-t border-gray-200 bg-gray-50 md:grid-cols-3">
    {
      stats.map((stat) => (
        <div class="border-b border-gray-200 px-6 py-6 text-center last:border-b-0 md:border-r md:border-b-0 md:last:border-r-0">
          <div class="text-2xl font-semibold tracking-tight text-gray-950">
            {stat.href ? (
              <a href={stat.href} target="_blank" rel="noopener noreferrer" class="hover:text-blue-700">
                {stat.value}
              </a>
            ) : (
              stat.value
            )}
          </div>
          <div class="mt-1 text-sm text-gray-600">{stat.label}</div>
        </div>
      ))
    }
  </div>
</section>
