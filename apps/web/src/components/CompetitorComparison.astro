---
import { getRelativeLocaleUrl } from 'astro:i18n'

interface Difference {
  label: string
  capgo: string
  competitor: string
}

interface NarrativeSection {
  title: string
  text: string
  items: string[]
}

interface SourceLink {
  label: string
  href: string
}

interface ComparisonPageData {
  eyebrow: string
  title: string
  subtitle: string
  competitor: string
  competitorShort: string
  capgoSummary: string
  competitorSummary: string
  verdict: string
  capgoFitTitle: string
  competitorFitTitle: string
  capgoFits: string[]
  competitorFits: string[]
  differences: Difference[]
  narratives: NarrativeSection[]
  faq: Array<{
    question: string
    answer: string
  }>
  sources: SourceLink[]
  sourceNote: string
}

interface Props {
  locale: string
  page: ComparisonPageData
}

const { locale, page } = Astro.props
const registerUrl = getRelativeLocaleUrl(locale, 'register')
const liveUpdateUrl = getRelativeLocaleUrl(locale, 'live-update')
---

<main class="bg-gray-950 text-white">
  <section class="bg-gray-900 py-14 sm:py-18 lg:py-20">
    <div class="mx-auto max-w-5xl px-4 sm:px-6 lg:px-8">
      <p class="inline-flex rounded-full border border-sky-400/30 bg-sky-500/10 px-4 py-2 text-sm font-semibold text-sky-100">{page.eyebrow}</p>
      <h1 class="mt-6 max-w-4xl text-4xl leading-tight font-bold tracking-tight text-white sm:text-5xl">{page.title}</h1>
      <p class="mt-5 max-w-2xl text-lg leading-8 text-gray-300">{page.subtitle}</p>
      <div class="mt-8 flex flex-col gap-3 sm:flex-row">
        <a
          href={registerUrl}
          class="inline-flex min-h-12 items-center justify-center rounded-lg bg-sky-500 px-5 py-3 text-base font-semibold text-white transition hover:bg-sky-400"
        >
          Start with Capgo
        </a>
        <a
          href={liveUpdateUrl}
          class="inline-flex min-h-12 items-center justify-center rounded-lg border border-gray-600 px-5 py-3 text-base font-semibold text-gray-100 transition hover:bg-gray-800"
        >
          See live updates
        </a>
      </div>
    </div>
  </section>
</main>

<section class="bg-gray-950 py-14 sm:py-20">
  <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
    <div class="grid gap-5 lg:grid-cols-3">
      <article class="rounded-lg border border-sky-500/30 bg-sky-500/5 p-6">
        <p class="text-sm font-semibold text-sky-200">Capgo</p>
        <h2 class="mt-3 text-2xl font-bold text-white">Capacitor release control</h2>
        <p class="mt-4 text-base leading-7 text-gray-300">{page.capgoSummary}</p>
      </article>
      <article class="rounded-lg border border-amber-500/30 bg-amber-500/5 p-6">
        <p class="text-sm font-semibold text-amber-200">{page.competitor}</p>
        <h2 class="mt-3 text-2xl font-bold text-white">{page.competitorShort} focus</h2>
        <p class="mt-4 text-base leading-7 text-gray-300">{page.competitorSummary}</p>
      </article>
      <article class="rounded-lg border border-emerald-500/30 bg-emerald-500/5 p-6">
        <p class="text-sm font-semibold text-emerald-200">Decision</p>
        <h2 class="mt-3 text-2xl font-bold text-white">Pick by app architecture</h2>
        <p class="mt-4 text-base leading-7 text-gray-300">{page.verdict}</p>
      </article>
    </div>
  </div>
</section>

<section class="bg-gray-900 py-14 sm:py-20">
  <div class="mx-auto grid max-w-7xl gap-6 px-4 sm:px-6 lg:grid-cols-2 lg:px-8">
    <article class="rounded-lg border border-sky-500/30 bg-gray-950 p-6">
      <h2 class="text-2xl font-bold text-white">{page.capgoFitTitle}</h2>
      <ul class="mt-6 space-y-3">
        {
          page.capgoFits.map((item) => (
            <li class="flex gap-3 text-base leading-7 text-gray-300">
              <span class="mt-3 h-2 w-2 shrink-0 rounded-full bg-sky-300" />
              <span>{item}</span>
            </li>
          ))
        }
      </ul>
    </article>
    <article class="rounded-lg border border-amber-500/30 bg-gray-950 p-6">
      <h2 class="text-2xl font-bold text-white">{page.competitorFitTitle}</h2>
      <ul class="mt-6 space-y-3">
        {
          page.competitorFits.map((item) => (
            <li class="flex gap-3 text-base leading-7 text-gray-300">
              <span class="mt-3 h-2 w-2 shrink-0 rounded-full bg-amber-300" />
              <span>{item}</span>
            </li>
          ))
        }
      </ul>
    </article>
  </div>
</section>

<section class="bg-gray-950 py-14 sm:py-20">
  <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
    <div class="max-w-3xl">
      <p class="text-sm font-semibold tracking-wide text-sky-200 uppercase">Side-by-side</p>
      <h2 class="mt-3 text-3xl font-bold text-white">The practical differences</h2>
    </div>
    <div class="mt-8 overflow-hidden rounded-lg border border-gray-800">
      <div class="hidden grid-cols-[0.7fr_1fr_1fr] bg-gray-900 text-sm font-semibold text-gray-300 md:grid">
        <div class="px-5 py-4">Area</div>
        <div class="px-5 py-4">Capgo</div>
        <div class="px-5 py-4">{page.competitorShort}</div>
      </div>
      <div class="divide-y divide-gray-800">
        {
          page.differences.map((item) => (
            <div class="grid gap-4 bg-gray-950 p-5 md:grid-cols-[0.7fr_1fr_1fr] md:gap-0 md:p-0">
              <div class="font-semibold text-white md:px-5 md:py-4">{item.label}</div>
              <div class="text-base leading-7 text-gray-300 md:px-5 md:py-4">
                <p class="mb-1 text-xs font-semibold tracking-wide text-sky-200 uppercase md:hidden">Capgo</p>
                {item.capgo}
              </div>
              <div class="text-base leading-7 text-gray-300 md:px-5 md:py-4">
                <p class="mb-1 text-xs font-semibold tracking-wide text-amber-200 uppercase md:hidden">{page.competitorShort}</p>
                {item.competitor}
              </div>
            </div>
          ))
        }
      </div>
    </div>
  </div>
</section>

<section class="bg-gray-900 py-14 sm:py-20">
  <div class="mx-auto grid max-w-7xl gap-6 px-4 sm:px-6 lg:grid-cols-3 lg:px-8">
    {
      page.narratives.map((section) => (
        <article class="rounded-lg border border-gray-800 bg-gray-950 p-6">
          <h2 class="text-2xl font-bold text-white">{section.title}</h2>
          <p class="mt-4 text-base leading-7 text-gray-300">{section.text}</p>
          <ul class="mt-6 space-y-3">
            {section.items.map((item) => (
              <li class="flex gap-3 text-base leading-7 text-gray-300">
                <span class="mt-3 h-2 w-2 shrink-0 rounded-full bg-emerald-300" />
                <span>{item}</span>
              </li>
            ))}
          </ul>
        </article>
      ))
    }
  </div>
</section>

<section class="bg-gray-950 py-14 sm:py-20">
  <div class="mx-auto max-w-4xl px-4 sm:px-6 lg:px-8">
    <h2 class="text-3xl font-bold text-white">Common questions</h2>
    <dl class="mt-8 space-y-6">
      {
        page.faq.map((item) => (
          <div class="rounded-lg border border-gray-800 bg-gray-900 p-6">
            <dt class="text-xl font-semibold text-white">{item.question}</dt>
            <dd class="mt-3 text-base leading-7 text-gray-300">{item.answer}</dd>
          </div>
        ))
      }
    </dl>
  </div>
</section>

<section class="bg-gray-900 py-14 sm:py-20">
  <div class="mx-auto max-w-4xl px-4 sm:px-6 lg:px-8">
    <h2 class="text-3xl font-bold text-white">Sources</h2>
    <p class="mt-4 text-base leading-7 text-gray-300">{page.sourceNote}</p>
    <ul class="mt-6 grid gap-3 text-base text-gray-300 sm:grid-cols-2">
      {
        page.sources.map((source) => (
          <li>
            <a href={source.href} class="text-sky-300 hover:underline">
              {source.label}
            </a>
          </li>
        ))
      }
    </ul>
  </div>
</section>

<section class="bg-gray-950 py-14 sm:py-20">
  <div class="mx-auto max-w-5xl px-4 sm:px-6 lg:px-8">
    <div class="rounded-lg border border-sky-500/30 bg-sky-500/10 p-6 text-center sm:p-8">
      <h2 class="text-3xl font-bold text-white">Ship Capacitor updates without waiting on every store review.</h2>
      <p class="mx-auto mt-4 max-w-2xl text-base leading-7 text-gray-300">
        Use Capgo for live updates, rollback, channels, device logs, plugin maintenance, and native builds when your app is built on Capacitor.
      </p>
      <div class="mt-8 flex flex-col justify-center gap-3 sm:flex-row">
        <a
          href={registerUrl}
          class="inline-flex min-h-12 items-center justify-center rounded-lg bg-white px-5 py-3 text-base font-semibold text-gray-950 transition hover:bg-gray-200"
        >
          Start free trial
        </a>
        <a
          href={liveUpdateUrl}
          class="inline-flex min-h-12 items-center justify-center rounded-lg border border-sky-300/40 px-5 py-3 text-base font-semibold text-sky-100 transition hover:bg-sky-400/10"
        >
          Read live update guide
        </a>
      </div>
    </div>
  </div>
</section>
