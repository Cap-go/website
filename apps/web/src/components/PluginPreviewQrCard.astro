---
import type { PluginPreviewQr } from '@/config/pluginPreviewQrs'
import { Icon as AstroIcon } from 'astro-icon/components'

interface Props {
  preview: PluginPreviewQr
  title: string
  compact?: boolean
}

const { preview, title, compact = false } = Astro.props
const imageAlt = `${title} plugin preview QR code`
---

<section
  class:list={[
    'rounded-2xl border border-cyan-300/20 bg-cyan-300/[0.06] p-4 shadow-[0_18px_52px_rgba(8,145,178,0.12)]',
    compact ? 'flex flex-col gap-4 sm:flex-row sm:items-center' : 'space-y-4',
  ]}
>
  <a
    href={preview.webUrl}
    target="_blank"
    rel="noopener noreferrer"
    class:list={['block shrink-0 overflow-hidden rounded-xl border border-white/15 bg-white p-2 transition hover:border-cyan-200/60', compact ? 'w-28' : 'mx-auto w-40']}
  >
    <img src={preview.qr} alt={imageAlt} loading="lazy" decoding="async" class="h-auto w-full" />
  </a>

  <div class={compact ? 'min-w-0' : ''}>
    <p class="text-[0.7rem] font-semibold tracking-[0.22em] text-cyan-100/80 uppercase">Try the example</p>
    <p class="mt-2 text-sm leading-6 text-gray-300">Download or open the Capgo mobile app first, then scan this QR code with your phone to test the live plugin example.</p>
    <a
      href={preview.webUrl}
      target="_blank"
      rel="noopener noreferrer"
      class="mt-3 inline-flex cursor-pointer items-center gap-2 text-sm font-semibold text-cyan-100 transition hover:text-white"
    >
      <span>Open preview</span>
      <AstroIcon name="heroicons:arrow-up-right-solid" class="size-4" aria-hidden="true" />
    </a>
  </div>
</section>
