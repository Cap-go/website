---
import { capgoAppStoreLinks } from '@/config/capgoAppStoreLinks'
import type { PluginPreviewQr } from '@/config/pluginPreviewQrs'
import { Icon as AstroIcon } from 'astro-icon/components'

interface Props {
  preview: PluginPreviewQr
  title: string
  compact?: boolean
}

const { preview, title, compact = false } = Astro.props
const imageAlt = `${title} plugin preview QR code`
const instruction = 'Download the Capgo app, then scan the QR code.'
const storeLinks = [
  { href: capgoAppStoreLinks.ios, label: 'App Store' },
  { href: capgoAppStoreLinks.android, label: 'Google Play' },
]
---

<section
  class:list={[
    compact ? 'rounded-xl border border-cyan-300/15 bg-slate-950/55 p-4' : 'rounded-2xl border border-cyan-300/20 bg-cyan-300/[0.06] p-4 shadow-[0_18px_52px_rgba(8,145,178,0.12)]',
  ]}
>
  {
    compact ? (
      <div class="grid gap-4 sm:grid-cols-[minmax(0,1fr)_auto] sm:items-center">
        <div class="min-w-0">
          <p class="text-[0.7rem] font-semibold tracking-[0.18em] text-cyan-100/80 uppercase">Test on device</p>
          <p class="mt-2 text-sm leading-6 text-gray-300">{instruction}</p>
          <div class="mt-3 flex flex-wrap gap-2">
            {storeLinks.map((store) => (
              <a
                href={store.href}
                target="_blank"
                rel="noopener noreferrer"
                class="inline-flex min-h-11 cursor-pointer items-center gap-2 rounded-lg border border-white/10 bg-white/[0.08] px-3 text-sm font-semibold text-white transition hover:border-cyan-200/50 hover:bg-white/[0.12] focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-blue-400"
                aria-label={`Download Capgo on ${store.label}`}
              >
                <AstroIcon name="heroicons:arrow-up-right-solid" class="size-4 text-cyan-100" aria-hidden="true" />
                <span>{store.label}</span>
              </a>
            ))}
          </div>
        </div>
        <a
          href={preview.webUrl}
          target="_blank"
          rel="noopener noreferrer"
          class="block w-24 shrink-0 overflow-hidden rounded-lg border border-white/15 bg-white p-2 transition hover:border-cyan-200/60 focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-blue-400 sm:w-28 sm:justify-self-end"
          aria-label={`${title} plugin preview QR link`}
        >
          <img src={preview.qr} alt={imageAlt} loading="lazy" decoding="async" class="h-auto w-full" />
        </a>
      </div>
    ) : (
      <div class="space-y-4">
        <a
          href={preview.webUrl}
          target="_blank"
          rel="noopener noreferrer"
          class="mx-auto block w-40 shrink-0 overflow-hidden rounded-xl border border-white/15 bg-white p-2 transition hover:border-cyan-200/60 focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-blue-400"
          aria-label={`${title} plugin preview QR link`}
        >
          <img src={preview.qr} alt={imageAlt} loading="lazy" decoding="async" class="h-auto w-full" />
        </a>
        <div>
          <p class="text-[0.7rem] font-semibold tracking-[0.18em] text-cyan-100/80 uppercase">Test on device</p>
          <p class="mt-2 text-sm leading-6 text-gray-300">{instruction}</p>
          <div class="mt-3 grid gap-2">
            {storeLinks.map((store) => (
              <a
                href={store.href}
                target="_blank"
                rel="noopener noreferrer"
                class="inline-flex min-h-11 cursor-pointer items-center justify-center gap-2 rounded-lg border border-white/10 bg-white/[0.08] px-3 text-sm font-semibold text-white transition hover:border-cyan-200/50 hover:bg-white/[0.12] focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-blue-400"
                aria-label={`Download Capgo on ${store.label}`}
              >
                <AstroIcon name="heroicons:arrow-up-right-solid" class="size-4 text-cyan-100" aria-hidden="true" />
                <span>{store.label}</span>
              </a>
            ))}
          </div>
        </div>
      </div>
    )
  }
</section>
