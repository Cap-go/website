---
import Blog from '@/components/Blog.astro'
import Layout from '@/layouts/Layout.astro'
import m from '@/copy/messages'
import type { CollectionEntry } from 'astro:content'
import { getRelativeLocaleUrl } from 'astro:i18n'
import { slug as slugify } from 'github-slugger'

const {
  allPosts,
  categorySourcePosts = allPosts,
  currentCategory,
} = Astro.props as {
  allPosts: CollectionEntry<'blog'>[]
  categorySourcePosts?: CollectionEntry<'blog'>[]
  currentCategory?: string
}

const config = Astro.locals.runtimeConfig
const content: { title?: string; description?: string; image?: string; author?: string; ldJSON?: Object; keywords?: string } = {}

const posts = [...allPosts].sort((a, b) => (new Date(a.data.created_at) > new Date(b.data.created_at) ? -1 : 1))

const tagCounts = new Map<string, number>()
categorySourcePosts.forEach((article) =>
  article.data.tag
    .split(',')
    .map((tag) => tag.trim())
    .filter(Boolean)
    .forEach((tag) => tagCounts.set(tag, (tagCounts.get(tag) ?? 0) + 1)),
)
const categories = Array.from(tagCounts.entries()).sort(([a], [b]) => a.localeCompare(b))
const currentCategorySlug = currentCategory ? slugify(currentCategory) : undefined

if (Astro.locals.runtimeConfig.public.blog_title) content['title'] = Astro.locals.runtimeConfig.public.blog_title
if (Astro.locals.runtimeConfig.public.blog_keywords) content['keywords'] = Astro.locals.runtimeConfig.public.blog_keywords
if (Astro.locals.runtimeConfig.public.blog_description) content['description'] = Astro.locals.runtimeConfig.public.blog_description
---

<Layout {content}>
  <div class="flex w-full flex-col items-center py-8">
    <div class="relative w-full max-w-7xl px-8 sm:px-10 lg:px-12">
      <header class="max-w-3xl">
        <h1 class="text-3xl leading-tight font-bold text-white sm:text-4xl lg:text-5xl">{m.latest_from_the_blog({}, { locale: Astro.locals.locale })}</h1>
        <h2 class="mt-2 text-base leading-relaxed text-gray-50">
          {config.public.blog_description}
        </h2>
      </header>

      <div class="mt-8 grid gap-8 lg:grid-cols-[17rem_minmax(0,1fr)] lg:items-start">
        <aside
          class="sticky top-0 z-20 rounded-lg border border-gray-800/80 bg-gray-900/95 p-2 backdrop-blur-sm lg:top-24 lg:flex lg:max-h-[calc(100vh-7rem)] lg:flex-col lg:overflow-hidden lg:rounded-none lg:border-0 lg:bg-transparent lg:p-0 lg:backdrop-blur-none"
        >
          <div class="relative">
            <input
              type="search"
              id="blog-search"
              name="blog-search"
              aria-label="Search blog articles"
              placeholder="Search articles"
              class="h-12 w-full rounded-lg border border-gray-700/80 bg-gray-950/60 pr-11 pl-4 text-base text-white placeholder-gray-500 focus:border-blue-400 focus:ring-2 focus:ring-blue-400/20 focus:outline-none"
            />
            <svg
              aria-hidden="true"
              class="pointer-events-none absolute top-1/2 right-4 h-5 w-5 -translate-y-1/2 text-gray-400"
              fill="none"
              viewBox="0 0 24 24"
              stroke="currentColor"
            >
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"></path>
            </svg>
          </div>

          <div class="relative mt-4 lg:hidden">
            <label for="blog-category-select" class="sr-only">Filter articles by category</label>
            <select
              id="blog-category-select"
              name="blog-category-select"
              aria-label="Filter articles by category"
              class="h-12 w-full appearance-none rounded-lg border border-gray-700/80 bg-gray-950/70 px-4 pr-10 text-base text-white focus:border-blue-400 focus:ring-2 focus:ring-blue-400/20 focus:outline-none"
            >
              <option value={getRelativeLocaleUrl(Astro.locals.locale, `blog`)} selected={!currentCategory}>All articles ({categorySourcePosts.length})</option>
              {
                categories.map(([category, count]) => {
                  const categorySlug = slugify(category)

                  return (
                    <option value={getRelativeLocaleUrl(Astro.locals.locale, `blog/category/${categorySlug}`)} selected={categorySlug === currentCategorySlug}>
                      {category} ({count})
                    </option>
                  )
                })
              }
            </select>
            <svg
              aria-hidden="true"
              class="pointer-events-none absolute top-1/2 right-4 h-4 w-4 -translate-y-1/2 text-gray-300"
              fill="none"
              viewBox="0 0 24 24"
              stroke="currentColor"
            >
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"></path>
            </svg>
          </div>

          <nav class="mt-4 hidden min-h-0 flex-1 space-y-1 overflow-y-auto rounded-lg border border-gray-800 bg-gray-950/40 p-2 lg:block" aria-label="Blog categories">
            <a
              href={getRelativeLocaleUrl(Astro.locals.locale, `blog`)}
              class:list={[
                'flex items-center justify-between gap-3 rounded-md px-3 py-2 text-sm font-semibold focus-visible:ring-2 focus-visible:ring-blue-400/30 focus-visible:outline-none',
                !currentCategory ? 'bg-blue-500/15 text-white' : 'text-gray-300 hover:bg-gray-900/80 hover:text-white',
              ]}
              aria-current={!currentCategory ? 'page' : undefined}
            >
              <span>All articles</span>
              <span class="text-xs text-gray-400 tabular-nums">{categorySourcePosts.length}</span>
            </a>
            {
              categories.map(([category, count]) => {
                const categorySlug = slugify(category)
                const isActive = categorySlug === currentCategorySlug

                return (
                  <a
                    href={getRelativeLocaleUrl(Astro.locals.locale, `blog/category/${categorySlug}`)}
                    class:list={[
                      'flex items-center justify-between gap-3 rounded-md px-3 py-2 text-sm font-semibold focus-visible:ring-2 focus-visible:ring-blue-400/30 focus-visible:outline-none',
                      isActive ? 'bg-blue-500/15 text-white' : 'text-gray-300 hover:bg-gray-900/80 hover:text-white',
                    ]}
                    aria-current={isActive ? 'page' : undefined}
                  >
                    <span>{category}</span>
                    <span class="text-xs text-gray-400 tabular-nums">{count}</span>
                  </a>
                )
              })
            }
          </nav>
        </aside>

        <main class="min-w-0">
          <div id="blog-search-results-count" aria-live="polite" aria-atomic="true" class="mb-4 min-h-5 text-sm text-gray-400"></div>
          <div id="blog-grid" class="grid w-full grid-cols-1 gap-2 md:grid-cols-2 xl:grid-cols-3">
            {
              posts.map((j, i) => (
                <div data-blog-card data-search={`${j.data.title} ${j.data.tag}`.toLowerCase()}>
                  <Blog tag={j.data.tag} link={j.data.slug} title={j.data.title} date={j.data.created_at} image={j.data.head_image} loading={i < 3 ? 'eager' : 'lazy'} />
                </div>
              ))
            }
          </div>
          <p id="blog-empty-state" class="hidden rounded-lg border border-gray-800 bg-gray-950/40 px-5 py-6 text-gray-300">No articles match your search.</p>
        </main>
      </div>
    </div>
  </div>
  <script>
    document.addEventListener('DOMContentLoaded', () => {
      const searchInput = document.getElementById('blog-search') as HTMLInputElement | null
      const categorySelect = document.getElementById('blog-category-select') as HTMLSelectElement | null
      const cards = Array.from(document.querySelectorAll('[data-blog-card]')) as HTMLElement[]
      const resultsCount = document.getElementById('blog-search-results-count')
      const emptyState = document.getElementById('blog-empty-state')
      const totalPosts = cards.length

      function filterPosts() {
        const searchTerm = searchInput?.value.toLowerCase().trim() ?? ''
        let visibleCount = 0

        cards.forEach((card) => {
          const matches = searchTerm === '' || (card.dataset.search ?? '').includes(searchTerm)
          card.hidden = !matches
          if (matches) visibleCount++
        })

        if (resultsCount) {
          resultsCount.textContent = searchTerm ? `Showing ${visibleCount} of ${totalPosts} articles` : ''
        }
        emptyState?.classList.toggle('hidden', visibleCount > 0)
      }

      searchInput?.addEventListener('input', filterPosts)
      categorySelect?.addEventListener('change', () => {
        if (categorySelect.value) window.location.href = categorySelect.value
      })
    })
  </script>
</Layout>
