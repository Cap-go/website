---
import type { ProductTestimonial } from '@/config/productTestimonials'

interface Props {
  eyebrow?: string
  title: string
  description?: string
  testimonials: ProductTestimonial[]
  variant?: 'dark' | 'light' | 'native'
}

const { eyebrow = 'Customer proof', title, description, testimonials, variant = 'dark' } = Astro.props
const visibleTestimonials = testimonials.slice(0, 3)

const isLight = variant === 'light'
const sectionClass =
  variant === 'light'
    ? 'border-y border-slate-200 bg-white text-slate-950'
    : variant === 'native'
      ? 'border-y border-white/10 bg-[#070d18] text-white'
      : 'border-y border-white/10 bg-slate-950 text-white'
const eyebrowClass = isLight ? 'text-blue-700' : 'text-cyan-300'
const titleClass = isLight ? 'text-slate-950' : 'text-white'
const descriptionClass = isLight ? 'text-slate-600' : 'text-slate-300'
const cardClass = isLight ? 'border-slate-200 bg-slate-50 shadow-sm' : 'border-white/10 bg-white/[0.04] shadow-2xl shadow-black/20'
const quoteClass = isLight ? 'text-slate-700' : 'text-slate-200'
const roleClass = isLight ? 'text-slate-500' : 'text-slate-400'
const starActiveClass = isLight ? 'text-amber-500' : 'text-amber-300'
const starMutedClass = isLight ? 'text-slate-300' : 'text-slate-700'
const gridClass = visibleTestimonials.length === 1 ? 'max-w-3xl' : visibleTestimonials.length === 2 ? 'max-w-5xl md:grid-cols-2' : 'lg:grid-cols-3'
---

{
  visibleTestimonials.length > 0 && (
    <section id="product-testimonials" class:list={['scroll-mt-20 py-16 sm:py-20', sectionClass]}>
      <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
        <div class="max-w-3xl">
          <p class:list={['font-mono text-sm font-semibold tracking-wide uppercase', eyebrowClass]}>{eyebrow}</p>
          <h2 class:list={['mt-3 text-3xl font-semibold tracking-tight text-balance sm:text-4xl', titleClass]}>{title}</h2>
          {description && <p class:list={['mt-5 text-base leading-7 text-pretty', descriptionClass]}>{description}</p>}
        </div>

        <div class:list={['mt-10 grid gap-4', gridClass]}>
          {visibleTestimonials.map((item) => (
            <article class:list={['flex min-h-full flex-col rounded-lg border p-5', cardClass]}>
              <div class="flex items-start justify-between gap-4">
                <div class="flex min-w-0 items-center gap-3">
                  <img
                    src={item.avatar}
                    alt={`Portrait of ${item.name}`}
                    width="48"
                    height="48"
                    loading="eager"
                    decoding="async"
                    class="h-12 w-12 shrink-0 rounded-lg object-cover outline-1 -outline-offset-1 outline-white/10"
                  />
                  <div class="min-w-0">
                    <h3 class:list={['text-sm font-semibold', titleClass]}>{item.name}</h3>
                    <p class:list={['mt-1 text-xs leading-5', roleClass]}>{item.role}</p>
                  </div>
                </div>
                <div class="flex shrink-0 gap-0.5" role="img" aria-label={`${item.rating} out of 5 stars`}>
                  {Array.from({ length: 5 }).map((_, index) => (
                    <svg class:list={['h-4 w-4', index < item.rating ? starActiveClass : starMutedClass]} viewBox="0 0 20 20" fill="currentColor" aria-hidden="true">
                      <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 0 0 .95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 0 0-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 0 0-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 0 0-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 0 0 .951-.69l1.07-3.292Z" />
                    </svg>
                  ))}
                </div>
              </div>

              <blockquote class="mt-5 flex-1">
                <p class:list={['text-sm leading-6', quoteClass]}>&ldquo;{item.quote}&rdquo;</p>
              </blockquote>
            </article>
          ))}
        </div>
      </div>
    </section>
  )
}
