---
import { solutionAppExamples, type SolutionAppExampleKey } from '@/config/solutionAppExamples'
import { findStoreTopApp, plainStoreSummary } from '@/services/storeTop'
import { renameCat, shortNumber } from '@/services/misc'

interface Props {
  solution: SolutionAppExampleKey
}

const { solution } = Astro.props
const example = solutionAppExamples[solution]
const app = example ? await findStoreTopApp(Astro.locals.runtimeConfig.public.baseApiUrl, example.appId) : null
const summary = app ? plainStoreSummary(app.summary) : ''
const category = app ? renameCat(app.category) : ''
const installs = app && Number.isFinite(app.installs) ? `${shortNumber(app.installs)} store installs` : ''
---

{
  app && (
    <section class="border-y border-white/10 bg-slate-950 py-16 sm:py-20">
      <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
        <div class="grid gap-8 lg:grid-cols-[0.85fr_1.15fr] lg:items-stretch">
          <div class="flex flex-col justify-center">
            <p class="font-mono text-sm font-semibold tracking-wide text-blue-300 uppercase">Real app example</p>
            <h2 class="mt-3 max-w-[16ch] text-3xl font-semibold tracking-tight text-balance text-white sm:text-4xl">{example.headline}</h2>
            <p class="mt-5 max-w-[64ch] text-base leading-7 text-pretty text-slate-300">{example.useCase}</p>
            <dl class="mt-8 grid gap-4 sm:grid-cols-3">
              <div>
                <dt class="font-mono text-sm font-semibold tracking-wide text-slate-500 uppercase">Example type</dt>
                <dd class="mt-2 text-base font-medium text-white">{example.label}</dd>
              </div>
              <div>
                <dt class="font-mono text-sm font-semibold tracking-wide text-slate-500 uppercase">Store category</dt>
                <dd class="mt-2 text-base font-medium text-white">{category}</dd>
              </div>
              <div>
                <dt class="font-mono text-sm font-semibold tracking-wide text-slate-500 uppercase">Source</dt>
                <dd class="mt-2 text-base font-medium text-white">Capacitor app dataset</dd>
              </div>
            </dl>
          </div>

          <article class="rounded-lg border border-white/10 bg-white/[0.04] p-5 shadow-2xl shadow-black/20 sm:p-6">
            <div class="flex flex-col gap-5 sm:flex-row sm:items-start">
              <img
                class="h-20 w-20 rounded-lg object-cover outline-1 -outline-offset-1 outline-white/10"
                src={app.icon}
                alt=""
                width="80"
                height="80"
                loading="lazy"
                decoding="async"
              />
              <div class="min-w-0 flex-1">
                <div class="flex flex-wrap gap-2">
                  <span class="rounded-full border border-blue-400/30 bg-blue-500/10 px-3 py-1 text-sm font-medium text-blue-200">Public store listing</span>
                  {installs && <span class="rounded-full border border-white/10 bg-white/5 px-3 py-1 text-sm font-medium text-slate-300">{installs}</span>}
                </div>
                <h3 class="mt-4 text-2xl font-semibold tracking-tight text-balance text-white">{app.title}</h3>
                <p class="mt-3 text-base leading-7 text-pretty text-slate-300">{summary}</p>
                <a
                  href={app.url}
                  target="_blank"
                  rel="noopener noreferrer"
                  class="mt-5 inline-flex items-center gap-2 text-base font-semibold text-blue-300 transition-colors hover:text-blue-200 focus-visible:outline-2 focus-visible:outline-offset-4 focus-visible:outline-blue-400"
                >
                  View Google Play listing
                  <svg class="h-5 w-5" viewBox="0 0 20 20" fill="currentColor" aria-hidden="true">
                    <path
                      fill-rule="evenodd"
                      d="M5.22 14.78a.75.75 0 0 1 0-1.06L12.94 6H8.75a.75.75 0 0 1 0-1.5h6a.75.75 0 0 1 .75.75v6a.75.75 0 0 1-1.5 0V7.06l-7.72 7.72a.75.75 0 0 1-1.06 0Z"
                      clip-rule="evenodd"
                    />
                  </svg>
                </a>
              </div>
            </div>

            <div class="mt-6 divide-y divide-white/10 border-t border-white/10">
              {example.plays.map((play) => (
                <div class="grid gap-3 py-4 sm:grid-cols-[auto_1fr] sm:items-start">
                  <span class="mt-1 flex h-6 w-6 items-center justify-center rounded-full bg-blue-500/15 text-sm font-semibold text-blue-200 ring-1 ring-blue-400/20">+</span>
                  <p class="text-base leading-7 text-slate-200">{play}</p>
                </div>
              ))}
            </div>

            <p class="mt-2 text-sm leading-6 text-slate-500">Public app store data is used as an example only. This is not a Capgo customer claim.</p>
          </article>
        </div>
      </div>
    </section>
  )
}
