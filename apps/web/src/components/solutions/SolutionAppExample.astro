---
import m, { type MessageKey, type MessageValues } from '@/copy/messages'
import { solutionAppExamples, type SolutionAppExampleKey } from '@/config/solutionAppExamples'
import { solutionStoreApps } from '@/config/solutionStoreApps'
import { renameCat, shortNumber } from '@/services/misc'
import { getRelativeLocaleUrl } from '@/services/links'
import TeamAvatars from '@/components/TeamAvatars.astro'

interface Props {
  solution: SolutionAppExampleKey
  randomize?: boolean
}

const { solution, randomize = false } = Astro.props
const locale = Astro.locals.locale
const example = solutionAppExamples[solution]
const copy = (key: MessageKey, values?: MessageValues) => m[key](values, { locale })
const appExamples = example.apps.map((appReference) => ({
  ...appReference,
  app: solutionStoreApps[appReference.appId],
  note: copy(appReference.noteKey),
}))
const plays = example.playKeys.map((playKey) => copy(playKey))
const categories = [...new Set(appExamples.map(({ app }) => renameCat(app.category)).filter(Boolean))].slice(0, 3).join(', ')
const registerUrl = getRelativeLocaleUrl(locale, 'register')
const talkToTeamUrl = 'https://book.capgo.app/enterprise-inquiry/'
const showExampleCtas = solution === 'enterprise'
---

{
  appExamples.length > 0 && (
    <section id="real-app-examples" class="border-y border-white/10 bg-[#030712] py-14 sm:py-16 lg:py-20">
      <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
        <div class="mb-8 grid gap-6 lg:mb-10 lg:grid-cols-[minmax(0,1fr)_26rem] lg:items-end">
          <div>
            <p class="inline-flex rounded-full border border-cyan-300/25 bg-cyan-300/10 px-3 py-1 text-xs font-semibold tracking-wide text-cyan-200 uppercase">
              {copy('solution_app_examples_eyebrow')}
            </p>
            <h2 class="mt-4 max-w-2xl text-3xl leading-tight font-semibold tracking-tight text-balance text-white sm:text-4xl">{copy(example.headlineKey)}</h2>
            <p class="mt-4 max-w-3xl text-base leading-7 text-pretty text-slate-300 sm:text-lg">{copy(example.useCaseKey)}</p>
            {showExampleCtas && (
              <div class="mt-6 flex flex-col gap-3 sm:flex-row">
                <a
                  href={registerUrl}
                  class="inline-flex min-h-11 items-center justify-center gap-2 rounded-lg bg-cyan-300 px-5 py-3 text-sm font-bold text-slate-950 shadow-lg shadow-cyan-950/30 transition hover:bg-cyan-200 focus-visible:outline-2 focus-visible:outline-offset-4 focus-visible:outline-cyan-300"
                >
                  {copy('solutions_get_started')}
                  <svg class="h-4 w-4" viewBox="0 0 20 20" fill="currentColor" aria-hidden="true">
                    <path
                      fill-rule="evenodd"
                      d="M5.22 14.78a.75.75 0 0 1 0-1.06L12.94 6H8.75a.75.75 0 0 1 0-1.5h6a.75.75 0 0 1 .75.75v6a.75.75 0 0 1-1.5 0V7.06l-7.72 7.72a.75.75 0 0 1-1.06 0Z"
                      clip-rule="evenodd"
                    />
                  </svg>
                </a>
                <a
                  href={talkToTeamUrl}
                  target="_blank"
                  rel="noopener noreferrer"
                  aria-label={copy('solutions_talk_to_team')}
                  class="inline-flex min-h-11 items-center justify-center gap-2 rounded-lg border border-white/10 bg-white px-5 py-3 text-sm font-bold text-gray-950 transition-colors hover:bg-blue-50 hover:text-blue-700 focus-visible:outline-2 focus-visible:outline-offset-4 focus-visible:outline-white"
                >
                  <TeamAvatars />
                  <span>{copy('solutions_talk_to_team')}</span>
                </a>
              </div>
            )}
          </div>

          <dl class="grid grid-cols-1 overflow-hidden rounded-lg border border-white/10 bg-white/[0.035] text-center shadow-2xl shadow-black/20 sm:grid-cols-3">
            <div class="border-b border-white/10 p-4 sm:border-r sm:border-b-0">
              <dt class="font-mono text-[0.68rem] font-semibold tracking-wide text-slate-500 uppercase">{copy('solution_app_examples_example_type')}</dt>
              <dd class="mt-2 text-sm font-semibold text-white">{copy(example.labelKey)}</dd>
            </div>
            <div class="border-b border-white/10 p-4 sm:border-r sm:border-b-0">
              <dt class="font-mono text-[0.68rem] font-semibold tracking-wide text-slate-500 uppercase">{copy('solution_app_examples_store_categories')}</dt>
              <dd class="mt-2 text-sm font-semibold text-pretty text-white">{categories}</dd>
            </div>
            <div class="p-4">
              <dt class="font-mono text-[0.68rem] font-semibold tracking-wide text-slate-500 uppercase">{copy('solution_app_examples_source')}</dt>
              <dd class="mt-2 text-sm font-semibold text-white">{copy('solution_app_examples_public_store_dataset')}</dd>
            </div>
          </dl>
        </div>

        <div class="grid gap-5 lg:grid-cols-[minmax(0,1fr)_26rem] lg:items-start">
          <div
            class="order-1 space-y-3 lg:order-1"
            data-randomize-app-examples={randomize ? 'true' : undefined}
            aria-live={randomize ? 'polite' : undefined}
            aria-atomic={randomize ? 'true' : undefined}
          >
            {appExamples.map(({ app, note }) => (
              <article class="group rounded-lg border border-white/10 bg-white/[0.04] p-4 shadow-2xl shadow-black/15 transition-colors duration-200 hover:border-cyan-300/35 hover:bg-white/[0.06]">
                <div class="grid gap-4 sm:grid-cols-[auto_minmax(0,1fr)_9.5rem] sm:items-start">
                  <img
                    class="h-14 w-14 shrink-0 rounded-lg object-cover outline-1 -outline-offset-1 outline-white/10"
                    src={app.icon}
                    alt={copy('solution_app_examples_icon_alt', { title: app.title })}
                    width="56"
                    height="56"
                    loading="lazy"
                    decoding="async"
                  />

                  <div class="min-w-0">
                    <p class="truncate text-xs font-semibold tracking-wide text-cyan-200 uppercase">{renameCat(app.category)}</p>
                    <h3 class="mt-1 text-base leading-6 font-semibold tracking-tight break-words text-white">{app.title}</h3>
                    <p class="mt-2 text-sm leading-6 text-pretty text-slate-300">{note}</p>
                  </div>

                  <div class="grid grid-cols-2 gap-2 text-sm sm:grid-cols-1">
                    <span class="rounded-md border border-emerald-400/20 bg-emerald-400/10 px-3 py-2 font-medium text-emerald-100">
                      {copy('solution_app_examples_installs', { count: shortNumber(app.installs) })}
                    </span>
                    <span class="rounded-md border border-amber-300/20 bg-amber-300/10 px-3 py-2 font-medium text-amber-100">
                      {copy('solution_app_examples_rating', { score: app.score.toFixed(1) })}
                    </span>
                  </div>
                </div>

                <a
                  href={app.url}
                  target="_blank"
                  rel="noopener noreferrer"
                  class="mt-4 inline-flex min-h-11 w-full items-center justify-center gap-2 rounded-lg border border-white/10 px-3 py-2 text-sm font-semibold text-cyan-200 transition-colors hover:border-cyan-300/40 hover:bg-cyan-300/10 hover:text-cyan-100 focus-visible:outline-2 focus-visible:outline-offset-4 focus-visible:outline-cyan-400 sm:w-fit sm:px-4"
                >
                  <span>{copy('solution_app_examples_view_listing')}</span>
                  <svg class="h-4 w-4 shrink-0" viewBox="0 0 20 20" fill="currentColor" aria-hidden="true">
                    <path
                      fill-rule="evenodd"
                      d="M5.22 14.78a.75.75 0 0 1 0-1.06L12.94 6H8.75a.75.75 0 0 1 0-1.5h6a.75.75 0 0 1 .75.75v6a.75.75 0 0 1-1.5 0V7.06l-7.72 7.72a.75.75 0 0 1-1.06 0Z"
                      clip-rule="evenodd"
                    />
                  </svg>
                </a>
              </article>
            ))}
          </div>

          <aside
            id="app-examples-cta"
            class="order-2 flex flex-col justify-between rounded-lg border border-cyan-300/20 bg-[linear-gradient(145deg,rgba(34,211,238,0.14),rgba(37,99,235,0.09)_48%,rgba(16,185,129,0.12))] p-6 shadow-2xl ring-1 shadow-cyan-950/25 ring-white/5 lg:order-2"
          >
            <div>
              <p class="font-mono text-xs font-semibold tracking-wide text-cyan-200 uppercase">{copy('solution_app_examples_cta_kicker')}</p>
              <h3 class="mt-3 text-2xl leading-8 font-semibold tracking-tight text-balance text-white">{copy('solution_app_examples_cta_title')}</h3>
              <p class="mt-4 text-base leading-7 text-pretty text-slate-300">{copy('solution_app_examples_cta_text')}</p>

              <div class="mt-6 space-y-3 border-y border-white/10 py-5">
                {plays.map((play) => (
                  <div class="grid grid-cols-[auto_1fr] gap-3 text-sm leading-6 text-slate-200">
                    <span class="mt-1 flex h-5 w-5 items-center justify-center rounded-full bg-emerald-400/15 text-emerald-200 ring-1 ring-emerald-300/25">
                      <svg class="h-3.5 w-3.5" viewBox="0 0 20 20" fill="currentColor" aria-hidden="true">
                        <path
                          fill-rule="evenodd"
                          d="M16.704 4.153a.75.75 0 0 1 .143 1.052l-8 10.5a.75.75 0 0 1-1.127.075l-4.5-4.5a.75.75 0 0 1 1.06-1.06l3.894 3.893 7.48-9.817a.75.75 0 0 1 1.05-.143Z"
                          clip-rule="evenodd"
                        />
                      </svg>
                    </span>
                    <span>{play}</span>
                  </div>
                ))}
              </div>
            </div>

            <div class="mt-6">
              <a
                href={getRelativeLocaleUrl(locale, 'register')}
                class="inline-flex min-h-12 w-full items-center justify-center rounded-lg bg-cyan-300 px-5 py-3 text-sm font-bold text-slate-950 shadow-lg shadow-cyan-950/30 transition hover:bg-cyan-200 focus-visible:outline-2 focus-visible:outline-offset-4 focus-visible:outline-cyan-300"
              >
                {copy('solution_app_examples_cta_button')}
              </a>
              <p class="mt-4 text-xs leading-5 text-slate-400">{copy('solution_app_examples_disclaimer')}</p>
            </div>
          </aside>
        </div>
      </div>
    </section>
  )
}

<script is:inline>
  for (const list of document.querySelectorAll('[data-randomize-app-examples="true"]')) {
    list.setAttribute('aria-busy', 'true')
    const cards = Array.from(list.children)

    for (let index = cards.length - 1; index > 0; index -= 1) {
      const swapIndex = Math.floor(Math.random() * (index + 1))
      const current = cards[index]
      cards[index] = cards[swapIndex]
      cards[swapIndex] = current
    }

    for (const card of cards) list.append(card)
    list.removeAttribute('aria-busy')
  }
</script>
