---
import m, { type MessageKey, type MessageValues } from '@/copy/messages'
import { solutionAppExamples, type SolutionAppExampleKey } from '@/config/solutionAppExamples'
import { solutionStoreApps } from '@/config/solutionStoreApps'
import { renameCat, shortNumber } from '@/services/misc'
import { getRelativeLocaleUrl } from 'astro:i18n'

interface Props {
  solution: SolutionAppExampleKey
  randomize?: boolean
}

const { solution, randomize = false } = Astro.props
const locale = Astro.locals.locale
const example = solutionAppExamples[solution]
const copy = (key: MessageKey, values?: MessageValues) => m[key](values, { locale })
const appExamples = example.apps.map((appReference) => ({
  ...appReference,
  app: solutionStoreApps[appReference.appId],
  note: copy(appReference.noteKey),
}))
const plays = example.playKeys.map((playKey) => copy(playKey))
const categories = [...new Set(appExamples.map(({ app }) => renameCat(app.category)).filter(Boolean))].slice(0, 3).join(', ')
---

{
  appExamples.length > 0 && (
    <section id="real-app-examples" class="border-y border-white/10 bg-slate-950 py-16 sm:py-20">
      <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
        <div class="grid gap-10 lg:grid-cols-[0.8fr_1.2fr] lg:items-start">
          <div class="lg:sticky lg:top-24">
            <p class="font-mono text-sm font-semibold tracking-wide text-cyan-300 uppercase">{copy('solution_app_examples_eyebrow')}</p>
            <h2 class="mt-3 max-w-[18ch] text-3xl font-semibold tracking-tight text-balance text-white sm:text-4xl">{copy(example.headlineKey)}</h2>
            <p class="mt-5 max-w-[64ch] text-base leading-7 text-pretty text-slate-300">{copy(example.useCaseKey)}</p>
            <dl class="mt-8 grid gap-4 sm:grid-cols-3 lg:grid-cols-1 xl:grid-cols-3">
              <div>
                <dt class="font-mono text-sm font-semibold tracking-wide text-slate-500 uppercase">{copy('solution_app_examples_example_type')}</dt>
                <dd class="mt-2 text-base font-medium text-white">{copy(example.labelKey)}</dd>
              </div>
              <div>
                <dt class="font-mono text-sm font-semibold tracking-wide text-slate-500 uppercase">{copy('solution_app_examples_store_categories')}</dt>
                <dd class="mt-2 text-base font-medium text-white">{categories}</dd>
              </div>
              <div>
                <dt class="font-mono text-sm font-semibold tracking-wide text-slate-500 uppercase">{copy('solution_app_examples_source')}</dt>
                <dd class="mt-2 text-base font-medium text-white">{copy('solution_app_examples_public_store_dataset')}</dd>
              </div>
            </dl>

            <div class="mt-8 divide-y divide-white/10 border-y border-white/10">
              {plays.map((play) => (
                <div class="grid gap-3 py-4 sm:grid-cols-[auto_1fr] sm:items-start">
                  <span class="mt-1 flex h-6 w-6 items-center justify-center rounded-full bg-emerald-500/15 text-sm font-semibold text-emerald-200 ring-1 ring-emerald-400/20">
                    +
                  </span>
                  <p class="text-base leading-7 text-slate-200">{play}</p>
                </div>
              ))}
            </div>

            <div id="app-examples-cta" class="mt-8 rounded-lg border border-cyan-300/20 bg-cyan-300/10 p-5">
              <h3 class="text-lg leading-6 font-semibold tracking-tight text-white">{copy('solution_app_examples_cta_title')}</h3>
              <p class="mt-3 text-sm leading-6 text-slate-300">{copy('solution_app_examples_cta_text')}</p>
              <a
                href={getRelativeLocaleUrl(locale, 'register')}
                class="mt-5 inline-flex min-h-11 items-center justify-center rounded-lg bg-cyan-400 px-5 py-3 text-sm font-semibold text-slate-950 shadow-lg shadow-cyan-950/30 transition hover:bg-cyan-300 focus-visible:outline-2 focus-visible:outline-offset-4 focus-visible:outline-cyan-300"
              >
                {copy('solution_app_examples_cta_button')}
              </a>
            </div>
          </div>

          <div class="grid gap-4 md:grid-cols-3" data-randomize-app-examples={randomize ? 'true' : undefined}>
            {appExamples.map(({ app, note }) => (
              <article class="flex min-h-full flex-col rounded-lg border border-white/10 bg-white/[0.04] p-5 shadow-2xl shadow-black/20">
                <div class="flex items-start gap-4">
                  <img
                    class="h-16 w-16 shrink-0 rounded-lg object-cover outline-1 -outline-offset-1 outline-white/10"
                    src={app.icon}
                    alt={copy('solution_app_examples_icon_alt', { title: app.title })}
                    width="64"
                    height="64"
                    loading="lazy"
                    decoding="async"
                  />
                  <div class="min-w-0 flex-1">
                    <p class="truncate text-sm font-medium text-cyan-200">{renameCat(app.category)}</p>
                    <h3 class="mt-1 text-lg leading-6 font-semibold tracking-tight break-words text-white">{app.title}</h3>
                  </div>
                </div>

                <div class="mt-5 flex flex-wrap gap-2">
                  <span class="rounded-full border border-emerald-400/25 bg-emerald-500/10 px-3 py-1 text-sm font-medium text-emerald-100">
                    {copy('solution_app_examples_installs', { count: shortNumber(app.installs) })}
                  </span>
                  <span class="rounded-full border border-amber-300/25 bg-amber-400/10 px-3 py-1 text-sm font-medium text-amber-100">
                    {copy('solution_app_examples_rating', { score: app.score.toFixed(1) })}
                  </span>
                </div>

                <p class="mt-4 grow text-sm leading-6 text-pretty text-slate-300">{note}</p>

                <a
                  href={app.url}
                  target="_blank"
                  rel="noopener noreferrer"
                  class="mt-5 inline-flex w-fit items-center gap-2 text-sm font-semibold text-cyan-300 transition-colors hover:text-cyan-200 focus-visible:outline-2 focus-visible:outline-offset-4 focus-visible:outline-cyan-400"
                >
                  {copy('solution_app_examples_view_listing')}
                  <svg class="h-4 w-4" viewBox="0 0 20 20" fill="currentColor" aria-hidden="true">
                    <path
                      fill-rule="evenodd"
                      d="M5.22 14.78a.75.75 0 0 1 0-1.06L12.94 6H8.75a.75.75 0 0 1 0-1.5h6a.75.75 0 0 1 .75.75v6a.75.75 0 0 1-1.5 0V7.06l-7.72 7.72a.75.75 0 0 1-1.06 0Z"
                      clip-rule="evenodd"
                    />
                  </svg>
                </a>
              </article>
            ))}
          </div>
        </div>

        <p class="mt-8 text-sm leading-6 text-slate-500">{copy('solution_app_examples_disclaimer')}</p>
      </div>
    </section>
  )
}

<script is:inline>
  for (const list of document.querySelectorAll('[data-randomize-app-examples="true"]')) {
    const cards = Array.from(list.children)

    for (let index = cards.length - 1; index > 0; index -= 1) {
      const swapIndex = Math.floor(Math.random() * (index + 1))
      const current = cards[index]
      cards[index] = cards[swapIndex]
      cards[swapIndex] = current
    }

    for (const card of cards) list.append(card)
  }
</script>
