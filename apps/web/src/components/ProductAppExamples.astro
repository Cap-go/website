---
import { solutionStoreApps, type SolutionStoreAppId } from '@/config/solutionStoreApps'
import { renameCat, shortNumber } from '@/services/misc'

interface Props {
  eyebrow?: string
  title: string
  description: string
  appIds?: SolutionStoreAppId[]
}

const { eyebrow = 'Apps built with Capacitor', title, description, appIds = ['com.windyty.android', 'com.studysmarter', 'org.lichess.mobileapp'] } = Astro.props

const apps = appIds.map((appId) => solutionStoreApps[appId])
---

<section class="border-y border-white/10 bg-slate-950 py-16 sm:py-20">
  <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
    <div class="max-w-3xl">
      <p class="font-mono text-sm font-semibold tracking-wide text-cyan-300 uppercase">{eyebrow}</p>
      <h2 class="mt-3 text-3xl font-semibold tracking-tight text-balance text-white sm:text-4xl">{title}</h2>
      <p class="mt-5 text-base leading-7 text-pretty text-slate-300">{description}</p>
      <p class="mt-6 text-sm leading-6 text-slate-500">Apps shown are sourced from a public store app dataset used across the website.</p>
    </div>

    <div class="mt-10 grid gap-4 md:grid-cols-3">
      {
        apps.map((app) => (
          <article class="flex min-h-full flex-col rounded-lg border border-white/10 bg-white/[0.04] p-5 shadow-2xl shadow-black/20">
            <div class="flex items-start gap-4">
              <img
                class="h-16 w-16 shrink-0 rounded-lg object-cover outline-1 -outline-offset-1 outline-white/10"
                src={app.icon}
                alt={`${app.title} app icon`}
                width="64"
                height="64"
                loading="eager"
                decoding="async"
              />
              <div class="min-w-0 flex-1">
                <p class="truncate text-sm font-medium text-cyan-200">{renameCat(app.category)}</p>
                <h3 class="mt-1 text-lg leading-6 font-semibold tracking-tight break-words text-white">{app.title}</h3>
              </div>
            </div>

            <div class="mt-5 flex flex-wrap gap-2">
              <span class="rounded-full border border-emerald-400/25 bg-emerald-500/10 px-3 py-1 text-sm font-medium text-emerald-100">{shortNumber(app.installs)} installs</span>
              <span class="rounded-full border border-amber-300/25 bg-amber-400/10 px-3 py-1 text-sm font-medium text-amber-100">{app.score.toFixed(1)} rating</span>
            </div>

            <a
              href={app.url}
              target="_blank"
              rel="noopener noreferrer"
              class="mt-5 inline-flex w-fit items-center gap-2 text-sm font-semibold text-cyan-300 transition-colors hover:text-cyan-200 focus-visible:outline-2 focus-visible:outline-offset-4 focus-visible:outline-cyan-400"
            >
              View store listing
              <svg class="h-4 w-4" viewBox="0 0 20 20" fill="currentColor" aria-hidden="true">
                <path
                  fill-rule="evenodd"
                  d="M5.22 14.78a.75.75 0 0 1 0-1.06L12.94 6H8.75a.75.75 0 0 1 0-1.5h6a.75.75 0 0 1 .75.75v6a.75.75 0 0 1-1.5 0V7.06l-7.72 7.72a.75.75 0 0 1-1.06 0Z"
                  clip-rule="evenodd"
                />
              </svg>
            </a>
          </article>
        ))
      }
    </div>
  </div>
</section>
