---
import m from '@/copy/messages'
import { getRelativeLocaleUrl } from 'astro:i18n'

const locale = Astro.locals.locale

const demos = [
  {
    title: m.landing_product_demos_cli_title({}, { locale }),
    description: m.landing_product_demos_cli_desc({}, { locale }),
    src: '/landing-demos/cli-live-update.webp',
    href: getRelativeLocaleUrl(locale, 'docs/getting-started/deploy'),
  },
  {
    title: m.landing_product_demos_live_title({}, { locale }),
    description: m.landing_product_demos_live_desc({}, { locale }),
    src: '/landing-demos/live-update-dashboard.webp',
    href: getRelativeLocaleUrl(locale, 'live-update'),
  },
  {
    title: m.landing_product_demos_teams_title({}, { locale }),
    description: m.landing_product_demos_teams_desc({}, { locale }),
    src: '/landing-demos/team-orgs.webp',
    href: getRelativeLocaleUrl(locale, 'docs/webapp/organizations'),
  },
  {
    title: m.landing_product_demos_api_title({}, { locale }),
    description: m.landing_product_demos_api_desc({}, { locale }),
    src: '/landing-demos/api-keys-rbac.webp',
    href: getRelativeLocaleUrl(locale, 'docs/public-api/api-keys'),
  },
]
---

<section class="bg-[#10151f] py-24 sm:py-32">
  <section id="product-demos" class="scroll-mt-16 bg-[#10151f] py-24 sm:py-32">
    <div class="grid gap-12 lg:grid-cols-[0.72fr_1.28fr] lg:items-start">
      <div>
        <p class="font-mono text-sm leading-7 font-semibold text-[#44BCFF] uppercase">{m.landing_product_demos_subtitle({}, { locale })}</p>
        <h2 class="mt-2 text-3xl leading-tight font-bold tracking-tight text-white sm:text-4xl">{m.landing_product_demos_title({}, { locale })}</h2>
        <p class="mt-6 text-lg leading-8 text-gray-300">
          {m.landing_product_demos_description({}, { locale })}
        </p>
      </div>

      <div class="grid gap-4 sm:grid-cols-2">
        {
          demos.map((demo) => (
            <a href={demo.href} class="group overflow-hidden rounded-lg border border-white/10 bg-white/[0.04] transition hover:border-blue-300/40 hover:bg-white/[0.06]">
              <div class="aspect-[16/10] overflow-hidden bg-[#070d18]">
                <img src={demo.src} alt="" loading="lazy" decoding="async" class="h-full w-full object-cover object-top transition duration-300 group-hover:scale-[1.015]" />
              </div>
              <div class="p-5">
                <h3 class="text-base font-semibold text-white">{demo.title}</h3>
                <p class="mt-2 text-sm leading-6 text-gray-400">{demo.description}</p>
              </div>
            </a>
          ))
        }
      </div>
    </div>
  </section>
</section>
