---
import m from '@/copy/messages'
import { getRelativeLocaleUrl } from '@/services/links'

const locale = Astro.locals.locale
const observeUrl = getRelativeLocaleUrl(locale, 'observe')
const logsUrl = getRelativeLocaleUrl(locale, 'docs/webapp/logs')
---

<div class="bg-[#1a1a1a] py-24 sm:py-32">
  <div class="mx-auto max-w-7xl px-6 lg:px-8">
    <div class="mx-auto mb-16 max-w-2xl text-center">
      <h2 class="font-mono text-base leading-7 font-semibold text-[#44BCFF]">{m.landing_monitoring_subtitle({}, { locale })}</h2>
      <p class="mt-2 text-3xl font-bold tracking-tight text-white sm:text-4xl">
        {m.landing_monitoring_title({}, { locale })}
      </p>
      <p class="mt-6 text-lg leading-8 text-gray-400">
        {m.landing_monitoring_description({}, { locale })}
      </p>
    </div>

    <div class="grid grid-cols-1 gap-8 md:grid-cols-3">
      <!-- Card 1: User Population -->
      <div class="flex flex-col rounded-2xl border border-white/10 bg-white/5 p-8">
        <h3 class="mb-2 text-lg font-semibold text-white">
          {m.landing_monitoring_user_pop({}, { locale })}
        </h3>
        <p class="mb-6 text-sm text-gray-400">
          {m.landing_monitoring_user_pop_desc({}, { locale })}
        </p>

        <div class="mt-auto space-y-6">
          <!-- Android -->
          <div>
            <div class="mb-1 flex justify-between text-xs text-gray-400">
              <span>Android</span>
              <span>v 2.0</span>
            </div>
            <div class="flex h-4 w-full overflow-hidden rounded-full bg-white/10">
              <div class="h-full bg-blue-500" style="width: 40%"></div>
              <div class="h-full bg-emerald-500" style="width: 30%"></div>
              <div class="h-full bg-purple-500" style="width: 30%"></div>
            </div>
          </div>

          <!-- Electron -->
          <div>
            <div class="mb-1 flex justify-between text-xs text-gray-400">
              <span>Electron</span>
              <span>v 1.4</span>
            </div>
            <div class="flex h-4 w-full overflow-hidden rounded-full bg-white/10">
              <div class="h-full bg-blue-500" style="width: 35%"></div>
              <div class="h-full bg-emerald-500" style="width: 45%"></div>
              <div class="h-full bg-purple-500" style="width: 20%"></div>
            </div>
          </div>

          <!-- iOS -->
          <div>
            <div class="mb-1 flex justify-between text-xs text-gray-400">
              <span>iOS</span>
              <span>v 2.0</span>
            </div>
            <div class="flex h-4 w-full overflow-hidden rounded-full bg-white/10">
              <div class="h-full bg-blue-500" style="width: 20%"></div>
              <div class="h-full bg-emerald-500" style="width: 50%"></div>
              <div class="h-full bg-purple-500" style="width: 30%"></div>
            </div>
          </div>

          <!-- Legend -->
          <div class="flex gap-4 pt-2 text-xs text-gray-400">
            <div class="flex items-center gap-1">
              <div class="h-2 w-2 rounded-full bg-blue-500"></div>
              <span>1.0</span>
            </div>
            <div class="flex items-center gap-1">
              <div class="h-2 w-2 rounded-full bg-emerald-500"></div>
              <span>1.1</span>
            </div>
            <div class="flex items-center gap-1">
              <div class="h-2 w-2 rounded-full bg-purple-500"></div>
              <span>2.0</span>
            </div>
          </div>
        </div>
      </div>

      <!-- Card 2: Bandwidth & Storage -->
      <div class="flex flex-col rounded-2xl border border-white/10 bg-white/5 p-8">
        <h3 class="mb-2 text-lg font-semibold text-white">
          {m.landing_monitoring_bandwidth({}, { locale })}
        </h3>
        <p class="mb-6 text-sm text-gray-400">
          {m.landing_monitoring_bandwidth_desc({}, { locale })}
        </p>

        <div class="relative mt-auto h-48">
          <!-- Simple SVG Line Chart -->
          <svg class="h-full w-full" viewBox="0 0 100 50" preserveAspectRatio="none">
            <!-- Grid lines -->
            <line x1="0" y1="12.5" x2="100" y2="12.5" stroke="rgba(255,255,255,0.1)" stroke-width="0.5"></line>
            <line x1="0" y1="25" x2="100" y2="25" stroke="rgba(255,255,255,0.1)" stroke-width="0.5"></line>
            <line x1="0" y1="37.5" x2="100" y2="37.5" stroke="rgba(255,255,255,0.1)" stroke-width="0.5"></line>

            <!-- Line 1 (Blue) -->
            <path d="M0,40 C30,35 70,30 100,5" fill="none" stroke="#3b82f6" stroke-width="2"></path>
            <!-- Area 1 -->
            <path d="M0,40 C30,35 70,30 100,5 V50 H0 Z" fill="url(#blueGradient)" opacity="0.2"></path>

            <!-- Line 2 (Green) -->
            <path d="M0,45 C30,42 70,38 100,20" fill="none" stroke="#10b981" stroke-width="2"></path>
            <!-- Area 2 -->
            <path d="M0,45 C30,42 70,38 100,20 V50 H0 Z" fill="url(#greenGradient)" opacity="0.2"></path>

            <defs>
              <linearGradient id="blueGradient" x1="0" y1="0" x2="0" y2="1">
                <stop offset="0%" stop-color="#3b82f6"></stop>
                <stop offset="100%" stop-color="#3b82f6" stop-opacity="0"></stop>
              </linearGradient>
              <linearGradient id="greenGradient" x1="0" y1="0" x2="0" y2="1">
                <stop offset="0%" stop-color="#10b981"></stop>
                <stop offset="100%" stop-color="#10b981" stop-opacity="0"></stop>
              </linearGradient>
            </defs>
          </svg>
        </div>
      </div>

      <!-- Card 3: Update Statistics -->
      <div class="flex flex-col rounded-2xl border border-white/10 bg-white/5 p-8">
        <h3 class="mb-2 text-lg font-semibold text-white">
          {m.landing_monitoring_updates({}, { locale })}
        </h3>
        <p class="mb-6 text-sm text-gray-400">
          {m.landing_monitoring_updates_desc({}, { locale })}
        </p>

        <div class="relative mt-auto flex h-48 items-end justify-between gap-1">
          <!-- Tooltip -->
          <div class="absolute top-10 right-10 z-10 rounded border border-white/10 bg-[#1a1a1a] p-2 text-xs shadow-lg">
            <span class="font-mono text-red-400">Error:</span>
            <span class="text-gray-300">Network connection lost</span>
          </div>

          <!-- Bars -->
          <div class="w-full rounded-t-sm bg-red-500/80" style="height: 30%"></div>
          <div class="w-full rounded-t-sm bg-red-500/80" style="height: 45%"></div>
          <div class="w-full rounded-t-sm bg-red-500/80" style="height: 25%"></div>
          <div class="w-full rounded-t-sm bg-red-500/80" style="height: 60%"></div>
          <div class="w-full rounded-t-sm bg-red-500/80" style="height: 35%"></div>
          <div class="w-full rounded-t-sm bg-red-500/80" style="height: 50%"></div>
          <div class="w-full rounded-t-sm bg-red-500/80" style="height: 40%"></div>
          <div class="w-full rounded-t-sm bg-red-500/80" style="height: 55%"></div>
          <div class="w-full rounded-t-sm bg-red-500/80" style="height: 65%"></div>
          <div class="w-full rounded-t-sm bg-red-500/80" style="height: 20%"></div>
          <div class="w-full rounded-t-sm bg-red-500/80" style="height: 10%"></div>
          <div class="w-full rounded-t-sm bg-red-500/80" style="height: 5%"></div>
          <div class="w-full rounded-t-sm bg-red-500/80" style="height: 5%"></div>
          <div class="w-full rounded-t-sm bg-red-500/80" style="height: 5%"></div>
        </div>
      </div>
    </div>

    <div class="mt-10 flex flex-wrap justify-center gap-3">
      <a
        href={observeUrl}
        class="inline-flex min-h-11 items-center rounded-lg bg-blue-600 px-5 py-3 text-sm font-semibold text-white shadow-lg shadow-blue-600/30 transition-[background-color,box-shadow,transform] focus-visible:ring-2 focus-visible:ring-blue-300 focus-visible:outline-none active:scale-95 [@media(hover:hover)]:hover:bg-blue-700"
      >
        Explore Observe <span class="ml-2" aria-hidden="true">→</span>
      </a>
      <a
        href={logsUrl}
        class="inline-flex min-h-11 items-center rounded-lg border border-white/10 px-5 py-3 text-sm font-semibold text-blue-100 transition-[border-color,color,transform] focus-visible:ring-2 focus-visible:ring-blue-300 focus-visible:outline-none active:scale-95 [@media(hover:hover)]:hover:border-blue-400/60 [@media(hover:hover)]:hover:text-white"
      >
        Explore Logs <span class="ml-2" aria-hidden="true">→</span>
      </a>
    </div>
  </div>
</div>
