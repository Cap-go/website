---
import { getRelativeLocaleUrl } from 'astro:i18n'
import m from '@/copy/messages'

const locale = Astro.locals.locale

const intelligenceCards = [
  {
    title: m.landing_release_intelligence_card_cli_title({}, { locale }),
    text: m.landing_release_intelligence_card_cli_desc({}, { locale }),
  },
  {
    title: m.landing_release_intelligence_card_dashboard_title({}, { locale }),
    text: m.landing_release_intelligence_card_dashboard_desc({}, { locale }),
  },
  {
    title: m.landing_release_intelligence_card_email_title({}, { locale }),
    text: m.landing_release_intelligence_card_email_desc({}, { locale }),
  },
]

const emailMetrics = [
  m.landing_release_intelligence_email_metric1({}, { locale }),
  m.landing_release_intelligence_email_metric2({}, { locale }),
  m.landing_release_intelligence_email_metric3({}, { locale }),
]
---

<section class="bg-[#10151f] py-24 sm:py-32">
  <div class="mx-auto max-w-7xl px-6 lg:px-8">
    <div class="grid gap-12 lg:grid-cols-[0.95fr_1.05fr] lg:items-center">
      <div>
        <p class="font-mono text-sm leading-7 font-semibold text-[#44BCFF] uppercase">
          {m.landing_release_intelligence_subtitle({}, { locale })}
        </p>
        <h2 class="mt-2 text-3xl leading-tight font-bold tracking-tight text-white sm:text-4xl">
          {m.landing_release_intelligence_title({}, { locale })}
        </h2>
        <p class="mt-6 text-lg leading-8 text-gray-300">
          {m.landing_release_intelligence_description({}, { locale })}
        </p>

        <div class="mt-8 grid gap-4 sm:grid-cols-3 lg:grid-cols-1">
          {
            intelligenceCards.map((card) => (
              <article class="rounded-xl border border-white/10 bg-white/[0.04] p-5">
                <h3 class="text-base font-semibold text-white">{card.title}</h3>
                <p class="mt-2 text-sm leading-6 text-gray-400">{card.text}</p>
              </article>
            ))
          }
        </div>

        <div class="mt-8">
          <a
            href={getRelativeLocaleUrl(locale, 'live-update')}
            class="inline-flex min-h-11 items-center justify-center rounded-lg bg-blue-600 px-5 py-3 text-sm font-semibold text-white shadow-lg shadow-blue-950/40 transition hover:bg-blue-500 focus:ring-2 focus:ring-blue-300 focus:outline-none"
          >
            {m.learn_more({}, { locale })}
          </a>
        </div>
      </div>

      <div class="overflow-hidden rounded-2xl border border-white/10 bg-[#171d2a] shadow-2xl shadow-blue-950/30">
        <div class="flex items-center justify-between border-b border-white/10 px-5 py-4">
          <div>
            <p class="text-xs font-semibold tracking-wide text-gray-400 uppercase">release-check</p>
            <p class="mt-1 text-sm font-semibold text-white">production / 2.8.0</p>
          </div>
          <span class="rounded-full border border-amber-300/30 bg-amber-300/10 px-3 py-1 text-xs font-semibold text-amber-100">native review</span>
        </div>

        <div class="grid gap-px bg-white/10 md:grid-cols-[1.1fr_0.9fr]">
          <div class="bg-[#171d2a] p-5">
            <div class="rounded-xl border border-white/10 bg-[#0c111b] p-4 font-mono text-xs leading-6 text-gray-200">
              <p><span class="text-gray-500">$</span> npx @capgo/cli@latest bundle releaseType</p>
              <p class="mt-3 text-amber-300">Result: native</p>
              <p class="text-gray-400">@capacitor/camera changed from 6.1.0 to 6.2.0</p>
              <p class="text-sky-300">Suggested path: ship signed native build first</p>
            </div>

            <div class="mt-5 space-y-3 text-sm">
              <div class="flex items-start gap-3">
                <span class="mt-2 h-2 w-2 shrink-0 rounded-full bg-emerald-400"></span>
                <span class="text-gray-300">OTA bundles keep shipping when native packages match.</span>
              </div>
              <div class="flex items-start gap-3">
                <span class="mt-2 h-2 w-2 shrink-0 rounded-full bg-amber-400"></span>
                <span class="text-gray-300">Potentially breaking bundles get a clear warning before users receive them.</span>
              </div>
              <div class="flex items-start gap-3">
                <span class="mt-2 h-2 w-2 shrink-0 rounded-full bg-sky-400"></span>
                <span class="text-gray-300">The same release context appears in the dashboard and summary email.</span>
              </div>
            </div>
          </div>

          <div class="bg-[#121824] p-5">
            <div class="rounded-xl border border-white/10 bg-white/[0.04] p-4">
              <p class="text-xs font-semibold tracking-wide text-blue-200 uppercase">
                {m.landing_release_intelligence_email_title({}, { locale })}
              </p>
              <div class="mt-4 space-y-3">
                {emailMetrics.map((item) => <div class="rounded-lg border border-white/10 bg-[#0c111b] px-3 py-2 text-sm leading-6 text-gray-300">{item}</div>)}
              </div>
            </div>

            <p class="mt-5 text-sm leading-6 text-gray-400">
              {m.landing_release_intelligence_panel_footer({}, { locale })}
            </p>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>
