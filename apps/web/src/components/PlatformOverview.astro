---
import { getRelativeLocaleUrl } from 'astro:i18n'

const locale = Astro.locals.locale

const products = [
  {
    eyebrow: 'Live Updates',
    title: 'Ship fixes in minutes',
    description: 'Deploy JavaScript, CSS, and asset updates to iOS, Android, and Electron without waiting for a store review.',
    href: getRelativeLocaleUrl(locale, 'live-update'),
    cta: 'Explore live updates',
    accent: 'from-sky-400/20 to-blue-500/10',
  },
  {
    eyebrow: 'Native Builds',
    title: 'Build binaries in the cloud',
    description: 'Trigger iOS and Android builds from the dashboard, CLI, or CI while keeping signing assets and artifacts managed in one place.',
    href: getRelativeLocaleUrl(locale, 'native-build'),
    cta: 'Explore native builds',
    accent: 'from-emerald-400/20 to-teal-500/10',
  },
  {
    eyebrow: 'Plugin Library',
    title: 'Add native capability faster',
    description: 'Use production-ready Capacitor plugins for payments, auth, storage, scanners, device APIs, and enterprise migrations.',
    href: getRelativeLocaleUrl(locale, 'plugins'),
    cta: 'Browse plugins',
    accent: 'from-amber-400/20 to-orange-500/10',
  },
]

const workflow = [
  'Create an app and connect your existing Capacitor project.',
  'Upload a web bundle or trigger a native build from your pipeline.',
  'Release to a channel, watch device logs, and roll back instantly if needed.',
]

const trustSignals = ['Open-source updater and backend', 'Self-hosting path for regulated teams', 'Global delivery with public status', 'Human migration support']
---

<section class="relative overflow-hidden bg-[#111318] py-20 sm:py-24">
  <div class="pointer-events-none absolute inset-x-0 top-0 h-px bg-linear-to-r from-transparent via-sky-400/50 to-transparent"></div>
  <div class="pointer-events-none absolute inset-0 bg-[radial-gradient(circle_at_50%_0%,rgba(56,189,248,0.12),transparent_34%)]"></div>

  <div class="relative mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
    <div class="grid gap-12 lg:grid-cols-[0.95fr_1.05fr] lg:items-center">
      <div>
        <p class="text-sm font-semibold tracking-[0.18em] text-sky-300 uppercase">Mobile release platform</p>
        <h2 class="mt-4 max-w-3xl text-3xl leading-tight font-bold text-white sm:text-5xl">One control plane for the parts of shipping mobile apps that slow teams down.</h2>
        <p class="mt-5 max-w-2xl text-lg leading-8 text-slate-300">
          Capgo keeps live updates, native builds, app testing, plugin migrations, logs, and rollbacks close to the workflow your team already uses.
        </p>

        <div class="mt-8 grid gap-3 sm:grid-cols-2">
          {
            trustSignals.map((signal) => (
              <div class="flex items-center gap-3 rounded-lg border border-white/10 bg-white/[0.03] px-4 py-3 text-sm text-slate-200">
                <svg class="h-4 w-4 shrink-0 text-emerald-300" viewBox="0 0 20 20" fill="currentColor" aria-hidden="true" focusable="false">
                  <path
                    fill-rule="evenodd"
                    d="M16.704 4.153a.75.75 0 01.143 1.052l-8 10.5a.75.75 0 01-1.127.075l-4.5-4.5a.75.75 0 011.06-1.06l3.894 3.893 7.48-9.817a.75.75 0 011.05-.143z"
                    clip-rule="evenodd"
                  />
                </svg>
                <span>{signal}</span>
              </div>
            ))
          }
        </div>
      </div>

      <div class="rounded-2xl border border-white/10 bg-[#0b0d12] p-4 shadow-2xl shadow-sky-950/30 sm:p-6">
        <div class="mb-5 flex items-center justify-between border-b border-white/10 pb-4">
          <div>
            <p class="text-xs font-semibold tracking-[0.16em] text-slate-500 uppercase">Release pipeline</p>
            <p class="mt-1 text-sm text-slate-300">Production channel</p>
          </div>
          <span class="rounded-full border border-emerald-300/30 bg-emerald-400/10 px-3 py-1 text-xs font-semibold text-emerald-200">Healthy</span>
        </div>

        <div class="grid gap-3 sm:grid-cols-3">
          {
            workflow.map((item, index) => (
              <div class="rounded-xl border border-white/10 bg-white/[0.03] p-4">
                <div class="flex h-8 w-8 items-center justify-center rounded-lg bg-sky-400/10 text-sm font-bold text-sky-200">{index + 1}</div>
                <p class="mt-4 text-sm leading-6 text-slate-300">{item}</p>
              </div>
            ))
          }
        </div>

        <div class="mt-4 rounded-xl border border-white/10 bg-[#05070a] p-4 font-mono text-xs text-slate-300">
          <div class="mb-3 flex items-center gap-2">
            <span class="h-2.5 w-2.5 rounded-full bg-rose-400"></span>
            <span class="h-2.5 w-2.5 rounded-full bg-amber-400"></span>
            <span class="h-2.5 w-2.5 rounded-full bg-emerald-400"></span>
          </div>
          <p><span class="text-slate-500">$</span> bunx @capgo/cli bundle upload --channel production</p>
          <p class="mt-2 text-emerald-300">Done: Bundle signed and uploaded</p>
          <p class="text-sky-300">Done: Rollout started for production</p>
          <p class="text-slate-400">Next: Device logs and rollback are ready in the dashboard</p>
        </div>
      </div>
    </div>

    <div class="mt-12 grid gap-5 md:grid-cols-3">
      {
        products.map((product) => (
          <a
            href={product.href}
            class={`group block rounded-2xl border border-white/10 bg-linear-to-br ${product.accent} p-6 transition hover:-translate-y-1 hover:border-sky-300/40`}
          >
            <p class="text-xs font-semibold tracking-[0.16em] text-slate-300 uppercase">{product.eyebrow}</p>
            <h3 class="mt-3 text-xl font-bold text-white">{product.title}</h3>
            <p class="mt-3 text-sm leading-6 text-slate-300">{product.description}</p>
            <span class="mt-5 inline-flex items-center text-sm font-semibold text-sky-200">
              {product.cta}
              <svg class="ml-2 h-4 w-4 transition group-hover:translate-x-1" viewBox="0 0 20 20" fill="currentColor" aria-hidden="true" focusable="false">
                <path
                  fill-rule="evenodd"
                  d="M3 10a.75.75 0 01.75-.75h10.638L10.23 5.29a.75.75 0 111.04-1.08l5.5 5.25a.75.75 0 010 1.08l-5.5 5.25a.75.75 0 11-1.04-1.08l4.158-3.96H3.75A.75.75 0 013 10z"
                  clip-rule="evenodd"
                />
              </svg>
            </span>
          </a>
        ))
      }
    </div>
  </div>
</section>
