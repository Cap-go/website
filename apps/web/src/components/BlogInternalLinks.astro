---
import { getRelativeLocaleUrl } from 'astro:i18n'

const locale = Astro.locals.locale
const currentPath = Astro.url.pathname.replace(/\/$/, '')

const candidates = [
  {
    href: getRelativeLocaleUrl(locale, 'docs/getting-started/quickstart/'),
    label: 'Live update quickstart',
    description: 'Connect the next release plan to the guided setup in the docs.',
  },
  {
    href: getRelativeLocaleUrl(locale, 'docs/live-updates/channels/'),
    label: 'Channel strategy',
    description: 'Split beta, staging, and production traffic without a new binary.',
  },
  {
    href: getRelativeLocaleUrl(locale, 'live-update/'),
    label: 'Capgo live updates',
    description: 'Ship safe web bundle fixes after App Store and Play Store approval.',
  },
  {
    href: getRelativeLocaleUrl(locale, 'plugins/'),
    label: 'Capgo plugin directory',
    description: 'Find maintained native bridges for the next feature in your app.',
  },
  {
    href: getRelativeLocaleUrl(locale, 'native-build/'),
    label: 'Native build automation',
    description: 'Rebuild iOS and Android when native code, plugins, or signing changes.',
  },
  {
    href: getRelativeLocaleUrl(locale, 'pricing/'),
    label: 'Capgo pricing',
    description: 'Compare plans for teams shipping live updates and native builds together.',
  },
]

const links = candidates.filter((link) => new URL(link.href, Astro.url).pathname.replace(/\/$/, '') !== currentPath).slice(0, 5)
---

<section aria-labelledby="blog-internal-links-title" class="my-12 border-y border-white/10 py-8">
  <div class="grid gap-6 lg:grid-cols-[minmax(0,0.8fr)_minmax(0,1.2fr)] lg:items-start">
    <div>
      <p class="text-xs font-semibold tracking-[0.24em] text-blue-200/70 uppercase">Capgo note</p>
      <h2 id="blog-internal-links-title" class="mt-3 text-2xl font-semibold tracking-normal text-white">Turn this into a safer release</h2>
      <p class="mt-3 text-sm leading-6 text-gray-400">
        Pair the advice in this article with Capgo docs and product pages so the next update has a rollout path, rollback plan, and the right native tooling.
      </p>
    </div>
    <div class="grid gap-3 sm:grid-cols-2">
      {
        links.map((link) => (
          <a href={link.href} class="group rounded-lg border border-white/10 bg-white/[0.03] p-4 transition hover:border-blue-300/30 hover:bg-white/[0.06]">
            <span class="flex items-center justify-between gap-3 text-sm font-semibold text-white">
              {link.label}
              <span class="text-blue-200 transition group-hover:translate-x-0.5" aria-hidden="true">
                -&gt;
              </span>
            </span>
            <span class="mt-2 block text-sm leading-6 text-gray-400">{link.description}</span>
          </a>
        ))
      }
    </div>
  </div>
</section>
