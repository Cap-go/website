---
import type { Plugin } from '@/config/plugins'
import { getSlug } from '@/services/github'
import { getRelativeLocaleUrl } from 'astro:i18n'

interface Props {
  docsHref: string
  hasDocs: boolean
  plugin: Plugin
  plugins: Plugin[]
}

const { docsHref, hasDocs, plugin, plugins } = Astro.props
const locale = Astro.locals.locale
const currentPath = Astro.url.pathname.replace(/\/$/, '')
const currentSlug = getSlug(plugin.href)
const relatedPlugins = plugins.filter((item) => getSlug(item.href) !== currentSlug).slice(0, 3)
const pluginLinks = relatedPlugins.map((item) => ({
  href: getRelativeLocaleUrl(locale, `plugins/${getSlug(item.href)}/`),
  label: `${item.title} plugin`,
  description: item.description,
}))

const candidates = [
  {
    href: docsHref,
    label: hasDocs ? `${plugin.title} docs` : 'Plugin docs directory',
    description: hasDocs ? 'Open the setup guide and API notes for this plugin.' : 'Open the docs directory to find setup guides for maintained Capgo plugins.',
  },
  ...pluginLinks.slice(0, 2),
  {
    href: getRelativeLocaleUrl(locale, 'blog/capacitor-plugins-what-you-need-to-know/'),
    label: 'Capacitor plugin guide',
    description: 'Read the blog primer before adding or replacing native dependencies.',
  },
  {
    href: getRelativeLocaleUrl(locale, 'docs/plugins/'),
    label: 'All plugin docs',
    description: 'Browse the complete documentation set for maintained Capgo plugins.',
  },
  {
    href: getRelativeLocaleUrl(locale, 'plugins/'),
    label: 'Plugin directory',
    description: 'Compare native bridges before adding another dependency.',
  },
  {
    href: getRelativeLocaleUrl(locale, 'live-update/'),
    label: 'Live updates',
    description: 'Ship JavaScript, CSS, and asset fixes after the native app is approved.',
  },
  {
    href: getRelativeLocaleUrl(locale, 'native-build/'),
    label: 'Native builds',
    description: 'Rebuild and sign iOS or Android when plugin changes require a new binary.',
  },
  {
    href: getRelativeLocaleUrl(locale, 'docs/getting-started/quickstart/'),
    label: 'Capgo quickstart',
    description: 'Set up the updater flow before rolling this plugin into production.',
  },
  ...pluginLinks.slice(2),
]

const seenPaths = new Set<string>()
const links = candidates
  .filter((link) => {
    const path = new URL(link.href, Astro.url).pathname.replace(/\/$/, '')
    if (path === currentPath || seenPaths.has(path)) return false
    seenPaths.add(path)
    return true
  })
  .slice(0, 6)
---

<section class="px-6 pb-16 lg:px-8 lg:pb-24" aria-labelledby="plugin-internal-links-title">
  <div class="mx-auto max-w-6xl border-t border-white/10 pt-10">
    <div class="grid gap-6 lg:grid-cols-[minmax(0,0.72fr)_minmax(0,1.28fr)] lg:items-start">
      <div>
        <p class="text-[0.7rem] font-semibold tracking-[0.28em] text-blue-200/70 uppercase">Useful next step</p>
        <h2 id="plugin-internal-links-title" class="mt-3 text-2xl font-semibold text-white sm:text-3xl">Connect this plugin to the rest of Capgo</h2>
        <p class="mt-3 text-sm leading-6 text-gray-400">
          Most plugin changes also need release planning. Use these internal pages to pair the native bridge with docs, live updates, and build automation.
        </p>
      </div>
      <div class="grid gap-3 sm:grid-cols-2">
        {
          links.map((link) => (
            <a href={link.href} class="group rounded-lg border border-white/10 bg-white/[0.03] p-4 transition hover:border-blue-300/30 hover:bg-white/[0.06]">
              <span class="flex items-center justify-between gap-3 text-sm font-semibold text-white">
                {link.label}
                <span class="text-blue-200 transition group-hover:translate-x-0.5" aria-hidden="true">
                  -&gt;
                </span>
              </span>
              <span class="mt-2 line-clamp-3 block text-sm leading-6 text-gray-400">{link.description}</span>
            </a>
          ))
        }
      </div>
    </div>
  </div>
</section>
