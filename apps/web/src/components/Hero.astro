---
import m from '@/copy/messages'
import { getRelativeLocaleUrl } from '@/services/links'
import TeamAvatars from '@/components/TeamAvatars.astro'

const ctaSubtext = `${m.days_free_trial({}, { locale: Astro.locals.locale })}. ${m.no_credit_card_required({}, { locale: Astro.locals.locale })}`
const nativeBuildUrl = getRelativeLocaleUrl(Astro.locals.locale, 'native-build')
const teamUrl = 'https://book.capgo.app/demo/'
---

<section>
  <div class="relative overflow-hidden">
    <div class="relative mx-auto max-w-7xl 2xl:max-w-[90vw] pb-8 md:pb-32">
      <!-- Background Grid of Squares -->
      <div class="pointer-events-none absolute inset-0 flex w-full flex-col justify-start gap-4 blur-sm select-none sm:blur-none">
        <!-- Row 0 -->
        <div class="grid w-full grid-cols-12 gap-4 2xl:gap-6">
          <!-- Left -->
          <div class="col-start-1 flex h-16 w-16 2xl:h-20 2xl:w-20 items-center justify-center overflow-hidden rounded-2xl bg-[#1a1d24]/30 opacity-20 backdrop-blur-sm"></div>
          <div class="col-start-2 flex h-16 w-16 2xl:h-20 2xl:w-20 items-center justify-center overflow-hidden rounded-2xl bg-[#1a1d24]/30 opacity-20 backdrop-blur-sm"></div>
          <div class="col-start-3 flex h-16 w-16 2xl:h-20 2xl:w-20 items-center justify-center overflow-hidden rounded-2xl bg-[#1a1d24]/30 opacity-40 backdrop-blur-sm"></div>
          <div class="col-start-4 flex h-16 w-16 2xl:h-20 2xl:w-20 items-center justify-center overflow-hidden rounded-2xl bg-[#1a1d24]/30 opacity-60 backdrop-blur-sm"></div>
          <!-- Right -->
          <div class="col-start-9 flex h-16 w-16 2xl:h-20 2xl:w-20 items-center justify-center overflow-hidden rounded-2xl bg-[#1a1d24]/30 opacity-70 backdrop-blur-sm"></div>
          <div class="col-start-10 flex h-16 w-16 2xl:h-20 2xl:w-20 items-center justify-center overflow-hidden rounded-2xl bg-[#1a1d24]/30 opacity-60 backdrop-blur-sm"></div>
          <div class="col-start-11 flex h-16 w-16 2xl:h-20 2xl:w-20 items-center justify-center overflow-hidden rounded-2xl bg-[#1a1d24]/30 opacity-40 backdrop-blur-sm"></div>
          <div class="col-start-12 flex h-16 w-16 2xl:h-20 2xl:w-20 items-center justify-center overflow-hidden rounded-2xl bg-[#1a1d24]/30 opacity-20 backdrop-blur-sm"></div>
        </div>
        <!-- Row 1 -->
        <div class="grid w-full grid-cols-12 gap-4 2xl:gap-6">
          <div class="col-start-1 flex h-16 w-16 2xl:h-20 2xl:w-20 overflow-hidden rounded-2xl bg-[#1a1d24]/30 backdrop-blur-sm">
            <img src="/logo_cloud/poplin_logo.webp" alt="Poplin" width="64" height="64" class="max-h-full max-w-full object-contain opacity-30" />
          </div>
          <!-- Left -->
          <div class="col-start-2 flex h-16 w-16 2xl:h-20 2xl:w-20 items-center justify-center overflow-hidden rounded-2xl bg-[#1a1d24]/30 backdrop-blur-sm">
            <img src="/logo_cloud/ajeer_logo.webp" alt="Ajeer" width="64" height="64" class="max-h-full max-w-full object-contain opacity-30" />
          </div>
          <!-- Right -->
          <div class="col-start-11 flex h-16 w-16 2xl:h-20 2xl:w-20 items-center justify-center overflow-hidden rounded-2xl bg-[#1a1d24]/30 backdrop-blur-sm">
            <img src="/logo_cloud/felix_health_logo.webp" alt="Felix Health" width="64" height="64" class="max-h-full max-w-full object-contain opacity-30" />
          </div>
          <div class="col-start-12 flex h-16 w-16 2xl:h-20 2xl:w-20 overflow-hidden rounded-2xl bg-[#1a1d24]/30 backdrop-blur-sm">
            <img src="/logo_cloud/public_square_logo.webp" alt="Public Square" width="64" height="64" class="max-h-full max-w-full object-contain opacity-30" />
          </div>
        </div>

        <!-- Row 2 -->
        <div class="grid w-full grid-cols-12 gap-4 2xl:gap-6">
          <!-- Left -->
          <div
            class="col-start-1 flex h-16 w-16 2xl:h-20 2xl:w-20 -translate-x-12 2xl:-translate-x-28 items-center justify-center overflow-hidden rounded-2xl bg-[#1a1d24]/30 opacity-60 backdrop-blur-sm"
          >
          </div>
          <div class="col-start-2 flex h-16 w-16 2xl:h-20 2xl:w-20 -translate-x-12 2xl:-translate-x-28 items-center justify-center overflow-hidden rounded-2xl bg-[#1a1d24]/80 backdrop-blur-sm">
            <img src="/logo_cloud/happypal_logo.webp" alt="HappyPal" width="64" height="64" class="max-h-full max-w-full object-contain opacity-30" />
          </div>
          <div class="col-start-3 flex h-16 w-16 2xl:h-20 2xl:w-20 -translate-x-12 2xl:-translate-x-28 items-center justify-center overflow-hidden rounded-2xl bg-[#1a1d24]/30 backdrop-blur-sm">
            <img src="/logo_cloud/seaport_logo.webp" alt="Seaport" width="64" height="64" class="max-h-full max-w-full object-contain opacity-30" />
          </div>

          <!-- Right -->
          <div class="col-start-10 flex h-16 w-16 2xl:h-20 2xl:w-20 translate-x-12 2xl:translate-x-28 items-center justify-center overflow-hidden rounded-2xl bg-[#1a1d24]/30 backdrop-blur-sm">
            <img src="/logo_cloud/janitor_logo.webp" alt="Janitor" width="64" height="64" class="max-h-full max-w-full object-contain opacity-30" />
          </div>
          <div class="col-start-11 flex h-16 w-16 2xl:h-20 2xl:w-20 translate-x-12 2xl:translate-x-28 items-center justify-center overflow-hidden rounded-2xl bg-[#1a1d24]/80 backdrop-blur-sm">
            <img src="/logo_cloud/suez_logo.webp" alt="Suez" width="64" height="64" class="max-h-full max-w-full object-contain opacity-30" />
          </div>
          <div
            class="col-start-12 flex h-16 w-16 2xl:h-20 2xl:w-20 translate-x-12 2xl:translate-x-28 items-center justify-center overflow-hidden rounded-2xl bg-[#1a1d24]/30 opacity-60 backdrop-blur-sm"
          >
          </div>
        </div>

        <!-- Row 3 -->
        <div class="grid w-full grid-cols-12 gap-4 2xl:gap-6">
          <div class="col-start-1 h-16 w-16 2xl:h-20 2xl:w-20 rounded-2xl bg-[#1a1d24]/30 backdrop-blur-sm">
            <img src="/logo_cloud/torchys_logo.webp" alt="Torchys" width="64" height="64" class="max-h-full max-w-full object-contain opacity-30" />
          </div>
          <!-- Left -->
          <div class="col-start-2 flex h-16 w-16 2xl:h-20 2xl:w-20 items-center justify-center overflow-hidden rounded-2xl bg-[#1a1d24]/30 backdrop-blur-sm">
            <img src="/logo_cloud/leaderboard_logo.webp" alt="Leaderboard" width="64" height="64" class="max-h-full max-w-full object-contain opacity-30" />
          </div>
          <div class="col-start-3 flex h-16 w-16 2xl:h-20 2xl:w-20 items-center justify-center overflow-hidden rounded-2xl bg-[#1a1d24]/80 backdrop-blur-sm">
            <img src="/logo_cloud/revel_logo.webp" alt="Revel" width="64" height="64" class="max-h-full max-w-full object-contain opacity-30" />
          </div>

          <!-- Right -->
          <div class="col-start-10 flex h-16 w-16 2xl:h-20 2xl:w-20 items-center justify-center overflow-hidden rounded-2xl bg-[#1a1d24]/80 backdrop-blur-sm">
            <img src="/logo_cloud/pizza_hut_logo.webp" alt="Pizza Hut" width="64" height="64" class="max-h-full max-w-full object-contain opacity-30" />
          </div>
          <div class="col-start-11 flex h-16 w-16 2xl:h-20 2xl:w-20 items-center justify-center overflow-hidden rounded-2xl bg-[#1a1d24]/30 backdrop-blur-sm">
            <img src="/logo_cloud/livance_logo.webp" alt="Livance" width="64" height="64" class="max-h-full max-w-full object-contain opacity-30" />
          </div>
          <div class="col-start-12 flex h-16 w-16 2xl:h-20 2xl:w-20 overflow-hidden rounded-2xl bg-[#1a1d24]/30 backdrop-blur-sm">
            <img src="/logo_cloud/codere_logo.webp" alt="Codere" width="64" height="64" class="max-h-full max-w-full object-contain opacity-30" />
          </div>
        </div>

        <!-- Row 4 -->
        <div class="grid w-full grid-cols-12 gap-4 2xl:gap-6">
          <!-- Left -->
          <div
            class="col-start-1 flex h-16 w-16 2xl:h-20 2xl:w-20 -translate-x-12 2xl:-translate-x-28 items-center justify-center overflow-hidden rounded-2xl bg-[#1a1d24]/30 opacity-60 backdrop-blur-sm"
          >
          </div>
          <div class="col-start-2 flex h-16 w-16 2xl:h-20 2xl:w-20 -translate-x-12 2xl:-translate-x-28 items-center justify-center overflow-hidden rounded-2xl bg-[#1a1d24]/80 backdrop-blur-sm">
            <img src="/logo_cloud/our_living_logo.webp" alt="OurLiving" width="64" height="64" class="max-h-full max-w-full object-contain opacity-30" />
          </div>
          <div class="col-start-3 flex h-16 w-16 2xl:h-20 2xl:w-20 -translate-x-12 2xl:-translate-x-28 items-center justify-center overflow-hidden rounded-2xl bg-[#1a1d24]/30 backdrop-blur-sm">
            <img src="/logo_cloud/nana_logo.webp" alt="Nana" width="64" height="64" class="max-h-full max-w-full object-contain opacity-30" />
          </div>

          <!-- Right -->
          <div class="col-start-10 flex h-16 w-16 2xl:h-20 2xl:w-20 translate-x-12 2xl:translate-x-28 items-center justify-center overflow-hidden rounded-2xl bg-[#1a1d24]/30 backdrop-blur-sm">
            <img src="/logo_cloud/nx_logo.webp" alt="NX" width="64" height="64" class="max-h-full max-w-full object-contain opacity-30" />
          </div>
          <div class="col-start-11 flex h-16 w-16 2xl:h-20 2xl:w-20 translate-x-12 2xl:translate-x-28 items-center justify-center overflow-hidden rounded-2xl bg-[#1a1d24]/80 backdrop-blur-sm">
            <img src="/logo_cloud/remnote_logo.webp" alt="RemNote" width="64" height="64" class="max-h-full max-w-full object-contain opacity-30" />
          </div>
          <div
            class="col-start-12 flex h-16 w-16 2xl:h-20 2xl:w-20 translate-x-12 2xl:translate-x-28 items-center justify-center overflow-hidden rounded-2xl bg-[#1a1d24]/30 opacity-60 backdrop-blur-sm"
          >
          </div>
        </div>

        <!-- Row 5 -->
        <div class="grid w-full grid-cols-12 gap-4 2xl:gap-6">
          <div class="col-start-1 h-16 w-16 2xl:h-20 2xl:w-20 rounded-2xl bg-[#1a1d24]/30 backdrop-blur-sm">
            <img src="/logo_cloud/shelf_logo.webp" alt="Shelf" width="64" height="64" class="max-h-full max-w-full object-contain opacity-30" />
          </div>
          <!-- Left -->
          <div class="col-start-2 flex h-16 w-16 2xl:h-20 2xl:w-20 items-center justify-center overflow-hidden rounded-2xl bg-[#1a1d24]/30 backdrop-blur-sm">
            <img src="/logo_cloud/pixiesset_logo.webp" alt="Pixiesset" width="64" height="64" class="max-h-full max-w-full object-contain opacity-30" />
          </div>
          <div class="col-start-3 flex h-16 w-16 2xl:h-20 2xl:w-20 items-center justify-center overflow-hidden rounded-2xl bg-[#1a1d24]/80 backdrop-blur-sm">
            <img src="/logo_cloud/vella_logo.webp" alt="Vella" width="64" height="64" class="max-h-full max-w-full object-contain opacity-30" />
          </div>

          <!-- Right -->
          <div class="col-start-10 flex h-16 w-16 2xl:h-20 2xl:w-20 items-center justify-center overflow-hidden rounded-2xl bg-[#1a1d24]/80 backdrop-blur-sm">
            <img src="/logo_cloud/irec_logo.webp" alt="IREC" width="64" height="64" class="max-h-full max-w-full object-contain opacity-30" />
          </div>
          <div class="col-start-11 flex h-16 w-16 2xl:h-20 2xl:w-20 items-center justify-center overflow-hidden rounded-2xl bg-[#1a1d24]/30 backdrop-blur-sm">
            <img src="/logo_cloud/plataforma_logo.webp" alt="Plataforma" width="64" height="64" class="max-h-full max-w-full object-contain opacity-30" />
          </div>
          <div class="col-start-12 flex h-16 w-16 2xl:h-20 2xl:w-20 overflow-hidden rounded-2xl bg-[#1a1d24]/30 backdrop-blur-sm">
            <img src="/logo_cloud/snowqueen_logo.webp" alt="Snowqueen" width="64" height="64" class="max-h-full max-w-full object-contain opacity-30" />
          </div>
        </div>
        <!-- Row 6 -->
        <div class="grid w-full grid-cols-12 gap-4 2xl:gap-6">
          <!-- Left -->
          <div
            class="col-start-1 flex h-16 w-16 2xl:h-20 2xl:w-20 -translate-x-12 2xl:-translate-x-28 items-center justify-center overflow-hidden rounded-2xl bg-[#1a1d24]/30 opacity-40 backdrop-blur-sm"
          >
          </div>
          <div
            class="col-start-2 flex h-16 w-16 2xl:h-20 2xl:w-20 -translate-x-12 2xl:-translate-x-28 items-center justify-center overflow-hidden rounded-2xl bg-[#1a1d24]/30 opacity-60 backdrop-blur-sm"
          >
          </div>
          <div class="col-start-3 flex h-16 w-16 2xl:h-20 2xl:w-20 -translate-x-12 2xl:-translate-x-28 items-center justify-center overflow-hidden rounded-2xl bg-[#1a1d24]/30 backdrop-blur-sm">
            <img src="/logo_cloud/marketplace_logo.webp" alt="Marketplace" width="64" height="64" class="max-h-full max-w-full object-contain opacity-30" />
          </div>
          <div class="col-start-4 flex h-16 w-16 2xl:h-20 2xl:w-20 -translate-x-12 2xl:-translate-x-28 items-center justify-center overflow-hidden rounded-2xl bg-[#1a1d24]/30 backdrop-blur-sm">
            <img src="/logo_cloud/gartner_health_logo.webp" alt="Gartner Health" width="64" height="64" class="max-h-full max-w-full object-contain opacity-30" />
          </div>
          <!-- Right -->
          <div class="col-start-9 flex h-16 w-16 2xl:h-20 2xl:w-20 translate-x-12 2xl:translate-x-28 items-center justify-center overflow-hidden rounded-2xl bg-[#1a1d24]/30 backdrop-blur-sm">
            <img src="/logo_cloud/kick_logo.webp" alt="Kick" width="64" height="64" class="max-h-full max-w-full object-contain opacity-30" />
          </div>
          <div class="col-start-10 flex h-16 w-16 2xl:h-20 2xl:w-20 translate-x-12 2xl:translate-x-28 items-center justify-center overflow-hidden rounded-2xl bg-[#1a1d24]/30 backdrop-blur-sm">
            <img src="/logo_cloud/oneclick_logo.webp" alt="OneClick" width="64" height="64" class="max-h-full max-w-full object-contain opacity-30" />
          </div>
          <div
            class="col-start-11 flex h-16 w-16 2xl:h-20 2xl:w-20 translate-x-12 2xl:translate-x-28 items-center justify-center overflow-hidden rounded-2xl bg-[#1a1d24]/30 opacity-60 backdrop-blur-sm"
          >
          </div>
          <div
            class="col-start-12 flex h-16 w-16 2xl:h-20 2xl:w-20 translate-x-12 2xl:translate-x-28 items-center justify-center overflow-hidden rounded-2xl bg-[#1a1d24]/30 opacity-40 backdrop-blur-sm"
          >
          </div>
        </div>
      </div>
      <div class="relative z-10 mx-auto max-w-4xl px-4 pt-4 text-center sm:px-6 sm:pt-6 lg:px-0 lg:pt-8 xl:pt-20 2xl:pt-36">
        <a
          id="hero-whatsnew-pill"
          href={nativeBuildUrl}
          class="font-inter mb-8 inline-flex min-h-10 max-w-full items-center gap-2 rounded-full border border-white/15 bg-white/5 px-2 py-1 pr-4 text-sm font-semibold text-slate-300 transition-colors hover:border-blue-400/40 hover:bg-white/10 hover:text-white focus-visible:ring-2 focus-visible:ring-blue-400 focus-visible:ring-offset-2 focus-visible:ring-offset-gray-950 focus-visible:outline-none"
        >
          <span class="inline-flex min-h-8 items-center rounded-full bg-white px-3 text-slate-950">What's new?</span>
          <span class="hidden sm:inline">Native builds for CapacitorJS apps</span>
          <span class="sm:hidden">Native builds</span>
          <svg class="h-4 w-4 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true" focusable="false">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3"></path>
          </svg>
        </a>

        <h1 class="font-pj text-4xl leading-tight font-bold tracking-tight sm:text-5xl sm:leading-tight lg:text-6xl lg:leading-tight xl:text-7xl">
          Everything you need to ship
          <br />
          <span class="text-azure-500">CapacitorJS apps</span>
        </h1>
        <p class="font-inter mx-auto mt-6 max-w-2xl text-lg leading-8 text-gray-400 sm:text-xl">
          Live updates, native builds, channels, rollback, and release automation for CapacitorJS apps.
        </p>
        <div class="mt-10 flex flex-col items-center gap-4">
          <div class="flex flex-col items-center gap-4 sm:flex-row">
            <div class="group relative inline-flex">
              <div
                class="absolute -inset-4 rounded-xl opacity-70 transition-all duration-1000 group-hover:-inset-5 group-hover:opacity-100 group-hover:duration-200"
                style="background: radial-gradient(ellipse at center, rgba(68, 188, 255, 0.6) 0%, rgba(68, 188, 255, 0.3) 40%, rgba(68, 188, 255, 0) 70%);"
              >
              </div>
              <a
                href={getRelativeLocaleUrl(Astro.locals.locale, 'register')}
                class="font-pj relative z-10 inline-flex items-center justify-center rounded-xl bg-blue-600 px-8 py-4 text-lg font-bold text-white shadow-lg shadow-blue-600/20 transition-all duration-200 hover:bg-blue-500 focus-visible:ring-2 focus-visible:ring-blue-400 focus-visible:ring-offset-2 focus-visible:ring-offset-gray-950 focus-visible:outline-none active:scale-[0.98]"
              >
                {m.cta_start_free({}, { locale: Astro.locals.locale })}
              </a>
            </div>
          </div>
          <div class="font-inter flex flex-col items-center justify-center gap-3 text-sm text-gray-400 sm:flex-row">
            <TeamAvatars size="lg" border="border-gray-950" shadow loading={false} />
            <p>
              Enterprise needs?
              <a
                href={teamUrl}
                target="_blank"
                rel="noopener noreferrer"
                class="font-semibold text-white underline-offset-4 transition-colors hover:text-blue-300 hover:underline focus-visible:ring-2 focus-visible:ring-blue-400 focus-visible:ring-offset-2 focus-visible:ring-offset-gray-950 focus-visible:outline-none"
              >
                Talk to our team
              </a>
            </p>
          </div>
          <p class="font-inter text-sm leading-6 text-gray-400">{ctaSubtext}</p>
        </div>
      </div>
    </div>
  </div>
  <!-- Features Bar -->
  <div class="bg-linear-to-b from-gray-900 to-[#1a1a1a] py-6 sm:py-16 lg:py-20">
    <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
      <!-- Single Horizontal Bar with Features and Stats -->
      <div class="mx-auto max-w-6xl">
        <div class="rounded-3xl bg-linear-to-br from-[#1a1d24]/50 to-[#14161b]/50 p-6 backdrop-blur-sm sm:p-8 lg:p-10">
          <div class="grid grid-cols-1 items-start gap-12 md:grid-cols-3">
            <!-- Production Recovery -->
            <div class="flex flex-col items-center gap-4 text-center">
              <div class="shrink-0">
                <div class="flex h-8 w-8 items-center justify-center rounded-2xl">
                  <svg class="h-8 w-8 text-gray-400" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true" focusable="false">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M5 10l7-7m0 0l7 7m-7-7v18"></path>
                  </svg>
                </div>
              </div>
              <div>
                <h2 class="mb-2 text-lg font-semibold text-white">{m.home_hero_outcome_recover_title({}, { locale: Astro.locals.locale })}</h2>
                <p class="text-sm leading-relaxed text-gray-400">{m.home_hero_outcome_recover_desc({}, { locale: Astro.locals.locale })}</p>
              </div>
            </div>

            <!-- Store Review Fit -->
            <div class="flex flex-col items-center gap-4 text-center">
              <div class="shrink-0">
                <div class="flex h-8 w-8 items-center justify-center rounded-2xl">
                  <div class="flex gap-2">
                    <svg class="h-6 w-6 text-gray-400" fill="currentColor" viewBox="0 0 384 512" aria-hidden="true" focusable="false">
                      <path
                        d="M318.7 268.7c-.2-36.7 16.4-64.4 50-84.8-18.8-26.9-47.2-41.7-84.7-44.6-35.5-2.8-74.3 20.7-88.5 20.7-15 0-49.4-19.7-76.4-19.7C63.3 141.2 4 184.8 4 273.5q0 39.3 14.4 81.2c12.8 36.7 59 126.7 107.2 125.2 25.2-.6 43-17.9 75.8-17.9 31.8 0 48.3 17.9 76.4 17.9 48.6-.7 90.4-82.5 102.6-119.3-65.2-30.7-61.7-90-61.7-91.9zm-56.6-164.2c27.3-32.4 24.8-61.9 24-72.5-24.1 1.4-52 16.4-67.9 34.9-17.5 19.8-27.8 44.3-25.6 71.9 26.1 2 49.9-11.4 69.5-34.3z"
                      ></path>
                    </svg>
                    <svg class="h-6 w-6 text-gray-400" fill="currentColor" viewBox="0 0 488 512" aria-hidden="true" focusable="false">
                      <path
                        d="M488 261.8C488 403.3 391.1 504 248 504 110.8 504 0 393.2 0 256S110.8 8 248 8c66.8 0 123 24.5 166.3 64.9l-67.5 64.9C258.5 52.6 94.3 116.6 94.3 256c0 86.5 69.1 156.6 153.7 156.6 98.2 0 135-70.4 140.8-106.9H248v-85.3h236.1c2.3 12.7 3.9 24.9 3.9 41.4z"
                      ></path>
                    </svg>
                  </div>
                </div>
              </div>
              <div>
                <h2 class="mb-2 text-lg font-semibold text-white">{m.home_hero_outcome_compliance_title({}, { locale: Astro.locals.locale })}</h2>
                <p class="text-sm leading-relaxed text-gray-400">{m.home_hero_outcome_compliance_desc({}, { locale: Astro.locals.locale })}</p>
              </div>
            </div>

            <!-- Release Proof -->
            <div class="flex flex-col items-center gap-4 text-center">
              <div class="shrink-0">
                <div class="flex h-8 w-8 items-center justify-center rounded-2xl">
                  <svg class="h-8 w-8 text-gray-400" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true" focusable="false">
                    <path
                      stroke-linecap="round"
                      stroke-linejoin="round"
                      stroke-width="1.5"
                      d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z"
                    ></path>
                  </svg>
                </div>
