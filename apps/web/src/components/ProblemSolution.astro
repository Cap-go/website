---
import m from '@/copy/messages'

const locale = Astro.locals.locale
---

<section class="relative overflow-hidden bg-[#1a1a1a] pt-24 pb-32 sm:py-32 lg:pb-44" data-scroll-chat-section>
  <!-- Background Gradient -->
  <div class="pointer-events-none absolute top-0 left-1/2 w-full max-w-7xl -translate-x-1/2 opacity-80">
    <svg width="1198" height="599" viewBox="0 0 1198 599" fill="none" xmlns="http://www.w3.org/2000/svg" class="h-auto w-full">
      <path
        d="M1198 599C1198 520.338 1182.51 442.447 1152.4 369.773C1122.3 297.099 1078.18 231.065 1022.56 175.443C966.935 119.821 900.901 75.6987 828.227 45.5962C755.553 15.4936 677.662 -3.43842e-06 599 0C520.338 3.43842e-06 442.447 15.4936 369.773 45.5962C297.099 75.6987 231.065 119.821 175.443 175.443C119.821 231.065 75.6987 297.099 45.5961 369.773C15.4936 442.447 -6.87683e-06 520.338 0 599L599 599H1198Z"
        fill="url(#paint0_linear_1_23404)"></path>
      <defs>
        <linearGradient id="paint0_linear_1_23404" x1="599" y1="-225" x2="599" y2="447" gradientUnits="userSpaceOnUse">
          <stop stop-color="#5273EB"></stop>
          <stop offset="1" stop-color="#1D1E22" stop-opacity="0"></stop>
        </linearGradient>
      </defs>
    </svg>
  </div>

  <div class="relative mx-auto max-w-7xl px-6 lg:px-8">
    <!-- Header -->
    <div class="mx-auto mb-16 max-w-2xl text-center">
      <h2 class="text-sm leading-7 font-semibold tracking-wide text-[#44BCFF] uppercase">{m.problem_solution_badge({}, { locale })}</h2>
      <p class="mt-2 text-3xl font-bold tracking-tight text-white sm:text-5xl">
        {m.problem_solution_title({}, { locale })}<br />
        <span class="underline decoration-[#44BCFF] underline-offset-4">{m.problem_solution_velocity({}, { locale })}</span>
      </p>
      <p class="mt-6 text-lg leading-8 text-gray-400">
        {m.problem_solution_subtitle({}, { locale })}
      </p>
    </div>

    <div class="mx-auto grid max-w-5xl grid-cols-1 gap-8 lg:grid-cols-2">
      <!-- Problem Card -->
      <div class="relative rounded-3xl border border-red-500/30 bg-[#111] p-6 sm:p-8">
        <!-- Red Cross Icon -->
        <div class="absolute -top-5 left-1/2 flex h-10 w-10 -translate-x-1/2 items-center justify-center rounded-full bg-red-500 ring-4 ring-[#0B0C10]">
          <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" class="h-6 w-6 text-white">
            <path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12"></path>
          </svg>
        </div>

        <div class="mt-4 text-center">
          <p class="text-xs font-semibold tracking-[0.2em] text-red-300 uppercase">{m.problem_solution_without_capgo({}, { locale })}</p>
        </div>

        <!-- Timeline -->
        <div class="mt-6 mb-10 flex flex-wrap justify-center gap-2">
          <span class="rounded-md border border-gray-700 bg-[#222] px-3 py-1 font-mono text-xs text-gray-300">/dev</span>
          <span class="rounded-md border border-gray-700 bg-[#222] px-3 py-1 font-mono text-xs text-gray-300">/build</span>
          <span class="rounded-md border border-blue-900/50 bg-[#222] px-3 py-1 font-mono text-xs text-blue-300">/submit</span>
          <span class="rounded-md border border-blue-900/50 bg-[#222] px-3 py-1 font-mono text-xs text-blue-300">/review</span>
          <span class="rounded-md border border-green-900/50 bg-[#222] px-3 py-1 font-mono text-xs text-green-400">/live</span>
        </div>

        <!-- Chat -->
        <div class="min-h-[25rem] space-y-5 font-sans text-base/6 sm:text-sm/6">
          <!-- Left Message -->
          <div class="scroll-chat-message flex gap-3" data-reveal-at="0.08" style="--message-index: 0">
            <div class="flex h-8 w-8 items-center justify-center rounded-full bg-gray-800 text-xs font-bold text-gray-400">A</div>
            <div class="max-w-[18rem] rounded-2xl rounded-tl-none bg-[#222] px-4 py-2 text-gray-200">
              {m.problem_chat_whats_status({}, { locale })}
            </div>
          </div>

          <div class="scroll-chat-message flex gap-3" data-reveal-at="0.2" style="--message-index: 1">
            <div class="flex h-8 w-8 items-center justify-center rounded-full bg-gray-800 text-xs font-bold text-gray-400">S</div>
            <div class="max-w-[18rem] rounded-2xl rounded-tl-none bg-[#222] px-4 py-2 text-gray-200">
              {m.problem_chat_customers_waiting({}, { locale })}
            </div>
          </div>

          <div class="scroll-chat-message flex justify-end" data-reveal-at="0.32" style="--message-index: 2">
            <div class="max-w-[18rem] rounded-2xl rounded-tr-none bg-[#D34545] px-4 py-2 text-white">
              {m.problem_chat_still_pending({}, { locale })}
            </div>
          </div>

          <div class="scroll-chat-message flex gap-3" data-reveal-at="0.44" style="--message-index: 3">
            <div class="flex h-8 w-8 items-center justify-center rounded-full bg-gray-800 text-xs font-bold text-gray-400">P</div>
            <div class="max-w-[18rem] rounded-2xl rounded-tl-none bg-[#222] px-4 py-2 text-gray-200">
              {m.problem_chat_any_eta({}, { locale })}
            </div>
          </div>

          <div class="scroll-chat-message flex gap-3" data-reveal-at="0.56" style="--message-index: 4">
            <div class="flex h-8 w-8 items-center justify-center rounded-full bg-gray-800 text-xs font-bold text-gray-400">S</div>
            <div class="max-w-[18rem] rounded-2xl rounded-tl-none bg-[#222] px-4 py-2 text-gray-200">
              {m.problem_chat_support_tickets({}, { locale })}
            </div>
          </div>

          <div class="scroll-chat-message flex justify-end" data-reveal-at="0.68" style="--message-index: 5">
            <div class="max-w-[18rem] rounded-2xl rounded-tr-none bg-[#D34545] px-4 py-2 text-white">
              <span
                data-random-store-message
                data-apple-message={m.problem_chat_hope_approved_apple({}, { locale })}
                data-google-message={m.problem_chat_hope_approved_google({}, { locale })}
              >
                {m.problem_chat_hope_approved_apple({}, { locale })}
              </span>
            </div>
          </div>

          <div class="scroll-chat-message flex justify-end" data-reveal-at="0.76" style="--message-index: 6">
            <div class="flex h-6 w-6 items-center justify-center rounded-full bg-[#D34545]/20 text-sm">🤬</div>
          </div>
        </div>
      </div>

      <!-- Solution Card -->
      <div class="relative rounded-3xl border border-blue-500/30 bg-[#111] p-6 sm:p-8">
        <!-- Blue Check Icon -->
        <div class="absolute -top-5 left-1/2 flex h-10 w-10 -translate-x-1/2 items-center justify-center rounded-full bg-blue-500 ring-4 ring-[#0B0C10]">
          <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" class="h-6 w-6 text-white">
            <path stroke-linecap="round" stroke-linejoin="round" d="M4.5 12.75l6 6 9-13.5"></path>
          </svg>
        </div>

        <div class="mt-4 text-center">
          <p class="text-xs font-semibold tracking-[0.2em] text-blue-300 uppercase">{m.problem_solution_with_capgo({}, { locale })}</p>
        </div>

        <!-- Timeline -->
        <div class="mt-6 mb-10 flex flex-wrap justify-center gap-2">
          <span class="rounded-md border border-gray-700 bg-[#222] px-3 py-1 font-mono text-xs text-gray-300">/dev</span>
          <span class="rounded-md border border-gray-700 bg-[#222] px-3 py-1 font-mono text-xs text-gray-300">/build</span>
          <span class="rounded-md border border-green-900/50 bg-[#222] px-3 py-1 font-mono text-xs text-green-400">/live</span>
        </div>

        <!-- Chat -->
        <div class="min-h-[25rem] space-y-5 font-sans text-base/6 sm:text-sm/6">
          <!-- Left Message -->
          <div class="scroll-chat-message flex gap-3" data-reveal-at="0.08" style="--message-index: 0">
            <div class="flex h-8 w-8 items-center justify-center rounded-full bg-gray-800 text-xs font-bold text-gray-400">A</div>
            <div class="max-w-[18rem] rounded-2xl rounded-tl-none bg-[#222] px-4 py-2 text-gray-200">
              {m.solution_chat_whats_status({}, { locale })}
            </div>
          </div>

          <div class="scroll-chat-message flex justify-end" data-reveal-at="0.24" style="--message-index: 1">
            <div class="max-w-[18rem] rounded-2xl rounded-tr-none bg-[#3B82F6] px-4 py-2 text-white">
              {m.solution_chat_hotfix_live({}, { locale })}
            </div>
          </div>

          <div class="scroll-chat-message flex gap-3" data-reveal-at="0.4" style="--message-index: 2">
            <div class="flex h-8 w-8 items-center justify-center rounded-full bg-gray-800 text-xs font-bold text-gray-400">S</div>
            <div class="max-w-[18rem] rounded-2xl rounded-tl-none bg-[#222] px-4 py-2 text-gray-200">
              {m.solution_chat_support_clear({}, { locale })}
            </div>
          </div>

          <div class="scroll-chat-message flex justify-end" data-reveal-at="0.56" style="--message-index: 3">
            <div class="max-w-[18rem] rounded-2xl rounded-tr-none bg-[#3B82F6] px-4 py-2 text-white">
              {m.solution_chat_shipped({}, { locale })}
            </div>
          </div>

          <div class="scroll-chat-message flex justify-end" data-reveal-at="0.68" style="--message-index: 4">
            <div class="max-w-[18rem] rounded-2xl rounded-tr-none bg-[#3B82F6] px-4 py-2 text-white">
              {m.solution_chat_users_have_it({}, { locale })}
            </div>
          </div>

          <div class="scroll-chat-message flex justify-end" data-reveal-at="0.76" style="--message-index: 5">
            <div class="flex h-6 w-6 items-center justify-center rounded-full bg-blue-500/20 text-sm">😍</div>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>

<script>
  const scrollChatSections = document.querySelectorAll<HTMLElement>('[data-scroll-chat-section]')

  if (scrollChatSections.length > 0) {
    const clamp = (value: number, min: number, max: number) => Math.min(Math.max(value, min), max)

    document.querySelectorAll<HTMLElement>('[data-random-store-message]').forEach((message) => {
      message.textContent = Math.random() < 0.5 ? (message.dataset.appleMessage ?? '') : (message.dataset.googleMessage ?? '')
    })

    const updateScrollMessages = () => {
      const viewportHeight = window.innerHeight || document.documentElement.clientHeight

      scrollChatSections.forEach((section) => {
        const rect = section.getBoundingClientRect()
        const progress = clamp((viewportHeight * 0.78 - rect.top) / (rect.height * 0.82), 0, 1)

        section.querySelectorAll<HTMLElement>('.scroll-chat-message').forEach((message) => {
          const revealAt = Number(message.dataset.revealAt ?? 0)
          message.classList.toggle('is-visible', progress >= revealAt)
        })
      })
    }

    let ticking = false
    const queueUpdate = () => {
      if (ticking) return

      ticking = true
      window.requestAnimationFrame(() => {
        updateScrollMessages()
        ticking = false
      })
    }

    scrollChatSections.forEach((section) => section.classList.add('scroll-chat-ready'))
    updateScrollMessages()

    window.addEventListener('scroll', queueUpdate, { passive: true })
    window.addEventListener('resize', queueUpdate)
  }
</script>

<style>
  .scroll-chat-ready .scroll-chat-message {
    opacity: 0;
    transform: translateY(18px) scale(0.98);
    filter: blur(2px);
    transition:
      opacity 420ms ease,
      transform 480ms cubic-bezier(0.22, 1, 0.36, 1),
      filter 420ms ease;
    transition-delay: calc(var(--message-index, 0) * 40ms);
  }

  .scroll-chat-ready .scroll-chat-message.is-visible {
    opacity: 1;
    transform: translateY(0) scale(1);
    filter: blur(0);
  }

  @media (prefers-reduced-motion: reduce) {
    .scroll-chat-ready .scroll-chat-message {
      opacity: 1;
      transform: none;
      filter: none;
      transition: none;
    }
  }
</style>
