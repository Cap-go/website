---
import { getRelativeLocaleUrl } from 'astro:i18n'
import m from '@/copy/messages'
---

<section class="bg-gray-900 py-10 sm:py-16 lg:py-24">
  <div class="mx-auto max-w-5xl px-4 sm:px-6 lg:px-8">
    <div class="mx-auto max-w-2xl text-center">
      <h2 class="text-3xl leading-tight font-bold text-white sm:text-4xl lg:text-5xl">
        {m.questions_and_answers({}, { locale: Astro.locals.locale })}
      </h2>
      <p class="mx-auto mt-4 max-w-xl text-base leading-relaxed text-gray-200">
        {m.explore_common_questions({}, { locale: Astro.locals.locale })}
      </p>
    </div>
    <!-- Plan Features & Limits -->
    <div class="mx-auto mt-16 max-w-3xl">
      <div class="mb-8 text-center">
        <h3 class="mb-2 cursor-default text-2xl font-semibold text-white transition-colors duration-200 hover:text-blue-400">Plan Features & Limits</h3>
        <p class="text-sm text-gray-200">Everything you need to know about your plan's capabilities</p>
      </div>

      <div class="space-y-1 overflow-hidden rounded-2xl border border-gray-700 bg-gray-800 shadow-xl shadow-black/20">
        <details class="group border-b border-gray-700 last:border-b-0 open:border-blue-500/40 open:bg-blue-950/40" id="faq-mau">
          <summary class="flex cursor-pointer items-center justify-between px-8 py-6 transition-all duration-200 group-open:bg-blue-900/40 hover:bg-gray-700/60">
            <span class="pr-4 text-lg font-medium text-white transition-colors duration-200 group-open:text-blue-400 group-hover:text-blue-400"
              >{m.how_are_mau_counted({}, { locale: Astro.locals.locale })}</span
            >
            <svg
              class="h-5 w-5 shrink-0 text-gray-200 transition-all duration-300 group-open:rotate-180 group-open:text-blue-400"
              fill="none"
              viewBox="0 0 24 24"
              stroke="currentColor"
            >
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M19 9l-7 7-7-7"></path>
            </svg>
          </summary>
          <div class="bg-gray-950/40 px-8 pt-2 pb-6">
            <div class="space-y-3 leading-relaxed text-gray-200">
              <p>{m.mau_counting_explanation({}, { locale: Astro.locals.locale })}</p>
              <p>
                {m.capgo_usage_explanation({}, { locale: Astro.locals.locale })}
                <a
                  class="text-blue-400 underline decoration-1 underline-offset-2 transition-colors hover:text-blue-300"
                  href={getRelativeLocaleUrl(Astro.locals.locale, 'blog/how-your-usage-is-counted')}
                >
                  {m.here({}, { locale: Astro.locals.locale })}
                </a>
              </p>
            </div>
          </div>
        </details>

        <details class="group border-b border-gray-700 last:border-b-0" id="faq-storage">
          <summary class="flex cursor-pointer items-center justify-between px-8 py-6 transition-all duration-200 group-open:bg-blue-900/40 hover:bg-gray-700/60">
            <span class="pr-4 text-lg font-medium text-white transition-colors duration-200 group-open:text-blue-400 group-hover:text-blue-400"
              >{m.storage_what_is_it_used_for({}, { locale: Astro.locals.locale })}</span
            >
            <svg
              class="h-5 w-5 shrink-0 text-gray-200 transition-all duration-300 group-open:rotate-180 group-open:text-blue-400"
              fill="none"
              viewBox="0 0 24 24"
              stroke="currentColor"
            >
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M19 9l-7 7-7-7"></path>
            </svg>
          </summary>
          <div class="px-8 pt-2 pb-6">
            <div class="leading-relaxed text-gray-200">
              {m.storage_detailed_explanation({}, { locale: Astro.locals.locale })}
            </div>
          </div>
        </details>

        <details class="group border-b border-gray-700 last:border-b-0" id="faq-bandwidth">
          <summary class="flex cursor-pointer items-center justify-between px-8 py-6 transition-all duration-200 group-open:bg-blue-900/40 hover:bg-gray-700/60">
            <span class="pr-4 text-lg font-medium text-white transition-colors duration-200 group-open:text-blue-400 group-hover:text-blue-400"
              >{m.how_is_bandwidth_counted({}, { locale: Astro.locals.locale })}</span
            >
            <svg
              class="h-5 w-5 shrink-0 text-gray-200 transition-all duration-300 group-open:rotate-180 group-open:text-blue-400"
              fill="none"
              viewBox="0 0 24 24"
              stroke="currentColor"
            >
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M19 9l-7 7-7-7"></path>
            </svg>
          </summary>
          <div class="bg-gray-950/40 px-8 pt-2 pb-6">
            <div class="leading-relaxed text-gray-200">
              {m.bandwidth_explanation({}, { locale: Astro.locals.locale })}
            </div>
          </div>
        </details>

        <details class="group border-b border-gray-700 last:border-b-0" id="faq-build-time">
          <summary class="flex cursor-pointer items-center justify-between px-8 py-6 transition-all duration-200 group-open:bg-blue-900/40 hover:bg-gray-700/60">
            <span class="pr-4 text-lg font-medium text-white transition-colors duration-200 group-open:text-blue-400 group-hover:text-blue-400"
              >{m.what_does_build_time_refer_to({}, { locale: Astro.locals.locale })}</span
            >
            <svg
              class="h-5 w-5 shrink-0 text-gray-200 transition-all duration-300 group-open:rotate-180 group-open:text-blue-400"
              fill="none"
              viewBox="0 0 24 24"
              stroke="currentColor"
            >
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M19 9l-7 7-7-7"></path>
            </svg>
          </summary>
          <div class="bg-gray-950/40 px-8 pt-2 pb-6">
            <div class="leading-relaxed text-gray-200">
              {m.build_time_explanation({}, { locale: Astro.locals.locale })}
            </div>
          </div>
        </details>

        <details class="group border-b border-gray-700 last:border-b-0 open:border-blue-500/40 open:bg-blue-950/40" id="faq-mau-limit">
          <summary class="flex cursor-pointer items-center justify-between px-8 py-6 transition-all duration-200 group-open:bg-blue-900/40 hover:bg-gray-700/60">
            <span class="pr-4 text-lg font-medium text-white transition-colors duration-200 group-open:text-blue-400 group-hover:text-blue-400"
              >{m.what_happens_if_i_reach_the_mau_limit({}, { locale: Astro.locals.locale })}</span
            >
            <svg
              class="h-5 w-5 shrink-0 text-gray-200 transition-all duration-300 group-open:rotate-180 group-open:text-blue-400"
              fill="none"
              viewBox="0 0 24 24"
              stroke="currentColor"
            >
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M19 9l-7 7-7-7"></path>
            </svg>
          </summary>
          <div class="bg-gray-950/40 px-8 pt-2 pb-6">
            <div class="leading-relaxed text-gray-200">
              {m.what_happens_if_i_reach_the_mau_limit_answer({}, { locale: Astro.locals.locale })}
            </div>
          </div>
        </details>

        <details class="group border-b border-gray-700 last:border-b-0 open:border-blue-500/40 open:bg-blue-950/40" id="faq-storage-limit">
          <summary class="flex cursor-pointer items-center justify-between px-8 py-6 transition-all duration-200 group-open:bg-blue-900/40 hover:bg-gray-700/60">
            <span class="pr-4 text-lg font-medium text-white transition-colors duration-200 group-open:text-blue-400 group-hover:text-blue-400"
              >{m.what_happens_if_i_reach_the_storage_limit({}, { locale: Astro.locals.locale })}</span
            >
            <svg
              class="h-5 w-5 shrink-0 text-gray-200 transition-all duration-300 group-open:rotate-180 group-open:text-blue-400"
              fill="none"
              viewBox="0 0 24 24"
              stroke="currentColor"
            >
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M19 9l-7 7-7-7"></path>
            </svg>
          </summary>
          <div class="bg-gray-950/40 px-8 pt-2 pb-6">
            <div class="leading-relaxed text-gray-200">
              {m.what_happens_if_i_reach_the_storage_limit_answer({}, { locale: Astro.locals.locale })}
            </div>
          </div>
        </details>

        <details class="group border-b border-gray-700 last:border-b-0 open:border-blue-500/40 open:bg-blue-950/40" id="faq-bandwidth-limit">
          <summary class="flex cursor-pointer items-center justify-between px-8 py-6 transition-all duration-200 group-open:bg-blue-900/40 hover:bg-gray-700/60">
            <span class="pr-4 text-lg font-medium text-white transition-colors duration-200 group-open:text-blue-400 group-hover:text-blue-400"
              >{m.what_happens_if_i_reach_the_bandwidth_limit({}, { locale: Astro.locals.locale })}</span
            >
            <svg
              class="h-5 w-5 shrink-0 text-gray-200 transition-all duration-300 group-open:rotate-180 group-open:text-blue-400"
              fill="none"
              viewBox="0 0 24 24"
              stroke="currentColor"
            >
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M19 9l-7 7-7-7"></path>
            </svg>
          </summary>
          <div class="bg-gray-950/40 px-8 pt-2 pb-6">
            <div class="leading-relaxed text-gray-200">
              {m.what_happens_if_i_reach_the_bandwidth_limit_answer({}, { locale: Astro.locals.locale })}
            </div>
          </div>
        </details>

        <details class="group border-b border-gray-700 last:border-b-0 open:border-blue-500/40 open:bg-blue-950/40" id="faq-capacitor-config">
          <summary class="flex cursor-pointer items-center justify-between px-8 py-6 transition-all duration-200 group-open:bg-blue-900/40 hover:bg-gray-700/60">
            <span class="pr-4 text-lg font-medium text-white transition-colors duration-200 group-open:text-blue-400 group-hover:text-blue-400"
              >{m.capacitor_config_changes_question({}, { locale: Astro.locals.locale })}</span
            >
            <svg
              class="h-5 w-5 shrink-0 text-gray-200 transition-all duration-300 group-open:rotate-180 group-open:text-blue-400"
              fill="none"
              viewBox="0 0 24 24"
              stroke="currentColor"
            >
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M19 9l-7 7-7-7"></path>
            </svg>
          </summary>
          <div class="bg-gray-950/40 px-8 pt-2 pb-6">
            <div class="leading-relaxed text-gray-200">
              {m.capacitor_config_changes_answer({}, { locale: Astro.locals.locale })}
            </div>
          </div>
        </details>
      </div>
    </div>

    <!-- Billing & Payments -->
    <div class="mx-auto mt-16 max-w-3xl">
      <div class="mb-8 text-center">
        <h3 class="mb-2 cursor-default text-2xl font-semibold text-white transition-colors duration-200 hover:text-blue-400">Billing & Payments</h3>
        <p class="text-sm text-gray-200">Everything about pricing, payments, and subscriptions</p>
      </div>

      <div class="space-y-1 overflow-hidden rounded-2xl border border-gray-700 bg-gray-800 shadow-xl shadow-black/20">
        <details class="group border-b border-gray-700 last:border-b-0 open:border-blue-500/40 open:bg-blue-950/40" id="faq-annual-ach">
          <summary class="flex cursor-pointer items-center justify-between px-8 py-6 transition-all duration-200 group-open:bg-blue-900/40 hover:bg-gray-700/60">
            <span class="pr-4 text-lg font-medium text-white transition-colors duration-200 group-open:text-blue-400 group-hover:text-blue-400"
              >{m.do_you_offer_annual_billing_and_ach_payment_options({}, { locale: Astro.locals.locale })}</span
            >
            <svg
              class="h-5 w-5 shrink-0 text-gray-200 transition-all duration-300 group-open:rotate-180 group-open:text-blue-400"
              fill="none"
              viewBox="0 0 24 24"
              stroke="currentColor"
            >
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M19 9l-7 7-7-7"></path>
            </svg>
          </summary>
          <div class="bg-gray-950/40 px-8 pt-2 pb-6">
            <div class="leading-relaxed text-gray-200">
              {m.ach_available_for_enterprise_annual_payments({}, { locale: Astro.locals.locale })}
            </div>
          </div>
        </details>

        <details class="group border-b border-gray-700 last:border-b-0 open:border-blue-500/40 open:bg-blue-950/40" id="faq-payment-methods">
          <summary class="flex cursor-pointer items-center justify-between px-8 py-6 transition-all duration-200 group-open:bg-blue-900/40 hover:bg-gray-700/60">
            <span class="pr-4 text-lg font-medium text-white transition-colors duration-200 group-open:text-blue-400 group-hover:text-blue-400"
              >{m.what_payment_methods_do_you_accept({}, { locale: Astro.locals.locale })}</span
            >
            <svg
              class="h-5 w-5 shrink-0 text-gray-200 transition-all duration-300 group-open:rotate-180 group-open:text-blue-400"
              fill="none"
              viewBox="0 0 24 24"
              stroke="currentColor"
            >
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M19 9l-7 7-7-7"></path>
            </svg>
          </summary>
          <div class="bg-gray-950/40 px-8 pt-2 pb-6">
            <div class="leading-relaxed text-gray-200">
              {m.what_payment_methods_answer({}, { locale: Astro.locals.locale })}
            </div>
          </div>
        </details>

        <details class="group border-b border-gray-700 last:border-b-0 open:border-blue-500/40 open:bg-blue-950/40">
          <summary class="flex cursor-pointer items-center justify-between px-8 py-6 transition-all duration-200 group-open:bg-blue-900/40 hover:bg-gray-700/60">
            <span class="pr-4 text-lg font-medium text-white transition-colors duration-200 group-open:text-blue-400 group-hover:text-blue-400"
              >{m.can_i_change_my_plan_at_any_time({}, { locale: Astro.locals.locale })}</span
            >
            <svg
              class="h-5 w-5 shrink-0 text-gray-200 transition-all duration-300 group-open:rotate-180 group-open:text-blue-400"
              fill="none"
              viewBox="0 0 24 24"
              stroke="currentColor"
            >
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M19 9l-7 7-7-7"></path>
            </svg>
          </summary>
          <div class="bg-gray-950/40 px-8 pt-2 pb-6">
            <div class="leading-relaxed text-gray-200">
              {m.can_i_change_my_plan_answer({}, { locale: Astro.locals.locale })}
            </div>
          </div>
        </details>

        <details class="group border-b border-gray-700 last:border-b-0 open:border-blue-500/40 open:bg-blue-950/40">
          <summary class="flex cursor-pointer items-center justify-between px-8 py-6 transition-all duration-200 group-open:bg-blue-900/40 hover:bg-gray-700/60">
            <span class="pr-4 text-lg font-medium text-white transition-colors duration-200 group-open:text-blue-400 group-hover:text-blue-400"
              >{m.can_i_cancel_at_any_time({}, { locale: Astro.locals.locale })}</span
            >
            <svg
              class="h-5 w-5 shrink-0 text-gray-200 transition-all duration-300 group-open:rotate-180 group-open:text-blue-400"
              fill="none"
              viewBox="0 0 24 24"
              stroke="currentColor"
            >
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M19 9l-7 7-7-7"></path>
            </svg>
          </summary>
          <div class="bg-gray-950/40 px-8 pt-2 pb-6">
            <div class="leading-relaxed text-gray-200">
              {m.cancellation_policy_details({}, { locale: Astro.locals.locale })}
            </div>
          </div>
        </details>

        <details class="group border-b border-gray-700 last:border-b-0 open:border-blue-500/40 open:bg-blue-950/40">
          <summary class="flex cursor-pointer items-center justify-between px-8 py-6 transition-all duration-200 group-open:bg-blue-900/40 hover:bg-gray-700/60">
            <span class="pr-4 text-lg font-medium text-white transition-colors duration-200 group-open:text-blue-400 group-hover:text-blue-400"
              >{m.do_you_offer_refunds({}, { locale: Astro.locals.locale })}</span
            >
            <svg
              class="h-5 w-5 shrink-0 text-gray-200 transition-all duration-300 group-open:rotate-180 group-open:text-blue-400"
              fill="none"
              viewBox="0 0 24 24"
              stroke="currentColor"
            >
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M19 9l-7 7-7-7"></path>
            </svg>
          </summary>
          <div class="bg-gray-950/40 px-8 pt-2 pb-6">
            <div class="leading-relaxed text-gray-200">
              {m.do_you_offer_refunds_answer({}, { locale: Astro.locals.locale })}
            </div>
          </div>
        </details>

        <details class="group border-b border-gray-700 last:border-b-0 open:border-blue-500/40 open:bg-blue-950/40">
          <summary class="flex cursor-pointer items-center justify-between px-8 py-6 transition-all duration-200 group-open:bg-blue-900/40 hover:bg-gray-700/60">
            <span class="pr-4 text-lg font-medium text-white transition-colors duration-200 group-open:text-blue-400 group-hover:text-blue-400"
              >{m.are_there_any_setup_fees_or_hidden_costs({}, { locale: Astro.locals.locale })}</span
            >
            <svg
              class="h-5 w-5 shrink-0 text-gray-200 transition-all duration-300 group-open:rotate-180 group-open:text-blue-400"
              fill="none"
              viewBox="0 0 24 24"
              stroke="currentColor"
            >
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M19 9l-7 7-7-7"></path>
            </svg>
          </summary>
          <div class="bg-gray-950/40 px-8 pt-2 pb-6">
            <div class="leading-relaxed text-gray-200">
              {m.are_there_any_setup_fees_answer({}, { locale: Astro.locals.locale })}
            </div>
          </div>
        </details>

        <details class="group border-b border-gray-700 last:border-b-0 open:border-blue-500/40 open:bg-blue-950/40" id="faq-credits">
          <summary class="flex cursor-pointer items-center justify-between px-8 py-6 transition-all duration-200 group-open:bg-blue-900/40 hover:bg-gray-700/60">
            <span class="pr-4 text-lg font-medium text-white transition-colors duration-200 group-open:text-blue-400 group-hover:text-blue-400"
              >{m.can_i_use_credits_without_subscription({}, { locale: Astro.locals.locale })}</span
            >
            <svg
              class="h-5 w-5 shrink-0 text-gray-200 transition-all duration-300 group-open:rotate-180 group-open:text-blue-400"
              fill="none"
              viewBox="0 0 24 24"
              stroke="currentColor"
            >
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M19 9l-7 7-7-7"></path>
            </svg>
          </summary>
          <div class="bg-gray-950/40 px-8 pt-2 pb-6">
            <div class="leading-relaxed text-gray-200">
              {m.can_i_use_credits_without_subscription_answer({}, { locale: Astro.locals.locale })}
            </div>
          </div>
        </details>

        <details class="group border-b border-gray-700 last:border-b-0 open:border-blue-500/40 open:bg-blue-950/40" id="faq-cancel">
          <summary class="flex cursor-pointer items-center justify-between px-8 py-6 transition-all duration-200 group-open:bg-blue-900/40 hover:bg-gray-700/60">
            <span class="pr-4 text-lg font-medium text-white transition-colors duration-200 group-open:text-blue-400 group-hover:text-blue-400"
              >{m.capgo_availability_faq_title({}, { locale: Astro.locals.locale })}</span
            >
            <svg
              aria-hidden="true"
              class="h-5 w-5 shrink-0 text-gray-200 transition-all duration-300 group-open:rotate-180 group-open:text-blue-400"
              fill="none"
              viewBox="0 0 24 24"
              stroke="currentColor"
            >
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M19 9l-7 7-7-7"></path>
            </svg>
          </summary>
          <div class="bg-gray-950/40 px-8 pt-2 pb-6">
            <div class="leading-relaxed text-gray-200">
              <p class="mb-3">{m.capgo_availability_faq_intro({}, { locale: Astro.locals.locale })}</p>
              <ul class="mb-4 list-inside list-disc space-y-2">
                <li><strong>Capgo is down:</strong> {m.capgo_availability_faq_capgo_down({}, { locale: Astro.locals.locale })}</li>
                <li><strong>Subscription canceled:</strong> {m.capgo_availability_faq_canceled({}, { locale: Astro.locals.locale })}</li>
                <li><strong>Above plan limits:</strong> {m.capgo_availability_faq_limits({}, { locale: Astro.locals.locale })}</li>
              </ul>
              <a href={getRelativeLocaleUrl(Astro.locals.locale, 'docs/capgo-availability')} class="text-blue-400 underline transition-colors hover:text-blue-300"
                >{m.capgo_availability_faq_link({}, { locale: Astro.locals.locale })} →</a
              >
            </div>
          </div>
        </details>
      </div>
    </div>

    <!-- Trial & Support -->
    <div class="mx-auto mt-16 max-w-3xl">
      <div class="mb-8 text-center">
        <h3 class="mb-2 cursor-default text-2xl font-semibold text-white transition-colors duration-200 hover:text-blue-400">Trial & Support</h3>
        <p class="text-sm text-gray-200">Free trials, discounts, and getting help</p>
      </div>

      <div class="space-y-1 overflow-hidden rounded-2xl border border-gray-700 bg-gray-800 shadow-xl shadow-black/20">
        <details class="group border-b border-gray-700 last:border-b-0 open:border-blue-500/40 open:bg-blue-950/40">
          <summary class="flex cursor-pointer items-center justify-between px-8 py-6 transition-all duration-200 group-open:bg-blue-900/40 hover:bg-gray-700/60">
            <span class="pr-4 text-lg font-medium text-white transition-colors duration-200 group-open:text-blue-400 group-hover:text-blue-400"
              >{m.unsure_about_active_users({}, { locale: Astro.locals.locale })}</span
            >
            <svg
              class="h-5 w-5 shrink-0 text-gray-200 transition-all duration-300 group-open:rotate-180 group-open:text-blue-400"
              fill="none"
              viewBox="0 0 24 24"
              stroke="currentColor"
            >
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M19 9l-7 7-7-7"></path>
            </svg>
          </summary>
          <div class="bg-gray-950/40 px-8 pt-2 pb-6">
            <div class="leading-relaxed text-gray-200">
              {m.free_trial_explanation({}, { locale: Astro.locals.locale })}
            </div>
          </div>
        </details>

        <details class="group border-b border-gray-700 last:border-b-0 open:border-blue-500/40 open:bg-blue-950/40">
          <summary class="flex cursor-pointer items-center justify-between px-8 py-6 transition-all duration-200 group-open:bg-blue-900/40 hover:bg-gray-700/60">
            <span class="pr-4 text-lg font-medium text-white transition-colors duration-200 group-open:text-blue-400 group-hover:text-blue-400"
