{
  "name": "capgo-website",
  "compatibility_date": "2026-03-29",
  "compatibility_flags": ["nodejs_compat", "disable_nodejs_process_v2"],
  "assets": {
    "directory": "./dist",
    "not_found_handling": "single-page-application"
  },
  "workers_dev": false,
  "routes": [
    {
      "pattern": "capgo.app",
      "custom_domain": true
    }
  ]
}
