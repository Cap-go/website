---
import Layout from '@/layouts/Layout.astro'
import * as m from '@/paraglide/messages'

const title = [Astro.locals.runtimeConfig.public.brand, m.support_policy_title({}, { locale: Astro.locals.locale })].join(' | ')
const description = m.support_policy_description({}, { locale: Astro.locals.locale })

const content = { title, description }
---

<Layout content={content}>
  <div class="py-8 m-auto prose-sm prose prose-invert">
    <h1>{m.support_policy_title({}, { locale: Astro.locals.locale })}</h1>
    <p>
      {m.support_policy_intro({}, { locale: Astro.locals.locale })}
    </p>
    <h2>{m.support_policy_scope_title({}, { locale: Astro.locals.locale })}</h2>
    <p>{m.support_policy_scope_intro({}, { locale: Astro.locals.locale })}</p>
    <h3>{m.support_policy_configuration_issues_title({}, { locale: Astro.locals.locale })}</h3>
    <ul>
      <li>{m.support_policy_configuration_issues_1({}, { locale: Astro.locals.locale })}</li>
      <li>{m.support_policy_configuration_issues_2({}, { locale: Astro.locals.locale })}</li>
      <li>{m.support_policy_configuration_issues_3({}, { locale: Astro.locals.locale })}</li>
    </ul>
    <h3>{m.support_policy_troubleshooting_title({}, { locale: Astro.locals.locale })}</h3>
    <ul>
      <li>{m.support_policy_troubleshooting_1({}, { locale: Astro.locals.locale })}</li>
      <li>{m.support_policy_troubleshooting_2({}, { locale: Astro.locals.locale })}</li>
      <li>{m.support_policy_troubleshooting_3({}, { locale: Astro.locals.locale })}</li>
    </ul>
    <h3>{m.support_policy_not_covered_title({}, { locale: Astro.locals.locale })}</h3>
    <p>{m.support_policy_not_covered_intro({}, { locale: Astro.locals.locale })}</p>
    <ul>
      <li>{m.support_policy_not_covered_1({}, { locale: Astro.locals.locale })}</li>
      <li>{m.support_policy_not_covered_2({}, { locale: Astro.locals.locale })}</li>
      <li>{m.support_policy_not_covered_3({}, { locale: Astro.locals.locale })}</li>
    </ul>
    <p>{m.support_policy_billing_support({}, { locale: Astro.locals.locale })}</p>
    <p>{m.support_policy_limited_support_intro({}, { locale: Astro.locals.locale })}</p>
    <ul>
      <li>{m.support_policy_limited_support_1({}, { locale: Astro.locals.locale })}</li>
      <li>{m.support_policy_limited_support_2({}, { locale: Astro.locals.locale })}</li>
      <li>{m.support_policy_limited_support_3({}, { locale: Astro.locals.locale })}</li>
    </ul>
    <h2>{m.support_policy_official_channels_title({}, { locale: Astro.locals.locale })}</h2>
    <ul>
      <li>{m.support_policy_official_channels_1({}, { locale: Astro.locals.locale })}</li>
      <li>{m.support_policy_official_channels_2({}, { locale: Astro.locals.locale })}</li>
    </ul>
    <p>
      {m.support_policy_official_channels_note({}, { locale: Astro.locals.locale })}
    </p>
    <p>
      {m.support_policy_code_debugging({}, { locale: Astro.locals.locale })}
    </p>
    <p>
      {m.support_policy_community_response({}, { locale: Astro.locals.locale })}
    </p>
    <p>{m.support_policy_team_participation({}, { locale: Astro.locals.locale })}</p>
    <h2>{m.support_policy_sla_title({}, { locale: Astro.locals.locale })}</h2>
    <p>
      {m.support_policy_sla_desc({}, { locale: Astro.locals.locale })}
      <a href="https://capgo.app/sla">https://capgo.app/sla</a>
    </p>
    <h2>{m.support_policy_proactive_monitoring_title({}, { locale: Astro.locals.locale })}</h2>
    <p>
      {m.support_policy_proactive_monitoring_desc({}, { locale: Astro.locals.locale })}
    </p>
    <h2>{m.support_policy_premium_support_title({}, { locale: Astro.locals.locale })}</h2>
    <p>{m.support_policy_premium_support_desc({}, { locale: Astro.locals.locale })}</p>

    <h2 id="service-disruption-and-ending">Service disruption and plan ending</h2>
    <p>
      The update system is designed to fail safe. If Capgo is unavailable, the app keeps running and no user-facing freeze is introduced by the update check.
    </p>
    <p>
      In every update mode, if the plugin cannot get an answer from the update service within 3 seconds, it cancels the request and opens the app normally.
    </p>
    <ul>
      <li>
        <strong>If Capgo is down:</strong> in background mode, this is usually invisible to users. In direct mode, the service may return a 500-style result when reachable; if the server is simply too slow, the plugin waits up to 3 seconds, cancels the query, and continues normal app startup.
      </li>
      <li>
        <strong>If payment is stopped or billing is canceled:</strong> the last successfully installed update remains on each phone, but no new updates are downloaded.
      </li>
      <li>
        <strong>If traffic goes beyond your plan:</strong> no devices (new or old) will receive additional updates until the plan is back in scope.
      </li>
    </ul>
    <p>
      In every scenario above, your app remains usable with the last installed version, and updates are simply skipped until service resumes.
    </p>

    <p><a href="mailto:martin@capgo.app">martin@capgo.app</a></p>
  </div>
</Layout>
