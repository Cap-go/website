---
import Layout from '@/layouts/Layout.astro'
import { integrations } from '@/config/integrations'

const brand = Astro.locals.runtimeConfig.public.brand

const title = `${brand} | Integrations`
const description = 'Current Capgo integrations and partner services.'

const content = { title, description }
---

<Layout content={content}>
  <div class="min-h-screen bg-gray-900">
    <section class="px-4 py-20 mx-auto max-w-6xl sm:px-6 lg:px-8">
      <div class="space-y-8 text-center">
        <p class="inline-flex px-4 py-2 text-xs font-medium border rounded-full text-zinc-300 border-zinc-700 bg-zinc-800/80">Integrations</p>
        <h1 class="text-4xl font-bold text-white sm:text-5xl">Capgo Integrations</h1>
        <p class="max-w-2xl mx-auto text-lg text-zinc-300">
          The only integration we currently list is ViaSocket.
        </p>
      </div>

      <div class="grid gap-8 mt-12 sm:grid-cols-2 lg:grid-cols-3">
        {integrations.map((integration) => (
          <div class="p-8 border rounded-2xl border-zinc-800 bg-zinc-900/70">
            <h2 class="mb-4 text-xl font-semibold text-white">{integration.name}</h2>
            <p class="mb-6 text-zinc-300">{integration.description}</p>
            <a
              href={integration.href}
              target={integration.target}
              rel={integration.rel}
              class="inline-flex items-center px-4 py-2 text-sm font-medium text-white rounded-lg bg-blue-600 hover:bg-blue-500"
            >
              <img src={integration.logo} alt={integration.name} class="w-8 h-8 mr-3" />
              Visit {integration.name} integration
            </a>
          </div>
        ))}
      </div>
    </section>
  </div>
</Layout>
