---
import Layout from '@/layouts/Layout.astro'
import * as m from '@/services/messages'
import { getRelativeLocaleUrl } from 'astro:i18n'
import HandoffIllustration from '@/components/solutions/HandoffIllustration.astro'
import BugFixIllustration from '@/components/solutions/BugFixIllustration.astro'
import RolloutIllustration from '@/components/solutions/RolloutIllustration.astro'
import SecurityIllustration from '@/components/solutions/SecurityIllustration.astro'
import { createServiceLdJson, createLdJsonGraph } from '@/lib/ldJson'

const locale = Astro.locals.locale
const brand = Astro.locals.runtimeConfig.public.brand

const title = `${brand} | ${m.solutions_cordova_to_capacitor_title({}, { locale })}`
const description = m.solutions_cordova_to_capacitor_description({}, { locale })

const serviceLdJson = createServiceLdJson(Astro.locals.runtimeConfig.public, {
  name: title,
  description: description,
  url: Astro.url.href,
  serviceType: 'Software Development Service',
  areaServed: ['Worldwide'],
})

const ldJSON = createLdJsonGraph(Astro.locals.runtimeConfig.public, serviceLdJson, {
  includeOrganization: true,
})

const content = { title, description, ldJSON }
---

<Layout content={content}>
  <div>
    <!-- Hero -->
    <section class="relative overflow-hidden py-20 sm:py-28 lg:py-36">
      <div class="pointer-events-none absolute inset-0 overflow-hidden">
        <div class="absolute inset-0 bg-linear-to-b from-sky-900/30 via-gray-900/60 to-gray-900"></div>
        <div class="absolute top-0 left-1/2 h-full w-full max-w-6xl -translate-x-1/2">
          <div aria-hidden="true" class="absolute top-16 left-10 h-112 w-md rounded-full bg-orange-500/10 blur-3xl"></div>
          <div aria-hidden="true" class="absolute right-10 bottom-12 h-112 w-md rounded-full bg-sky-500/10 blur-3xl"></div>
        </div>
      </div>

      <div class="relative mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
        <div class="mx-auto max-w-4xl text-center">
          <div class="mb-8 inline-flex items-center rounded-full border border-sky-400/40 bg-sky-500/10 px-4 py-2 text-sm font-medium text-sky-200">
            <svg aria-hidden="true" class="mr-2 h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 17l4 4 4-4m-4-5v9m4-19H8a2 2 0 00-2 2v10a2 2 0 002 2h8a2 2 0 002-2V4a2 2 0 00-2-2z"
              ></path>
            </svg>
            {m.solutions_cordova_to_capacitor_badge({}, { locale })}
          </div>

          <h1 class="text-4xl leading-tight font-bold text-white sm:text-5xl lg:text-6xl">
            {m.solutions_cordova_to_capacitor_hero_title({}, { locale })}
          </h1>

          <p class="mx-auto mt-8 max-w-3xl text-xl leading-relaxed text-gray-300">
            {m.solutions_cordova_to_capacitor_hero_subtitle({}, { locale })}
          </p>

          <div class="mt-10 flex flex-col items-center justify-center gap-4 sm:flex-row">
            <a
              href={getRelativeLocaleUrl(locale, 'register')}
              class="rounded-xl bg-sky-600 px-8 py-4 text-base font-semibold text-white shadow-lg shadow-sky-500/20 transition-all duration-200 hover:bg-sky-700 focus:ring-2 focus:ring-sky-500 focus:ring-offset-2"
            >
              {m.solutions_start_free_trial({}, { locale })}
            </a>
            <a
              href="https://cal.com/team/capgo/convert-your-cordova-app-to-capacitor"
              class="rounded-xl border border-gray-600 px-8 py-4 text-base font-semibold text-gray-300 transition-all duration-200 hover:bg-gray-800 hover:text-white"
            >
              {m.solutions_talk_to_team({}, { locale })}
            </a>
          </div>

          <div class="mt-10 inline-flex items-center gap-2 rounded-full border border-orange-400/30 bg-orange-500/10 px-4 py-2 text-orange-200">
            <svg aria-hidden="true" class="h-5 w-5 text-orange-300" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"></path>
            </svg>
            {m.solutions_cordova_to_capacitor_hero_highlight({}, { locale })}
          </div>
        </div>
      </div>
    </section>

    <!-- Reality -->
    <section class="bg-gray-800 py-20">
      <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
        <div class="mx-auto mb-16 max-w-3xl text-center">
          <h2 class="mb-4 text-sm font-semibold tracking-wide text-orange-300 uppercase">{m.solutions_cordova_to_capacitor_reality_label({}, { locale })}</h2>
          <h3 class="text-3xl font-bold text-white sm:text-4xl">{m.solutions_cordova_to_capacitor_reality_title({}, { locale })}</h3>
          <p class="mt-4 text-xl text-gray-400">{m.solutions_cordova_to_capacitor_reality_subtitle({}, { locale })}</p>
        </div>

        <div class="grid grid-cols-1 gap-8 md:grid-cols-2">
          <div class="rounded-2xl border border-orange-500/20 bg-gray-900 p-8">
            <div class="flex items-start gap-4">
              <div class="flex h-12 w-12 shrink-0 items-center justify-center rounded-lg bg-orange-500/20">
                <svg aria-hidden="true" class="h-6 w-6 text-orange-300" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                  <path
                    stroke-linecap="round"
                    stroke-linejoin="round"
                    stroke-width="2"
                    d="M12 8c-1.657 0-3 .895-3 2s1.343 2 3 2 3 .895 3 2-1.343 2-3 2m0-8c1.11 0 2.08.402 2.599 1M12 8V7m0 1v8m0 0v1m0-1c-1.11 0-2.08-.402-2.599-1"></path>
                </svg>
              </div>
              <div>
                <h4 class="mb-1 text-lg font-bold text-white">{m.solutions_cordova_to_capacitor_pain1_title({}, { locale })}</h4>
                <p class="text-gray-400">{m.solutions_cordova_to_capacitor_pain1_desc({}, { locale })}</p>
              </div>
            </div>
          </div>

          <div class="rounded-2xl border border-orange-500/20 bg-gray-900 p-8">
            <div class="flex items-start gap-4">
              <div class="flex h-12 w-12 shrink-0 items-center justify-center rounded-lg bg-orange-500/20">
                <svg aria-hidden="true" class="h-6 w-6 text-orange-300" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                  <path
                    stroke-linecap="round"
                    stroke-linejoin="round"
                    stroke-width="2"
                    d="M12 9v2m0 4h.01M5.07 19h13.86c1.54 0 2.5-1.67 1.73-3L13.73 4c-.77-1.33-2.69-1.33-3.46 0L3.34 16c-.77 1.33.19 3 1.73 3z"></path>
                </svg>
              </div>
              <div>
                <h4 class="mb-1 text-lg font-bold text-white">{m.solutions_cordova_to_capacitor_pain2_title({}, { locale })}</h4>
                <p class="text-gray-400">{m.solutions_cordova_to_capacitor_pain2_desc({}, { locale })}</p>
              </div>
            </div>
          </div>

          <div class="rounded-2xl border border-orange-500/20 bg-gray-900 p-8">
            <div class="flex items-start gap-4">
              <div class="flex h-12 w-12 shrink-0 items-center justify-center rounded-lg bg-orange-500/20">
                <svg aria-hidden="true" class="h-6 w-6 text-orange-300" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                  <path
                    stroke-linecap="round"
                    stroke-linejoin="round"
                    stroke-width="2"
                    d="M9 17v-2a4 4 0 014-4h4M9 7h.01M15 7h.01M7 21h10a2 2 0 002-2V5a2 2 0 00-2-2H7a2 2 0 00-2 2v14a2 2 0 002 2z"></path>
                </svg>
              </div>
              <div>
                <h4 class="mb-1 text-lg font-bold text-white">{m.solutions_cordova_to_capacitor_pain3_title({}, { locale })}</h4>
                <p class="text-gray-400">{m.solutions_cordova_to_capacitor_pain3_desc({}, { locale })}</p>
              </div>
            </div>
          </div>

          <div class="rounded-2xl border border-orange-500/20 bg-gray-900 p-8">
            <div class="flex items-start gap-4">
              <div class="flex h-12 w-12 shrink-0 items-center justify-center rounded-lg bg-orange-500/20">
                <svg aria-hidden="true" class="h-6 w-6 text-orange-300" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z"></path>
                </svg>
              </div>
              <div>
                <h4 class="mb-1 text-lg font-bold text-white">{m.solutions_cordova_to_capacitor_pain4_title({}, { locale })}</h4>
                <p class="text-gray-400">{m.solutions_cordova_to_capacitor_pain4_desc({}, { locale })}</p>
              </div>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- Benefits -->
    <section class="bg-gray-900 py-20">
      <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
        <div class="mx-auto mb-16 max-w-3xl text-center">
          <h2 class="mb-4 text-sm font-semibold tracking-wide text-sky-300 uppercase">{m.solutions_cordova_to_capacitor_benefits_label({}, { locale })}</h2>
          <h3 class="text-3xl font-bold text-white sm:text-4xl">{m.solutions_cordova_to_capacitor_benefits_title({}, { locale })}</h3>
          <p class="mt-4 text-xl text-gray-400">{m.solutions_cordova_to_capacitor_benefits_subtitle({}, { locale })}</p>
        </div>

        <div class="grid grid-cols-1 items-start gap-8 lg:grid-cols-2">
          <div class="grid grid-cols-1 gap-6 sm:grid-cols-2">
            <div class="rounded-2xl border border-gray-700 bg-gray-800 p-6 transition-colors hover:border-sky-500/40">
              <div class="mb-4 flex h-12 w-12 items-center justify-center rounded-lg bg-sky-500/15">
                <svg aria-hidden="true" class="h-6 w-6 text-sky-300" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                  <path
                    stroke-linecap="round"
                    stroke-linejoin="round"
                    stroke-width="2"
                    d="M8 10h.01M12 10h.01M16 10h.01M9 16h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h10a2 2 0 012 2v14a2 2 0 01-2 2z"></path>
                </svg>
              </div>
              <h4 class="mb-2 text-lg font-bold text-white">{m.solutions_cordova_to_capacitor_benefit1_title({}, { locale })}</h4>
              <p class="text-gray-400">{m.solutions_cordova_to_capacitor_benefit1_desc({}, { locale })}</p>
            </div>

            <div class="rounded-2xl border border-gray-700 bg-gray-800 p-6 transition-colors hover:border-sky-500/40">
              <div class="mb-4 flex h-12 w-12 items-center justify-center rounded-lg bg-sky-500/15">
                <svg aria-hidden="true" class="h-6 w-6 text-sky-300" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"></path>
                </svg>
              </div>
              <h4 class="mb-2 text-lg font-bold text-white">{m.solutions_cordova_to_capacitor_benefit2_title({}, { locale })}</h4>
              <p class="text-gray-400">{m.solutions_cordova_to_capacitor_benefit2_desc({}, { locale })}</p>
            </div>

            <div class="rounded-2xl border border-gray-700 bg-gray-800 p-6 transition-colors hover:border-sky-500/40">
              <div class="mb-4 flex h-12 w-12 items-center justify-center rounded-lg bg-sky-500/15">
                <svg aria-hidden="true" class="h-6 w-6 text-sky-300" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z"></path>
                </svg>
              </div>
              <h4 class="mb-2 text-lg font-bold text-white">{m.solutions_cordova_to_capacitor_benefit3_title({}, { locale })}</h4>
              <p class="text-gray-400">{m.solutions_cordova_to_capacitor_benefit3_desc({}, { locale })}</p>
            </div>

            <div class="rounded-2xl border border-gray-700 bg-gray-800 p-6 transition-colors hover:border-sky-500/40">
              <div class="mb-4 flex h-12 w-12 items-center justify-center rounded-lg bg-sky-500/15">
                <svg aria-hidden="true" class="h-6 w-6 text-sky-300" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"></path>
                </svg>
              </div>
              <h4 class="mb-2 text-lg font-bold text-white">{m.solutions_cordova_to_capacitor_benefit4_title({}, { locale })}</h4>
              <p class="text-gray-400">{m.solutions_cordova_to_capacitor_benefit4_desc({}, { locale })}</p>
            </div>

            <div class="rounded-2xl border border-gray-700 bg-gray-800 p-6 transition-colors hover:border-sky-500/40">
              <div class="mb-4 flex h-12 w-12 items-center justify-center rounded-lg bg-sky-500/15">
                <svg aria-hidden="true" class="h-6 w-6 text-sky-300" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M7 16a4 4 0 01-.88-7.903A5 5 0 1115.9 6L16 6a5 5 0 011 9.9M13 13l-1 1m0 0l-1-1m1 1V8"
                  ></path>
                </svg>
              </div>
              <h4 class="mb-2 text-lg font-bold text-white">{m.solutions_cordova_to_capacitor_benefit5_title({}, { locale })}</h4>
              <p class="text-gray-400">{m.solutions_cordova_to_capacitor_benefit5_desc({}, { locale })}</p>
            </div>

            <div class="rounded-2xl border border-gray-700 bg-gray-800 p-6 transition-colors hover:border-sky-500/40">
              <div class="mb-4 flex h-12 w-12 items-center justify-center rounded-lg bg-sky-500/15">
                <svg aria-hidden="true" class="h-6 w-6 text-sky-300" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                  <path
                    stroke-linecap="round"
                    stroke-linejoin="round"
                    stroke-width="2"
                    d="M12 11c1.104 0 2-.896 2-2V7a2 2 0 10-4 0v2c0 1.104.896 2 2 2zm6 0h-1V9a5 5 0 00-10 0v2H6a2 2 0 00-2 2v7a2 2 0 002 2h12a2 2 0 002-2v-7a2 2 0 00-2-2z"></path>
                </svg>
              </div>
              <h4 class="mb-2 text-lg font-bold text-white">{m.solutions_cordova_to_capacitor_benefit6_title({}, { locale })}</h4>
              <p class="text-gray-400">{m.solutions_cordova_to_capacitor_benefit6_desc({}, { locale })}</p>
            </div>

            <div class="rounded-2xl border border-gray-700 bg-gray-800 p-6 transition-colors hover:border-sky-500/40">
              <div class="mb-4 flex h-12 w-12 items-center justify-center rounded-lg bg-sky-500/15">
                <svg aria-hidden="true" class="h-6 w-6 text-sky-300" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 16h-1v-4h-1m1-4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"></path>
                </svg>
              </div>
              <h4 class="mb-2 text-lg font-bold text-white">{m.solutions_cordova_to_capacitor_benefit7_title({}, { locale })}</h4>
              <p class="text-gray-400">{m.solutions_cordova_to_capacitor_benefit7_desc({}, { locale })}</p>
            </div>

            <div class="rounded-2xl border border-gray-700 bg-gray-800 p-6 transition-colors hover:border-sky-500/40">
              <div class="mb-4 flex h-12 w-12 items-center justify-center rounded-lg bg-sky-500/15">
                <svg aria-hidden="true" class="h-6 w-6 text-sky-300" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 17v-2a4 4 0 014-4h4m-6-5h.01M19 21V5a2 2 0 00-2-2H7a2 2 0 00-2 2v16"></path>
                </svg>
              </div>
              <h4 class="mb-2 text-lg font-bold text-white">{m.solutions_cordova_to_capacitor_benefit8_title({}, { locale })}</h4>
              <p class="text-gray-400">{m.solutions_cordova_to_capacitor_benefit8_desc({}, { locale })}</p>
            </div>
          </div>

          <div class="space-y-6">
            <div class="rounded-2xl border border-gray-700 bg-gray-800 p-8">
              <div class="grid grid-cols-1 items-center gap-6 sm:grid-cols-2">
                <div>
                  <h4 class="mb-3 text-xl font-bold text-white">{m.solutions_cordova_to_capacitor_scope_title({}, { locale })}</h4>
                  <p class="text-gray-400">{m.solutions_cordova_to_capacitor_scope_note({}, { locale })}</p>
                </div>
                <div class="overflow-hidden rounded-xl border border-gray-700 bg-gray-900">
                  <HandoffIllustration />
                </div>
              </div>

              <div class="mt-8 grid grid-cols-1 gap-6 md:grid-cols-2">
                <div class="rounded-xl border border-gray-700 bg-gray-900 p-6">
                  <h5 class="mb-2 font-bold text-white">{m.solutions_cordova_to_capacitor_scope_keep_title({}, { locale })}</h5>
                  <ul class="space-y-2 text-sm text-gray-400" set:html={m.solutions_cordova_to_capacitor_scope_keep_html({}, { locale })} />
                </div>
                <div class="rounded-xl border border-gray-700 bg-gray-900 p-6">
                  <h5 class="mb-2 font-bold text-white">{m.solutions_cordova_to_capacitor_scope_upgrade_title({}, { locale })}</h5>
                  <ul class="space-y-2 text-sm text-gray-400" set:html={m.solutions_cordova_to_capacitor_scope_upgrade_html({}, { locale })} />
                </div>
              </div>
            </div>

            <div class="grid grid-cols-1 gap-6 sm:grid-cols-2">
              <div class="overflow-hidden rounded-2xl border border-gray-700 bg-gray-800">
                <div class="border-b border-gray-700 p-5">
                  <h5 class="font-bold text-white">{m.solutions_cordova_to_capacitor_visual1_title({}, { locale })}</h5>
                  <p class="mt-1 text-sm text-gray-400">{m.solutions_cordova_to_capacitor_visual1_desc({}, { locale })}</p>
                </div>
                <div class="bg-gray-900">
                  <BugFixIllustration />
                </div>
              </div>

              <div class="overflow-hidden rounded-2xl border border-gray-700 bg-gray-800">
                <div class="border-b border-gray-700 p-5">
                  <h5 class="font-bold text-white">{m.solutions_cordova_to_capacitor_visual2_title({}, { locale })}</h5>
                  <p class="mt-1 text-sm text-gray-400">{m.solutions_cordova_to_capacitor_visual2_desc({}, { locale })}</p>
                </div>
                <div class="bg-gray-900">
                  <SecurityIllustration />
                </div>
              </div>

              <div class="overflow-hidden rounded-2xl border border-gray-700 bg-gray-800 sm:col-span-2">
                <div class="border-b border-gray-700 p-5">
                  <h5 class="font-bold text-white">{m.solutions_cordova_to_capacitor_visual3_title({}, { locale })}</h5>
                  <p class="mt-1 text-sm text-gray-400">{m.solutions_cordova_to_capacitor_visual3_desc({}, { locale })}</p>
                </div>
                <div class="bg-gray-900">
                  <RolloutIllustration />
                </div>
              </div>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- 10-Day Plan -->
    <section class="bg-gray-800 py-20">
      <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
        <div class="mx-auto mb-16 max-w-3xl text-center">
          <h2 class="mb-4 text-sm font-semibold tracking-wide text-sky-300 uppercase">{m.solutions_cordova_to_capacitor_plan_label({}, { locale })}</h2>
          <h3 class="text-3xl font-bold text-white sm:text-4xl">{m.solutions_cordova_to_capacitor_plan_title({}, { locale })}</h3>
          <p class="mt-4 text-xl text-gray-400">{m.solutions_cordova_to_capacitor_plan_subtitle({}, { locale })}</p>
        </div>

        <div class="mx-auto max-w-4xl">
          <ol class="space-y-4">
            {
              Array.from({ length: 10 }).map((_, idx) => {
                const day = idx + 1
                const titleKey = `solutions_cordova_to_capacitor_day${day}_title` as const
                const descKey = `solutions_cordova_to_capacitor_day${day}_desc` as const
                // @ts-expect-error message keys are generated, but TS can't infer from the string
                const dayTitle = m[titleKey]({}, { locale })
                // @ts-expect-error message keys are generated, but TS can't infer from the string
                const dayDesc = m[descKey]({}, { locale })
                return (
                  <li class="rounded-2xl border border-gray-700 bg-gray-900 p-6">
                    <div class="flex items-start gap-4">
                      <div class="shrink-0">
                        <div class="flex h-10 w-10 items-center justify-center rounded-xl border border-sky-400/25 bg-sky-500/15 font-bold text-sky-300">{day}</div>
                      </div>
                      <div>
                        <h4 class="text-lg font-bold text-white">{dayTitle}</h4>
                        <p class="mt-2 text-gray-400">{dayDesc}</p>
                      </div>
                    </div>
                  </li>
                )
              })
            }
          </ol>
        </div>
      </div>
    </section>

    <!-- Deliverables -->
    <section class="bg-gray-900 py-20">
      <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
        <div class="mx-auto mb-14 max-w-3xl text-center">
          <h2 class="mb-4 text-sm font-semibold tracking-wide text-sky-300 uppercase">{m.solutions_cordova_to_capacitor_deliverables_label({}, { locale })}</h2>
          <h3 class="text-3xl font-bold text-white sm:text-4xl">{m.solutions_cordova_to_capacitor_deliverables_title({}, { locale })}</h3>
        </div>

        <div class="mx-auto max-w-4xl rounded-2xl border border-gray-700 bg-gray-800 p-8">
          <ul class="grid grid-cols-1 gap-4 text-gray-300 md:grid-cols-2">
            <li class="flex items-start gap-3">
              <svg aria-hidden="true" class="mt-0.5 h-5 w-5 text-sky-300" viewBox="0 0 20 20" fill="currentColor">
                <path
                  fill-rule="evenodd"
                  d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z"
                  clip-rule="evenodd"></path>
              </svg>
