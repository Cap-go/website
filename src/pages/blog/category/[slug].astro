---
import BlogListing from '@/components/BlogListing.astro'
import { getCollection } from 'astro:content'
import { slug as slugify } from 'github-slugger'

export const prerender = false

if (!Astro.params.slug) return new Response(`Astro.params.slug is invalid for: ${Astro.url.pathname}`, { status: 404 })

const allPosts = await getCollection('blog', ({ data }) => data.published !== false && data.locale === Astro.locals.locale)
const localePosts = allPosts.filter((post) => post.data.tag.split(',').some((tag) => slugify(tag.trim()) === Astro.params.slug))

if (localePosts.length === 0) return new Response(`No blog category found for: ${Astro.url.pathname}`, { status: 404 })
---

<BlogListing allPosts={localePosts} />
