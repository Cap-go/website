---
import Layout from '@/layouts/Layout.astro'
import { createLdJsonGraph, createWebPageLdJson } from '@/lib/ldJson'
import { decodePayload } from '@/lib/tools/udid'
import { getRelativeLocaleUrl } from 'astro:i18n'

const UDID_RESULT_COOKIE = 'ios_udid_payload'
const UDID_RESULT_PATH = '/tools/ios-udid-finder/result/'
const locale = Astro.locals.locale
const toAbsoluteLocaleUrl = (path: string) => new URL(getRelativeLocaleUrl(locale, path), Astro.url.origin).toString()
const cookieValue = Astro.cookies.get(UDID_RESULT_COOKIE)?.value ?? null
const payload = decodePayload(cookieValue)

Astro.response.headers.set('Cache-Control', 'no-store, max-age=0, must-revalidate')
Astro.response.headers.set('Pragma', 'no-cache')

if (cookieValue) {
  Astro.cookies.delete(UDID_RESULT_COOKIE, { path: UDID_RESULT_PATH })
}

const title = payload?.udid ? 'iOS UDID Finder Result | Device Identifier Received' : 'iOS UDID Finder Result'
const description = payload?.udid
  ? 'Your device response has been received. Review the UDID, model, serial number, and other identifiers below.'
  : 'No device response payload was found.'
const webPage = createWebPageLdJson(Astro.locals.runtimeConfig.public, {
  name: title,
  description,
  url: Astro.url.href,
})
const ldJSON = createLdJsonGraph(Astro.locals.runtimeConfig.public, webPage, {
  includeOrganization: true,
  includeBreadcrumbs: true,
  breadcrumbs: [
    { name: 'Home', url: toAbsoluteLocaleUrl('') },
    { name: 'Tools', url: toAbsoluteLocaleUrl('tools') },
    { name: 'iOS UDID Finder', url: toAbsoluteLocaleUrl('tools/ios-udid-finder') },
    { name: 'Result', url: Astro.url.href },
  ],
})

const content = {
  title,
  description,
  keywords: 'ios udid result, iphone udid response, ipad device identifier result, ios profile service result, tester device registration',
  robots: 'noindex, nofollow',
  ldJSON,
}

const rows = payload
  ? [
      ['UDID', payload.udid],
      ['Device name', payload.deviceName],
      ['Product', payload.product],
      ['iOS version', payload.version],
      ['Serial number', payload.serial],
      ['IMEI', payload.imei],
      ['MEID', payload.meid],
    ].filter((row) => row[1])
  : []
---

<Layout content={content}>
  <section class="py-16 sm:py-20">
    <div class="mx-auto max-w-4xl px-4 sm:px-6 lg:px-8">
      <div class="rounded-3xl border border-white/10 bg-white/5 p-8">
        <p class="text-sm font-semibold tracking-[0.25em] text-fuchsia-300 uppercase">Device response</p>
        <h1 class="mt-3 text-4xl font-bold text-white">iOS UDID Finder result</h1>
        <p id="copy-status" class="sr-only" aria-live="polite"></p>

        {
          payload?.udid ? (
            <>
              <p class="mt-4 text-sm leading-7 text-slate-300">
                The backend received the device payload successfully. Copy the values you need for Apple Developer or your tester registry below.
              </p>
              <div class="mt-8 space-y-4">
                {rows.map(([label, value], index) => (
                  <div class="rounded-2xl border border-white/10 bg-slate-950/70 p-5">
                    <div class="flex flex-col gap-3 sm:flex-row sm:items-center sm:justify-between">
                      <div>
                        <p class="text-xs tracking-[0.25em] text-fuchsia-300 uppercase">{label}</p>
                        <p class="mt-2 font-mono text-sm break-all text-white">{value}</p>
                      </div>
                      <button
                        type="button"
                        class="inline-flex items-center justify-center rounded-2xl border border-white/10 px-4 py-2 text-sm font-semibold text-white transition hover:border-fuchsia-300/60 hover:bg-white/5"
                        data-copy-value={value}
                      >
                        Copy
                      </button>
                    </div>
                  </div>
                ))}
              </div>
            </>
          ) : (
            <div class="mt-8 rounded-2xl border border-amber-400/20 bg-amber-400/10 p-6 text-sm leading-7 text-amber-100">
              No device response was available for this session. Open this page through the profile-service redirect after installing the UDID profile on the device.
            </div>
          )
        }

        <div class="mt-8 flex flex-col gap-4 sm:flex-row">
          <a
            href={getRelativeLocaleUrl(Astro.locals.locale, 'tools/ios-udid-finder')}
            class="inline-flex items-center justify-center rounded-2xl bg-fuchsia-400 px-6 py-3 text-sm font-semibold text-slate-950 transition hover:bg-fuchsia-300"
          >
            Back to the UDID finder
          </a>
          <a
            href={getRelativeLocaleUrl(Astro.locals.locale, 'docs/cli/cloud-build/ios')}
            class="inline-flex items-center justify-center rounded-2xl border border-white/15 px-6 py-3 text-sm font-semibold text-white transition hover:border-fuchsia-300/60 hover:bg-white/5"
          >
            Continue to iOS signing docs
          </a>
        </div>
      </div>
    </div>
  </section>
</Layout>

<script>
  const statusRegion = document.querySelector<HTMLElement>('#copy-status')

  function announceCopyStatus(message: string): void {
    if (statusRegion) {
      statusRegion.textContent = message
    }
  }

  async function copyText(value: string): Promise<void> {
    try {
      await navigator.clipboard.writeText(value)
    } catch {
      const helper = document.createElement('textarea')
      helper.value = value
      helper.setAttribute('readonly', 'true')
      helper.style.position = 'absolute'
      helper.style.opacity = '0'
      document.body.append(helper)
      helper.select()
      const copied = document.execCommand('copy')
      helper.remove()
      if (!copied) {
        throw new Error('Copy failed')
      }
    }
  }

  document.querySelectorAll<HTMLButtonElement>('[data-copy-value]').forEach((button) => {
    button.addEventListener('click', async () => {
      const value = button.dataset.copyValue
      if (!value) return

      const original = button.textContent || 'Copy'

      try {
        await copyText(value)
        button.textContent = 'Copied'
        announceCopyStatus('Value copied to clipboard.')
      } catch {
        button.textContent = 'Copy failed'
        announceCopyStatus('Copy to clipboard failed.')
      }

      window.setTimeout(() => {
        button.textContent = original
        announceCopyStatus('')
      }, 1600)
    })
  })
</script>
