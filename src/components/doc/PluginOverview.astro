---
import { Card, CardGrid } from '@astrojs/starlight/components'

interface PluginOverviewCard {
  body: string
  title: string
}

interface Props {
  cards: PluginOverviewCard[]
  summary: string
}

const { cards, summary } = Astro.props
---

<p>{summary}</p>

<CardGrid stagger>
  {cards.map((card) => <Card title={card.title}>{card.body}</Card>)}
</CardGrid>
