{
  "name": "capgo-website",
  "compatibility_date": "2025-09-15",
  "compatibility_flags": ["nodejs_compat", "disable_nodejs_process_v2", "fetch_iterable_type_support"],
  "ai": {
    "binding": "AI",
    "remote": false,
  },
  "assets": {
    "directory": "./dist",
    "not_found_handling": "single-page-application",
  },
  "workers_dev": false,
  "routes": [
    {
      "pattern": "capgo.app",
      "custom_domain": true,
    },
  ],
}
