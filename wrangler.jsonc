{
  "name": "capgo-website",
  "compatibility_date": "2025-09-15",
  "compatibility_flags": ["nodejs_compat"],
  "ai": {
    "binding": "AI"
  },
  "assets": {
    "directory": "./dist",
    "not_found_handling": "single-page-application"
  },
  "workers_dev": false,
  "routes": [
    {
      "pattern": "capgo.app",
      "custom_domain": true
    }
  ]
}
